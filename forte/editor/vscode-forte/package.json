{
  "name": "forte-studio",
  "displayName": "Forte Studio",
  "description": "Compose music as code inside VS Code: diagnostics, play/build, a drag-editable arrangement, a beat grid, blocks and song history. VS Code supplies git, GitHub and your AI pair.",
  "version": "0.3.0",
  "publisher": "forte",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "languages": [
      {
        "id": "forte",
        "aliases": [
          "Forte"
        ],
        "extensions": [
          ".forte"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "forte",
        "scopeName": "source.forte",
        "path": "./syntaxes/forte.tmLanguage.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forte-studio",
          "title": "Forte Studio",
          "icon": "media/mark.svg"
        }
      ]
    },
    "views": {
      "forte-studio": [
        {
          "id": "forteHistory",
          "name": "History"
        },
        {
          "id": "forteBlocks",
          "name": "Blocks"
        }
      ]
    },
    "commands": [
      {
        "command": "forte.play",
        "title": "Forte: Play (hot reload)"
      },
      {
        "command": "forte.build",
        "title": "Forte: Build"
      },
      {
        "command": "forte.stop",
        "title": "Forte: Stop Playback"
      },
      {
        "command": "forte.repl",
        "title": "Forte: REPL"
      },
      {
        "command": "forte.sendToRepl",
        "title": "Forte: Send Selection to REPL"
      },
      {
        "command": "forte.showArrangement",
        "title": "Forte: Show Arrangement"
      },
      {
        "command": "forte.showGrid",
        "title": "Forte: Beat Grid"
      },
      {
        "command": "forte.commit",
        "title": "Forte: Commit",
        "icon": "$(check)"
      },
      {
        "command": "forte.refreshHistory",
        "title": "Forte: Refresh History",
        "icon": "$(refresh)"
      },
      {
        "command": "forte.diffCommit",
        "title": "Diff vs 作業ツリー",
        "icon": "$(diff)"
      },
      {
        "command": "forte.checkoutCommit",
        "title": "この時点に戻す",
        "icon": "$(discard)"
      },
      {
        "command": "forte.merge",
        "title": "Forte: Merge Branch…"
      },
      {
        "command": "forte.refreshBlocks",
        "title": "Blocks を更新",
        "icon": "$(refresh)"
      },
      {
        "command": "forte.blockListen",
        "title": "▶ 試聴",
        "icon": "$(play)"
      },
      {
        "command": "forte.blockRefs",
        "title": "どこから使われている?"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "forte.commit",
          "when": "view == forteHistory",
          "group": "navigation@1"
        },
        {
          "command": "forte.refreshHistory",
          "when": "view == forteHistory",
          "group": "navigation@2"
        },
        {
          "command": "forte.refreshBlocks",
          "when": "view == forteBlocks",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "forte.diffCommit",
          "when": "view == forteHistory && viewItem == commit",
          "group": "inline@1"
        },
        {
          "command": "forte.checkoutCommit",
          "when": "view == forteHistory && viewItem == commit",
          "group": "inline@2"
        },
        {
          "command": "forte.blockListen",
          "when": "view == forteBlocks && viewItem == forteBlock",
          "group": "inline@1"
        },
        {
          "command": "forte.blockRefs",
          "when": "view == forteBlocks && viewItem == forteBlock",
          "group": "context@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "forte.sendToRepl",
        "key": "shift+enter",
        "when": "editorTextFocus && editorLangId == forte"
      }
    ],
    "configuration": {
      "title": "Forte Studio",
      "properties": {
        "forte.path": {
          "type": "string",
          "default": "forte",
          "description": "Path to the forte CLI binary (cargo install --path crates/fortelang)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
