{
  "name": "forte-lang",
  "displayName": "Forte",
  "description": "Compose music as code: diagnostics, syntax highlighting, play/build for .forte songs.",
  "version": "0.1.0",
  "publisher": "forte",
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages"],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "forte",
        "aliases": ["Forte"],
        "extensions": [".forte"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "forte",
        "scopeName": "source.forte",
        "path": "./syntaxes/forte.tmLanguage.json"
      }
    ],
    "commands": [
      { "command": "forte.play", "title": "Forte: Play (hot reload)" },
      { "command": "forte.build", "title": "Forte: Build" },
      { "command": "forte.stop", "title": "Forte: Stop Playback" }
    ],
    "configuration": {
      "title": "Forte",
      "properties": {
        "forte.path": {
          "type": "string",
          "default": "forte",
          "description": "Path to the forte CLI binary (built with `cargo build --release -p fortelang`)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
