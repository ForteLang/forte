// glitchworks 0.1.0 — the clicks & cuts toolkit: microscopic percussion,
// sine blips and noise textures for IDM / glitch / microhouse, built to be
// pushed through crush / stutter / gate.
block Glitchworks {
  desc "The glitch album toolkit: sampler machines (choke chops, granular stretch, glides, scrub windows, keyed sidechain), ensembles bounced and re-cut as one grain, body-first drums, and a songbook of thirty-second pieces — everything resampled, everything in motion."
  tags "glitch, idm, sampler, granular, chop, glide, braindance, ambient, 0.1.0"
  artist "Forte Essentials"
  license "CC-BY-NC-SA-4.0"
  version "0.1.0"
}
