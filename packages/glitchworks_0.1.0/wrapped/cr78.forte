// glitchworks/wrapped/cr78 — essentials sources bounced to audio and
// re-instrumentalized: sampler + convention chain in one block. Inherit
// and add plays:
//   import { Knock78 } from "packages/glitchworks_0.1.0/wrapped/cr78.forte"
//   block Line : Knock78 { track Hit { play … at bars(1..4) } }
import { BD78, Bongo78, CY78, Cowbell78, HH78, SD78, Tamb78 } from "../../essentials_0.6.0/instruments/cr78.forte"

// Knock78 — BD78 transient-shaped, tape-saturated, NY-compressed — the produced hit.
block Knock78 {
  sample Knock78Src = bounce(BD78(), note: C1, beats: 1)
  track Hit {
    instrument sampler(sample: Knock78Src, sustain: 0.0, decay: 0.35)
    insert transient(attack: 0.8, sustain: 0.35)
    insert saturate(mode: "tape", drive: 0.5)
    insert parcomp(amount: 0.5, drive: 0.6, color: 0.35)
    volume 0.8
  }
}

// Dust78Kick — BD78 bit-dusted and tape-warmed — the lofi convention.
block Dust78Kick {
  sample Dust78KickSrc = bounce(BD78(), note: C1, beats: 1)
  track Hit {
    instrument sampler(sample: Dust78KickSrc, sustain: 0.75)
    insert crush(bits: 0.45, rate: 0.3, mix: 0.55)
    insert saturate(mode: "tape", drive: 0.35, tone: 0.55)
    insert comp(thresh: 0.5, ratio: 0.55, makeup: 0.15)
    volume 0.75
  }
}

// Crack78 — SD78 fuzz bite + parallel crush + sparkle — cuts through any mix.
block Crack78 {
  sample Crack78Src = bounce(SD78(), note: D2, beats: 1)
  track Hit {
    instrument sampler(sample: Crack78Src, sustain: 0.0, decay: 0.3)
    insert transient(attack: 0.85, sustain: 0.3)
    insert saturate(mode: "fuzz", drive: 0.4, tone: 0.6)
    insert parcomp(amount: 0.55, drive: 0.65, color: 0.5)
    insert exciter(amount: 0.25)
    volume 0.8
  }
}

// Hiss78Hat — HH78 bit-dusted and tape-warmed — the lofi convention.
block Hiss78Hat {
  sample Hiss78HatSrc = bounce(HH78(), note: F#2, beats: 0.5)
  track Hat {
    instrument sampler(sample: Hiss78HatSrc, sustain: 0.75)
    insert crush(bits: 0.45, rate: 0.3, mix: 0.55)
    insert saturate(mode: "tape", drive: 0.35, tone: 0.55)
    insert comp(thresh: 0.5, ratio: 0.55, makeup: 0.15)
    volume 0.6
  }
}

// Bongo78Ring — Bongo78 ring-modulated into inharmonic metal, tube-warmed.
block Bongo78Ring {
  sample Bongo78RingSrc = bounce(Bongo78(), note: F2, beats: 0.5)
  track Metal {
    instrument sampler(sample: Bongo78RingSrc, sustain: 0.6)
    insert ringmod(freq: 0.55, mix: 0.45)
    insert saturate(mode: "tube", drive: 0.4)
    insert delay(time: 0.22, fdbk: 0.3, mix: 0.2)
    volume 0.8
  }
}

// Bell78Wire — Cowbell78 ring-modulated into inharmonic metal, tube-warmed.
block Bell78Wire {
  sample Bell78WireSrc = bounce(Cowbell78(), note: G2, beats: 0.5)
  track Metal {
    instrument sampler(sample: Bell78WireSrc, sustain: 0.6)
    insert ringmod(freq: 0.55, mix: 0.45)
    insert saturate(mode: "tube", drive: 0.4)
    insert delay(time: 0.22, fdbk: 0.3, mix: 0.2)
    volume 0.8
  }
}

// Tamb78Wash — Tamb78 played backwards into a crushed reverb — the vapor texture.
block Tamb78Wash {
  sample Tamb78WashSrc = bounce(Tamb78(), note: A2, beats: 1)
  track Pad {
    instrument sampler(sample: Tamb78WashSrc, reverse: "on", sustain: 0.85, release: 0.4)
    insert reverb(size: 0.7, decay: 0.65, mix: 0.4)
    insert crush(bits: 0.35, rate: 0.25, mix: 0.35)
    volume 0.5
  }
}

// Cym78Reverse — CY78 played backwards into a crushed reverb — the vapor texture.
block Cym78Reverse {
  sample Cym78ReverseSrc = bounce(CY78(), note: C3, beats: 2)
  track Pad {
    instrument sampler(sample: Cym78ReverseSrc, reverse: "on", sustain: 0.85, release: 0.4)
    insert reverb(size: 0.7, decay: 0.65, mix: 0.4)
    insert crush(bits: 0.35, rate: 0.25, mix: 0.35)
    volume 0.5
  }
}
