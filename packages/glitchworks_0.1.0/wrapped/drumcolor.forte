// glitchworks/drumcolor — drums rebuilt from the verdict "何もかもダメ":
// the oscillators were never the problem, the PROCESSING and the GROOVE
// were. Three principles, non-negotiable:
//   1. A snare is not one sound. SnareRainbow carries SEVEN produced snare
//      colors on one kit, and the groove ROTATES them — the backbeat never
//      lands on the same color twice in a row.
//   2. A kick is a STACK (sub + punch + click bounced together), not an
//      oscillator, and it comes in weights.
//   3. The beat is engineered, not played: SlicerBeat re-decides its slice
//      order every bar, flips pitches, drops reverses in, and tightens —
//      the DAW-slicer workflow as a block.
import { Kick808, Kick909, Kick606, KickSub, SnareTight, Snare908, SnareBrush, HatClosed, HatOpen, HatPedal, Rim, Snap, Ride } from "../../essentials_0.6.0/instruments/drums.forte"
import { SnareModal } from "../instruments/modal.forte"

// ---- SnareRainbow — ONE rich snare, EVERY hit a different edit -------------
// The lesson from three failed passes: color rotation is not enough when
// every hit replays the same edit. Here the anchor sample is ONE deeply
// produced snare (two snares layered into a room with an echo tail), and
// the GROOVE is a chain of different EDITS of it:
//   Edit  — beat 2: the gate length and pitch change EVERY bar
//           (0.45-beat ring → 0.14-beat choke → −2 semitones → +2)
//   Color — beat 4: a rotating second voice (dub echo / dark body /
//           crushed / rim), never the same twice in a row
//   Cut   — headless hits (slice 2 = body without the attack) and
//           tail-only hisses (slice 5+) filling the pockets
//   Smear — the occasional snare STRETCHED longer than it was played,
//           leaning into the next bar
//   Rev   — the reversed pre-echo pulling into the turns
block SnareRainbow {
  // the anchor: two snares + room + echo, bounced as one rich hit
  block SnrMainSrc {
    track A { instrument SnareTight(snap: 0.75)
      insert saturate(mode: "fuzz", drive: 0.35, tone: 0.55)
      volume 0.9
      play beat`x--- ---- ---- ----` at bars(1..1) }
    track B { instrument Snare908(snap: 0.6, tone: 0.55)
      insert delay(time: 0.09, fdbk: 0.6, mix: 0.5)
      volume 0.8
      play beat`x--- ---- ---- ----` at bars(1..1) }
    // the FAT TAIL is the point: length edits only read if the sample
    // keeps ringing long past the gate
    track Room { instrument SnareBrush
      insert reverb(size: 0.6, decay: 0.55, mix: 0.7)
      volume 0.55
      play beat`x--- ---- ---- ----` at bars(1..1) }
  }
  sample SnrMain = bounce(SnrMainSrc, note: C3, beats: 2)
  // the color voices for beat 4
  block SnrEchoSrc {
    track S { instrument Snare908(snap: 0.65, tone: 0.6)
      insert delay(time: 0.08, fdbk: 0.62, mix: 0.5)
      insert saturate(mode: "tape", drive: 0.45)
      volume 0.95
      play beat`x--- ---- ---- ----` at bars(1..1) }
  }
  sample SnrEcho = bounce(SnrEchoSrc, note: C#3, beats: 2)
  block SnrBodySrc {
    track S { instrument SnareModal(wires: 0.35, shell: 0.8)
      insert saturate(mode: "tube", drive: 0.4)
      insert eq(low: 0.7, mid: 0.5, high: 0.35)
      volume 0.95
      play beat`x--- ---- ---- ----` at bars(1..1) }
  }
  sample SnrBody = bounce(SnrBodySrc, note: D#3, beats: 1)
  block SnrCrushSrc {
    track S { instrument SnareTight(snap: 0.7)
      insert crush(bits: 0.55, rate: 0.35, mix: 0.7)
      insert filter(type: "lp", cutoff: 0.55, reso: 0.35)
      volume 0.95
      play beat`x--- ---- ---- ----` at bars(1..1) }
  }
  sample SnrCrush = bounce(SnrCrushSrc, note: D3, beats: 1)
  block SnrRimSrc {
    track S { instrument Rim volume 0.9
      insert exciter(amount: 0.4)
      play beat`x--- ---- ---- ----` at bars(1..1) }
    track N { instrument Snap volume 0.6
      play beat`x--- ---- ---- ----` at bars(1..1) }
  }
  sample SnrRim = bounce(SnrRimSrc, note: E3, beats: 1)

  // beat 2: the SAME snare, a DIFFERENT edit every bar — length gates the
  // ring (sustain 1 + instant release), the note repitches the whole hit
  track Edit {
    instrument sampler(attack: 0.04, gain: 1.0, sample: SnrMain, choke: "on", vary: 0.22, sustain: 1.0, release: 0.05)
    modulate pitch with random(rate: 0.1, amount: 0.03, smooth: 0.7) as swim
    insert parcomp(amount: 0.5, drive: 0.6, color: 0.45)
    volume 0.95
    // the arc opens TIGHT and earns its ring: crack → down+longer →
    // choke → up — the first impression is dry and punchy
    play late(notes`_:1 C3~:0.22 _:2.78`, by: 0.055) at bars(1..1)
    play late(notes`_:1 G#2~:0.45 _:2.55`, by: 0.05) at bars(2..2)
    play late(notes`_:1 C3~:0.1 _:2.9`, by: 0.06) at bars(3..3)
    play late(notes`_:1 D#3~:0.35 _:2.65`, by: 0.045) at bars(4..4)
  }
  // beat 4: the color voice rotates — echo, body, crush, rim run
  track Color {
    instrument kit(C#3: SnrEcho, D3: SnrCrush, D#3: SnrBody, E3: SnrRim, sustain: 1.0, release: 0.3)
    insert parcomp(amount: 0.45, drive: 0.55, color: 0.4)
    volume 0.9
    play late(notes`_:3 C#3!:0.5 _:0.5`, by: 0.05) at bars(1..1)
    play late(notes`_:3 D#3!:0.5 _:0.5`, by: 0.055) at bars(2..2)
    play late(notes`_:3 D3!:0.35 _:0.65`, by: 0.05) at bars(3..3)
    play late(notes`_:3 E3:0.2 D3:0.3 _:0.5`, by: 0.045) at bars(4..4)
  }
  // the pockets: headless hits (slice 1-2 = body, no attack) and
  // tail-only hisses (slice 4+), choked tight
  track Cut {
    instrument sampler(attack: 0.04, gain: 1.0, sample: SnrMain, slices: 8, end: 0.5, choke: "on", vary: 0.35, sustain: 0.0, decay: 0.3)
    modulate pitch with random(rate: 0.16, amount: 0.045, smooth: 0.55) as scatter
    volume 0.5
    play notes`_:2.25 D3:0.25 _:1.5` at bars(1..1)
    play notes`_:0.75 F3:0.25 _:2 E3:0.25 _:0.75` at bars(2..2)
    play notes`_:2.5 F3:0.125 G3:0.125 _:1.25` at bars(3..3)
    play notes`_:2.5 D3:0.125 E3:0.125 F3:0.125 G3:0.125 C3:0.25 _:0.75` at bars(4..4)
  }
  // the smear: the snare stretched LONGER than it was played, pitched a
  // touch down, leaning across the barline
  track Smear {
    instrument sampler(attack: 0.06, gain: 1.0, sample: SnrMain, stretch: 0.3, pitch: 0.458, choke: "on", vary: 0.15, sustain: 1.0, release: 0.2)
    insert width(amount: 0.75)
    volume 0.6
    play notes`_:3.4 C3~:0.6` at bars(2..2)
    play notes`_:2.9 C3~:1.1` at bars(4..4)
  }
  // the reversed pre-echo, pulling into the turns
  track Rev {
    instrument sampler(attack: 0.06, gain: 1.0, sample: SnrMain, reverse: "on", end: 0.5, sustain: 1.0, release: 0.08, vary: 0.2)
    volume 0.45
    play notes`_:0.5 C3~:0.5 _:3` at bars(3..3)
    play notes`_:3.55 C3~:0.45` at bars(4..4)
  }
}

// ---- KickStack — the kick as a produced STACK, in three weights ------------
block KickStack {
  // weight 1: the standard — sub + punch + click bounced as ONE hit
  block KikStackSrc {
    track Sub { instrument KickSub volume 0.85
      play beat`x--- ---- ---- ----` at bars(1..1) }
    track Punch { instrument Kick909(click: 0.5)
      insert transient(attack: 0.85, sustain: 0.3)
      insert saturate(mode: "tape", drive: 0.5)
      volume 0.9
      play beat`x--- ---- ---- ----` at bars(1..1) }
    track Click { instrument HatPedal volume 0.35
      play beat`x--- ---- ---- ----` at bars(1..1) }
  }
  sample KikStack = bounce(KikStackSrc, note: C1, beats: 1)
  // weight 2: the boom — 808 long, pitch falling into the floor
  block KikBoomSrc {
    track K { instrument Kick808(decay: 0.75, punch: 0.7)
      insert saturate(mode: "tape", drive: 0.55)
      insert parcomp(amount: 0.6, drive: 0.65, color: 0.3)
      volume 0.95
      play beat`x--- ---- ---- ----` at bars(1..1) }
  }
  sample KikBoom = bounce(KikBoomSrc, note: C#1, beats: 2)
  // weight 3: the spit — 606 short, fuzzed, for runs
  block KikSpitSrc {
    track K { instrument Kick606
      insert saturate(mode: "fuzz", drive: 0.55, tone: 0.45)
      insert parcomp(amount: 0.65, drive: 0.7, color: 0.4)
      volume 0.95
      play beat`x--- ---- ---- ----` at bars(1..1) }
  }
  sample KikSpit = bounce(KikSpitSrc, note: D1, beats: 1)

  track Feet {
    instrument kit(C1: KikStack, C#1: KikBoom, D1: KikSpit, sustain: 1.0, release: 0.25)
    insert parcomp(amount: 0.5, drive: 0.6, color: 0.3)
    volume 0.95
    play notes`C1:0.5 _:1 D1:0.5 C1:0.5 _:1.5` at bars(1..1)
    play notes`C1:0.5 _:1 D1:0.5 C1:0.5 _:1 C#1:0.5` at bars(2..2)
    play notes`C1:0.5 _:1 D1:0.5 C1:0.5 _:1.5` at bars(3..3)
    play notes`C1:0.5 _:0.5 D1:0.25 D1:0.25 C1:0.5 _:0.5 D1:0.25 D1:0.25 C#1:0.5 _:0.5` at bars(4..4)
  }
  // the fragment machine: the stacked kick eating itself on the turns
  track Frag {
    instrument sampler(attack: 0.06, sample: KikStack, slices: 8, end: 0.333, choke: "on", vary: 0.3, sustain: 0.0, decay: 0.3)
    modulate pitch with random(rate: 0.1, amount: 0.04, smooth: 0.7) as swim
    insert saturate(mode: "fuzz", drive: 0.35, tone: 0.5)
    volume 0.8
    play notes`_:3 D1:0.25 F1:0.25 C1:0.25 A1:0.25` at bars(2..2)
    play notes`_:3 C1:0.125 D1:0.125 E1:0.125 F1:0.125 G1:0.125 A1:0.125 B1:0.125 C2:0.125` at bars(4..4)
  }
}

// ---- SlicerBeat — the DAW-slicer workflow as one block ---------------------
// A dense 2-bar kit phrase, bounced once, then RE-DECIDED live: slice
// order changes every bar, a stepped flip re-pitches the pads, reverses
// interject, the stutter fires on the turn and the decay tightens across
// the arc. This is the beat as an EDIT, not a performance.
block SlicerBeat {
  block SlicerBeatSrc {
    track K { instrument Kick909(click: 0.45)
      insert saturate(mode: "tape", drive: 0.45)
      volume 0.95
      play beat`x--- --x- ---- x---` at bars(1..1)
      play beat`x--- ---- --x- ----` at bars(2..2) }
    track S { instrument Snare908(snap: 0.7)
      insert delay(time: 0.08, fdbk: 0.5, mix: 0.35)
      insert saturate(mode: "fuzz", drive: 0.35)
      volume 0.9
      play late(beat`---- x--- ---- x-.-`, by: 0.04) at bars(1..1)
      play late(beat`---- x..- ---- x--X`, by: 0.04) at bars(2..2) }
    track H { instrument HatClosed(bright: 0.8) volume 0.5
      play humanize(beat`x-xx x-x- xx-x x-xx`, time: 0.01, vel: 18, seed: 67) at bars(1..2) }
    track R { instrument Ride volume 0.3
      play beat`x--- x--- x--- x---` at bars(1..2) }
  }
  sample SlicerBeatS = bounce(SlicerBeatSrc, note: C3, beats: 8)
  track SliceA {
    instrument sampler(attack: 0.06, sample: SlicerBeatS, slices: 16, end: 0.8, choke: "on", vary: 0.2, sustain: 0.0, decay: 0.5)
    modulate pitch with random(rate: 0.09, amount: 0.03, smooth: 0.75) as swim
    insert transient(attack: 0.75, sustain: 0.4)
    insert saturate(mode: "tape", drive: 0.35)
    insert stutter(beats: 0.25, mix: 0.0)
    insert parcomp(amount: 0.55, drive: 0.6, color: 0.4)
    automate decay from 0.5 to 0.2 over bars(3..4)
    automate stutter.mix from 0.0 to 0.6 over bars(4..4)
    automate stutter.mix from 0.6 to 0.0 over bars(5..5)
    volume 0.95
    play notes`C3:0.5 D3:0.25 _:0.25 F3:0.5 G3:0.25 G#3:0.25 A#3:0.5 _:0.25 C3:0.25 D#3:0.5 _:0.5` at bars(1..1)
    play notes`C3:0.5 _:0.25 D3:0.25 F#3:0.5 G3:0.25 _:0.25 A#3:0.25 B3:0.25 C3:0.5 D3:0.25 D#3:0.25 _:0.5` at bars(2..2)
    play notes`C3:0.25 C#3:0.25 D3:0.25 D#3:0.25 F3:0.25 _:0.25 G3:0.25 G#3:0.25 A#3:0.25 A3:0.25 _:0.25 B3:0.25 C3:0.25 D#3:0.25 _:0.5` at bars(3..3)
    play notes`C3:0.25 D3:0.125 D#3:0.125 F3:0.25 F#3:0.25 G3:0.125 G#3:0.125 A3:0.25 A#3:0.25 B3:0.125 A#3:0.125 G3:0.25 D#3:0.125 D3:0.125 C3:0.25 C#3:0.25 D3:0.25 C3:0.25 _:0.5` at bars(4..4)
  }
  track SliceB {
    // the second opinion: pitched a fifth down, reversed, answering in
    // the gaps SliceA leaves
    instrument sampler(attack: 0.06, sample: SlicerBeatS, slices: 16, end: 0.8, choke: "on", vary: 0.3, pitch: 0.354, reverse: "on", sustain: 0.0, decay: 0.3)
    modulate pitch with steps(seq: "0.5 0.5 0.625 0.5 0.375 0.5 0.75 0.5", every: "1/8", amount: 0.12) as flip
    insert crush(bits: 0.4, rate: 0.25, mix: 0.35)
    volume 0.45
    play notes`_:1.25 E3:0.25 _:2 A3:0.25 _:0.25` at bars(1..3)
    play notes`_:0.75 F3:0.25 _:1 B3:0.125 A3:0.125 _:1.25 D3:0.25 E3:0.25` at bars(4..4)
  }
}
