// glitchworks/wrapped/snares — produced snares with 生音感 (live feel).
// A real snare is LAYERED (tonal shell body + wire buzz + brush swish +
// clap crack), bounced to one hit, then processed for weight and room:
// transient (crack) -> eq (scoop mud, lift body+crack) -> saturate (meat)
// -> parcomp (room-filling smack) -> reverb (natural space).
//   import { LiveSnare } from "packages/glitchworks_0.1.0/wrapped/snares.forte"
//   block Back : LiveSnare { track Snare { play notes`F3:1 _:1 F3:1 _:1` at bars(1..8) } }
// Trigger at F3 for the natural pitch; other notes retune the whole drum.
import { SnareTight, Snare908, SnareBrush, Clap, Rim } from "../../essentials_0.6.0/instruments/drums.forte"

// the shared layered bed — body (F3 ~175Hz shell) + wires + swish + crack
block SnareBed {
  track Body  { instrument SnareTight(snap: 0.55) volume 0.95
    play notes`F3:0.35` at bars(1..1) }
  track Wires { instrument Snare908(tone: 0.8, snap: 0.7) volume 0.6
    play notes`F3:0.35` at bars(1..1) }
  track Brush { instrument SnareBrush(soft: 0.45) volume 0.5
    play notes`F3:0.35` at bars(1..1) }
  track Crack { instrument Clap(tone: 0.72) volume 0.55
    play notes`F3:0.1` at bars(1..1) }
}

// LiveSnare — the full produced snare: body, room and crack in balance
block LiveSnare {
  sample LiveSnareSrc = bounce(SnareBed, note: F3, beats: 1)
  track Snare {
    instrument sampler(sample: LiveSnareSrc, sustain: 0.0, decay: 0.6)
    insert transient(attack: 0.72, sustain: 0.5)
    insert eq(low: 0.3, mid: 0.78, high: 0.6)
    insert saturate(mode: "tube", drive: 0.42)
    insert parcomp(amount: 0.5, drive: 0.6, color: 0.4)
    insert reverb(size: 0.55, decay: 0.52, mix: 0.24)
    volume 0.95
  }
}

// FatSnare — bigger room, more saturation, longer tail: the anthemic hit
block FatSnare {
  sample FatSnareSrc = bounce(SnareBed, note: E3, beats: 1)
  track Snare {
    instrument sampler(sample: FatSnareSrc, sustain: 0.0, decay: 0.8)
    insert transient(attack: 0.65, sustain: 0.62)
    insert eq(low: 0.28, mid: 0.72, high: 0.55)
    insert saturate(mode: "tape", drive: 0.5)
    insert parcomp(amount: 0.6, drive: 0.7, color: 0.5)
    insert reverb(size: 0.72, decay: 0.68, mix: 0.34)
    volume 0.95
  }
}

// TightSnare — dry, cracky, close-mic'd: the breakbeat backbeat
block TightSnare {
  sample TightSnareSrc = bounce(SnareBed, note: G3, beats: 1)
  track Snare {
    instrument sampler(sample: TightSnareSrc, sustain: 0.0, decay: 0.35)
    insert transient(attack: 0.82, sustain: 0.35)
    insert eq(low: 0.32, mid: 0.7, high: 0.68)
    insert saturate(mode: "fuzz", drive: 0.35, tone: 0.6)
    insert parcomp(amount: 0.45, drive: 0.55, color: 0.35)
    insert reverb(size: 0.4, decay: 0.4, mix: 0.16)
    volume 0.95
  }
}
