// glitchworks/wrapped/leadsx — essentials sources bounced to audio and
// re-instrumentalized: sampler + convention chain in one block. Inherit
// and add plays:
//   import { SawWire } from "packages/glitchworks_0.1.0/wrapped/leadsx.forte"
//   block Line : SawWire { track Wire { play … at bars(1..4) } }
import { Pluck, SawLead, SquareLead, Whistle } from "../../essentials_0.6.0/instruments/leads.forte"

// SawWire — SawLead fuzz-crushed and compressed — audio-domain acid.
block SawWire {
  sample SawWireSrc = bounce(SawLead(), note: C3, beats: 1)
  track Wire {
    instrument sampler(sample: SawWireSrc, glide: 0.06, sustain: 0.7, loop: "on")
    insert saturate(mode: "fuzz", drive: 0.55, tone: 0.5)
    insert comp(thresh: 0.4, ratio: 0.7, attack: 0.01, release: 0.12, makeup: 0.25)
    volume 0.8
  }
}

// SquareDust — SquareLead bit-dusted and tape-warmed — the lofi convention.
block SquareDust {
  sample SquareDustSrc = bounce(SquareLead(), note: C4, beats: 1)
  track Key {
    instrument sampler(sample: SquareDustSrc, sustain: 0.75)
    insert crush(bits: 0.45, rate: 0.3, mix: 0.55)
    insert saturate(mode: "tape", drive: 0.35, tone: 0.55)
    insert comp(thresh: 0.5, ratio: 0.55, makeup: 0.15)
    volume 0.7
  }
}

// PluckPads — Pluck sliced into 8 pads (root+n = slice n at original speed) — the MPC chop.
block PluckPads {
  sample PluckPadsSrc = bounce(Pluck(), note: C4, beats: 2)
  track Chop {
    instrument sampler(sample: PluckPadsSrc, slices: 8, sustain: 0.0, decay: 0.25)
    insert parcomp(amount: 0.5, drive: 0.6, color: 0.4)
    insert saturate(mode: "tape", drive: 0.4)
    volume 0.7
  }
}

// WhistleGhost — Whistle played backwards into a crushed reverb — the vapor texture.
block WhistleGhost {
  sample WhistleGhostSrc = bounce(Whistle(), note: C5, beats: 2)
  track Pad {
    instrument sampler(sample: WhistleGhostSrc, reverse: "on", sustain: 0.85, release: 0.4)
    insert reverb(size: 0.7, decay: 0.65, mix: 0.4)
    insert crush(bits: 0.35, rate: 0.25, mix: 0.35)
    volume 0.5
  }
}
