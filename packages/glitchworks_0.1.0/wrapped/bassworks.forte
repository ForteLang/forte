// glitchworks/bassworks — BASS GROOVES, ready to drop: every block is a
// bass source produced, bounced and already playing a line. The low end
// obeys the same laws as the drums here: cuts leave rests, no two notes
// identical, and the machine can re-decide the line (pitch steps, stretch,
// gates) while it plays.
import { Bass303, Square303 } from "../../essentials_0.6.0/instruments/tb303.forte"
import { SH101Bass, SH101Zap } from "../../essentials_0.6.0/instruments/sh101.forte"
import { Wobble } from "../../essentials_0.6.0/instruments/leads.forte"
import { P5Brass } from "../../essentials_0.6.0/instruments/prophet5.forte"
import { KickSub } from "../../essentials_0.6.0/instruments/drums.forte"
import { UprightBass, GuitarPluck } from "../instruments/modal.forte"

// ---- AcidHalf — an acid line at half speed, still in key ------------------
block AcidHalf {
  block AcidHalfSrc {
    track A { instrument Bass303(cutoff: 0.6, reso: 0.8, envmod: 0.65) volume 0.9
      play notes`C2!:0.25 C2~:0.25 D#2:0.25 C2:0.25 G2!~:0.5 C2:0.25 A#1:0.25 C2!:0.25 C3~:0.25 C2:0.5 F2:0.25 D#2:0.25 C2:0.5` at bars(1..1) }
  }
  sample AcidHalfS = bounce(AcidHalfSrc, note: C2, beats: 4)
  track Slow {
    instrument sampler(attack: 0.06, sample: AcidHalfS, end: 0.667, stretch: 0.25, sustain: 1.0, release: 0.2, vary: 0.08)
    modulate pitch with random(rate: 0.07, amount: 0.03, smooth: 0.8) as swim
    // bar 4: the tape lunges toward full speed and falls back
    automate stretch from 0.25 to 0.45 over bars(4..4)
    automate stretch from 0.45 to 0.25 over bars(5..5)
    insert saturate(mode: "fuzz", drive: 0.4, tone: 0.55)
    insert parcomp(amount: 0.5, drive: 0.6, color: 0.4)
    volume 0.85
    play notes`C2~:8 D#2~:4 C2~:4` at bars(1..4)
  }
}

// ---- SquareRoll — a square 303 that keeps rolling over itself -------------
block SquareRoll {
  block SquareRollSrc {
    track Q { instrument Square303(cutoff: 0.55, reso: 0.7) volume 0.9
      play notes`C2:0.5 C2:0.25 D#2:0.25 G2:0.5 F2:0.5 C2:0.5 A#1:0.5 C2:0.5 D2:0.5` at bars(1..1) }
  }
  sample SquareRollS = bounce(SquareRollSrc, note: C2, beats: 4)
  track Roll {
    instrument sampler(attack: 0.06, sample: SquareRollS, slices: 16, end: 0.667, choke: "on", vary: 0.15, sustain: 0.0, decay: 0.4)
    modulate pitch with steps(seq: "0.5 0.5 0.625 0.5 0.5 0.375 0.5 0.75", every: "1/8", amount: 0.15) as flip
    insert saturate(mode: "tape", drive: 0.4)
    volume 0.85
    play notes`C2:0.25 D2:0.25 _:0.25 F2:0.25 C2:0.25 _:0.25 G2:0.25 A2:0.25 C2:0.5 _:0.5 D#2:0.25 C#2:0.25 _:0.5` at bars(1..3)
    play notes`_:3.5 A#2:0.125 G#2:0.125 F2:0.125 D2:0.125` at bars(2..2)
    play notes`C2:0.25 D2:0.25 F2:0.25 _:0.25 C2:0.125 C#2:0.125 G2:0.25 A2:0.25 _:0.25 C2:0.25 A#2:0.125 G#2:0.125 F2:0.25 D#2:0.25 C#2:0.25 C2:0.25 _:0.5` at bars(4..4)
  }
}

// ---- SH101Drive — driven 101 eighths that jump the octave -----------------
block SH101Drive {
  block SH101DriveSrc {
    track B { instrument SH101Bass volume 0.9
      play notes`C2:0.5 C2:0.5 C2:0.5 C2:0.5 C2:0.5 C2:0.5 C2:0.5 C2:0.5` at bars(1..1) }
  }
  sample SH101DriveS = bounce(SH101DriveSrc, note: C2, beats: 4)
  track Drive {
    instrument sampler(attack: 0.06, sample: SH101DriveS, slices: 8, end: 0.667, choke: "on", vary: 0.1, sustain: 0.0, decay: 0.45)
    modulate pitch with steps(seq: "0.5 0.5 0.75 0.5 0.5 0.75 0.5 0.625", every: "1/8", amount: 0.5) as jump
    insert drive(drive: 0.35)
    insert comp(thresh: 0.45, ratio: 0.6, attack: 0.02, release: 0.15, makeup: 0.2)
    volume 0.85
    play notes`C2:0.5 D2:0.5 C2:0.5 E2:0.5 C2:0.5 F2:0.5 C2:0.5 G2:0.5` at bars(1..3)
    play notes`C2:0.5 D2:0.25 D#2:0.25 C2:0.5 E2:0.25 F2:0.25 C2:0.25 C2:0.25 G2:0.5 A2:0.25 G2:0.25 F2:0.25 D#2:0.25 C2:0.25 _:0.25` at bars(4..4)
  }
}

// ---- UprightWalk — a walking bass re-walked by the sampler ----------------
block UprightWalk {
  block UprightWalkSrc {
    track U {
      instrument UprightBass(body: 0.55)
      insert comp(thresh: 0.5, ratio: 0.5, makeup: 0.15)
      insert vinyl(wow: 0.3, crackle: 0.1, hiss: 0.1, dust: 0.3)
      volume 0.95
      play humanize(notes`C2:1 D#2:1 F2:1 G2:1`, time: 0.02, vel: 12, seed: 41) at bars(1..1)
    }
  }
  sample UprightWalkS = bounce(UprightWalkSrc, note: C2, beats: 4)
  track Walk {
    instrument sampler(attack: 0.06, sample: UprightWalkS, gain: 1.0, slices: 8, end: 0.667, choke: "on", vary: 0.12, sustain: 0.0, decay: 0.6)
    modulate pitch with random(rate: 0.06, amount: 0.025, smooth: 0.85) as swim
    insert comp(thresh: 0.45, ratio: 0.6, attack: 0.02, release: 0.18, makeup: 0.25)
    volume 0.95
    play notes`C2:1 E2:1 C2:0.5 D2:0.5 G2:0.5 F2:0.5 C2:1 E2:0.75 D2:0.25 A2:1 G2:0.5 F2:0.5` at bars(1..3)
    play notes`C2:0.75 D2:0.25 E2:0.5 G2:0.5 F2:0.375 E2:0.375 D2:0.25 C2:0.5 A2:0.25 G2:0.25` at bars(4..4)
  }
}

// ---- WobbleGate — an LFO bass carved by a gate you can steer --------------
block WobbleGate {
  block WobbleGateSrc {
    track W { instrument Wobble volume 0.9
      play notes`C2~:4` at bars(1..1) }
  }
  sample WobbleGateS = bounce(WobbleGateSrc, note: C2, beats: 4)
  track Carve {
    instrument sampler(attack: 0.06, sample: WobbleGateS, end: 0.667, loop: "on", sustain: 1.0, release: 0.15, vary: 0.06)
    insert gate(depth: 0.95, beats: 0.25, duty: 0.45)
    modulate gate.duty with random(rate: 0.09, amount: 0.18, smooth: 0.6) as carve
    insert saturate(mode: "fuzz", drive: 0.35, tone: 0.5)
    volume 0.85
    play notes`C2~:6 D#2~:2 C2~:4 A#1~:2 G1~:2` at bars(1..4)
  }
}

// ---- SubPulse — a sub floor that pumps on its own -------------------------
block SubPulse {
  block SubPulseSrc {
    track K { instrument KickSub volume 0.95
      play notes`C1~:4` at bars(1..1) }
  }
  sample SubPulseS = bounce(SubPulseSrc, note: C1, beats: 4)
  track Pulse {
    instrument sampler(attack: 0.06, sample: SubPulseS, end: 0.667, loop: "on", sustain: 1.0, release: 0.25, glide: 0.1)
    modulate pitch with random(rate: 0.05, amount: 0.02, smooth: 0.85) as swim
    insert pump(amount: 0.7, beats: 1)
    insert saturate(mode: "tape", drive: 0.4)
    volume 0.85
    play notes`C1~:6 G1~:2 C1~:4 A#0~:4` at bars(1..4)
  }
}

// ---- PickBass — muted funk plucks, chopped tighter than played ------------
block PickBass {
  block PickBassSrc {
    track P {
      instrument GuitarPluck(pick: 0.4)
      insert saturate(mode: "tube", drive: 0.3)
      volume 0.95
      play humanize(notes`C2:0.25 C2:0.25 _:0.25 C2:0.25 D#2:0.25 _:0.25 C2:0.25 F2:0.25 C2:0.25 _:0.25 G2:0.25 C2:0.25 _:0.25 A#2:0.25 C2:0.25 _:0.25`, time: 0.01, vel: 18, seed: 47) at bars(1..1)
    }
  }
  sample PickBassS = bounce(PickBassSrc, note: C2, beats: 4)
  track Funk {
    instrument sampler(attack: 0.06, sample: PickBassS, slices: 16, end: 0.667, choke: "on", vary: 0.18, sustain: 0.0, decay: 0.3)
    modulate pitch with random(rate: 0.1, amount: 0.03, smooth: 0.7) as swim
    insert comp(thresh: 0.5, ratio: 0.55, makeup: 0.15)
    volume 0.9
    play notes`C2:0.25 _:0.25 D2:0.25 E2:0.25 _:0.25 G2:0.25 C2:0.25 _:0.25 A2:0.25 C2:0.25 _:0.5 F2:0.25 D#2:0.25 _:0.5` at bars(1..3)
    play notes`C2:0.25 _:0.25 D2:0.125 D#2:0.125 E2:0.25 _:0.25 G2:0.25 C2:0.125 C2:0.125 A2:0.25 _:0.25 C2:0.25 F2:0.125 E2:0.125 D#2:0.25 D2:0.25 C2:0.25 _:0.5` at bars(4..4)
  }
}

// ---- BassStabEcho — dub stabs answering themselves ------------------------
block BassStabEcho {
  block BassStabEchoSrc {
    track B {
      instrument P5Brass(blow: 0.45)
      insert delay(time: 0.09, fdbk: 0.6, mix: 0.5)
      insert filter(type: "lp", cutoff: 0.5, reso: 0.3)
      volume 0.9
      play notes`[C2 G2]:0.5 _:3.5` at bars(1..1)
    }
  }
  sample BassStabEchoS = bounce(BassStabEchoSrc, note: C2, beats: 4)
  track Dub {
    instrument sampler(attack: 0.06, sample: BassStabEchoS, gain: 1.0, slices: 8, end: 0.667, choke: "on", vary: 0.15, sustain: 0.0, decay: 0.6)
    modulate pitch with random(rate: 0.08, amount: 0.03, smooth: 0.75) as swim
    insert parcomp(amount: 0.5, drive: 0.6, color: 0.35)
    insert reverb(size: 0.6, decay: 0.5, mix: 0.2)
    volume 0.95
    play notes`C2:1 _:1 D2:0.5 _:0.5 C2:0.5 _:0.5 F2:1 _:1 C2:0.5 E2:0.5 _:1` at bars(1..3)
    play notes`C2:0.5 D2:0.25 _:0.25 F2:0.5 _:0.5 C2:0.25 E2:0.25 G2:0.5 _:1` at bars(4..4)
  }
}

// ---- LaserBass — the zap as a bassline, re-aimed every eighth -------------
block LaserBass {
  block LaserBassSrc {
    track Z { instrument SH101Zap volume 0.95
      play notes`C2:0.5 _:3.5` at bars(1..1) }
  }
  sample LaserBassS = bounce(LaserBassSrc, note: C2, beats: 2)
  track Beam {
    instrument sampler(attack: 0.06, gain: 1.0, sample: LaserBassS, end: 0.5, choke: "on", vary: 0.15, sustain: 0.0, decay: 0.45)
    modulate pitch with steps(seq: "0.5 0.625 0.5 0.75 0.375 0.5 0.875 0.5", every: "1/8", amount: 0.2) as aim
    insert filter(type: "lp", cutoff: 0.65, reso: 0.6)
    insert saturate(mode: "fuzz", drive: 0.35, tone: 0.6)
    volume 0.85
    play notes`C2:0.5 C2:0.25 _:0.25 C3:0.5 C2:0.5 _:0.5 G2:0.25 C2:0.25 C2:0.5 _:0.5` at bars(1..3)
    play notes`C2:0.25 C3:0.25 C2:0.25 D#3:0.25 C2:0.25 G2:0.25 C3:0.125 C2:0.125 F2:0.25 C2:0.25 _:0.25 C2:0.25 G2:0.25 D#2:0.25 C2:0.25 _:0.25` at bars(4..4)
  }
}

// ---- OctaveHouse — the octaver-pedal house bass ----------------------------
// One fat note, resampled; the LINE is the octave jump (the pedal), the
// pump breathes once a beat like the house records it comes from.
block OctaveHouse {
  block OctaveHouseSrc {
    track B { instrument SH101Bass
      insert saturate(mode: "tube", drive: 0.4)
      insert comp(thresh: 0.45, ratio: 0.6, attack: 0.02, release: 0.15, makeup: 0.2)
      volume 0.95
      play notes`C2~:2 _:2` at bars(1..1) }
  }
  sample OctaveHouseS = bounce(OctaveHouseSrc, note: C2, beats: 2)
  track Pedal {
    instrument sampler(attack: 0.06, sample: OctaveHouseS, end: 0.5, choke: "on", vary: 0.1, sustain: 0.0, decay: 0.4)
    modulate pitch with random(rate: 0.07, amount: 0.02, smooth: 0.85) as swim
    insert pump(amount: 0.6, beats: 1)
    insert saturate(mode: "tape", drive: 0.35)
    volume 0.9
    play notes`C2:0.5 C3:0.5 C2:0.5 C3:0.5 C2:0.5 C3:0.5 C2:0.5 C3:0.5` at bars(1..3)
    play notes`C2:0.5 C3:0.5 D#2:0.5 D#3:0.5 F2:0.5 F3:0.5 G2:0.25 G3:0.25 A#2:0.25 A#3:0.25` at bars(4..4)
  }
}

// ---- FuzzWahBass — a bass through the pedalboard ---------------------------
// Fuzz first, then an LFO riding the filter like a wah rocked by a foot.
block FuzzWahBass {
  block FuzzWahBassSrc {
    track G { instrument GuitarPluck(pick: 0.5) volume 0.95
      play notes`C2~:2 _:2` at bars(1..1) }
  }
  sample FuzzWahBassS = bounce(FuzzWahBassSrc, note: C2, beats: 2)
  track Pedalboard {
    instrument sampler(attack: 0.06, sample: FuzzWahBassS, end: 0.5, choke: "on", vary: 0.12, sustain: 0.0, decay: 0.5)
    insert saturate(mode: "fuzz", drive: 0.55, tone: 0.6)
    insert filter(type: "lp", cutoff: 0.5, reso: 0.55)
    modulate filter.cutoff with lfo(rate: 0.3, amount: 0.3, shape: "sine") as wah
    insert comp(thresh: 0.45, ratio: 0.6, attack: 0.02, release: 0.15, makeup: 0.2)
    volume 0.9
    play notes`C2:0.75 C2:0.25 D#2:0.5 C2:0.5 F2:0.75 D#2:0.25 C2:0.5 G2:0.25 F2:0.25` at bars(1..3)
    play notes`C2:0.5 D#2:0.25 F2:0.25 G2:0.5 F2:0.25 D#2:0.25 C2:0.25 C2:0.25 A#1:0.5 C2:0.75 _:0.25` at bars(4..4)
  }
}

// ---- SubDeep — the quiet floor: a pure sub that MOVES ----------------------
block SubDeep {
  block SubDeepSrc {
    track K { instrument KickSub volume 0.95
      play notes`C1~:4` at bars(1..1) }
  }
  sample SubDeepS = bounce(SubDeepSrc, note: C1, beats: 4)
  track Deep {
    instrument sampler(attack: 0.1, sample: SubDeepS, end: 0.667, loop: "on", sustain: 1.0, release: 0.35, glide: 0.18)
    modulate pitch with random(rate: 0.04, amount: 0.015, smooth: 0.9) as swim
    // bar 4: the floor dives a fourth and slides back
    automate pitch from 0.5 to 0.396 over bars(4..4)
    automate pitch from 0.396 to 0.5 over bars(5..5)
    insert saturate(mode: "tape", drive: 0.3)
    insert comp(thresh: 0.5, ratio: 0.55, attack: 0.03, release: 0.2, makeup: 0.15)
    volume 0.85
    play notes`C1~:6 D#1~:2 C1~:4 A#0~:2 C1~:2` at bars(1..4)
  }
}

