// glitchworks/grooveworks — GROOVES, ready to drop: every block here is a
// drum/percussion source PRODUCED (insert chains), bounced, chopped and
// already playing a FOUR-BAR ARC — not a loop. House rules, learned the
// hard way: (1) bar 4 always breaks the pattern (fills, rolls, the sound
// eating itself), (2) something drifts at all times (a random pitch swim,
// a stepped flip, a window slide) so no two bars are the same audio,
// (3) choke cuts leave rests, (4) crackle is NOT baked here — one vinyl
// bed per SONG (see textureworks TapeAir), or every track pops at once.
//
// Slice math reminder: a bounce carries +2 beats of tail — 4-beat source →
// end: 0.667, 2-beat → 0.5, 1-beat → 0.333. Slice n = bounce note + n.
import { Kick808, Kick909, Kick606, KickSub, SnareTight, Snare908, SnareBrush, HatClosed, HatOpen, HatPedal, Rim, Stick, Clap, Snap, Tom, TomFloor, Ride, Crash, Shaker, Cowbell } from "../../essentials_0.6.0/instruments/drums.forte"
import { KickModal, SnareModal, RideModal } from "../instruments/modal.forte"

// ---- SnareFlip — the backbeat that keeps getting re-edited ----------------
block SnareFlip {
  block SnareFlipSrc {
    track S {
      instrument SnareTight(snap: 0.72)
      insert delay(time: 0.08, fdbk: 0.55, mix: 0.4)
      insert saturate(mode: "fuzz", drive: 0.35, tone: 0.55)
      insert parcomp(amount: 0.55, drive: 0.6, color: 0.45)
      volume 0.95
      play beat`x--- ---- ---- ----` at bars(1..1)
    }
  }
  sample SnareFlipS = bounce(SnareFlipSrc, note: C3, beats: 1)
  track Main {
    instrument sampler(sample: SnareFlipS, gain: 1.0, sustain: 0.0, decay: 0.5, vary: 0.15)
    modulate pitch with random(rate: 0.12, amount: 0.03, smooth: 0.7) as swim
    volume 0.9
    play late(beat`---- x--- ---- x---`, by: 0.06) at bars(1..2)
    play late(beat`---- x--- ---- --x-`, by: 0.05) at bars(3..3)
    play late(beat`---- x-.- .--- x..-`, by: 0.045) at bars(4..4)
  }
  track Chop {
    instrument sampler(sample: SnareFlipS, gain: 1.0, slices: 8, end: 0.333, choke: "on", vary: 0.3, sustain: 0.0, decay: 0.3)
    volume 0.8
    play notes`_:7 D3:0.25 F3:0.25 C3:0.25 G3:0.25` at bars(1..2)
    play notes`_:2.5 E3:0.125 D3:0.125 C3:0.25 _:1` at bars(3..3)
    play notes`_:3 G3:0.125 F3:0.125 D3:0.125 C3:0.125 A3:0.25 C3:0.25` at bars(4..4)
  }
  track Ghost {
    instrument sampler(sample: SnareFlipS, gain: 1.0, end: 0.333, reverse: "on", sustain: 1.0, release: 0.1, vary: 0.2)
    volume 0.45
    play notes`_:3.25 C3~:0.75` at bars(2..2)
    play notes`_:3.5 C3~:0.5` at bars(4..4)
  }
}

// ---- HatWork — sixteenths that never repeat, rolls that trip --------------
block HatWork {
  block HatWorkSrc {
    track HC { instrument HatClosed(bright: 0.85) volume 0.6
      play beat`x-x- x-x- x-x- x-x-` at bars(1..1) }
    track HO { instrument HatOpen(decay: 0.3) volume 0.5
      play beat`--x- ---- --x- ----` at bars(1..1) }
  }
  sample HatWorkS = bounce(HatWorkSrc, note: C3, beats: 4)
  track Hats {
    instrument sampler(sample: HatWorkS, gain: 1.0, slices: 16, end: 0.667, choke: "on", vary: 0.3, sustain: 0.0, decay: 0.3)
    modulate pitch with random(rate: 0.2, amount: 0.04, smooth: 0.6) as swim
    insert saturate(mode: "tape", drive: 0.35, tone: 0.5)
    volume 0.9
    play notes`C3:0.25 D3:0.25 C#3:0.25 E3:0.25 C3:0.25 F3:0.25 D3:0.25 G3:0.25 C3:0.25 D#3:0.25 C#3:0.25 A3:0.25 C3:0.25 D3:0.25 F#3:0.25 B3:0.25` at bars(1..3)
    play notes`C3:0.25 D3:0.25 _:0.25 E3:0.25 C3:0.125 C#3:0.125 F3:0.25 _:0.25 G3:0.25 _:0.25 A3:0.125 G3:0.125 C4:0.125 B3:0.125 A3:0.125 G3:0.125 D3:0.25 _:0.25 C3:0.5` at bars(4..4)
  }
}

// ---- BrushShuffle — brushed shuffle whose answer keeps changing -----------
block BrushShuffle {
  block BrushShuffleSrc {
    track B { instrument SnareBrush volume 0.9
      play beat`x-x- x-x- x-x- x-x-` at bars(1..1) }
    track R { instrument Rim volume 0.5
      play beat`---- x--- ---- x---` at bars(1..1) }
  }
  sample BrushShuffleS = bounce(BrushShuffleSrc, note: C3, beats: 4)
  track Shuffle {
    instrument sampler(sample: BrushShuffleS, gain: 1.0, slices: 8, end: 0.667, choke: "on", vary: 0.25, sustain: 0.0, decay: 0.45)
    modulate pitch with random(rate: 0.1, amount: 0.035, smooth: 0.7) as swim
    insert parcomp(amount: 0.55, drive: 0.6, color: 0.4)
    insert saturate(mode: "tape", drive: 0.3, tone: 0.55)
    volume 0.95
    play notes`C3:0.5 D3:0.5 _:0.5 E3:0.5 C3:0.5 F3:0.25 F#3:0.25 _:0.5 G3:0.5` at bars(1..2)
    play notes`C3:0.5 D3:0.5 _:0.5 E3:0.25 D#3:0.25 C3:0.5 F3:0.25 F#3:0.25 _:0.25 G3:0.25 A3:0.25 G3:0.25` at bars(3..3)
    play notes`C3:0.5 _:0.5 D3:0.25 E3:0.25 F3:0.25 G3:0.25 C3:0.25 C3:0.125 D3:0.125 A3:0.25 G3:0.25 F3:0.25 E3:0.25 D3:0.25 C3:0.25` at bars(4..4)
  }
}

// ---- TomTalk — toms in conversation, always re-pitching -------------------
block TomTalk {
  block TomTalkSrc {
    track T { instrument Tom volume 0.9
      play beat`x--- -x-- ---- ----` at bars(1..1) }
    track TF { instrument TomFloor volume 0.9
      play beat`---- ---- x--- -x--` at bars(1..1) }
  }
  sample TomTalkS = bounce(TomTalkSrc, note: C3, beats: 4)
  track Talk {
    instrument sampler(sample: TomTalkS, gain: 1.0, slices: 8, end: 0.667, choke: "on", vary: 0.25, sustain: 0.0, decay: 0.45)
    modulate pitch with steps(seq: "0.5 0.625 0.5 0.375 0.5 0.75 0.5 0.25", every: "1/4", amount: 0.25) as bend
    insert saturate(mode: "tube", drive: 0.35)
    volume 0.85
    play notes`C3:0.5 _:0.5 E3:0.5 D3:0.25 _:0.25 G3:0.5 _:0.5 F3:0.25 C3:0.25 _:0.5` at bars(1..3)
    play notes`C3:0.25 E3:0.25 G3:0.25 F3:0.25 D3:0.125 E3:0.125 C3:0.25 G3:0.25 _:0.5 F3:0.25 E3:0.25 D3:0.25 C3:0.5 _:0.5` at bars(4..4)
  }
}

// ---- RideGrain — a cymbal at half speed, freezing at the turn -------------
block RideGrain {
  block RideGrainSrc {
    track R { instrument RideModal(wash: 0.4) volume 0.8
      play beat`x--- x--- x--- x---` at bars(1..1) }
  }
  sample RideGrainS = bounce(RideGrainSrc, note: C3, beats: 4)
  track Grain {
    instrument sampler(sample: RideGrainS, gain: 1.0, end: 0.667, stretch: 0.25, sustain: 1.0, release: 0.3, vary: 0.1)
    // the shimmer slows to a near-freeze at the end of every 4th bar
    automate stretch from 0.25 to 0.05 over bars(4..4)
    automate stretch from 0.05 to 0.25 over bars(5..5)
    insert exciter(amount: 0.3)
    insert width(amount: 0.8)
    insert reverb(size: 0.6, decay: 0.5, mix: 0.25)
    volume 0.9
    play notes`C3~:8 D3~:4 C3~:4` at bars(1..4)
  }
}

// ---- ClapRun — claps that trip over themselves, differently every bar -----
block ClapRun {
  block ClapRunSrc {
    track C { instrument Clap volume 0.9
      play beat`x--- ---- ---- ----` at bars(1..1) }
    track SN { instrument Snap volume 0.6
      play beat`--x- ---- ---- ----` at bars(1..1) }
  }
  sample ClapRunS = bounce(ClapRunSrc, note: C3, beats: 1)
  track Run {
    instrument sampler(sample: ClapRunS, gain: 1.0, sustain: 0.0, decay: 0.4, vary: 0.3, choke: "on")
    modulate pitch with random(rate: 0.15, amount: 0.05, smooth: 0.5) as swim
    insert parcomp(amount: 0.55, drive: 0.6, color: 0.45)
    insert exciter(amount: 0.3)
    volume 0.95
    play beat`---- x--- ---- x*3-` at bars(1..1)
    play beat`---- x--- ---- x---` at bars(2..2)
    play beat`---- x-x- ---- x*4-` at bars(3..3)
    play beat`---- x--- ---x*3 --x*5-` at bars(4..4)
  }
}

// ---- PercModal — a hand-percussion section that argues --------------------
block PercModal {
  block PercModalSrc {
    track CB { instrument Cowbell volume 0.55
      play beat`x--- --x- ---- x---` at bars(1..1) }
    track ST { instrument Stick volume 0.7
      play beat`--x- x--- -x-- --x-` at bars(1..1) }
    track SH { instrument Shaker volume 0.6
      play beat`x-x- x-x- x-x- x-x-` at bars(1..1) }
  }
  sample PercModalS = bounce(PercModalSrc, note: C3, beats: 4)
  track Perc {
    instrument sampler(sample: PercModalS, gain: 1.0, slices: 16, end: 0.667, choke: "on", vary: 0.3, sustain: 0.0, decay: 0.35)
    modulate pitch with random(rate: 0.18, amount: 0.045, smooth: 0.55) as swim
    insert parcomp(amount: 0.5, drive: 0.6, color: 0.4)
    insert saturate(mode: "tape", drive: 0.3)
    volume 0.95
    play notes`C3:0.25 E3:0.25 _:0.25 G3:0.25 C#3:0.25 _:0.25 A3:0.25 D3:0.25 _:0.5 F3:0.25 B3:0.25 C3:0.25 _:0.25 D#3:0.25 G#3:0.25` at bars(1..3)
    play notes`C3:0.25 E3:0.25 G3:0.125 A3:0.125 _:0.25 C#3:0.25 D3:0.125 D#3:0.125 F3:0.25 _:0.25 B3:0.125 A#3:0.125 G#3:0.125 G3:0.125 F3:0.25 D#3:0.25 C3:0.25 _:0.25 G3:0.25 C3:0.25` at bars(4..4)
  }
}

// ---- AmenTwo — the busy break, recut differently every pass ---------------
block AmenTwo {
  block AmenTwoSrc {
    track K { instrument Kick808(decay: 0.35) volume 0.95
      play beat`x--- --x- --x- ----` at bars(1..1) }
    track S { instrument Snare908(snap: 0.7) volume 0.9
      play late(beat`---- X--. ---- x-.X`, by: 0.03) at bars(1..1) }
    track HC { instrument HatClosed(bright: 0.85) volume 0.5
      play humanize(beat`x-x- x-xx x-x- xx-x`, time: 0.01, vel: 16, seed: 23) at bars(1..1) }
    track RD { instrument Ride volume 0.35
      play beat`x--- x--- x--- x---` at bars(1..1) }
  }
  sample AmenTwoS = bounce(AmenTwoSrc, note: C3, beats: 4)
  track Cut {
    instrument sampler(sample: AmenTwoS, gain: 1.0, slices: 16, end: 0.667, choke: "on", vary: 0.2, sustain: 0.0, decay: 0.5)
    modulate pitch with random(rate: 0.1, amount: 0.03, smooth: 0.7) as swim
    insert transient(attack: 0.75, sustain: 0.4)
    insert saturate(mode: "tape", drive: 0.35)
    insert stutter(beats: 0.25, mix: 0.0)
    insert parcomp(amount: 0.5, drive: 0.55, color: 0.4)
    volume 0.9
    play notes`C3:0.25 C#3:0.25 _:0.25 D#3:0.25 G3:0.5 _:0.5 A3:0.25 C3:0.25 _:0.25 D3:0.25 F3:0.25 A#3:0.25 C3:0.25 _:0.25` at bars(1..2)
    play notes`C3:0.25 _:0.25 C#3:0.25 D#3:0.25 G3:0.25 G#3:0.25 _:0.5 A3:0.25 A#3:0.25 C3:0.5 D3:0.125 D#3:0.125 F3:0.25 _:0.5` at bars(3..3)
    play notes`C3:0.25 C#3:0.125 D3:0.125 D#3:0.25 _:0.25 G3:0.25 A3:0.125 A#3:0.125 B3:0.25 C4:0.25 _:0.25 A#3:0.125 G3:0.125 D#3:0.25 C3:0.25 G3:0.25 C3:0.25 _:0.5` at bars(4..4)
  }
  track Rev {
    instrument sampler(sample: AmenTwoS, gain: 1.0, slices: 16, end: 0.667, choke: "on", vary: 0.3, reverse: "on", sustain: 0.0, decay: 0.25)
    insert crush(bits: 0.35, rate: 0.2, mix: 0.3)
    volume 0.4
    play notes`_:3.5 B3:0.25 G3:0.25` at bars(2..2)
    play notes`_:3.25 D#3:0.25 F3:0.25 A#3:0.25` at bars(4..4)
  }
}

// ---- HalfBreak — the busy break at half speed, waking up at the turn ------
block HalfBreak {
  block HalfBreakSrc {
    track K { instrument Kick808(decay: 0.35) volume 0.95
      play beat`x--- --x- --x- ----` at bars(1..1) }
    track S { instrument Snare908(snap: 0.7) volume 0.9
      play late(beat`---- X--. ---- x-.X`, by: 0.03) at bars(1..1) }
    track HC { instrument HatClosed(bright: 0.85) volume 0.5
      play humanize(beat`x-x- x-xx x-x- xx-x`, time: 0.01, vel: 16, seed: 23) at bars(1..1) }
  }
  sample HalfBreakS = bounce(HalfBreakSrc, note: C3, beats: 4)
  track Doom {
    instrument sampler(sample: HalfBreakS, gain: 1.0, end: 0.667, stretch: 0.25, sustain: 1.0, release: 0.25, vary: 0.1)
    // bar 4: the tape catches up to full speed, then drops back
    automate stretch from 0.25 to 0.5 over bars(4..4)
    automate stretch from 0.5 to 0.25 over bars(5..5)
    insert saturate(mode: "tape", drive: 0.45)
    insert crush(bits: 0.35, rate: 0.2, mix: 0.3)
    volume 0.85
    play notes`C3~:8 D3~:2 C3~:6` at bars(1..4)
  }
}

// ---- KickRumble — a 606 kick rolling a different floor each bar -----------
block KickRumble {
  block KickRumbleSrc {
    track K {
      instrument Kick606
      insert saturate(mode: "fuzz", drive: 0.5, tone: 0.5)
      insert parcomp(amount: 0.6, drive: 0.65, color: 0.35)
      volume 0.95
      play beat`x--- ---- ---- ----` at bars(1..1)
    }
  }
  sample KickRumbleS = bounce(KickRumbleSrc, note: C3, beats: 1)
  track Roll {
    instrument sampler(sample: KickRumbleS, gain: 1.0, slices: 8, end: 0.333, choke: "on", vary: 0.25, sustain: 0.0, decay: 0.35)
    modulate pitch with random(rate: 0.08, amount: 0.04, smooth: 0.75) as swim
    volume 0.9
    play notes`C3:0.5 _:0.5 C3:0.5 D3:0.25 E3:0.25 C3:0.5 _:0.5 C3:0.25 D3:0.25 F3:0.25 G3:0.25` at bars(1..3)
    play notes`C3:0.5 _:0.25 D3:0.25 C3:0.25 E3:0.125 F3:0.125 G3:0.25 A3:0.25 _:0.25 C3:0.125 D3:0.125 E3:0.125 F3:0.125 G3:0.125 A3:0.125 B3:0.125 C4:0.125 C3:0.75` at bars(4..4)
  }
}

// ---- ShakerSwing — sixteenth shaker with human wrists and a stumble -------
block ShakerSwing {
  block ShakerSwingSrc {
    track SH { instrument Shaker volume 0.8
      play humanize(beat`x-x- x-x- x-x- x-x-`, time: 0.012, vel: 20, seed: 31) at bars(1..1) }
  }
  sample ShakerSwingS = bounce(ShakerSwingSrc, note: C3, beats: 4)
  track Sway {
    instrument sampler(sample: ShakerSwingS, gain: 1.0, slices: 16, end: 0.667, choke: "on", vary: 0.35, sustain: 0.0, decay: 0.3)
    modulate pitch with random(rate: 0.25, amount: 0.04, smooth: 0.5) as swim
    insert parcomp(amount: 0.6, drive: 0.65, color: 0.45)
    volume 0.95
    play notes`C3:0.25 D3:0.25 E3:0.25 F3:0.25 G3:0.25 A3:0.25 A#3:0.25 B3:0.25 C3:0.25 D3:0.25 D#3:0.25 F3:0.25 G3:0.25 G#3:0.25 A3:0.25 C4:0.25` at bars(1..3)
    play notes`C3:0.25 D3:0.25 E3:0.25 _:0.25 G3:0.125 A3:0.125 A#3:0.25 B3:0.25 _:0.25 C4:0.125 B3:0.125 A3:0.125 G3:0.125 F3:0.25 D#3:0.25 D3:0.25 C3:0.25 _:0.5` at bars(4..4)
  }
}

// ---- ModalBackbeat — the modal kit, laid back and self-editing ------------
block ModalBackbeat {
  block ModalBackbeatSrc {
    track K { instrument KickModal(ring: 0.4, knock: 0.4) volume 0.9
      play beat`x--- ---- x-x- ----` at bars(1..1) }
    track S { instrument SnareModal(wires: 0.7, shell: 0.5) volume 0.85
      play late(beat`---- x--- ---- x--.`, by: 0.05) at bars(1..1) }
  }
  sample ModalBackbeatS = bounce(ModalBackbeatSrc, note: C3, beats: 4)
  track Beat {
    instrument sampler(sample: ModalBackbeatS, gain: 1.0, slices: 16, end: 0.667, choke: "on", vary: 0.15, sustain: 0.0, decay: 0.5)
    modulate pitch with random(rate: 0.08, amount: 0.025, smooth: 0.8) as swim
    insert saturate(mode: "tape", drive: 0.4)
    insert parcomp(amount: 0.5, drive: 0.6, color: 0.4)
    volume 0.9
    play notes`C3:0.5 _:0.5 E3:0.5 _:0.5 G3:0.5 _:0.25 C#3:0.25 A#3:0.5 _:0.5` at bars(1..3)
    play notes`C3:0.5 _:0.25 E3:0.25 G3:0.25 F3:0.125 E3:0.125 _:0.25 C#3:0.25 A#3:0.25 B3:0.125 A#3:0.125 G3:0.25 E3:0.25 C3:0.5 _:0.5` at bars(4..4)
  }
}
