// glitchworks/textureworks — TEXTURES AND TRANSITIONS, ready to drop: the
// layers between the layers. Swells that announce sections, frozen walls,
// carved air, morse pulses — the stuff that makes a mix read as a WORLD
// instead of a stack of instruments.
import { Hiss, Dust, ColdTone } from "../instruments/textures.forte"
import { NoiseCrash, Zap, Impact } from "../../essentials_0.6.0/instruments/fx.forte"
import { Crash } from "../../essentials_0.6.0/instruments/drums.forte"
import { ChoirPad } from "../../essentials_0.6.0/instruments/pads.forte"

// ---- CrashRise — a reversed cymbal stretched into a two-beat door ---------
block CrashRise {
  block CrashRiseSrc {
    track C { instrument Crash volume 0.9
      play notes`C3~:3 _:1` at bars(1..1) }
  }
  sample CrashRiseS = bounce(CrashRiseSrc, note: C3, beats: 4)
  track Door {
    instrument sampler(sample: CrashRiseS, gain: 1.0, end: 0.667, reverse: "on", stretch: 0.3, sustain: 1.0, release: 0.2, vary: 0.1)
    insert reverb(size: 0.7, decay: 0.6, mix: 0.3)
    volume 0.8
    // lands exactly on the next bar line
    play notes`_:2 C3~:2` at bars(1..1)
  }
}

// ---- NoiseWall — crash noise frozen into a pressure wall, gate-carved -----
block NoiseWall {
  block NoiseWallSrc {
    track N { instrument NoiseCrash volume 0.9
      play notes`C3:2 _:2` at bars(1..1) }
  }
  sample NoiseWallS = bounce(NoiseWallSrc, note: C3, beats: 4)
  track Wall {
    // stretch 0.05: two seconds of noise become a near-static wall
    instrument sampler(sample: NoiseWallS, gain: 1.0, end: 0.667, stretch: 0.05, sustain: 1.0, release: 0.3, vary: 0.05)
    insert gate(depth: 0.9, beats: 0.5, duty: 0.55)
    insert filter(type: "lp", cutoff: 0.6, reso: 0.3)
    volume 0.6
    play notes`C3~:8` at bars(1..2)
  }
}

// ---- DustRattle — granular dust as a percussion bed ------------------------
block DustRattle {
  block DustRattleSrc {
    track D { instrument Dust(color: 0.65) volume 0.9
      play beat`euclid(11, 16)` at bars(1..1) }
  }
  sample DustRattleS = bounce(DustRattleSrc, note: C3, beats: 4)
  track Rattle {
    instrument sampler(sample: DustRattleS, gain: 1.0, slices: 16, end: 0.667, choke: "on", vary: 0.35, sustain: 0.0, decay: 0.25)
    insert exciter(amount: 0.25)
    volume 0.8
    play notes`C3:0.25 E3:0.25 _:0.25 G3:0.25 _:0.25 A3:0.25 C#3:0.25 _:0.25 D3:0.25 _:0.25 F#3:0.25 B3:0.25 _:0.5 G#3:0.25 D#3:0.25` at bars(1..1)
  }
}

// ---- ChoirGrain — a choir frozen mid-vowel, waiting for a sidechain -------
// Keyed-duck it at the use site and it breathes with your drums:
//   insert duck(from: <drums>, mode: "key", amount: 1.0, release: 0.3)
block ChoirGrain {
  block ChoirGrainSrc {
    track C { instrument ChoirPad volume 0.9
      play notes`[C3 G3 C4]~:4` at bars(1..1) }
  }
  sample ChoirGrainS = bounce(ChoirGrainSrc, note: C3, beats: 4)
  track Vowel {
    instrument sampler(sample: ChoirGrainS, gain: 1.0, end: 0.667, stretch: 0.1, sustain: 1.0, release: 0.4, vary: 0.08)
    insert vinyl(wow: 0.4, crackle: 0.08, hiss: 0.12, dust: 0.3)
    insert width(amount: 0.85)
    volume 0.75
    play notes`C3~:8` at bars(1..2)
  }
}

// ---- ZapArp — bleeps with the timing of a broken sequencer ----------------
block ZapArp {
  block ZapArpSrc {
    track Z { instrument Zap volume 0.85
      play beat`x-x- -x-- x--x -x-x` at bars(1..1) }
  }
  sample ZapArpS = bounce(ZapArpSrc, note: C4, beats: 4)
  track Bleep {
    instrument sampler(sample: ZapArpS, gain: 1.0, slices: 16, end: 0.667, choke: "on", vary: 0.25, sustain: 0.0, decay: 0.3)
    modulate pitch with steps(seq: "0.5 0.625 0.5 0.75 0.5 0.375 0.625 0.5", every: "1/8", amount: 0.3) as scatter
    insert delay(time: 0.19, fdbk: 0.4, mix: 0.25)
    volume 0.7
    play notes`C4:0.25 _:0.25 D4:0.25 _:0.5 F4:0.25 _:0.25 G4:0.25 _:0.5 A4:0.25 C4:0.25 _:0.75` at bars(1..1)
  }
}

// ---- ImpactStamp — downbeat stamps with a reversed shadow -----------------
block ImpactStamp {
  block ImpactStampSrc {
    track I {
      instrument Impact
      insert reverb(size: 0.6, decay: 0.5, mix: 0.3)
      volume 0.95
      play beat`x--- ---- ---- ----` at bars(1..1)
    }
  }
  sample ImpactStampS = bounce(ImpactStampSrc, note: C2, beats: 2)
  track Stamp {
    instrument sampler(sample: ImpactStampS, gain: 1.0, sustain: 0.0, decay: 0.6, vary: 0.1)
    volume 0.85
    play notes`C2:1 _:7` at bars(1..2)
  }
  track Shadow {
    instrument sampler(sample: ImpactStampS, gain: 1.0, end: 0.5, reverse: "on", sustain: 1.0, release: 0.2)
    insert crush(bits: 0.4, rate: 0.25, mix: 0.35)
    volume 0.5
    play notes`_:6.5 C2~:1.5` at bars(1..2)
  }
}

// ---- ColdPulse — the test-signal morse bed, gated and wide ----------------
block ColdPulse {
  block ColdPulseSrc {
    track T { instrument ColdTone(beatrate: 0.3) volume 0.85
      play notes`C5~:4` at bars(1..1) }
  }
  sample ColdPulseS = bounce(ColdPulseSrc, note: C5, beats: 4)
  track Morse {
    instrument sampler(sample: ColdPulseS, gain: 1.0, end: 0.667, loop: "on", sustain: 1.0, release: 0.1, vary: 0.04)
    insert gate(depth: 0.97, beats: 0.25, duty: 0.3)
    insert width(amount: 0.9)
    insert delay(time: 0.33, fdbk: 0.3, mix: 0.2)
    volume 0.5
    play notes`C5~:6 D#5~:2` at bars(1..2)
  }
}

// ---- TapeAir — the room the record was cut in ------------------------------
block TapeAir {
  block TapeAirSrc {
    track H { instrument Hiss(body: 0.4) volume 0.9
      play notes`C4~:4` at bars(1..1) }
  }
  sample TapeAirS = bounce(TapeAirSrc, note: C4, beats: 4)
  track Air {
    instrument sampler(sample: TapeAirS, gain: 1.0, end: 0.667, loop: "on", sustain: 1.0, release: 0.5)
    insert vinyl(wow: 0.3, crackle: 0.25, hiss: 0.25, dust: 0.4)
    insert gate(depth: 0.4, beats: 1, duty: 0.7)
    volume 0.3
    play notes`C4~:8` at bars(1..2)
  }
}
