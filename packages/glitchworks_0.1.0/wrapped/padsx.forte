  sample EightiesShineSrc = bounce(EightiesPad(), note: C4, beats: 3)
  track Pad {
    instrument sampler(sample: EightiesShineSrc, sustain: 0.8, release: 0.35)
    insert exciter(amount: 0.45, freq: 0.6)
    insert chorus(rate: 0.25, depth: 0.4, mix: 0.35)
