// records/dawn — the choir record. Choir and bowed strings swelling
// through the album changes, one far bell marking the motif. Cut for
// digging: the emotional wall, freezable, stretchable.
import { ChoirPad, EightiesPad } from "../../essentials_0.6.0/instruments/pads.forte"
import { BowedStrings } from "../instruments/modal.forte"
import { Bell } from "../../essentials_0.6.0/instruments/keys.forte"

song "Dawn" {
  desc "The choir record: choir and bowed strings swelling through the changes, one far bell marking the motif."
  artist "Forte Essentials"
  tempo 120bpm
  swing 0.54
  master 1.1
  key A minor

  track Voices {
    instrument ChoirPad
    insert width(amount: 0.9)
    insert reverb(size: 0.75, decay: 0.65, mix: 0.35)
    volume 0.85
    play notes`[A2 E3 A3 C4]~:8` at bars(1..2)
    play notes`[F2 C3 F3 A3]~:4 [G2 D3 G3 B3]~:4` at bars(3..4)
    play notes`[A2 E3 A3 C4]~:8` at bars(5..6)
    play notes`[F2 C3 F3 A3]~:4 [G2 D3 G3 B3]~:4` at bars(7..8)
  }
  track Bow {
    instrument BowedStrings(section: 0.55)
    insert width(amount: 0.8)
    insert reverb(size: 0.7, decay: 0.6, mix: 0.3)
    volume 0.6
    play notes`[E4 A4]~:8` at bars(1..2)
    play notes`[C4 F4]~:4 [D4 G4]~:4` at bars(3..4)
    play notes`[E4 C5]~:8` at bars(5..6)
    play notes`[C4 A4]~:4 [B3 G4]~:4` at bars(7..8)
  }
  track Warmth {
    instrument EightiesPad
    insert filter(type: "lp", cutoff: 0.4, reso: 0.15)
    volume 0.5
    play notes`[A1 A2]~:8 [F1 F2]~:4 [G1 G2]~:4` at bars(1..4)
    play notes`[A1 A2]~:8 [F1 F2]~:4 [G1 G2]~:4` at bars(5..8)
  }
  track Far {
    instrument Bell(decay: 0.7)
    insert delay(time: 0.5, fdbk: 0.4, mix: 0.35)
    insert reverb(size: 0.8, decay: 0.7, mix: 0.45)
    volume 0.4
    play notes`A4~:1 C5~:0.5 B4~:0.5 E5~:2` at bars(4..4)
    play notes`E5~:1 D5~:0.5 C5~:0.5 A4~:2` at bars(8..8)
  }
}
