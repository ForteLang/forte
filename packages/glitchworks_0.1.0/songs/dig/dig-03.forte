// dig-03 — brass on wax: the two G-minor records in the crate (brass debt
// and pedalboard alley) cut against each other in the SAME key — no
// repitch needed, the crate was dug right. Our rainbow snare and a
// walking upright hold the session together.
import { SnareRainbow } from "../../wrapped/drumcolor.forte"
import { UprightWalk } from "../../wrapped/bassworks.forte"

song "Dig 03 — Brass on Wax" {
  desc "The two G-minor records cut against each other in the same key, our snare and a walking upright holding the session."
  artist "Forte Essentials"
  tempo 98bpm
  swing 0.58
  master 1.7
  key G minor

  sample Brass = dig("../glitch/glitch-08.forte", beats: 16)
  sample Alley = dig("../glitch/glitch-12.forte", beats: 16, skip: 16)

  track WaxA {
    instrument sampler(attack: 0.05, sample: Brass, slices: 16, choke: "on", sustain: 1.0, release: 0.06, vary: 0.07)
    volume 0.95
    play notes`C3~:1 _:0.75 C#3~:0.75 _:1 D3~:0.5` at bars(1..4)
    play notes`E3~:1.25 _:0.75 F3~:0.5 _:1.5` at bars(5..8)
    play notes`G#3~:1 _:0.75 A3~:0.75 _:1 A#3~:0.5` at bars(9..12)
  }
  track WaxB {
    instrument sampler(attack: 0.05, sample: Alley, slices: 16, choke: "on", sustain: 1.0, release: 0.05, vary: 0.08)
    volume 0.85
    play notes`_:2.5 E3~:0.5 _:0.5 F3~:0.5` at bars(3..8)
    play notes`_:2.5 C4~:0.75 _:0.75` at bars(9..12)
  }

  play SnareRainbow(volume: 0.85) at bars(3..11)
  block Bass : UprightWalk {
    track Walk {
      play notes`C2:1 E2:1 C2:0.5 D2:0.5 G2:0.5 F2:0.5 C2:1 E2:0.75 D2:0.25 A2:1 G2:0.5 F2:0.5` at bars(5..12)
    }
  }
  play Bass(volume: 0.9) at bars(5..12)
}
