// dig-05 — jungle reissue: the amen record re-cut HARDER than it was
// pressed, the chip record splintering in the gaps a fifth up, and our
// own sliding 808 keeping the low end original. A reissue with new cuts.
import { GlideSub, GlideVox } from "../../wrapped/glitchset.forte"

song "Dig 05 — Jungle Reissue" {
  desc "The amen record re-cut harder than it was pressed, the chip record splintering a fifth up in the gaps."
  artist "Forte Essentials"
  tempo 158bpm
  swing 0.52
  master 1.6
  key C minor

  sample Amen = dig("../glitch/glitch-05.forte", beats: 16)
  sample Chip = dig("../glitch/glitch-09.forte", beats: 16, skip: 16)

  track ReCut {
    instrument sampler(attack: 0.04, sample: Amen, slices: 16, choke: "on", sustain: 1.0, release: 0.04, vary: 0.08)
    volume 0.95
    play notes`C3~:0.75 _:0.25 C#3~:0.5 D3~:0.5 _:0.5 D#3~:0.75 _:0.75` at bars(1..7)
    play notes`C3~:0.25 C3~:0.25 _:0.5 E3~:0.125 E3~:0.125 E3~:0.125 E3~:0.125 _:0.5 G#3~:0.5 _:1.5` at bars(8..8)
    play notes`E3~:0.75 _:0.25 F3~:0.5 _:0.5 G3~:0.5 _:0.5 G#3~:0.5 _:0.5` at bars(9..15)
    play notes`C3~:0.5 _:0.5 C3~:0.25 _:0.75 C3~:0.125 _:1.875` at bars(16..16)
  }
  track Splinter {
    instrument sampler(attack: 0.04, sample: Chip, slices: 16, choke: "on", sustain: 1.0, release: 0.04, vary: 0.1, semis: 7)
    volume 0.7
    play notes`_:3 G3~:0.5 _:0.5` at bars(2..7)
    play notes`_:1.5 A3~:0.25 A3~:0.25 _:0.5 B3~:0.5 _:1` at bars(8..8)
    play notes`_:3 C4~:0.25 C#4~:0.25 _:0.5` at bars(9..15)
    play notes`_:2 C4~:0.5 _:1.5` at bars(16..16)
  }

  block Low : GlideSub {
    track Slide {
      play notes`C1~:3 D#1~:1 C1~:2 G1~:1 F1~:1` at bars(1..14)
      play notes`C1~:4` at bars(15..16)
    }
  }
  play Low(volume: 0.9) at bars(1..16)
  block Far : GlideVox {
    track Slide {
      play notes`_:2 C4~:1 A#3~:1` at bars(9..14)
    }
  }
  play Far(volume: 0.55) at bars(9..14)
}
