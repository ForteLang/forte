// dig-01 — crate one: two records off the shelf (the first cut and the
// funk fraction), traded in two-beat cuts like a DJ with two hands. The
// body kit and a sliding sub are OURS, played live under the records.
import { BodyBeat, GlideSub } from "../../wrapped/glitchset.forte"

song "Dig 01 — Crate One" {
  desc "Two records traded in two-beat cuts, our body kit and sliding sub live underneath."
  artist "Forte Essentials"
  tempo 102bpm
  swing 0.56
  master 1.3
  key C minor

  sample RecA = dig("../glitch/glitch-01.forte", beats: 16)
  sample RecB = dig("../glitch/glitch-06.forte", beats: 16, skip: 16)

  // the two hands: A on the front halves, B answering on the backs
  track HandA {
    instrument sampler(attack: 0.05, sample: RecA, slices: 16, choke: "on", sustain: 1.0, release: 0.05, vary: 0.06)
    volume 0.95
    play notes`C3~:1.5 _:0.5 C#3~:1 _:1` at bars(1..4)
    play notes`E3~:1 _:0.5 F3~:0.5 _:2` at bars(5..8)
    play notes`G#3~:1.5 _:0.5 A3~:0.5 _:1.5` at bars(9..12)
    play notes`C3~:1 _:0.5 C3~:0.25 C3~:0.25 _:2` at bars(13..14)
  }
  track HandB {
    instrument sampler(attack: 0.05, sample: RecB, slices: 16, choke: "on", sustain: 1.0, release: 0.05, vary: 0.06)
    volume 0.9
    play notes`_:2 E3~:1 _:0.5 F3~:0.5` at bars(1..4)
    play notes`_:2 G#3~:0.5 _:0.5 A3~:0.75 _:0.25` at bars(5..8)
    play notes`_:2 C4~:1 C#4~:0.5 _:0.5` at bars(9..12)
    play notes`_:2 C4~:0.5 _:0.5 C4~:0.25 _:0.75` at bars(13..14)
  }

  // ours: the kit and the sub, playing WITH the records
  play BodyBeat(volume: 0.9) at bars(3..14)
  block Ours : GlideSub {
    track Slide {
      play notes`C1~:3 D#1~:1 C1~:2 G1~:1 F1~:1` at bars(5..12)
      play notes`C1~:4` at bars(13..14)
    }
  }
  play Ours(volume: 0.85) at bars(5..14)
}
