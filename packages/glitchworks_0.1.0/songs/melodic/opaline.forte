// opaline — the first FULL-LENGTH pressing (3:31). The long-form law:
// build-ups and drops, never a flat loop. Arc: intro → groove → BUILD →
// DROP → breakdown → bigger BUILD → peak DROP → outro. Two records are
// pressed (the groove band and the heavier drop band); the bed hums
// through everything and rests exactly twice — the one-bar gasps before
// each drop, the sanctioned total silences. Pitch discipline: strictly
// in key; a glide-in at bar 1, tape-death at the end, and the toy layer
// carrying the micro-bug on one voice.

device NightWash : Instrument {
  node w = lfo(rate: 0.05, shape: "sine")
  node e = adsr(a: 0.9, d: 0.3, s: 0.9, r: 0.9)
  node n = noise()
  node f = svf(in: n, mod: w, cutoff: 0.4, reso: 0.25)
  out gain(in: f, mod: e)
}

device GlassKick : Instrument {
  node pe = adsr(a: 0.001, d: 0.045, s: 0.0, r: 0.02)
  node e = adsr(a: 0.001, d: 0.28, s: 0.0, r: 0.05)
  node o = osc(shape: "sine", mod: pe)
  node warm = shaper(in: o, drive: 0.25, mode: "tanh")
  out gain(in: warm, mod: e)
}

device AirHat : Instrument {
  node e = adsr(a: 0.004, d: 0.08, s: 0.0, r: 0.04)
  node n = noise()
  node hi = gain(in: n, mod: e)
  out pan(in: hi, pos: 0.62)
}

device GlassBass : Instrument {
  param cutoff = 0.4 in 0..1
  node e = adsr(a: 0.004, d: 0.16, s: 0.2, r: 0.08)
  node o = osc(shape: "saw")
  node f = vcf(in: o, mod: e, cutoff: cutoff, reso: 0.55, drive: 0.35, track: 0.5, drift: 0.25, mode: "ladder")
  out gain(in: f, mod: e)
}

// the toy: fixed few-cent detune + per-voice drift on a stable progression
device Toy : Instrument {
  node e = adsr(a: 0.002, d: 0.12, s: 0.1, r: 0.15)
  node o = uni(shape: "tri", voices: 3, detune: 0.16, spread: 0.7)
  node f = vcf(in: o, cutoff: 0.9, reso: 0.15, drift: 0.6, mode: "svf")
  out gain(in: f, mod: e)
}

// the riser: a noise sweep that opens toward the drop
device Riser : Instrument {
  param open = 0.35 in 0..1
  node e = adsr(a: 1.0, d: 0.2, s: 1.0, r: 0.3)
  node n = noise()
  node f = svf(in: n, cutoff: open, reso: 0.35)
  out gain(in: f, mod: e)
}

song "opaline" {
  desc "Full-length melodic glitch: two pressed records, real build-ups, real drops, the bed resting only for the two pre-drop gasps."
  artist "Forte Essentials"
  tempo 116bpm
  swing "mpc54"
  key A minor
  level -12
  insert glue(thresh: 0.13, ratio: 0.5, attack: 0.05, release: 0.3, knee: 0.5, schpf: 0.4, makeup: 0.2)
  insert limiter(ceiling: 0.82, release: 0.25)

  section intro = bars(1..12)
  section groove = bars(13..28)
  section build1 = bars(29..36)
  section drop1 = bars(37..52)
  section breakdown = bars(53..68)
  section build2 = bars(69..76)
  section drop2 = bars(77..92)
  section outro = bars(93..102)

  // ---- record 1: the groove band (8 bars) ----
  block GrooveMix {
    key A minor
    let P = prog`i | VI | III | VII | i | iv7 | VI | V7`
    track Pad {
      instrument prisma(wave: "saw", cutoff: 0.66, attack: 0.25, sustain: 0.8, release: 0.45, unison: 7, detune: 0.3, spread: 0.6, sub: 0.1)
      volume 0.62
      insert space(type: "plate", size: 0.55, decay: 0.5, mix: 0.22)
      play chords(P, lead: "nearest", voicing: "drop2", register: 4) at bars(1..8)
    }
    track Bass {
      instrument GlassBass(cutoff: 0.42)
      volume 0.72
      play bass(P, rate: 0.5) at bars(1..8)
    }
    track Kick {
      instrument GlassKick()
      volume 1.0
      play beat`x--- x--- x--- x---` at bars(1..8)
    }
    track Hat {
      instrument AirHat()
      insert filter(type: "hp", cutoff: 0.8)
      volume 0.95
      play beat`--x- -xx- --x- -xxx` at bars(1..8)
    }
  }
  sample GrooveRec = bounce(GrooveMix, note: C3, beats: 32)

  // ---- record 2: the drop band (8 bars, heavier and brighter) ----
  block DropMix {
    key A minor
    let P = prog`i | VI | III | VII | i | VI | iv7 | V7`
    track Pad {
      instrument prisma(wave: "saw", cutoff: 0.72, attack: 0.12, sustain: 0.85, release: 0.4, unison: 7, detune: 0.34, spread: 0.62, sub: 0.12)
      volume 0.66
      insert space(type: "plate", size: 0.5, decay: 0.45, mix: 0.2)
      play chords(P, lead: "nearest", voicing: "close", register: 4) at bars(1..8)
    }
    track Stab {
      instrument Toy()
      volume 0.62
      insert space(type: "room", size: 0.4, decay: 0.4, mix: 0.22)
      play arp(P, rate: 0.25, style: "down") at bars(1..8)
    }
    track Bass {
      instrument GlassBass(cutoff: 0.5)
      volume 0.8
      play bass(P, rate: 0.25) at bars(1..8)
    }
    track Kick {
      instrument GlassKick()
      volume 1.0
      play beat`x--- x--- x--- x--x` at bars(1..8)
    }
    track Hat {
      instrument AirHat()
      insert filter(type: "hp", cutoff: 0.8)
      volume 1.0
      play beat`--x- -xx- --x- xxxx` at bars(1..8)
    }
    track Ride {
      instrument AirHat()
      insert filter(type: "hp", cutoff: 0.74)
      volume 0.6
      play beat`x-x- x-x- x-x- x-x-` at bars(1..8)
    }
  }
  sample DropRec = bounce(DropMix, note: C3, beats: 32)

  // ---- the groove cutter: record 1 chopped, breathing ----
  block GrooveCut {
    track Cut {
      instrument sampler(attack: 0.02, gain: 1.0, sample: GrooveRec, slices: 32, end: 0.941, choke: "on", sustain: 1.0, release: 0.05)
      automate pitch from 0.417 to 0.5 over bars(13..13)
      insert parcomp(amount: 1.0, drive: 0.7, color: 0.45, os: "2x")
      insert eq(low: 0.48, mid: 0.5, high: 0.62)
      insert exciter(amount: 0.85, freq: 0.7)
      volume 0.85
      play notes`C3~:1 C#3~:1 D3~:0.75 _:0.25 D#3~:1` at bars(1..1)
      play notes`E3~:1 F3~:1 F#3~:0.5 F#3~:0.5 G3~:1` at bars(2..2)
      play notes`G#3~:1 A3~:0.75 _:0.25 A#3~:1 B3~:1` at bars(3..3)
      play notes`C4~:1 C#4~:1 D4~:1 D#4~:0.75 _:0.25` at bars(4..4)
      play notes`E4~:1 F4~:0.75 _:0.25 F#4~:1 G4~:1` at bars(5..5)
      play notes`G#4~:1 A4~:1 A#4~:0.5 A#4~:0.5 B4~:1` at bars(6..6)
      play notes`C5~:1 C#5~:1 D5~:0.75 _:0.25 D#5~:1` at bars(7..7)
      play notes`E5~:1 F5~:1 F#5~:1 G5~:1` at bars(8..8)
      play notes`C3~:1 C#3~:0.5 C#3~:0.5 D3~:1 D#3~:1` at bars(9..9)
      play notes`E3~:1 F3~:1 _:0.5 G3~:0.5 G#3~:1` at bars(10..10)
      play notes`A3~:0.75 _:0.25 A#3~:1 B3~:1 C4~:1` at bars(11..11)
      play notes`C#4~:1 D4~:0.5 D4~:0.5 D#4~:1 E4~:1` at bars(12..12)
      play notes`F4~:1 F#4~:1 G4~:0.75 _:0.25 G#4~:1` at bars(13..13)
      play notes`A4~:1 A#4~:0.5 A#4~:0.5 B4~:1 C5~:1` at bars(14..14)
      play notes`C#5~:1 D5~:1 D#5~:0.75 _:0.25 E5~:1` at bars(15..15)
      play notes`F5~:1 F#5~:1 G5~:1 C3~:1` at bars(16..16)
    }
    track Back {
      instrument sampler(attack: 0.03, gain: 1.0, sample: GrooveRec, slices: 32, end: 0.941, reverse: "on", sustain: 1.0, release: 0.08)
      volume 0.5
      play notes`_:3 E4~:1` at bars(4..4)
      play notes`_:3.25 A4~:0.75` at bars(10..10)
      play notes`_:3 C5~:1` at bars(15..15)
    }
  }

  // ---- the drop cutter: record 2, mostly straight, stutter fits ----
  block DropCut {
    track Cut {
      instrument sampler(attack: 0.015, gain: 1.0, sample: DropRec, slices: 32, end: 0.941, choke: "on", sustain: 1.0, release: 0.05)
      insert stutter(beats: 0.25, mix: 0.0)
      automate stutter.mix from 0.0 to 0.75 over bars(44..44)
      automate stutter.mix from 0.75 to 0.0 over bars(45..45)
      automate stutter.mix from 0.0 to 0.75 over bars(84..84)
      automate stutter.mix from 0.75 to 0.0 over bars(85..85)
      insert parcomp(amount: 1.0, drive: 0.7, color: 0.45, os: "2x")
      insert eq(low: 0.48, mid: 0.5, high: 0.64)
      insert exciter(amount: 0.85, freq: 0.7)
      volume 1.0
      // drop 1: the record hits nearly straight
      play notes`C3~:1 C#3~:1 D3~:1 D#3~:1` at bars(1..1)
      play notes`E3~:1 F3~:1 F#3~:1 G3~:1` at bars(2..2)
      play notes`G#3~:1 A3~:1 A#3~:1 B3~:1` at bars(3..3)
      play notes`C4~:1 C#4~:1 D4~:0.75 _:0.25 D#4~:1` at bars(4..4)
      play notes`E4~:1 F4~:1 F#4~:1 G4~:1` at bars(5..5)
      play notes`G#4~:1 A4~:1 A#4~:1 B4~:1` at bars(6..6)
      play notes`C5~:1 C#5~:1 D5~:1 D#5~:1` at bars(7..7)
      play notes`E5~:1 F5~:0.5 F5~:0.5 F#5~:1 G5~:1` at bars(8..8)
      play notes`C3~:1 C#3~:1 D3~:1 D#3~:1` at bars(9..9)
      play notes`E3~:1 F3~:1 F#3~:0.75 _:0.25 G3~:1` at bars(10..10)
      play notes`G#3~:1 A3~:1 A#3~:1 B3~:1` at bars(11..11)
      play notes`C4~:1 C#4~:1 D4~:1 D#4~:1` at bars(12..12)
      play notes`E4~:1 F4~:1 F#4~:0.5 F#4~:0.5 G4~:1` at bars(13..13)
      play notes`G#4~:1 A4~:1 A#4~:1 B4~:1` at bars(14..14)
      play notes`C5~:1 C#5~:1 D5~:0.75 _:0.25 D#5~:1` at bars(15..15)
      play notes`E5~:1 F5~:1 F#5~:1 G5~:1` at bars(16..16)
    }
    track Back {
      instrument sampler(attack: 0.03, gain: 1.0, sample: DropRec, slices: 32, end: 0.941, reverse: "on", sustain: 1.0, release: 0.08)
      volume 0.5
      play notes`_:3 G4~:1` at bars(4..4)
      play notes`_:3 C5~:1` at bars(12..12)
    }
  }

  // ---- the builds: roll + riser, ending in the gasp ----
  block Build {
    track Roll {
      instrument GlassKick()
      volume 0.8
      play beat`x--- x--- x-x- x-x-` at bars(1..2)
      play beat`x-x- x-x- xxxx xxxx` at bars(3..4)
      play beat`x-x- xxxx xx-x xxxx` at bars(5..6)
      play beat`xxxx xxxx x*3x*3x*3x*3 x*3x*3x*3x*3` at bars(7..7)
      play beat`x*3x*3x*3x*3 x*3x*3x*3x*3 ---- ----` at bars(8..8)
    }
    track Sweep {
      instrument Riser()
      volume 0.5
      insert space(type: "hall", size: 0.7, decay: 0.6, width: 0.4, mix: 0.3)
      automate open from 0.2 to 0.9 over bars(29..36)
      automate open from 0.2 to 0.95 over bars(69..76)
      play notes`A3~:16 A3~:12 _:4` at bars(1..8)
    }
    track Lift {
      instrument Toy()
      volume 0.5
      play notes`A4:0.5 C5:0.5 E5:0.5 A5:0.5 A4:0.5 C5:0.5 E5:0.5 A5:0.5` at bars(5..7)
    }
  }

  // ---- intro / breakdown material: the toy over the bed ----
  block Sparse {
    key A minor
    let P = prog`i | VI | III | VII`
    track Keys {
      instrument Toy()
      volume 0.6
      insert space(type: "hall", size: 0.7, decay: 0.65, width: 0.45, mix: 0.3)
      play arp(P, rate: 0.5, style: "up") at bars(1..4)
    }
    track Pluck {
      instrument GlassBass(cutoff: 0.5)
      volume 0.45
      play bass(P, rate: 2) at bars(1..4)
    }
  }

  // ---- the bed: under everything; it rests ONLY for the two gasps ----
  track Drone {
    instrument prisma(wave: "saw", cutoff: 0.42, attack: 0.6, sustain: 0.9, release: 0.8, unison: 5, detune: 0.22, spread: 0.45, sub: 0.12)
    volume 0.3
    insert space(type: "hall", size: 0.75, decay: 0.7, width: 0.4, mix: 0.3)
    insert tapestop(amount: 0.0)
    automate tapestop.amount from 0.0 to 1.0 over bars(101..102)
    automate volume from 0.3 to 0.1 over bars(101..102)
    play notes`[A2 E3 A3]~:16 [F2 C3 A3]~:16 [A2 E3 A3]~:16 [E2 B2 E3]~:16` at bars(1..35)
    play notes`[A2 E3 A3]~:16 [F2 C3 A3]~:16 [A2 E3 A3]~:16 [E2 B2 E3]~:16` at bars(37..75)
    play notes`[A2 E3 A3]~:16 [F2 C3 A3]~:16 [A2 E3 A3]~:16 [E2 B2 E3]~:16` at bars(77..102)
  }
  track Wash {
    instrument NightWash()
    insert vinyl(wow: 0.3, crackle: 0.35, hiss: 0.2, dust: 0.35)
    insert tapestop(amount: 0.0)
    automate tapestop.amount from 0.0 to 1.0 over bars(101..102)
    automate volume from 0.32 to 0.08 over bars(101..102)
    volume 0.32
    play notes`A3~:16` at bars(1..35)
    play notes`A3~:16` at bars(37..75)
    play notes`A3~:16` at bars(77..102)
  }

  // ---- the arrangement ----
  play Sparse at bars(1..12)
  play GrooveCut as Groove at bars(13..28)
  play GrooveCut as Groove at bars(29..35)
  play Build as Rise at bars(29..36)
  play DropCut as Drops at bars(37..52)
  play Sparse as Break at bars(53..68)
  play GrooveCut as Groove at bars(61..68)
  play GrooveCut as Groove at bars(69..75)
  play Build as Rise at bars(69..76)
  play DropCut as Drops at bars(77..92)
  play Sparse as Break at bars(93..100)
}
