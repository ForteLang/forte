// Sketch: IDM — audition piece, NOT an album track. Rebuilt around the
// principle that groove lives in the HIGH+LOW interplay: a crisp snare
// backbeat drives it, then glitch destabilizes the rests. Reverb tails are
// cut mid-ring by gates and sidechains (impossible in a live take — that
// unnatural cut IS the glitch). Upper melody + harmony on top, noise beds
// carved hard underneath.
import { Kick808, SnareTight, Snare908, HatClosed, HatOpen, Rim, Clap } from "../../essentials_0.6.0/instruments/drums.forte"
import { SubWrap } from "../wrapped/bassx.forte"
import { Dust, Hiss } from "../instruments/textures.forte"
import { SawLead } from "../../essentials_0.6.0/instruments/leads.forte"
import { GlassPad } from "../../essentials_0.6.0/instruments/pads.forte"
import { SnareBed, LiveSnare, TightSnare } from "../wrapped/snares.forte"

song "Sketch IDM" {
  desc "Audition sketch: snare-backbeat groove destabilized by glitch, reverb tails cut mid-ring, melody up top, noise carved under. Breakbeat/IDM. Not an album track."
  artist "Forte Essentials"
  tempo 180bpm
  swing 0.58
  master 0.92
  key D minor

  // ---- LOW: kick + sub, the floor ----
  block Kick {
    track K { instrument Kick808(decay: 0.3, punch: 0.7) volume 0.92
      play beat`x--- --x- x--- ----` at bars(1..32) }
  }
  block Sub : SubWrap {
    track Sub {
      insert duck(from: Kick, amount: 0.85, attack: 0.02, release: 0.12, shape: 0.7)
      play notes`D1~:1.5 D1~:0.5 F1~:1 A0:1` at bars(5..16)
      play notes`D1~:1 F1~:0.5 D1~:0.5 G1~:1 A0:1` at bars(17..28)
    }
  }

  // ---- HIGH: the snare backbeat — the groove engine, then glitched ----
  // a bright snare on 2 and 4 with reverb, then a ghost/roll layer whose
  // rests get destabilized. The reverb is CUT by the next hit.
  // the produced snare drives the backbeat — layered, saturated, roomy
  block Back : LiveSnare {
    track Snare {
      play notes`_:1 F3:1 _:1 F3:1` at bars(1..32)
    }
  }
  block Backfill : TightSnare {
    track Snare {
      play notes`_:1 _:1 _:1 _:0.5 G3:0.5` at bars(9..28)
    }
  }
  // the glitch snare: a bounced snare hit, sliced and re-cut into unstable
  // rolls and reversed stabs — the backbeat, destabilized
  block Ghost {
    track G {
      instrument Snare908(tone: 0.6, snap: 0.75)
      insert reverb(size: 0.4, decay: 0.4, mix: 0.3)
      insert duck(from: Kick, amount: 0.6, attack: 0.01, release: 0.09, shape: 0.5)
      volume 0.5
      play beat`---- ---x --x- -x-x` at bars(9..16)
      play humanize(beat`--x- x--x --xx -xx-`, time: 0.012, seed: 7) at bars(17..28)
    }
  }
  block Hats {
    track HC { instrument HatClosed volume 0.6
      insert eq(low: 0.15, mid: 0.5, high: 0.85)
      play beat`x-x- x-xx x-x- xx-x` at bars(5..28) }
    track HO { instrument HatOpen volume 0.5
      play beat`--x- ---- --x- --x-` at bars(13..28) }
  }

  // ---- UPPER: harmony stab, reverb tail cut mid-ring by a hard gate ----
  block Stab {
    track S {
      instrument GlassPad
      insert reverb(size: 0.72, decay: 0.7, mix: 0.42)
      insert gate(depth: 0.95, beats: 0.125, duty: 0.4)
      insert duck(from: Kick, amount: 0.55, attack: 0.01, release: 0.14, shape: 0.6)
      volume 0.62
      play notes`[D4 F4 A4]:2 _:2 [D4 G4 Bb4]:2 _:2` at bars(9..16)
      play notes`[D4 F4 A4]:1.5 _:0.5 [C4 F4 A4]:1 [D4 G4 Bb4]:1 _:2` at bars(17..28)
    }
  }
  // ---- UPPER: a lead melody, swept and delayed ----
  block Lead {
    track M {
      instrument SawLead(cutoff: 0.85)
      insert eq(low: 0.2, mid: 0.5, high: 0.7)
      insert delay(time: 0.28, fdbk: 0.42, mix: 0.35)
      insert duck(from: Kick, amount: 0.5, attack: 0.01, release: 0.1, shape: 0.5)
      volume 0.6
      play notes`A4:1 D5:0.5 F5:0.5 E5:1 _:1` at bars(17..24)
      play notes`D5:1 A4:0.5 F4:0.5 D4:2` at bars(25..28)
    }
  }

  // ---- NOISE: a crushed hiss bed and dust, carved hard by the kick ----
  block NoiseBed {
    track N {
      instrument Hiss(body: 0.55)
      insert crush(bits: 0.35, rate: 0.3, mix: 0.6)
      insert duck(from: Kick, amount: 0.95, attack: 0.01, release: 0.16, shape: 0.6)
      volume 0.3
      play notes`D4:16` at bars(5..12)
      play notes`D4:16` at bars(21..28)
    }
  }
  block Grit {
    track D {
      instrument Dust(color: 0.75)
      insert crush(bits: 0.45, rate: 0.2, mix: 0.5)
      insert reverb(size: 0.5, decay: 0.5, mix: 0.3)
      insert duck(from: Kick, amount: 0.7, attack: 0.01, release: 0.1, shape: 0.5)
      volume 0.4
      play humanize(beat`- x - x*3 - x - x*2`, time: 0.015, seed: 21) at bars(13..28)
    }
  }

  play Kick at bars(1..32)
  play Sub at bars(5..28)
  play Back at bars(1..32)
  play Backfill at bars(9..28)
  play Ghost at bars(9..28)
  play Hats at bars(5..28)
  play Stab at bars(9..28)
  play Lead at bars(17..28)
  play NoiseBed at bars(5..28)
  play Grit at bars(13..28)
}
