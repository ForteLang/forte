// Sketch: clicks & cuts, properly this time — audition piece, NOT an album
// track. Chopped 909 hats resequenced by pitch, a fuzz-crushed 303 chop,
// ring-modulated bells, a stutter fill every 8, and a tape stop to close.
// The groove comes from the unnatural cuts.
import { Chop909Hat, Crack909, Knock909 } from "../wrapped/drums909.forte"
import { AcidChop } from "../wrapped/tb303x.forte"
import { Bell808Ring } from "../wrapped/drums808.forte"
import { Sub808Deep } from "../wrapped/drums808.forte"

song "Sketch Cuts" {
  desc "Audition sketch: sliced hats resequenced, chopped acid, ring bells, stutter fills, tape stop. Not an album track."
  artist "Forte Essentials"
  tempo 126bpm
  master 2.4
  key A minor

  block Kick : Knock909 {
    track Hit { play beat`x--- x--- x--- x---` at bars(1..15) }
  }
  block Low : Sub808Deep {
    track Sub { play notes`A0~:3.5 E0~:0.5` at bars(3..15) }
  }
  block HatCuts : Chop909Hat {
    track Chop {
      // pitches = slice indices: the hat loop re-cut out of order
      play notes`F#2:0.25 A2:0.25 G2:0.25 F#2:0.25 A#2:0.25 F#2:0.25 C3:0.25 G2:0.25` at bars(1..16)
    }
  }
  block AcidCut : AcidChop {
    track Chop {
      insert stutter(beats: 0.125, mix: 0.0)
      play notes`C2:0.25 D2:0.25 _:0.5 F2:0.25 C2:0.25 _:0.5 G2:0.25 C2:0.25 _:1` at bars(5..16)
      automate stutter.mix from 0.0 to 0.9 over bars(8..8)
      automate stutter.mix from 0.0 to 0.0 over bars(9..9)
      automate stutter.mix from 0.0 to 0.9 over bars(15..15)
      automate stutter.mix from 0.0 to 0.0 over bars(16..16)
    }
  }
  block Bells : Bell808Ring {
    track Metal {
      play humanize(beat`- - x - - x*2 - -`, time: 0.02, seed: 9) at bars(9..14)
    }
  }
  block Snare : Crack909 {
    track Hit { play beat`---- x--- ---- x--x` at bars(5..15) }
  }
  block Stop : Knock909 {
    track Hit {
      insert tapestop(amount: 0.0)
      play beat`x-x- x-x- x-x- x-x-` at bars(16..16)
      automate tapestop.amount from 0.0 to 1.0 over bars(16..16)
    }
  }

  play Kick at bars(1..15)
  play Low at bars(3..15)
  play HatCuts at bars(1..16)
  play AcidCut at bars(5..16)
  play Bells at bars(9..14)
  play Snare at bars(5..15)
  play Stop at bars(16..16)
}
