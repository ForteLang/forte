// Clock Drift — three cycles of different lengths (1.5, 0.75, 2.5 beats)
// slowly drift apart and realign every 30 beats. The kick is the only
// clock that never lies. Genre signature: polymeter as composition —
// the phasing IS the melody.
import { Click, Tick, Blip } from "../instruments/clicks.forte"
import { ThumpKick, DeepSub, PressureBass } from "../instruments/lowend.forte"
import { Hiss, Dust, ColdTone } from "../instruments/textures.forte"

song "Clock Drift" {
  desc "Three cycles of different lengths drift and realign; the kick never lies. 125bpm polymeter glitch."
  artist "Forte Essentials"
  tempo 125bpm
  master 4.0
  key E minor

  section intro = bars(1..8)
  section drift = bars(9..56)
  section still = bars(57..64)
  section again = bars(65..88)
  section outro = bars(89..96)

  track Kick {
    instrument ThumpKick(decay: 0.42, drop: 0.3)
    insert comp(thresh: 0.5, ratio: 0.5, attack: 0.01, release: 0.1, makeup: 0.15)
    volume 0.95
    play beat`x--- x--- x--- x---` at drift
    play beat`x--- x--- x--- x---` at again
  }
  track Sub {
    instrument DeepSub(decay: 0.8)
    volume 0.7
    play notes`E1:3.5 _:0.5` at drift
    play notes`E1:3.5 _:0.5` at again
  }
  track CycleA {
    instrument Blip(decay: 0.06)
    insert delay(time: 0.26, fdbk: 0.3, mix: 0.25)
    volume 0.5
    play cycle(notes`E5:0.25 _:1.25`, span: 1.5) at drift
    play cycle(notes`E5:0.25 _:1.25`, span: 1.5) at again
  }
  track CycleB {
    instrument Click(snap: 0.85)
    volume 0.55
    play cycle(beat`x - .`, span: 0.75) at bars(17..56)
    play cycle(beat`x - .`, span: 0.75) at again
  }
  track CycleC {
    instrument Tick(tone: 0.45)
    volume 0.5
    play cycle(notes`B3:0.25 _:2.25`, span: 2.5) at bars(25..56)
    play cycle(notes`B3:0.25 _:2.25`, span: 2.5) at bars(73..88)
  }
  track Bass {
    instrument PressureBass(cutoff: 0.3)
    insert crush(bits: 0.3, rate: 0.15, mix: 0.4)
    volume 0.6
    play notes`E2:0.5 _:1 E2:0.25 _:0.25 G2:0.25 _:1.75` at bars(33..56)
    play notes`E2:0.5 _:1 E2:0.25 _:0.25 B2:0.25 _:1.75` at again
  }
  track Still {
    instrument ColdTone(beatrate: 0.15)
    volume 0.45
    play notes`E4:8 B4:8 E4:8 G4:8` at still
    play notes`E4:8 _:8` at intro
    play notes`E4:16 _:8` at outro
    automate volume from 0.45 to 0.0 over bars(93..96)
  }
  track Dust {
    instrument Dust(color: 0.7)
    volume 0.42
    play humanize(beat`- - x - x*2 - - -`, time: 0.02, seed: 31) at bars(41..56)
    play humanize(beat`- - x - x*2 - - -`, time: 0.02, seed: 32) at bars(73..88)
  }
  track Hiss {
    instrument Hiss(body: 0.42)
    insert gate(depth: 0.88, beats: 0.25, duty: 0.35)
    volume 0.3
    play notes`E3:32` at bars(33..40)
    play notes`E3:32` at bars(73..80)
  }
}
