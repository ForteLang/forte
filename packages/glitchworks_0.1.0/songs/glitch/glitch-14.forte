// glitch-14 — piano reassembly: the upright that never existed, taken
// apart bar by bar — the loop recut, the music box answering in mirror
// writing, kick and sub carrying the floor while the cuts tighten.
import { PianoLoop, BellFlip } from "../../wrapped/melodyworks.forte"
import { LowKit } from "../../wrapped/glitchset.forte"
import { SubPulse } from "../../wrapped/bassworks.forte"

song "Glitch 14 — Piano Reassembly" {
  desc "The upright that never existed taken apart bar by bar, the music box answering in mirror writing, cuts tightening."
  artist "Forte Essentials"
  tempo 118bpm
  swing 0.56
  master 1.15
  key C minor

  block Loop : PianoLoop {
    track Loop {
      automate decay from 0.6 to 0.15 over bars(13..16)
      insert stutter(beats: 0.25, mix: 0.0)
      automate stutter.mix from 0.0 to 0.55 over bars(8..8)
      automate stutter.mix from 0.55 to 0.0 over bars(9..9)
      play notes`C3:1 D3:1 E3:0.5 F3:0.5 G3:1` at bars(1..3)
      play notes`C3:0.75 D3:0.25 E3:0.5 G3:0.25 F3:0.25 D3:0.5 E3:0.5 C3:0.5 G3:0.5` at bars(4..4)
      play notes`E3:1 D3:1 C3:0.5 G3:0.5 F3:1` at bars(5..7)
      play notes`C3:0.75 D3:0.25 E3:0.5 G3:0.25 F3:0.25 D3:0.5 E3:0.5 C3:0.5 G3:0.5` at bars(8..8)
      play notes`C3:1 D3:1 E3:0.5 F3:0.5 G3:1` at bars(9..11)
      play notes`C3:0.5 D3:0.5 E3:0.5 F3:0.5 G3:0.5 F3:0.5 E3:0.5 D3:0.5` at bars(12..12)
      play notes`C3:1 E3:1 D3:0.5 F3:0.5 G3:1` at bars(13..16)
    }
  }

  block Mirror : BellFlip {
    track Box {
      play notes`C4:0.5 E4:0.5 _:0.5 G4:0.5 _:1 D4:0.5 F4:0.5` at bars(5..8)
    }
    track Mirror {
      play notes`_:5 F4:0.5 _:1.5 A4:0.5 _:0.5` at bars(9..16)
    }
  }

  play LowKit at bars(1..16)
  play SubPulse(volume: 0.85) at bars(2..16)
  play Loop(volume: 0.9) at bars(1..16)
  play Mirror(volume: 0.7) at bars(5..16)
}
