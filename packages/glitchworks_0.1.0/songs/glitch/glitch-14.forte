// glitch-14 — piano reassembly: the piano room (looped upright, mirror
// bells, low kit, sub) bounced to one record and taken apart key by key —
// the cuts get smaller, the silences get bigger, and the room is
// reassembled in the wrong order until it swings.
import { PianoLoop, BellFlip } from "../../wrapped/melodyworks.forte"
import { LowKit } from "../../wrapped/glitchset.forte"
import { SubPulse } from "../../wrapped/bassworks.forte"

song "Glitch 14 — Piano Reassembly" {
  desc "The piano room bounced to one record and taken apart key by key, reassembled in the wrong order until it swings."
  artist "Forte Essentials"
  tempo 118bpm
  swing 0.56
  master 2.4
  key C minor

  block Mix {
    play LowKit at bars(1..4)
    play SubPulse(volume: 0.85) at bars(1..4)
    play PianoLoop(volume: 0.9) at bars(1..4)
    play BellFlip(volume: 0.7) at bars(1..4)
  }
  sample MixS = bounce(Mix, note: C3, beats: 16)

  block Cutter {
    track Cut {
      instrument sampler(attack: 0.05, gain: 1.0, sample: MixS, slices: 16, end: 0.889, choke: "on", sustain: 1.0, release: 0.05, vary: 0.07)
      modulate pitch with random(rate: 0.05, amount: 0.015, smooth: 0.85) as swim
      volume 0.95
      play notes`C3~:1 C#3~:0.75 _:0.25 D3~:1 _:1` at bars(1..3)
      play notes`C3~:0.75 _:0.25 D3~:0.5 _:0.5 D#3~:0.25 D#3~:0.25 _:0.5 F3~:0.5 _:0.5` at bars(4..4)
      play notes`E3~:0.75 _:0.25 G3~:0.5 _:0.5 F3~:0.75 _:0.25 F#3~:0.5 _:0.5` at bars(5..7)
      play notes`E3~:0.25 E3~:0.25 _:0.5 G3~:0.25 _:0.25 F3~:0.125 F3~:0.125 F3~:0.125 F3~:0.125 _:0.5 F#3~:0.5 _:1` at bars(8..8)
      play notes`G#3~:0.75 _:0.25 B3~:0.5 _:0.5 A3~:0.5 _:0.5 A#3~:0.5 _:0.5` at bars(9..11)
      play notes`G#3~:0.25 _:0.25 A3~:0.25 _:0.5 A#3~:0.25 _:0.75 B3~:0.25 _:1.5` at bars(12..12)
      play notes`C4~:0.75 _:0.25 D#4~:0.5 _:0.5 C#4~:0.5 _:0.5 D4~:0.5 _:0.5` at bars(13..15)
      play notes`C4~:0.5 _:0.5 C4~:0.25 _:0.5 C4~:0.25 _:0.75 C3~:0.5 _:0.75` at bars(16..16)
    }
    track Mirror {
      instrument sampler(attack: 0.06, gain: 1.0, sample: MixS, reverse: "on", end: 0.889, sustain: 1.0, release: 0.1, vary: 0.1)
      volume 0.6
      play notes`_:3 C3~:1` at bars(4..4)
      play notes`_:3 D3~:1` at bars(8..8)
      play notes`_:3 C3~:1` at bars(12..12)
    }
  }
  play Cutter at bars(1..16)
}
