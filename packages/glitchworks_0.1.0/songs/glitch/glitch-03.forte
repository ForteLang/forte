// glitch-03 — stutter budget: the whole house floor (kit, octaver, hats,
// strings, glass) bounced to one record; the song is the record re-cut
// four-on-the-floor with holes, and the stutter budget doubles every turn.
import { LowKit, StutterStrings, EnsembleGlass } from "../../wrapped/glitchset.forte"
import { OctaveHouse } from "../../wrapped/bassworks.forte"
import { HatWork } from "../../wrapped/grooveworks.forte"

song "Glitch 03 — Stutter Budget" {
  desc "The whole house floor bounced and re-cut four-on-the-floor with holes; the stutter budget doubles at every turn."
  artist "Forte Essentials"
  tempo 124bpm
  swing 0.53
  master 2.0
  key C minor

  block Mix {
    play LowKit at bars(1..4)
    play OctaveHouse(volume: 0.8) at bars(1..4)
    play HatWork(volume: 0.8) at bars(1..4)
    play StutterStrings(volume: 0.8) at bars(1..4)
    play EnsembleGlass(volume: 0.8) at bars(1..4)
  }
  sample MixS = bounce(Mix, note: C3, beats: 16)

  block Cutter {
    track Cut {
      instrument sampler(attack: 0.05, gain: 1.0, sample: MixS, slices: 16, end: 0.889, choke: "on", sustain: 1.0, release: 0.05, vary: 0.06)
      modulate pitch with random(rate: 0.05, amount: 0.012, smooth: 0.85) as swim
      volume 0.95
      // the floor with holes: downbeat slices, gates just short of the beat
      play notes`C3~:0.75 _:0.25 C#3~:0.75 _:0.25 D3~:0.75 _:0.25 D#3~:0.75 _:0.25` at bars(1..3)
      play notes`C3~:0.75 _:0.25 C#3~:0.5 _:0.5 D3~:0.25 D3~:0.25 _:0.5 D#3~:0.25 _:0.75` at bars(4..4)
      play notes`E3~:0.75 _:0.25 F3~:0.75 _:0.25 F#3~:0.75 _:0.25 G3~:0.75 _:0.25` at bars(5..7)
      play notes`E3~:0.5 _:0.5 F3~:0.25 F3~:0.25 _:0.5 F#3~:0.125 F#3~:0.125 F#3~:0.125 F#3~:0.125 _:0.5 G3~:0.5 _:0.5` at bars(8..8)
      play notes`G#3~:0.75 _:0.25 A3~:0.5 _:0.5 A#3~:0.75 _:0.25 B3~:0.5 _:0.5` at bars(9..11)
      play notes`G#3~:0.25 _:0.25 A3~:0.25 _:0.25 A#3~:0.25 A#3~:0.25 _:0.5 B3~:0.125 B3~:0.125 B3~:0.125 B3~:0.125 _:0.5 C3~:0.5 _:0.5` at bars(12..12)
      play notes`C4~:0.75 _:0.25 C#4~:0.75 _:0.25 D4~:0.75 _:0.25 D#4~:0.75 _:0.25` at bars(13..15)
      play notes`C4~:0.25 C4~:0.25 _:0.5 C#4~:0.125 C#4~:0.125 C#4~:0.125 C#4~:0.125 _:0.5 D4~:0.125 D4~:0.125 _:0.25 D#4~:0.125 D#4~:0.125 D#4~:0.125 D#4~:0.125 _:1` at bars(16..16)
    }
  }
  play Cutter at bars(1..16)
}
