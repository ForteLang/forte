// glitch-20 — last cut: the closer. The whole production (moment rack,
// dusk ensemble, sliding sub, rainbow snare) bounced to ONE record, and
// the record is played like the last instrument left on earth — cuts,
// silences, one backwards look — then held as a chord, ridden down,
// power cut. The cut is the signature.
import { MomentKit } from "../../wrapped/chopworks.forte"
import { EnsembleDusk, GlideSub } from "../../wrapped/glitchset.forte"
import { SnareRainbow } from "../../wrapped/drumcolor.forte"

song "Glitch 20 — Last Cut" {
  desc "The closer: the whole production on one record, cut like the last instrument on earth — then ridden down and power-cut."
  artist "Forte Essentials"
  tempo 94bpm
  swing 0.57
  master 2.0
  key C minor

  block Mix {
    block Rack : MomentKit {
      track Rack {
        play notes`C3:0.5 _:0.5 E3:0.5 _:0.5 G3:0.5 _:0.5 D3:0.5 _:0.5` at bars(1..3)
        play notes`C3:0.5 E3:0.25 _:0.25 G3:0.5 _:0.5 A3:0.25 G3:0.25 _:0.5 D3:0.5 C3:0.5` at bars(4..4)
      }
    }
    block Sub : GlideSub {
      track Slide { play notes`C1~:3 D#1~:1 C1~:2 G1~:1 F1~:1` at bars(1..4) }
    }
    play Rack at bars(1..4)
    play EnsembleDusk(volume: 0.85) at bars(1..4)
    play Sub(volume: 0.9) at bars(1..4)
    play SnareRainbow(volume: 0.85) at bars(1..4)
  }
  sample MixS = bounce(Mix, note: C3, beats: 16)

  block Cutter {
    track Cut {
      instrument sampler(attack: 0.05, gain: 1.0, sample: MixS, slices: 16, end: 0.889, choke: "on", sustain: 1.0, release: 0.05, vary: 0.07)
      modulate pitch with random(rate: 0.05, amount: 0.015, smooth: 0.85) as swim
      volume 0.95
      play notes`C3~:1 _:0.5 C#3~:0.5 _:0.5 D3~:0.75 _:0.75` at bars(1..3)
      play notes`C3~:0.5 _:0.5 C#3~:0.25 C#3~:0.25 _:0.5 D#3~:0.5 _:1.5` at bars(4..4)
      play notes`E3~:0.75 _:0.5 F3~:0.5 _:0.75 F#3~:0.5 _:1` at bars(5..7)
      play notes`E3~:0.25 E3~:0.25 _:0.5 F3~:0.25 _:0.75 G3~:0.5 _:1.5` at bars(8..8)
      play notes`G#3~:0.75 _:0.75 A3~:0.5 _:1 A#3~:0.5 _:0.5` at bars(9..11)
    }
    track Look {
      instrument sampler(attack: 0.06, gain: 1.0, sample: MixS, reverse: "on", end: 0.889, sustain: 1.0, release: 0.1, vary: 0.1)
      volume 0.65
      play notes`_:3 C3~:1` at bars(4..4)
      play notes`_:2.5 C3~:1.5` at bars(8..8)
      play notes`_:3 C3~:1` at bars(11..11)
    }
    // the finale: the record held as a chord, ridden down, power cut
    track Hold {
      instrument sampler(attack: 0.08, gain: 1.0, sample: MixS, end: 0.889, sustain: 1.0, release: 0.3)
      insert tapestop(amount: 0.0)
      automate pitch from 0.5 to 0.396 over bars(12..12)
      automate tapestop.amount from 0.0 to 1.0 over bars(12..12)
      volume 0.9
      play notes`C3~:4` at bars(12..12)
    }
  }
  play Cutter at bars(1..12)
}
