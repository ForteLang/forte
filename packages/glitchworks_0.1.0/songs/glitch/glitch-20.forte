// glitch-20 — last cut: the closer. A whole production held in one kit
// rack, played like an instrument; the dusk ensemble chopped under it,
// one snare edited to the end — and the finale is the entire song held
// as a chord, pitch ridden down, power cut. The cut is the signature.
import { MomentKit } from "../../wrapped/chopworks.forte"
import { EnsembleDusk, GlideSub } from "../../wrapped/glitchset.forte"
import { SnareRainbow } from "../../wrapped/drumcolor.forte"

song "Glitch 20 — Last Cut" {
  desc "The closer: a whole production played as a kit, and the finale holds the song as a chord, rides the pitch down, cuts the power."
  artist "Forte Essentials"
  tempo 94bpm
  swing 0.57
  master 0.9
  key C minor

  block Rack : MomentKit {
    track Rack {
      insert tapestop(amount: 0.0)
      play notes`C3:0.5 _:0.5 E3:0.5 _:0.5 G3:0.5 _:0.5 D3:0.5 _:0.5` at bars(1..4)
      play notes`C3:0.5 E3:0.25 _:0.25 G3:0.5 _:0.5 A3:0.25 G3:0.25 _:0.5 D3:0.5 C3:0.5` at bars(5..8)
      play notes`C3:0.5 _:0.5 E3:0.5 _:0.5 G3:0.5 _:0.5 D3:0.5 _:0.5` at bars(9..11)
      // the finale: the whole production as a chord, ridden down, cut
      play notes`[C4 G4]~:4` at bars(12..12)
      automate pitch from 0.5 to 0.396 over bars(12..12)
      automate tapestop.amount from 0.0 to 1.0 over bars(12..12)
    }
  }

  block Dusk : EnsembleDusk {
    track Chop {
      play notes`C3:1 _:0.5 D3:0.5 C3:0.75 E3:0.25 _:0.5 F3:0.5` at bars(1..3)
      play notes`C3:0.75 D3:0.25 E3:0.5 F3:0.25 G3:0.25 C3:0.5 D3:0.5 _:1` at bars(4..4)
      play notes`C3:1 _:0.5 D3:0.5 C3:0.75 E3:0.25 _:0.5 F3:0.5` at bars(5..7)
      play notes`C3:0.75 D3:0.25 E3:0.5 F3:0.25 G3:0.25 C3:0.5 D3:0.5 _:1` at bars(8..8)
      play notes`C3:1 _:0.5 D3:0.5 C3:0.75 E3:0.25 _:0.5 F3:0.5` at bars(9..11)
    }
  }

  block Sub : GlideSub {
    track Slide {
      play notes`C1~:3 D#1~:1 C1~:2 G1~:1 F1~:1` at bars(1..8)
      play notes`C1~:3 A#0~:1 C1~:2 F1~:1 G1~:1` at bars(9..11)
      play notes`C1~:4` at bars(12..12)
    }
  }

  play Rack at bars(1..12)
  play Dusk(volume: 0.85) at bars(1..12)
  play Sub(volume: 0.9) at bars(1..12)
  play SnareRainbow(volume: 0.85) at bars(3..11)
}
