// glitch-16 — bell ledger: the bell shop (music box, platter-bent bell,
// low kit, shaker, morse) bounced to one record; the song cuts it like a
// jeweller — small precise gates, the shop falling silent between
// weighings, and the mirror playing what's left backwards.
import { GlideBell, LowKit } from "../../wrapped/glitchset.forte"
import { BellFlip } from "../../wrapped/melodyworks.forte"
import { ColdPulse } from "../../wrapped/textureworks.forte"
import { ShakerSwing } from "../../wrapped/grooveworks.forte"

song "Glitch 16 — Bell Ledger" {
  desc "The bell shop bounced to one record, cut like a jeweller: small precise gates, silence between weighings, a backwards mirror."
  artist "Forte Essentials"
  tempo 110bpm
  swing 0.56
  master 2.8
  key C minor

  block Mix {
    play LowKit at bars(1..4)
    play BellFlip(volume: 0.85) at bars(1..4)
    play GlideBell(volume: 0.7) at bars(1..4)
    play ShakerSwing(volume: 0.6) at bars(1..4)
    play ColdPulse(volume: 0.55) at bars(1..4)
  }
  sample MixS = bounce(Mix, note: C3, beats: 16)

  block Cutter {
    track Cut {
      instrument sampler(attack: 0.05, gain: 1.0, sample: MixS, slices: 16, end: 0.889, choke: "on", sustain: 1.0, release: 0.05, vary: 0.07)
      modulate pitch with random(rate: 0.05, amount: 0.015, smooth: 0.85) as swim
      volume 0.95
      play notes`C3~:0.75 _:0.25 C#3~:0.5 _:0.5 D3~:0.5 _:0.5 D#3~:0.5 _:0.5` at bars(1..3)
      play notes`C3~:0.5 _:0.5 C#3~:0.25 _:0.25 D3~:0.25 D3~:0.25 _:0.5 D#3~:0.25 _:1.25` at bars(4..4)
      play notes`E3~:0.5 _:0.5 F3~:0.5 _:0.75 F#3~:0.25 _:0.5 G3~:0.5 _:0.5` at bars(5..7)
      play notes`E3~:0.25 _:0.25 F3~:0.125 F3~:0.125 _:0.5 F#3~:0.25 _:0.5 G3~:0.25 G3~:0.25 _:0.5 G#3~:0.5 _:0.5` at bars(8..8)
      play notes`G#3~:0.5 _:0.5 A3~:0.5 _:0.75 A#3~:0.25 _:0.5 B3~:0.5 _:0.5` at bars(9..11)
      play notes`G#3~:0.25 _:0.5 A3~:0.25 _:0.75 A#3~:0.25 _:0.5 B3~:0.125 _:1.375` at bars(12..12)
      play notes`C4~:0.75 _:0.25 C#4~:0.5 _:0.5 D4~:0.5 _:0.5 D#4~:0.5 _:0.5` at bars(13..14)
    }
    track Mirror {
      instrument sampler(attack: 0.06, gain: 1.0, sample: MixS, reverse: "on", end: 0.889, sustain: 1.0, release: 0.1, vary: 0.1)
      volume 0.6
      play notes`_:2.5 C3~:1.5` at bars(4..4)
      play notes`_:3 D3~:1` at bars(8..8)
      play notes`_:2.5 C3~:0.75 _:0.25 D3~:0.5` at bars(12..12)
      play notes`_:2 C3~:2` at bars(14..14)
    }
  }
  play Cutter at bars(1..14)
}
