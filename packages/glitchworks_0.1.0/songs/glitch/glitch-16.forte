// glitch-16 — bell ledger: a music box played forwards and backwards at
// once, a bell bent by hand on the platter, morse blinking far right —
// kick and sub keeping the books underneath.
import { GlideBell, LowKit } from "../../wrapped/glitchset.forte"
import { BellFlip } from "../../wrapped/melodyworks.forte"
import { ColdPulse } from "../../wrapped/textureworks.forte"
import { ShakerSwing } from "../../wrapped/grooveworks.forte"

song "Glitch 16 — Bell Ledger" {
  desc "A music box forwards and backwards at once, a bell bent on the platter, morse far right, the books kept low."
  artist "Forte Essentials"
  tempo 110bpm
  swing 0.56
  master 1.3
  key C minor

  block Box : BellFlip {
    track Box {
      play notes`C4:0.5 E4:0.5 _:0.5 G4:0.5 _:1 D4:0.5 F4:0.5` at bars(1..8)
      play notes`C4:0.5 _:0.5 E4:0.5 G4:0.5 _:0.5 A4:0.5 _:0.5 F4:0.5` at bars(9..14)
    }
    track Mirror {
      play notes`_:5 F4:0.5 _:1.5 A4:0.5 _:0.5` at bars(3..10)
      play notes`_:2 F4:0.5 _:1 A4:0.5 _:2 G4:0.5 _:1.5` at bars(11..14)
    }
  }

  block Bent : GlideBell {
    track Bent {
      play notes`C5~:1 G4~:1 A#4~:1.5 C5~:0.5 D#5~:1.5 C5~:2.5` at bars(9..12)
      play notes`C5~:2 A#4~:1.5 G4~:0.5 F4~:2 C5~:2` at bars(13..14)
    }
  }

  play LowKit at bars(1..14)
  play Box(volume: 0.85) at bars(1..14)
  play ShakerSwing(volume: 0.6) at bars(5..13)
  play Bent(volume: 0.7) at bars(9..14)
  play ColdPulse(volume: 0.55) at bars(7..12)
}
