// glitch-10 — violin economy: the chamber (violin phrase, heartbeat sub,
// clockwork rims, rainbow snare) bounced to one record — cut with the
// patience of a ballad: long bows, then the whole room holds its breath.
// The record rides down at the close.
import { ViolinSolo } from "../../wrapped/melodyworks.forte"
import { HeartSub, WoodTick } from "../../wrapped/glitchset.forte"
import { SnareRainbow } from "../../wrapped/drumcolor.forte"

song "Glitch 10 — Violin Economy" {
  desc "The chamber bounced to one record, cut with a ballad's patience: long bows, breath-holding silences, ridden down at the close."
  artist "Forte Essentials"
  tempo 92bpm
  swing 0.55
  master 2.2
  key C minor

  block Mix {
    play HeartSub(volume: 0.9) at bars(1..4)
    play WoodTick(volume: 0.7) at bars(1..4)
    play ViolinSolo(volume: 0.9) at bars(1..4)
    play SnareRainbow(volume: 0.6) at bars(1..4)
  }
  sample MixS = bounce(Mix, note: C3, beats: 16)

  block Cutter {
    track Cut {
      instrument sampler(attack: 0.07, gain: 1.0, sample: MixS, slices: 16, end: 0.889, choke: "on", sustain: 1.0, release: 0.07, vary: 0.06)
      modulate pitch with random(rate: 0.04, amount: 0.012, smooth: 0.9) as swim
      automate pitch from 0.5 to 0.396 over bars(12..12)
      insert parcomp(amount: 0.6, drive: 0.7, color: 0.4)
      volume 0.95
      play notes`C3~:1.5 _:0.5 C#3~:1 _:1` at bars(1..1)
      play notes`E3~:2 _:0.5 F3~:1 _:0.5` at bars(2..2)
      play notes`G#3~:1.5 _:1 A3~:0.5 _:1` at bars(3..3)
      play notes`C4~:1 _:0.5 C#4~:0.5 _:0.5 D#4~:0.5 _:1` at bars(4..4)
      play notes`C3~:1 _:1 E3~:1 _:1` at bars(5..5)
      play notes`F3~:0.75 _:0.75 F#3~:0.5 _:2` at bars(6..6)
      play notes`G#3~:1.5 _:0.5 A#3~:0.5 _:0.5 B3~:0.5 _:0.5` at bars(7..7)
      play notes`C4~:0.5 _:0.5 C4~:0.25 C4~:0.25 _:0.5 D4~:0.5 _:1.5` at bars(8..8)
      play notes`C3~:1.5 _:1 C#3~:0.5 _:1` at bars(9..9)
      play notes`E3~:1 _:0.75 F3~:0.25 _:1 G3~:0.5 _:0.5` at bars(10..10)
      play notes`G#3~:0.75 _:0.75 A3~:0.5 _:1 C3~:0.5 _:0.5` at bars(11..11)
      play notes`C3~:2 _:0.5 C3~:1.5` at bars(12..12)
    }
  }
  play Cutter at bars(1..12)
}
