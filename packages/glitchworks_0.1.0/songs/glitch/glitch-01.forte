// glitch-01 — the first cut: the WHOLE band (kick line, rainbow snare,
// pumped sub, re-cut piano) is bounced to one record — and the song is
// that record CHOPPED. Every rest is the entire mix going silent at once,
// reverb tails and all. The power dies at the end.
import { KickFlip } from "../../wrapped/chopworks.forte"
import { SnareRainbow } from "../../wrapped/drumcolor.forte"
import { SubPulse } from "../../wrapped/bassworks.forte"
import { ReCutPiano } from "../../wrapped/glitchset.forte"

song "Glitch 01 — First Cut" {
  desc "The whole band bounced to one record and chopped: every rest is the entire mix cutting to silence at once."
  artist "Forte Essentials"
  tempo 96bpm
  swing 0.56
  master 1.8
  key C minor

  // the record: four bars of the full band, bounced as ONE sample
  block Mix {
    block Drums : KickFlip {
      track Main {
        play beat`x--- ---- x-x- ----` at bars(1..3)
        play beat`x--- --x- x-x- ---x*3` at bars(4..4)
      }
      track Chop {
        play notes`_:3 D3:0.25 F3:0.25 C3:0.25 A3:0.25` at bars(4..4)
      }
    }
    block Floor : SubPulse {
      track Pulse { play notes`C1~:6 G1~:2 C1~:4 A#0~:4` at bars(1..4) }
    }
    play Drums at bars(1..4)
    play SnareRainbow(volume: 0.9) at bars(1..4)
    play Floor(volume: 0.85) at bars(1..4)
    play ReCutPiano(volume: 0.8) at bars(1..4)
  }
  sample MixS = bounce(Mix, note: C3, beats: 16)

  // the song: the record re-cut, slice = one beat of the mix (C3..D#4),
  // note length = gate length — the rests are MIX-WIDE silence
  block Cutter {
    track Cut {
      instrument sampler(attack: 0.05, gain: 1.0, sample: MixS, slices: 16, end: 0.889, choke: "on", sustain: 1.0, release: 0.05, vary: 0.06)
      modulate pitch with random(rate: 0.05, amount: 0.015, smooth: 0.85) as swim
      insert tapestop(amount: 0.0)
      automate tapestop.amount from 0.0 to 1.0 over bars(12..12)
      volume 0.95
      // establish: the record nearly in order, already breathing
      play notes`C3~:1 C#3~:0.75 _:0.25 D3~:1 D#3~:0.75 _:0.25` at bars(1..1)
      play notes`E3~:1 F3~:0.5 _:0.5 F#3~:0.75 _:0.25 G3~:1` at bars(2..2)
      play notes`G#3~:1 A3~:0.75 _:0.25 A#3~:0.5 _:0.5 B3~:1` at bars(3..3)
      play notes`C4~:1 C#4~:0.5 _:0.5 D4~:0.5 _:0.5 D#4~:0.25 D#4~:0.25 _:0.5` at bars(4..4)
      // argue: shorter gates, reorders, real holes
      play notes`C3~:0.5 _:0.5 C#3~:0.5 _:0.5 E3~:0.5 _:0.5 F3~:0.25 _:0.25 G3~:0.5` at bars(5..5)
      play notes`G#3~:0.5 _:0.25 A3~:0.25 _:0.5 C3~:0.5 _:1 C#3~:0.25 _:0.25 B3~:0.5` at bars(6..6)
      play notes`E3~:0.75 _:0.25 E3~:0.25 _:0.25 F3~:0.5 _:1.5 G3~:0.5` at bars(7..7)
      play notes`C4~:0.25 C4~:0.25 C4~:0.25 C4~:0.25 _:0.5 D4~:0.25 D4~:0.25 _:0.5 D#4~:0.125 D#4~:0.125 D#4~:0.125 D#4~:0.125 _:1` at bars(8..8)
      // carve: sixteenth gates and daring silences
      play notes`C3~:0.25 _:0.25 C3~:0.125 _:0.375 C#3~:0.25 _:0.75 E3~:0.5 _:1 G3~:0.5` at bars(9..9)
      play notes`_:0.5 G#3~:0.25 _:0.25 A3~:0.125 _:0.375 A#3~:0.25 _:0.75 C3~:1 _:0.5` at bars(10..10)
      play notes`C3~:0.125 _:0.125 C3~:0.125 _:0.125 E3~:0.25 _:0.75 F3~:0.125 _:0.375 G#3~:0.5 _:0.5 C4~:1` at bars(11..11)
      // the power dies mid-phrase
      play notes`C3~:1 C#3~:0.5 _:0.5 C3~:2` at bars(12..12)
    }
  }
  play Cutter at bars(1..12)
}
