// glitch-01 — the first cut: a kick LINE that eats itself into fragment
// fills, one snare re-edited every hit, a pumped sub, and a piano that
// gets re-cut tighter and tighter until the power dies.
import { KickFlip } from "../../wrapped/chopworks.forte"
import { SnareRainbow } from "../../wrapped/drumcolor.forte"
import { SubPulse } from "../../wrapped/bassworks.forte"
import { ReCutPiano } from "../../wrapped/glitchset.forte"

song "Glitch 01 — First Cut" {
  desc "A kick line eating itself into fills, one snare re-edited every hit, piano re-cut tighter until the power dies."
  artist "Forte Essentials"
  tempo 96bpm
  swing 0.56
  master 0.6
  key C minor

  block Drums : KickFlip {
    track Main {
      play beat`x--- ---- x-x- ----` at bars(1..3)
      play beat`x--- --x- x-x- ---x*3` at bars(4..4)
      play beat`x--- ---- x-x- ----` at bars(5..7)
      play beat`x--- --x- x-x- x*4---` at bars(8..8)
      play beat`x--- --x- x-x- ----` at bars(9..11)
    }
    track Chop {
      play notes`_:3 D3:0.25 F3:0.25 C3:0.25 A3:0.25` at bars(4..4)
      play notes`_:2 C3:0.25 D3:0.25 E3:0.25 F3:0.25 G3:0.25 A3:0.25 B3:0.25 C4:0.25` at bars(8..8)
      play notes`C3:0.5 _:0.5 D3:0.25 E3:0.25 F3:0.25 G3:0.25 A3:0.25 G3:0.25 F3:0.25 E3:0.25 D3:0.25 C3:0.25 _:0.5` at bars(12..12)
    }
  }

  block Floor : SubPulse {
    track Pulse {
      insert duck(from: Drums, amount: 0.8, attack: 0.02, release: 0.15, shape: 0.7)
      play notes`C1~:6 G1~:2 C1~:4 A#0~:4` at bars(1..4)
      play notes`C1~:6 D#1~:2 C1~:4 G0~:2 A#0~:2` at bars(5..8)
      play notes`C1~:6 G1~:2 A#0~:4 C1~:4` at bars(9..12)
    }
  }

  block Keys : ReCutPiano {
    track ReCut {
      automate decay from 0.6 to 0.12 over bars(9..12)
      insert tapestop(amount: 0.0)
      automate tapestop.amount from 0.0 to 1.0 over bars(12..12)
      play notes`C3:1 D3:1 E3:0.5 F3:0.5 G3:1` at bars(3..3)
      play notes`C3:0.75 D3:0.25 F3:1 E3:0.5 G3:0.5 C3:1` at bars(4..4)
      play notes`E3:1 D3:0.5 C3:0.5 G3:0.75 F3:0.25 D3:1` at bars(5..5)
      play notes`C3:0.5 D3:0.5 E3:0.25 F3:0.25 G3:0.5 F3:0.5 E3:0.5 D3:0.5 C3:0.5` at bars(6..6)
      play notes`C3:1 D3:1 E3:0.5 F3:0.5 G3:1` at bars(7..7)
      play notes`E3:1 D3:0.5 C3:0.5 G3:0.75 F3:0.25 D3:1` at bars(8..8)
      play notes`C3:0.75 D3:0.25 F3:1 E3:0.5 G3:0.5 C3:1` at bars(9..9)
      play notes`C3:0.5 D3:0.5 E3:0.25 F3:0.25 G3:0.5 F3:0.5 E3:0.5 D3:0.5 C3:0.5` at bars(10..10)
      play notes`C3:0.5 _:0.5 E3:0.5 _:0.5 G3:0.5 _:0.5 F3:0.5 D3:0.5` at bars(11..11)
      play notes`C3~:4` at bars(12..12)
    }
  }

  play Drums at bars(1..12)
  play SnareRainbow at bars(1..11)
  play Floor at bars(1..12)
  play Keys at bars(1..12)
}
