// glitch-13 — backspin economy: the band (rolling 606, rainbow snare,
// pumped sub, backspins) bounced to one record — and the record spends
// half its life running BACKWARDS: forward cuts answered by reversed
// ones, silence balancing the books between them.
import { BackspinPerc } from "../../wrapped/glitchset.forte"
import { SnareRainbow } from "../../wrapped/drumcolor.forte"
import { KickRumble } from "../../wrapped/grooveworks.forte"
import { SubPulse } from "../../wrapped/bassworks.forte"

song "Glitch 13 — Backspin Economy" {
  desc "The band bounced to one record that spends half its life backwards: forward cuts answered by reversed ones."
  artist "Forte Essentials"
  tempo 98bpm
  swing 0.57
  master 2.5
  key C minor

  block Mix {
    play KickRumble at bars(1..4)
    play SnareRainbow(volume: 0.9) at bars(1..4)
    play SubPulse(volume: 0.9) at bars(1..4)
    play BackspinPerc(volume: 0.8) at bars(1..4)
  }
  sample MixS = bounce(Mix, note: C3, beats: 16)

  block Cutter {
    track Cut {
      instrument sampler(attack: 0.05, gain: 1.0, sample: MixS, slices: 16, end: 0.889, choke: "on", sustain: 1.0, release: 0.05, vary: 0.08)
      modulate pitch with random(rate: 0.05, amount: 0.015, smooth: 0.85) as swim
      volume 0.95
      play notes`C3~:0.75 _:0.25 C#3~:0.5 _:1.5 D#3~:0.5 _:0.5` at bars(1..3)
      play notes`C3~:0.5 _:0.5 D3~:0.25 D3~:0.25 _:0.5 D#3~:0.5 _:1.5` at bars(4..4)
      play notes`E3~:0.75 _:0.25 F3~:0.5 _:1.25 G3~:0.25 _:0.5 G#3~:0.5` at bars(5..7)
      play notes`E3~:0.25 E3~:0.25 _:0.5 F3~:0.5 _:1 G3~:0.25 _:1.25` at bars(8..8)
      play notes`G#3~:0.75 _:0.25 A3~:0.5 _:1 A#3~:0.5 _:1` at bars(9..11)
      play notes`C3~:0.5 _:0.5 C3~:0.25 _:0.75 C3~:0.25 _:1.75` at bars(12..12)
    }
    // the other half of the ledger: the same record, backwards
    track Spin {
      instrument sampler(attack: 0.05, gain: 1.0, sample: MixS, reverse: "on", end: 0.889, sustain: 1.0, release: 0.08, vary: 0.12)
      volume 0.75
      play notes`_:1.5 C3~:0.75 _:1.75` at bars(2..2)
      play notes`_:3 C3~:1` at bars(4..4)
      play notes`_:1.5 D3~:0.75 _:1.75` at bars(6..6)
      play notes`_:2.5 C3~:1.5` at bars(8..8)
      play notes`_:1.5 C3~:0.5 _:0.5 D3~:0.5 _:1` at bars(10..10)
      play notes`_:2 C3~:2` at bars(12..12)
    }
  }
  play Cutter at bars(1..12)
}
