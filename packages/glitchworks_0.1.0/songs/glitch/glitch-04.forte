// glitch-04 — half heart: the doom break, diving sub, vowel wall and
// rainbow snare bounced to one slab — then cut with LONG gates and longer
// silences, halftime holes you could fall into. The slab freezes mid-air
// at the end.
import { HalfBreak } from "../../wrapped/grooveworks.forte"
import { SubDeep } from "../../wrapped/bassworks.forte"
import { FreezeChoirHard } from "../../wrapped/glitchset.forte"
import { SnareRainbow } from "../../wrapped/drumcolor.forte"

song "Glitch 04 — Half Heart" {
  desc "The doom slab cut with long gates and longer silences — halftime holes you could fall into; it freezes mid-air at the end."
  artist "Forte Essentials"
  tempo 92bpm
  swing 0.55
  master 2.3
  key C minor

  block Mix {
    play HalfBreak at bars(1..4)
    play SubDeep(volume: 0.9) at bars(1..4)
    play FreezeChoirHard(volume: 0.75) at bars(1..4)
    play SnareRainbow(volume: 0.85) at bars(1..4)
  }
  sample MixS = bounce(Mix, note: C3, beats: 16)

  block Cutter {
    track Cut {
      instrument sampler(attack: 0.06, gain: 1.0, sample: MixS, slices: 16, end: 0.889, choke: "on", sustain: 1.0, release: 0.06, vary: 0.07)
      modulate pitch with random(rate: 0.04, amount: 0.015, smooth: 0.9) as swim
      volume 0.95
      // halftime: long gates, then the hole
      play notes`C3~:1.5 _:0.5 C#3~:1 _:1` at bars(1..1)
      play notes`E3~:1.5 _:0.5 F3~:0.75 _:1.25` at bars(2..2)
      play notes`G#3~:2 _:1 A#3~:0.5 _:0.5` at bars(3..3)
      play notes`C4~:1 _:0.5 D4~:0.5 _:0.75 D#4~:0.25 D#4~:0.25 _:0.75` at bars(4..4)
      play notes`C3~:1.5 _:0.5 D3~:0.5 _:1.5` at bars(5..5)
      play notes`_:1 E3~:1 _:1 G3~:0.5 _:0.5` at bars(6..6)
      play notes`G#3~:1.25 _:0.75 A3~:0.25 _:0.25 A#3~:0.5 _:1` at bars(7..7)
      play notes`C4~:0.5 _:0.5 C4~:0.25 C4~:0.25 _:0.5 C#4~:0.5 _:1.5` at bars(8..8)
      play notes`C3~:1.5 _:1 C#3~:0.5 _:1` at bars(9..9)
      play notes`E3~:0.75 _:0.75 F3~:0.25 _:1.25 F#3~:0.5 _:0.5` at bars(10..10)
      play notes`G#3~:0.5 _:0.5 A3~:0.25 _:0.75 C3~:0.25 _:0.25 C#3~:0.25 _:1.25` at bars(11..11)
    }
    // the end: the record slows into a granular hang — no pitch fall
    track Freeze {
      instrument sampler(attack: 0.1, gain: 1.0, sample: MixS, end: 0.889, stretch: 0.5, sustain: 1.0, release: 0.4)
      automate stretch from 0.5 to 0.02 over bars(12..12)
      volume 0.9
      play notes`C3~:4` at bars(12..12)
    }
  }
  play Cutter at bars(1..12)
}
