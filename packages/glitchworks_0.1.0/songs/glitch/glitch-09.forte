// glitch-09 — cartridge splinter: the chip band (broken cartridge, laser
// bass, body kit) bounced to one record and SPLINTERED — sixteenth cuts,
// machine-gun retrigs, silences like the console crashing. The cartridge
// gets pulled at the end.
import { EnsembleChip, BodyBeat } from "../../wrapped/glitchset.forte"
import { LaserBass } from "../../wrapped/bassworks.forte"

song "Glitch 09 — Cartridge Splinter" {
  desc "The chip band bounced to one record and splintered: sixteenth cuts, retrig bursts, console-crash silences."
  artist "Forte Essentials"
  tempo 132bpm
  swing 0.53
  master 2.4
  key C minor

  block Mix {
    play BodyBeat at bars(1..4)
    play LaserBass(volume: 0.85) at bars(1..4)
    play EnsembleChip(volume: 0.8) at bars(1..4)
  }
  sample MixS = bounce(Mix, note: C3, beats: 16)

  block Cutter {
    track Cut {
      instrument sampler(attack: 0.04, gain: 1.0, sample: MixS, slices: 16, end: 0.889, choke: "on", sustain: 1.0, release: 0.04, vary: 0.09)
      modulate pitch with random(rate: 0.08, amount: 0.02, smooth: 0.7) as swim
      insert tapestop(amount: 0.0)
      automate tapestop.amount from 0.0 to 1.0 over bars(16..16)
      volume 0.95
      play notes`C3~:0.5 _:0.25 C#3~:0.25 _:0.25 D3~:0.25 _:0.5 D#3~:0.5 _:0.25 E3~:0.25 _:0.5 F3~:0.5` at bars(1..3)
      play notes`C3~:0.25 C3~:0.25 _:0.25 D3~:0.125 D3~:0.125 _:0.5 D#3~:0.25 _:0.25 F3~:0.125 F3~:0.125 F3~:0.125 F3~:0.125 _:0.5 G3~:0.25 _:0.75` at bars(4..4)
      play notes`E3~:0.5 _:0.5 F3~:0.25 _:0.25 F#3~:0.25 _:0.25 G3~:0.5 _:0.5 G#3~:0.5 _:0.5` at bars(5..7)
      play notes`E3~:0.125 E3~:0.125 E3~:0.125 E3~:0.125 _:0.5 F#3~:0.125 F#3~:0.125 F#3~:0.125 F#3~:0.125 _:0.5 G#3~:0.25 _:0.25 B3~:0.25 _:0.75` at bars(8..8)
      play notes`G#3~:0.5 _:0.25 A3~:0.25 _:0.5 A#3~:0.25 _:0.25 B3~:0.5 _:0.5 C4~:0.5 _:0.5` at bars(9..12)
      play notes`C4~:0.5 _:0.25 C#4~:0.25 _:0.25 D4~:0.25 _:0.5 D#4~:0.25 _:0.25 C3~:0.5 _:1` at bars(13..15)
      play notes`C3~:0.25 C3~:0.25 _:0.5 C3~:0.125 C3~:0.125 C3~:0.125 C3~:0.125 _:0.5 C3~:2` at bars(16..16)
    }
  }
  play Cutter at bars(1..16)
}
