// glitch-09 — cartridge splinter: three chip voices as one broken
// cartridge, splintered over the dark body kit; the laser re-aims every
// eighth and the cartridge finally jams into a stutter and gets pulled.
import { EnsembleChip, BodyBeat } from "../../wrapped/glitchset.forte"
import { LaserBass } from "../../wrapped/bassworks.forte"

song "Glitch 09 — Cartridge Splinter" {
  desc "A broken cartridge splintered over the dark body kit, a laser bass re-aiming every eighth, the cartridge jamming at the end."
  artist "Forte Essentials"
  tempo 132bpm
  swing 0.53
  master 1.25
  key C minor

  block Cartridge : EnsembleChip {
    track Cartridge {
      insert stutter(beats: 0.125, mix: 0.0)
      automate stutter.mix from 0.0 to 0.6 over bars(8..8)
      automate stutter.mix from 0.6 to 0.0 over bars(9..9)
      automate stutter.mix from 0.0 to 0.85 over bars(15..16)
      automate decay from 0.3 to 0.1 over bars(13..16)
      insert tapestop(amount: 0.0)
      automate tapestop.amount from 0.0 to 1.0 over bars(16..16)
      play notes`C4:0.25 D4:0.25 F4:0.25 _:0.25 G4:0.25 C4:0.25 _:0.25 A#4:0.25 C4:0.25 D#4:0.25 _:0.25 F#4:0.25 G4:0.25 _:0.25 B4:0.25 C5:0.25` at bars(1..7)
      play notes`C4:0.25 D4:0.125 D#4:0.125 F4:0.25 G4:0.25 C4:0.125 C4:0.125 A#4:0.25 G4:0.25 _:0.25 D#4:0.25 C4:0.125 F#4:0.125 G4:0.25 A#4:0.25 B4:0.125 C5:0.125 _:0.5 C4:0.25 G4:0.25` at bars(8..8)
      play notes`C4:0.25 D4:0.25 F4:0.25 _:0.25 G4:0.25 C4:0.25 _:0.25 A#4:0.25 C4:0.25 D#4:0.25 _:0.25 F#4:0.25 G4:0.25 _:0.25 B4:0.25 C5:0.25` at bars(9..16)
    }
  }

  play BodyBeat at bars(1..16)
  play LaserBass(volume: 0.85) at bars(2..16)
  play Cartridge(volume: 0.8) at bars(4..16)
}
