// glitch-17 â€” freeze tag: the club (stacked kick, rolling square 303,
// ride shimmer, claps) bounced to one record â€” the cuts chase it around
// the room, and every fourth bar somebody gets TAGGED: the whole record
// hangs frozen mid-air, then the chase resumes. Last one out stays frozen.
import { RideGrain, ClapRun } from "../../wrapped/grooveworks.forte"
import { SquareRoll } from "../../wrapped/bassworks.forte"
import { KickStack } from "../../wrapped/drumcolor.forte"

song "Glitch 17 â€” Freeze Tag" {
  desc "The club bounced to one record; every fourth bar the whole record is tagged frozen mid-air, then the chase resumes."
  artist "Forte Essentials"
  tempo 126bpm
  swing 0.54
  master 1.7
  key C minor

  block Mix {
    play KickStack at bars(1..4)
    play SquareRoll(volume: 0.85) at bars(1..4)
    play RideGrain(volume: 0.8) at bars(1..4)
    play ClapRun(volume: 0.65) at bars(1..4)
  }
  sample MixS = bounce(Mix, note: C3, beats: 16)

  block Cutter {
    track Cut {
      instrument sampler(attack: 0.04, gain: 1.0, sample: MixS, slices: 16, end: 0.889, choke: "on", sustain: 1.0, release: 0.04, vary: 0.07)
      modulate pitch with random(rate: 0.06, amount: 0.015, smooth: 0.8) as swim
      volume 0.95
      play notes`C3~:0.75 _:0.25 C#3~:0.5 _:0.5 D3~:0.75 _:0.25 D#3~:0.5 _:0.5` at bars(1..3)
      play notes`C3~:0.5 _:0.5 C#3~:0.25 C#3~:0.25 _:0.5 D3~:0.5 _:1.5` at bars(4..4)
      play notes`E3~:0.75 _:0.25 F3~:0.5 _:0.5 F#3~:0.5 _:0.5 G3~:0.5 _:0.5` at bars(5..7)
      play notes`E3~:0.25 E3~:0.25 _:0.5 F3~:0.25 _:0.25 F#3~:0.125 F#3~:0.125 F#3~:0.125 F#3~:0.125 _:0.5 G3~:0.5 _:1` at bars(8..8)
      play notes`G#3~:0.75 _:0.25 A3~:0.5 _:0.5 A#3~:0.5 _:0.5 B3~:0.5 _:0.5` at bars(9..11)
      play notes`G#3~:0.5 _:0.5 A3~:0.25 A3~:0.25 _:0.5 A#3~:0.25 _:1.75` at bars(12..12)
      play notes`C4~:0.75 _:0.25 C#4~:0.5 _:0.5 D4~:0.5 _:0.5 D#4~:0.5 _:0.5` at bars(13..15)
    }
    // the tag: the whole record hangs mid-air, no pitch fall
    track Tag {
      instrument sampler(attack: 0.08, gain: 1.0, sample: MixS, end: 0.889, stretch: 0.5, sustain: 1.0, release: 0.3)
      automate stretch from 0.5 to 0.03 over bars(4..4)
      automate stretch from 0.5 to 0.03 over bars(8..8)
      automate stretch from 0.5 to 0.03 over bars(12..12)
      automate stretch from 0.5 to 0.015 over bars(16..16)
      volume 0.85
      play notes`_:3 C3~:1` at bars(4..4)
      play notes`_:3 E3~:1` at bars(8..8)
      play notes`_:3 G#3~:1` at bars(12..12)
      play notes`C3~:4` at bars(16..16)
    }
  }
  play Cutter at bars(1..16)
}
