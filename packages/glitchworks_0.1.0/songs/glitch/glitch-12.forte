// glitch-12 — pedalboard alley: a bass through fuzz into a foot-rocked
// wah, the modal kit laid back behind it, the funk guitar recut with
// rests — stomp-box music chopped by a sampler that keeps changing shoes.
import { FuzzWahBass } from "../../wrapped/bassworks.forte"
import { ModalBackbeat, PercModal } from "../../wrapped/grooveworks.forte"
import { GuitarChop } from "../../wrapped/melodyworks.forte"

song "Glitch 12 — Pedalboard Alley" {
  desc "Fuzz into a foot-rocked wah, the modal kit laid back, funk guitar recut with rests — stomp-box music through a sampler."
  artist "Forte Essentials"
  tempo 108bpm
  swing 0.58
  master 0.7
  key G minor

  block Pedal : FuzzWahBass {
    track Pedalboard {
      insert stutter(beats: 0.25, mix: 0.0)
      automate stutter.mix from 0.0 to 0.5 over bars(8..8)
      automate stutter.mix from 0.5 to 0.0 over bars(9..9)
      automate decay from 0.5 to 0.15 over bars(11..12)
      play notes`C2:0.75 C2:0.25 D#2:0.5 C2:0.5 F2:0.75 D#2:0.25 C2:0.5 G2:0.25 F2:0.25` at bars(1..3)
      play notes`C2:0.5 D#2:0.25 F2:0.25 G2:0.5 F2:0.25 D#2:0.25 C2:0.25 C2:0.25 A#1:0.5 C2:0.75 _:0.25` at bars(4..4)
      play notes`C2:0.75 C2:0.25 D#2:0.5 C2:0.5 G2:0.75 F2:0.25 D#2:0.5 C2:0.25 A#1:0.25` at bars(5..7)
      play notes`C2:0.5 D#2:0.25 F2:0.25 G2:0.5 F2:0.25 D#2:0.25 C2:0.25 C2:0.25 A#1:0.5 C2:0.75 _:0.25` at bars(8..8)
      play notes`C2:0.75 C2:0.25 D#2:0.5 C2:0.5 F2:0.75 D#2:0.25 C2:0.5 G2:0.25 F2:0.25` at bars(9..12)
    }
  }

  play ModalBackbeat at bars(1..12)
  play Pedal(volume: 0.9) at bars(1..12)
  play GuitarChop(volume: 0.8) at bars(3..12)
  play PercModal(volume: 0.6) at bars(7..12)
}
