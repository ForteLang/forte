// glitch-12 — pedalboard alley: the stomp-box band (fuzz-wah bass, modal
// kit, funk guitar, hand percussion) bounced to one record and cut with a
// player's right hand — mutes, stabs, and the alley going dead quiet
// between phrases. The cuts shrink until only the wah is left flapping.
import { FuzzWahBass } from "../../wrapped/bassworks.forte"
import { ModalBackbeat, PercModal } from "../../wrapped/grooveworks.forte"
import { GuitarChop } from "../../wrapped/melodyworks.forte"

song "Glitch 12 — Pedalboard Alley" {
  desc "The stomp-box band bounced to one record, cut with a player's right hand: mutes, stabs, dead-quiet gaps between phrases."
  artist "Forte Essentials"
  tempo 108bpm
  swing 0.58
  master 1.6
  key G minor

  block Mix {
    play ModalBackbeat at bars(1..4)
    play FuzzWahBass(volume: 0.9) at bars(1..4)
    play GuitarChop(volume: 0.8) at bars(1..4)
    play PercModal(volume: 0.6) at bars(1..4)
  }
  sample MixS = bounce(Mix, note: C3, beats: 16)

  block Cutter {
    track Cut {
      instrument sampler(attack: 0.05, gain: 1.0, sample: MixS, slices: 16, end: 0.889, choke: "on", sustain: 1.0, release: 0.05, vary: 0.08)
      modulate pitch with random(rate: 0.06, amount: 0.015, smooth: 0.8) as swim
      volume 0.95
      play notes`C3~:0.75 _:0.25 C#3~:0.5 _:0.5 D3~:0.75 _:0.25 D#3~:0.5 _:0.5` at bars(1..3)
      play notes`C3~:0.5 _:0.25 C#3~:0.25 _:0.5 D3~:0.25 D3~:0.25 _:0.5 D#3~:0.125 D#3~:0.125 D#3~:0.125 D#3~:0.125 _:1` at bars(4..4)
      play notes`E3~:0.75 _:0.25 F3~:0.5 _:0.75 F#3~:0.25 _:0.5 G3~:0.5 _:0.5` at bars(5..7)
      play notes`E3~:0.25 E3~:0.25 _:0.5 F3~:0.25 _:0.25 F#3~:0.25 F#3~:0.25 _:0.5 G3~:0.25 _:0.25 G#3~:0.25 _:0.75` at bars(8..8)
      play notes`G#3~:0.75 _:0.25 A3~:0.5 _:0.75 A#3~:0.5 _:0.25 B3~:0.5 _:0.5` at bars(9..10)
      play notes`C3~:0.5 _:0.5 C#3~:0.25 _:0.5 D3~:0.25 _:0.75 D#3~:0.25 _:1` at bars(11..11)
      play notes`C3~:0.5 _:0.5 C3~:0.25 _:0.5 C3~:0.25 _:0.75 C3~:0.125 _:1.125` at bars(12..12)
    }
  }
  play Cutter at bars(1..12)
}
