// glitch-15 — vox machine: the voice band (impossible syllables, gliding
// vox, body kit, steered wobble) bounced to one record — and re-cut as
// NEW syllables: short vowels, hard consonant cuts, whole words of
// silence. The machine chokes on its own sentence at the end.
import { VoxCutUp } from "../../wrapped/melodyworks.forte"
import { GlideVox, BodyBeat } from "../../wrapped/glitchset.forte"
import { WobbleGate } from "../../wrapped/bassworks.forte"

song "Glitch 15 — Vox Machine" {
  desc "The voice band bounced to one record and re-cut as new syllables: short vowels, hard consonants, whole words of silence."
  artist "Forte Essentials"
  tempo 120bpm
  swing 0.55
  master 2.2
  key C minor

  block Mix {
    play BodyBeat at bars(1..4)
    play WobbleGate(volume: 0.85) at bars(1..4)
    play VoxCutUp(volume: 0.9) at bars(1..4)
    play GlideVox(volume: 0.7) at bars(1..4)
  }
  sample MixS = bounce(Mix, note: C3, beats: 16)

  block Cutter {
    track Cut {
      instrument sampler(attack: 0.05, gain: 1.0, sample: MixS, slices: 16, end: 0.889, choke: "on", sustain: 1.0, release: 0.05, vary: 0.08)
      modulate pitch with random(rate: 0.06, amount: 0.018, smooth: 0.8) as swim
      volume 0.95
      play notes`C3~:0.5 _:0.25 C#3~:0.25 _:0.5 D3~:0.5 _:0.5 D#3~:0.5 _:1` at bars(1..3)
      play notes`C3~:0.25 _:0.25 C#3~:0.25 C#3~:0.25 _:0.5 D3~:0.5 _:0.5 D#3~:0.25 _:0.25 E3~:0.25 _:0.75` at bars(4..4)
      play notes`E3~:0.5 _:0.5 F3~:0.25 _:0.75 F#3~:0.5 _:0.5 G3~:0.25 _:0.75` at bars(5..7)
      play notes`E3~:0.125 E3~:0.125 E3~:0.125 E3~:0.125 _:0.5 F3~:0.25 _:0.25 G3~:0.25 G3~:0.25 _:0.5 G#3~:0.5 _:1` at bars(8..8)
      play notes`G#3~:0.5 _:0.5 A3~:0.25 _:0.75 A#3~:0.5 _:0.5 B3~:0.25 _:0.75` at bars(9..12)
      play notes`C4~:0.5 _:0.5 C#4~:0.25 _:0.75 D4~:0.5 _:0.5 D#4~:0.25 _:0.75` at bars(13..15)
      play notes`C3~:0.25 C3~:0.25 _:0.5 C3~:0.125 C3~:0.125 C3~:0.125 C3~:0.125 _:0.5 C3~:0.5 _:0.5 C3~:0.25 _:0.75` at bars(16..16)
    }
    track Answer {
      instrument sampler(attack: 0.06, gain: 1.0, sample: MixS, reverse: "on", end: 0.889, sustain: 1.0, release: 0.1, vary: 0.1)
      volume 0.55
      play notes`_:3 C3~:1` at bars(6..6)
      play notes`_:3 D3~:1` at bars(10..10)
      play notes`_:2.5 C3~:1.5` at bars(14..14)
    }
  }
  play Cutter at bars(1..16)
}
