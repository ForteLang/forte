// glitch-08 — brass debt: dub economics. One brass stab (two brasses and
// a sub glued) choked into eight answers, dub bass echoing itself, toms in
// conversation — and the tape dies a little at every settling of accounts.
import { EnsembleBrass, TomGroove, BackspinPerc } from "../../wrapped/glitchset.forte"
import { BassStabEcho } from "../../wrapped/bassworks.forte"

song "Glitch 08 — Brass Debt" {
  desc "Dub economics: one glued brass stab choked into answers, echoing bass, talking toms, the tape dying at each turn."
  artist "Forte Essentials"
  tempo 100bpm
  swing 0.58
  master 1.35
  key G minor

  block Stabs : EnsembleBrass {
    track Stab {
      insert tapestop(amount: 0.0)
      automate tapestop.amount from 0.0 to 0.55 over bars(4..4)
      automate tapestop.amount from 0.55 to 0.0 over bars(5..5)
      automate tapestop.amount from 0.0 to 0.7 over bars(8..8)
      automate tapestop.amount from 0.7 to 0.0 over bars(9..9)
      automate tapestop.amount from 0.0 to 1.0 over bars(12..12)
      play notes`C3:0.75 _:0.75 C3:0.5 _:1 D3:0.5 _:0.5` at bars(1..3)
      play notes`C3:0.5 _:0.5 D3:0.375 D#3:0.375 _:0.25 C3:0.5 E3:0.5 _:1 F3:0.5 _:0.5` at bars(4..4)
      play notes`C3:0.75 _:0.75 D#3:0.5 _:1 C3:0.5 _:0.5` at bars(5..7)
      play notes`C3:0.5 _:0.5 D3:0.375 D#3:0.375 _:0.25 C3:0.5 E3:0.5 _:1 F3:0.5 _:0.5` at bars(8..8)
      play notes`C3:0.75 _:0.75 C3:0.5 _:1 D3:0.5 _:0.5` at bars(9..11)
      play notes`C3:0.75 _:0.75 C3:0.5 _:2` at bars(12..12)
    }
  }

  play TomGroove at bars(1..12)
  play BassStabEcho(volume: 0.9) at bars(1..12)
  play Stabs(volume: 0.9) at bars(3..12)
  play BackspinPerc(volume: 0.7) at bars(5..12)
}
