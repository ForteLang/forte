// held-light 05 â€” hollow: the still centre of the album. No floor at all.
// The choir record and the piano record breathe against each other in
// whole phrases; the voice record passes through twice like someone
// crossing a church; everything freezes once, in the middle, together.
song "Hollow" {
  desc "The still centre: choir and piano breathing in whole phrases, a voice crossing twice, one shared freeze in the middle."
  artist "Forte Essentials"
  tempo 100bpm
  swing 0.54
  master 1.8
  key A minor

  sample Choir  = dig("../../records/dawn.forte", beats: 16)
  sample ChoirB = dig("../../records/dawn.forte", beats: 16, skip: 16)
  sample Felt   = dig("../../records/felt.forte", beats: 16)
  sample Voice  = dig("../../records/lantern.forte", beats: 16)

  block Air {
    track Breath {
      instrument sampler(attack: 0.15, gain: 1.0, sample: Choir, sustain: 1.0, release: 0.4, vary: 0.02)
      volume 0.9
      automate volume from 0.0 to 0.9 over bars(1..6)
      play notes`C3~:16` at bars(1..24)
      play notes`C3~:16` at bars(41..64)
    }
    track BreathFar {
      instrument sampler(attack: 0.2, gain: 1.0, sample: ChoirB, sustain: 1.0, release: 0.5, vary: 0.02, semis: 12)
      volume 0.4
      play notes`C3~:16` at bars(17..40)
      play notes`C3~:16` at bars(57..72)
    }
  }

  block Keys {
    track Phrase {
      instrument sampler(attack: 0.1, gain: 1.0, sample: Felt, sustain: 1.0, release: 0.3, vary: 0.02)
      volume 0.85
      play notes`C3~:16` at bars(9..40)
      play notes`C3~:16` at bars(49..72)
    }
    // sparse cut answers â€” single beats of piano let go into the quiet
    track Answer {
      instrument sampler(attack: 0.06, gain: 1.0, sample: Felt, slices: 16, choke: "on", sustain: 1.0, release: 0.15, vary: 0.05)
      volume 0.6
      play notes`_:3 C4~:1` at bars(14..14)
      play notes`_:2.5 G#3~:1.5` at bars(22..22)
      play notes`_:3 E3~:1` at bars(30..30)
      play notes`_:2.5 C4~:1.5` at bars(54..54)
      play notes`_:3 D4~:1` at bars(62..62)
    }
  }

  block Crossing {
    track Voice {
      instrument sampler(attack: 0.12, gain: 1.0, sample: Voice, sustain: 1.0, release: 0.3, vary: 0.02)
      volume 0.75
      play notes`C3~:16` at bars(25..32)
      play notes`C3~:16` at bars(57..64)
    }
  }

  // the shared freeze: bar 40 â€” the whole room hangs, then breathes on
  block Still {
    track Hang {
      instrument sampler(attack: 0.1, gain: 1.0, sample: Choir, stretch: 0.5, sustain: 1.0, release: 0.6)
      automate stretch from 0.5 to 0.015 over bars(39..40)
      automate stretch from 0.015 to 0.5 over bars(41..41)
      volume 0.85
      play notes`C3~:12` at bars(38..40)
    }
    // the end: everything gone but the hang, sinking
    track Sink {
      instrument sampler(attack: 0.15, gain: 1.0, sample: ChoirB, stretch: 0.5, sustain: 1.0, release: 0.8)
      automate stretch from 0.5 to 0.02 over bars(78..80)
      automate pitch from 0.5 to 0.458 over bars(78..80)
      volume 0.8
      play notes`C3~:16` at bars(73..76)
      play notes`C3~:16` at bars(77..80)
    }
  }

  play Air at bars(1..72)
  play Keys at bars(1..72)
  play Crossing at bars(1..64)
  play Still at bars(1..80)
}
