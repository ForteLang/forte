// held-light 07 — sodium: the night-drive one. The voice record cut into
// streetlight syllables over the full floor; mid-song the OTHER voice —
// the vox machine from the glitch crate, three semitones down — answers
// from the opposite lane; the two voices close the song alone together.
song "Sodium" {
  desc "Streetlight syllables over the full floor; the other crate's voice answers from the opposite lane; the two close it alone."
  artist "Forte Essentials"
  tempo 122bpm
  swing 0.54
  master 1.6
  key A minor

  sample Voice  = dig("../../records/lantern.forte", beats: 16)
  sample Kit    = dig("../../records/floor.forte", beats: 16)
  sample KitB   = dig("../../records/floor.forte", beats: 16, skip: 16)
  sample Arp    = dig("../../records/lattice.forte", beats: 16)
  sample OtherV = dig("../glitch/glitch-15.forte", beats: 16)

  block Ground {
    track Kick {
      instrument sampler(attack: 0.05, gain: 1.0, sample: Kit, slices: 16, choke: "on", sustain: 1.0, release: 0.05, vary: 0.04)
      volume 0.95
      automate volume from 0.0 to 0.95 over bars(1..2)
      play notes`C3~:0.75 _:0.25 C#3~:0.75 _:0.25 D3~:0.75 _:0.25 D#3~:0.75 _:0.25` at bars(1..31)
      play notes`C3~:0.5 _:0.5 C#3~:0.25 C#3~:0.25 _:0.5 D3~:0.5 _:1.5` at bars(32..32)
      play notes`E3~:0.75 _:0.25 F3~:0.75 _:0.25 F#3~:0.75 _:0.25 G3~:0.75 _:0.25` at bars(33..79)
      play notes`E3~:0.5 _:0.5 F3~:0.25 F3~:0.25 _:0.5 G3~:0.5 _:1.5` at bars(80..80)
      play notes`C3~:0.75 _:0.25 C#3~:0.75 _:0.25 D3~:0.75 _:0.25 D#3~:0.75 _:0.25` at bars(81..95)
      play notes`C3~:0.75 _:0.25 C#3~:0.5 _:0.5 D3~:1 _:1` at bars(96..96)
    }
    track Fills {
      instrument sampler(attack: 0.05, gain: 1.0, sample: KitB, slices: 16, choke: "on", sustain: 1.0, release: 0.05, vary: 0.08)
      volume 0.6
      play notes`_:3 G3~:0.25 G3~:0.25 _:0.5` at bars(16..16)
      play notes`_:3 B3~:0.25 C4~:0.25 _:0.5` at bars(48..48)
      play notes`_:2.5 D4~:0.5 _:0.5 D#4~:0.5` at bars(80..80)
    }
  }

  block Lane {
    track Syllables {
      instrument sampler(attack: 0.05, gain: 1.0, sample: Voice, slices: 16, choke: "on", sustain: 1.0, release: 0.07, vary: 0.06)
      insert duck(from: Ground, amount: 0.55, attack: 0.02, release: 0.12, shape: 0.6)
      volume 0.9
      play notes`C3~:0.5 _:0.5 C#3~:0.5 _:0.5 D3~:0.5 _:1 D#3~:0.5` at bars(5..32)
      play notes`G#3~:0.5 _:0.5 A3~:0.5 _:0.5 A#3~:0.5 _:1 B3~:0.5` at bars(49..80)
    }
    track Held {
      instrument sampler(attack: 0.1, gain: 1.0, sample: Voice, sustain: 1.0, release: 0.25, vary: 0.02)
      insert duck(from: Ground, amount: 0.5, attack: 0.02, release: 0.13, shape: 0.6)
      volume 0.6
      play notes`C3~:16` at bars(17..32)
      play notes`C3~:16` at bars(65..96)
    }
  }

  // ---- the opposite lane: the glitch crate's voice, in key ----
  block Opposite {
    track Answers {
      instrument sampler(attack: 0.05, gain: 1.0, sample: OtherV, slices: 16, choke: "on", sustain: 1.0, release: 0.06, vary: 0.07, semis: -3)
      insert duck(from: Ground, amount: 0.55, attack: 0.02, release: 0.12, shape: 0.6)
      volume 0.8
      automate volume from 0.0 to 0.8 over bars(33..35)
      play notes`_:2 C3~:0.5 _:0.5 D3~:0.5 _:0.5` at bars(33..64)
      play notes`_:2 G#3~:0.5 _:0.5 A3~:0.5 _:0.5` at bars(81..95)
    }
  }

  block Shine {
    track Arps {
      instrument sampler(attack: 0.05, gain: 1.0, sample: Arp, slices: 16, choke: "on", sustain: 1.0, release: 0.06, vary: 0.05, semis: 12)
      insert duck(from: Ground, amount: 0.6, attack: 0.02, release: 0.12, shape: 0.6)
      volume 0.5
      play notes`C3~:0.5 _:0.5 C#3~:0.5 _:0.5 D3~:0.5 _:0.5 D#3~:0.5 _:0.5` at bars(65..95)
    }
  }

  // the two voices alone, trading last words
  block Close {
    track One {
      instrument sampler(attack: 0.08, gain: 1.0, sample: Voice, sustain: 1.0, release: 0.4, vary: 0.02)
      volume 0.85
      play notes`C3~:8 _:8` at bars(97..104)
    }
    track Two {
      instrument sampler(attack: 0.08, gain: 1.0, sample: OtherV, sustain: 1.0, release: 0.4, vary: 0.03, semis: -3)
      insert tapestop(amount: 0.0)
      automate tapestop.amount from 0.0 to 1.0 over bars(104..104)
      volume 0.75
      play notes`_:8 C3~:8` at bars(97..104)
    }
  }

  play Ground at bars(1..96)
  play Lane at bars(1..96)
  play Opposite at bars(1..95)
  play Shine at bars(1..95)
  play Close at bars(1..104)
}
