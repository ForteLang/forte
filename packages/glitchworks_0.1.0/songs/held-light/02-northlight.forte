// held-light 02 — northlight: the driving one. Arps over the floor from
// the first bar; halfway through, a record from the OTHER crate — the
// bell shop, three semitones down into A minor — walks in like a guest
// who knows the song. Breakdown on the choir, then both records peak
// together. Ends clean on one last bell.
song "Northlight" {
  desc "Arps over the floor; the bell-shop record walks in from the other crate, repitched into key; both peak together."
  artist "Forte Essentials"
  tempo 122bpm
  swing 0.54
  master 1.55
  key A minor

  sample Arp   = dig("../../records/lattice.forte", beats: 16)
  sample ArpB  = dig("../../records/lattice.forte", beats: 16, skip: 16)
  sample Kit   = dig("../../records/floor.forte", beats: 16)
  sample Choir = dig("../../records/dawn.forte", beats: 16, skip: 16)
  // the guest: a C-minor record from the glitch crate, pulled into A minor
  sample Bells = dig("../glitch/glitch-16.forte", beats: 16)

  block Ground {
    track Kick {
      instrument sampler(attack: 0.05, gain: 1.0, sample: Kit, slices: 16, choke: "on", sustain: 1.0, release: 0.05, vary: 0.04)
      volume 0.95
      automate volume from 0.0 to 0.95 over bars(1..4)
      play notes`C3~:0.75 _:0.25 C#3~:0.75 _:0.25 D3~:0.75 _:0.25 D#3~:0.75 _:0.25` at bars(1..15)
      play notes`C3~:0.75 _:0.25 C#3~:0.5 _:0.5 D3~:0.5 _:0.5 D#3~:0.25 _:0.75` at bars(16..16)
      play notes`E3~:0.75 _:0.25 F3~:0.75 _:0.25 F#3~:0.75 _:0.25 G3~:0.75 _:0.25` at bars(17..47)
      play notes`E3~:0.5 _:0.5 F3~:0.25 F3~:0.25 _:0.5 G3~:0.5 _:1.5` at bars(48..48)
      play notes`C3~:0.75 _:0.25 C#3~:0.75 _:0.25 D3~:0.75 _:0.25 D#3~:0.75 _:0.25` at bars(65..107)
      play notes`C3~:0.75 _:0.25 C#3~:0.5 _:0.5 D3~:1 _:1` at bars(108..108)
    }
  }

  block Melody {
    track Arps {
      instrument sampler(attack: 0.05, gain: 1.0, sample: Arp, slices: 16, choke: "on", sustain: 1.0, release: 0.07, vary: 0.05)
      insert duck(from: Ground, amount: 0.6, attack: 0.02, release: 0.13, shape: 0.6)
      volume 0.9
      play notes`C3~:0.5 _:0.5 C#3~:0.5 _:0.5 D3~:0.5 _:0.5 D#3~:0.5 _:0.5` at bars(1..16)
      play notes`E3~:0.5 _:0.5 F3~:0.5 _:0.5 F#3~:0.5 _:0.5 G3~:0.5 _:0.5` at bars(17..32)
      play notes`C4~:0.5 _:0.5 C#4~:0.5 _:0.5 D4~:0.5 _:0.5 D#4~:0.5 _:0.5` at bars(65..80)
      play notes`E3~:0.5 F3~:0.5 _:0.5 F#3~:0.5 G3~:0.5 _:0.5 G#3~:0.5 _:0.5` at bars(81..104)
    }
    track Halo {
      instrument sampler(attack: 0.08, gain: 1.0, sample: ArpB, sustain: 1.0, release: 0.2, vary: 0.03)
      insert duck(from: Ground, amount: 0.55, attack: 0.02, release: 0.13, shape: 0.6)
      volume 0.6
      play notes`C3~:16` at bars(9..32)
      play notes`C3~:16` at bars(65..104)
    }
  }

  // ---- the guest record, in key and on time ----
  block Guest {
    track Shop {
      instrument sampler(attack: 0.05, gain: 1.0, sample: Bells, slices: 16, choke: "on", sustain: 1.0, release: 0.06, vary: 0.06, semis: -3)
      insert duck(from: Ground, amount: 0.55, attack: 0.02, release: 0.13, shape: 0.6)
      volume 0.85
      automate volume from 0.0 to 0.85 over bars(33..35)
      play notes`C3~:0.75 _:0.75 C#3~:0.5 _:1 D3~:0.5 _:0.5` at bars(33..47)
      play notes`C3~:0.5 _:0.5 C#3~:0.25 C#3~:0.25 _:0.5 D3~:0.5 _:1.5` at bars(48..48)
      play notes`G#3~:0.75 _:0.75 A3~:0.5 _:1 A#3~:0.5 _:0.5` at bars(81..104)
    }
    // its reversed tail pulls each eight bars around
    track Turn {
      instrument sampler(attack: 0.06, gain: 1.0, sample: Bells, reverse: "on", sustain: 1.0, release: 0.1, vary: 0.08, semis: -3)
      volume 0.6
      play notes`_:2 C3~:2` at bars(40..40)
      play notes`_:2 C3~:2` at bars(56..56)
      play notes`_:2 C3~:2` at bars(96..96)
    }
  }

  // ---- breakdown: the choir's far half, frozen then released ----
  block Break {
    track Wall {
      instrument sampler(attack: 0.12, gain: 1.0, sample: Choir, sustain: 1.0, release: 0.3, vary: 0.02)
      volume 0.95
      play notes`C3~:16` at bars(49..64)
    }
    track Freeze {
      instrument sampler(attack: 0.1, gain: 1.0, sample: Choir, stretch: 0.5, sustain: 1.0, release: 0.4)
      automate stretch from 0.5 to 0.04 over bars(63..64)
      volume 0.7
      play notes`C3~:8` at bars(63..64)
    }
  }

  // one last bell, alone
  block Coda {
    track Bell {
      instrument sampler(attack: 0.08, gain: 1.0, sample: Bells, slices: 16, choke: "on", sustain: 1.0, release: 0.3, vary: 0.04, semis: -3)
      volume 0.8
      play notes`C3~:2 _:2` at bars(109..110)
      play notes`C3~:4` at bars(111..112)
    }
  }

  play Ground at bars(1..108)
  play Melody at bars(1..104)
  play Guest at bars(1..104)
  play Break at bars(1..64)
  play Coda at bars(1..112)
}
