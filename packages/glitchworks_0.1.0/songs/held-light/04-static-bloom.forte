// held-light 04 — static bloom: the fast one. The arp record and a house
// record from the other crate (three semitones down, right in key) trade
// the groove; the choir blooms UP AN OCTAVE at the peak; the floor never
// blinks until the last bar, where everything cuts at once.
song "Static Bloom" {
  desc "Arps and the house record trade the groove; the choir blooms an octave up at the peak; the last bar cuts everything at once."
  artist "Forte Essentials"
  tempo 124bpm
  swing 0.53
  master 1.5
  key A minor

  sample Arp   = dig("../../records/lattice.forte", beats: 16)
  sample Kit   = dig("../../records/floor.forte", beats: 16)
  sample Choir = dig("../../records/dawn.forte", beats: 16)
  sample House = dig("../glitch/glitch-03.forte", beats: 16)

  block Ground {
    track Kick {
      instrument sampler(attack: 0.05, gain: 1.0, sample: Kit, slices: 16, choke: "on", sustain: 1.0, release: 0.05, vary: 0.04)
      volume 0.95
      automate volume from 0.0 to 0.95 over bars(1..2)
      play notes`C3~:0.75 _:0.25 C#3~:0.75 _:0.25 D3~:0.75 _:0.25 D#3~:0.75 _:0.25` at bars(1..47)
      play notes`E3~:0.5 _:0.5 F3~:0.25 F3~:0.25 _:0.5 G3~:0.5 _:1.5` at bars(48..48)
      play notes`E3~:0.75 _:0.25 F3~:0.75 _:0.25 F#3~:0.75 _:0.25 G3~:0.75 _:0.25` at bars(49..95)
      play notes`C3~:0.75 _:0.25 C#3~:0.75 _:0.25 D3~:0.75 _:0.25 D#3~:0.75 _:0.25` at bars(97..110)
      play notes`C3~:0.5 _:0.5 C3~:0.25 _:0.75 C3~:0.25 _:1.75` at bars(111..112)
    }
  }

  block TradeA {
    track Arps {
      instrument sampler(attack: 0.05, gain: 1.0, sample: Arp, slices: 16, choke: "on", sustain: 1.0, release: 0.06, vary: 0.05)
      insert duck(from: Ground, amount: 0.6, attack: 0.02, release: 0.12, shape: 0.6)
      volume 0.9
      play notes`C3~:0.5 _:0.5 C#3~:0.5 _:0.5 D3~:0.5 _:0.5 D#3~:0.5 _:0.5` at bars(5..24)
      play notes`C4~:0.5 _:0.5 C#4~:0.5 _:0.5 D4~:0.5 _:0.5 D#4~:0.5 _:0.5` at bars(49..72)
      play notes`E3~:0.5 F3~:0.5 _:0.5 F#3~:0.5 G3~:0.5 _:0.5 G#3~:0.5 _:0.5` at bars(97..110)
    }
  }
  block TradeB {
    track Rooms {
      instrument sampler(attack: 0.05, gain: 1.0, sample: House, slices: 16, choke: "on", sustain: 1.0, release: 0.05, vary: 0.06, semis: -3)
      insert duck(from: Ground, amount: 0.55, attack: 0.02, release: 0.12, shape: 0.6)
      volume 0.85
      automate volume from 0.0 to 0.85 over bars(25..27)
      play notes`C3~:0.5 _:0.5 C#3~:0.5 _:0.5 D3~:0.5 _:0.5 D#3~:0.25 _:0.75` at bars(25..47)
      play notes`E3~:0.5 _:0.5 F3~:0.5 _:0.5 F#3~:0.5 _:0.5 G3~:0.25 _:0.75` at bars(73..95)
      play notes`C3~:0.25 C3~:0.25 _:0.5 C#3~:0.25 _:0.75 D3~:0.5 _:1.5` at bars(96..96)
    }
  }

  // ---- the bloom: the choir an octave up over the peak ----
  block Bloom {
    track Up {
      instrument sampler(attack: 0.12, gain: 1.0, sample: Choir, sustain: 1.0, release: 0.3, vary: 0.02, semis: 12)
      insert duck(from: Ground, amount: 0.5, attack: 0.02, release: 0.13, shape: 0.6)
      volume 0.6
      automate volume from 0.0 to 0.6 over bars(49..52)
      play notes`C3~:16` at bars(49..95)
    }
    track Root {
      instrument sampler(attack: 0.15, gain: 1.0, sample: Choir, sustain: 1.0, release: 0.3, vary: 0.02)
      insert duck(from: Ground, amount: 0.55, attack: 0.02, release: 0.13, shape: 0.6)
      volume 0.55
      play notes`C3~:16` at bars(65..95)
    }
  }

  play Ground at bars(1..112)
  play TradeA at bars(1..110)
  play TradeB at bars(1..96)
  play Bloom at bars(1..95)
}
