// held-light 01 — first light: the album opens the way the day does.
// The piano record alone, playing straight off the platter; the floor
// arrives already ducking everything around it; the arp record carries
// the motif up in cuts; then the SWITCH — the choir record takes the
// whole room — and the morning merges everything it met.
song "First Light" {
  desc "The piano record alone, the floor arriving, the arps lifting the motif — then the choir takes the room, and morning merges them."
  artist "Forte Essentials"
  tempo 118bpm
  swing 0.54
  master 1.45
  key A minor

  sample Felt  = dig("../../records/felt.forte", beats: 16)
  sample FeltB = dig("../../records/felt.forte", beats: 16, skip: 16)
  sample Arp   = dig("../../records/lattice.forte", beats: 16)
  sample Choir = dig("../../records/dawn.forte", beats: 16)
  sample Kit   = dig("../../records/floor.forte", beats: 16)

  // ---- the ground: the floor record, chopped with breathing holes ----
  block Ground {
    track Kick {
      instrument sampler(attack: 0.05, gain: 1.0, sample: Kit, slices: 16, choke: "on", sustain: 1.0, release: 0.05, vary: 0.04)
      volume 0.95
      play notes`C3~:0.75 _:0.25 C#3~:0.75 _:0.25 D3~:0.75 _:0.25 D#3~:0.75 _:0.25` at bars(17..31)
      play notes`C3~:0.75 _:0.25 C#3~:0.5 _:0.5 D3~:0.5 _:0.5 D#3~:0.25 _:0.75` at bars(32..32)
      play notes`E3~:0.75 _:0.25 F3~:0.75 _:0.25 F#3~:0.75 _:0.25 G3~:0.75 _:0.25` at bars(33..47)
      play notes`E3~:0.5 _:0.5 F3~:0.25 F3~:0.25 _:0.5 G3~:0.5 _:1.5` at bars(48..48)
      play notes`C3~:0.75 _:0.25 C#3~:0.75 _:0.25 D3~:0.75 _:0.25 D#3~:0.75 _:0.25` at bars(65..87)
      play notes`C3~:0.75 _:0.25 C#3~:0.5 _:0.5 D3~:0.5 _:1` at bars(88..88)
    }
  }

  // ---- the piano record, straight off the platter (and its last word) ----
  block Piano {
    track Straight {
      instrument sampler(attack: 0.08, gain: 1.0, sample: Felt, sustain: 1.0, release: 0.15, vary: 0.02)
      insert duck(from: Ground, amount: 0.5, attack: 0.02, release: 0.13, shape: 0.6)
      volume 0.9
      automate volume from 0.0 to 0.95 over bars(1..4)
      play notes`C3~:16` at bars(1..16)
      play notes`C3~:16` at bars(65..80)
      play notes`C3~:16` at bars(89..100)
    }
    // the same record CUT, answering itself while the floor runs
    track Cut {
      instrument sampler(attack: 0.05, gain: 1.0, sample: FeltB, slices: 16, choke: "on", sustain: 1.0, release: 0.08, vary: 0.05)
      insert duck(from: Ground, amount: 0.5, attack: 0.02, release: 0.13, shape: 0.6)
      volume 0.85
      play notes`C3~:1 _:0.5 C#3~:0.5 _:1 D3~:0.75 _:0.25` at bars(17..31)
      play notes`C3~:1 _:0.5 D3~:0.5 _:2` at bars(32..32)
      play notes`G#3~:1 _:1 A3~:0.75 _:1.25` at bars(81..87)
    }
    // the closing ride-down on the piano's last chord
    track Last {
      instrument sampler(attack: 0.1, gain: 1.0, sample: FeltB, sustain: 1.0, release: 0.4)
      insert tapestop(amount: 0.0)
      automate pitch from 0.5 to 0.396 over bars(101..104)
      automate tapestop.amount from 0.0 to 1.0 over bars(104..104)
      volume 0.85
      play notes`C3~:16` at bars(101..104)
    }
  }

  // ---- the arp record: the motif climbing in cuts ----
  block Lights {
    track Arps {
      instrument sampler(attack: 0.05, gain: 1.0, sample: Arp, slices: 16, choke: "on", sustain: 1.0, release: 0.07, vary: 0.05)
      insert duck(from: Ground, amount: 0.6, attack: 0.02, release: 0.13, shape: 0.6)
      volume 0.85
      automate volume from 0.0 to 0.85 over bars(33..36)
      play notes`C3~:0.5 _:0.5 C#3~:0.5 _:0.5 D3~:0.5 _:0.5 D#3~:0.5 _:0.5` at bars(33..47)
      play notes`E3~:0.5 F3~:0.5 F#3~:0.5 G3~:0.5 G#3~:0.5 A3~:0.5 A#3~:0.5 B3~:0.5` at bars(48..48)
      play notes`E3~:0.5 _:0.5 F3~:0.5 _:0.5 F#3~:0.5 _:0.5 G3~:0.5 _:0.5` at bars(65..80)
      play notes`C4~:0.5 _:0.5 C#4~:0.5 _:0.5 D4~:0.5 _:0.5 D#4~:0.5 _:0.5` at bars(81..87)
      play notes`C4~:1 _:0.5 C#4~:0.5 _:2` at bars(88..88)
      play notes`E3~:0.5 _:1.5 F3~:0.5 _:1.5` at bars(89..96)
    }
  }

  // ---- THE SWITCH: the choir record takes the whole room ----
  block Cathedral {
    track Wall {
      instrument sampler(attack: 0.12, gain: 1.0, sample: Choir, sustain: 1.0, release: 0.25, vary: 0.02)
      volume 0.9
      play notes`C3~:16` at bars(49..64)
    }
    track WallUnder {
      instrument sampler(attack: 0.15, gain: 1.0, sample: Choir, sustain: 1.0, release: 0.3, vary: 0.02)
      insert duck(from: Ground, amount: 0.55, attack: 0.02, release: 0.14, shape: 0.6)
      volume 0.6
      play notes`C3~:16` at bars(65..88)
    }
    // it arrives out of a freeze, like light through a door
    track Door {
      instrument sampler(attack: 0.1, gain: 1.0, sample: Choir, stretch: 0.5, sustain: 1.0, release: 0.4)
      automate stretch from 0.04 to 0.5 over bars(49..50)
      volume 0.7
      play notes`C3~:8` at bars(49..50)
    }
  }

  play Piano at bars(1..104)
  play Ground at bars(1..88)
  play Lights at bars(1..96)
  play Cathedral at bars(1..88)
}
