// held-light 08 — afterimage: the closer. Every record on the album
// passes through one last time — piano, arps, voice, choir — each
// quoted over the slowing floor; then the choir is held whole, ridden
// down, and the light goes out. What remains is the motif, once, alone.
song "Afterimage" {
  desc "Every record passes through once more over the slowing floor; the choir is held, ridden down, and the light goes out."
  artist "Forte Essentials"
  tempo 116bpm
  swing 0.54
  master 1.7
  key A minor

  sample Felt  = dig("../../records/felt.forte", beats: 16)
  sample Arp   = dig("../../records/lattice.forte", beats: 16)
  sample Voice = dig("../../records/lantern.forte", beats: 16)
  sample Choir = dig("../../records/dawn.forte", beats: 16)
  sample Kit   = dig("../../records/floor.forte", beats: 16)

  block Ground {
    track Kick {
      instrument sampler(attack: 0.05, gain: 1.0, sample: Kit, slices: 16, choke: "on", sustain: 1.0, release: 0.05, vary: 0.04)
      volume 0.9
      automate volume from 0.0 to 0.9 over bars(9..12)
      play notes`C3~:0.75 _:0.25 C#3~:0.75 _:0.25 D3~:0.75 _:0.25 D#3~:0.75 _:0.25` at bars(9..63)
      play notes`C3~:0.75 _:0.25 C#3~:0.75 _:0.25 D3~:0.75 _:1.25` at bars(64..71)
      play notes`C3~:0.75 _:0.25 C#3~:0.75 _:2.25` at bars(72..79)
      play notes`C3~:0.75 _:3.25` at bars(80..84)
    }
  }

  // the quotations, one per turn of the album
  block Quotes {
    track Piano {
      instrument sampler(attack: 0.08, gain: 1.0, sample: Felt, sustain: 1.0, release: 0.2, vary: 0.02)
      insert duck(from: Ground, amount: 0.45, attack: 0.02, release: 0.13, shape: 0.6)
      volume 0.9
      automate volume from 0.0 to 0.9 over bars(1..4)
      play notes`C3~:16` at bars(1..24)
      play notes`C3~:16` at bars(73..84)
    }
    track Arps {
      instrument sampler(attack: 0.05, gain: 1.0, sample: Arp, slices: 16, choke: "on", sustain: 1.0, release: 0.07, vary: 0.05)
      insert duck(from: Ground, amount: 0.55, attack: 0.02, release: 0.12, shape: 0.6)
      volume 0.8
      play notes`C3~:0.5 _:0.5 C#3~:0.5 _:0.5 D3~:0.5 _:0.5 D#3~:0.5 _:0.5` at bars(17..40)
    }
    track Voice {
      instrument sampler(attack: 0.08, gain: 1.0, sample: Voice, sustain: 1.0, release: 0.25, vary: 0.02)
      insert duck(from: Ground, amount: 0.5, attack: 0.02, release: 0.13, shape: 0.6)
      volume 0.8
      play notes`C3~:16` at bars(33..56)
    }
    track ChoirIn {
      instrument sampler(attack: 0.12, gain: 1.0, sample: Choir, sustain: 1.0, release: 0.3, vary: 0.02)
      insert duck(from: Ground, amount: 0.5, attack: 0.02, release: 0.13, shape: 0.6)
      volume 0.75
      play notes`C3~:16` at bars(49..72)
    }
  }

  // the light goes out: the choir held whole, ridden down, cut
  block Out {
    track Held {
      instrument sampler(attack: 0.12, gain: 1.0, sample: Choir, sustain: 1.0, release: 0.5)
      insert tapestop(amount: 0.0)
      automate pitch from 0.5 to 0.396 over bars(85..90)
      automate tapestop.amount from 0.0 to 1.0 over bars(90..90)
      volume 0.9
      play notes`C3~:16` at bars(85..88)
      play notes`C3~:8` at bars(89..90)
    }
    // the afterimage: the motif once, alone, from the piano record
    track Once {
      instrument sampler(attack: 0.08, gain: 1.0, sample: Felt, slices: 16, choke: "on", sustain: 1.0, release: 0.3, vary: 0.03)
      volume 0.7
      play notes`_:1 C4~:1 _:0.5 C#4~:0.5 _:1` at bars(93..93)
      play notes`_:1 C3~:2 _:1` at bars(95..95)
    }
  }

  play Quotes at bars(1..84)
  play Ground at bars(1..84)
  play Out at bars(1..96)
}
