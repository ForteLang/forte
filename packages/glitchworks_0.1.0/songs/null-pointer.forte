// Null Pointer — the sparsest cut: half the grid is deliberately empty and
// the groove points at silence. Kick drops out for whole passages; clicks
// answer nothing. Genre signature: minimal's negative space as the hook.
import { Click, Tick, Blip } from "../instruments/clicks.forte"
import { ThumpKick, DeepSub, PressureBass } from "../instruments/lowend.forte"
import { Hiss, Dust, ColdTone } from "../instruments/textures.forte"

song "Null Pointer" {
  desc "Half the grid is empty on purpose: the groove points at silence. 120bpm sparse glitch."
  artist "Forte Essentials"
  tempo 120bpm
  master 4.0
  key C minor

  section intro = bars(1..8)
  section a     = bars(9..32)
  section void  = bars(33..40)
  section b     = bars(41..64)
  section outro = bars(65..76)

  track Kick {
    instrument ThumpKick(decay: 0.48, drop: 0.28)
    insert comp(thresh: 0.5, ratio: 0.5, attack: 0.01, release: 0.1, makeup: 0.15)
    volume 0.95
    play beat`x--- ---- x--- ----` at a
    play beat`x--- x--- x--- x---` at b
  }
  track Sub {
    instrument DeepSub(decay: 0.9)
    volume 0.72
    play notes`C1:2 _:6` at a
    play notes`C1:3.5 _:0.5` at b
  }
  track Bass {
    instrument PressureBass(cutoff: 0.26)
    insert gate(depth: 0.9, beats: 0.5, duty: 0.5)
    volume 0.6
    play notes`C2:0.5 _:3.5` at a
    play notes`C2:0.5 _:1 C2:0.25 _:0.25 Eb2:0.25 _:1.75` at b
  }
  track Clicks {
    instrument Click(snap: 0.9)
    volume 0.55
    play beat`euclid(3, 16)` at a
    play beat`euclid(5, 16, rot: 2)` at b
  }
  track Ticks {
    instrument Tick(tone: 0.35)
    volume 0.48
    play cycle(beat`x - - .`, span: 1.25) at bars(17..32)
    play cycle(beat`x - - .`, span: 1.25) at b
  }
  track Blips {
    instrument Blip(decay: 0.09)
    insert delay(time: 0.32, fdbk: 0.5, mix: 0.4)
    insert stutter(beats: 0.25, mix: 0.0)
    volume 0.5
    play notes`G4:0.25 _:3.75` at a
    play notes`G4:0.25 _:1.75 C5:0.25 _:1.75` at b
    automate stutter.mix from 0.0 to 0.85 over bars(63..64)
    automate stutter.mix from 0.0 to 0.0 over bars(65..65)
  }
  track Void {
    instrument ColdTone(beatrate: 0.35)
    insert crush(bits: 0.55, rate: 0.5, mix: 0.5)
    volume 0.48
    play notes`C4:8 G4:8 C4:8 Eb4:8` at void
    play notes`C4:8 _:8` at intro
    play notes`C4:16 _:8` at outro
    automate volume from 0.48 to 0.0 over bars(73..76)
  }
  track Dust {
    instrument Dust(color: 0.85)
    volume 0.4
    play humanize(beat`- - - x - - x*2 -`, time: 0.025, seed: 41) at bars(25..64)
  }
  track Hiss {
    instrument Hiss(body: 0.35)
    insert gate(depth: 0.92, beats: 1.0, duty: 0.25)
    volume 0.28
    play notes`C3:32` at bars(49..56)
  }
}
