// iron-lullaby — strings on a pitch wheel over a low kit, a piano
// re-cutting itself softly, a far bell instead of a night light.
import { GlideStrings, LowKit, ReCutPiano, FarBell } from "../../wrapped/glitchset.forte"

song "Iron Lullaby" {
  desc "Sliding strings over a low kit, a softly re-cut piano, a far bell for a night light."
  artist "Forte Essentials"
  tempo 82bpm
  swing 0.55
  master 1.2
  key A minor

  play GlideStrings(volume: 0.8) at bars(1..10)
  play ReCutPiano(volume: 0.85) at bars(2..10)
  play LowKit(volume: 0.75) at bars(4..9)
  play FarBell(volume: 0.7) at bars(7..10)
}
