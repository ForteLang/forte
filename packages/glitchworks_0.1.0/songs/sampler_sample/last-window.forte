// last-window — the album breathes out: the slow wave, a violin saying
// the last thing, rain starting as the heartbeat fades.
import { SlowWave, HeartSub } from "../../wrapped/glitchset.forte"
import { ViolinSolo } from "../../wrapped/melodyworks.forte"
import { RainField } from "../../wrapped/textureworks.forte"

song "Last Window" {
  desc "The slow wave, a violin saying the last thing, rain starting as the heartbeat fades."
  artist "Forte Essentials"
  tempo 68bpm
  swing 0.5
  master 1.7
  key D minor

  play SlowWave at bars(1..8)
  play ViolinSolo(volume: 0.85) at bars(2..7)
  play HeartSub at bars(2..6)
  play RainField(volume: 0.9) at bars(5..8)
}
