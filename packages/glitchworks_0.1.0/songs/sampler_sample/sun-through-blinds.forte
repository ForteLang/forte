// sun-through-blinds — funk guitar recut over a wooden shell, the
// upright walking through the light, vibes hanging in the dust.
import { BodyBeat } from "../../wrapped/glitchset.forte"
import { GuitarChop, VibesFreeze } from "../../wrapped/melodyworks.forte"
import { UprightWalk } from "../../wrapped/bassworks.forte"

song "Sun Through Blinds" {
  desc "Recut funk guitar over a wooden shell, an upright walking through the light, vibes in the dust."
  artist "Forte Essentials"
  tempo 90bpm
  swing 0.59
  master 1.15
  key C minor

  play BodyBeat at bars(1..11)
  play UprightWalk(volume: 0.8) at bars(2..11)
  play GuitarChop(volume: 0.85) at bars(3..11)
  play VibesFreeze(volume: 0.65) at bars(7..11)
}
