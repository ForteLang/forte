// brass-weather — a front moving in: brass stabs against a wooden shell,
// a voice sliding under the clouds, a reversed cymbal opening the rain.
import { EnsembleBrass, GlideVox, BodyBeat } from "../wrapped/glitchset.forte"
import { CrashRise } from "../wrapped/textureworks.forte"

song "Brass Weather" {
  desc "Brass stabs against a wooden shell, a sliding voice, a reversed cymbal opening rain."
  artist "Forte Essentials"
  tempo 94bpm
  swing 0.57
  master 1.15
  key F minor

  play BodyBeat at bars(1..12)
  play EnsembleBrass(volume: 0.85) at bars(2..12)
  play GlideVox(volume: 0.7) at bars(5..12)
  play CrashRise(volume: 0.75) at bars(8..8)
}
