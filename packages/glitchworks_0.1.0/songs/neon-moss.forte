// neon-moss — a gated wobble growing on the low end, glass shimmer on
// top, the morse bed blinking through the cracks.
import { EnsembleGlass, LowKit } from "../wrapped/glitchset.forte"
import { WobbleGate } from "../wrapped/bassworks.forte"
import { ColdPulse } from "../wrapped/textureworks.forte"

song "Neon Moss" {
  desc "A gated wobble on the low end, glass shimmer above, morse blinking through the cracks."
  artist "Forte Essentials"
  tempo 118bpm
  swing 0.54
  master 1.15
  key C minor

  play LowKit at bars(1..15)
  play WobbleGate(volume: 0.8) at bars(2..15)
  play EnsembleGlass(volume: 0.75) at bars(5..14)
  play ColdPulse(volume: 0.55) at bars(9..15)
}
