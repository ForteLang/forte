// Packet Loss â€” the groove keeps dropping out and reassembling: gate-chopped
// bass, stutter fills every 8 bars, clicks in 7-against-16. Genre signature:
// glitch's interrupted continuity â€” the payload arrives, but never intact.
import { Click, Tick, Blip } from "../instruments/clicks.forte"
import { ThumpKick, DeepSub, PressureBass } from "../instruments/lowend.forte"
import { Hiss, Dust, ColdTone } from "../instruments/textures.forte"

song "Packet Loss" {
  desc "The groove drops out and reassembles: gated bass, stutter fills, 7/16 clicks. 126bpm glitch minimal."
  artist "Forte Essentials"
  tempo 126bpm
  master 3.6
  key D minor

  section head = bars(1..8)
  section run1 = bars(9..40)
  section hole = bars(41..48)
  section run2 = bars(49..80)
  section tail = bars(81..92)

  track Kick {
    instrument ThumpKick(decay: 0.4, drop: 0.3)
    insert comp(thresh: 0.5, ratio: 0.5, attack: 0.01, release: 0.1, makeup: 0.15)
    volume 0.95
    play beat`x--- x--- x--- x---` at run1
    play beat`x--- x--- x-x- x---` at bars(33..40)
    play beat`x--- x--- x--- x---` at run2
    play beat`x--- x--- x--- x---` at bars(81..88)
  }
  track Sub {
    instrument DeepSub(decay: 0.75)
    volume 0.7
    play notes`D1:3.5 _:0.5` at run1
    play notes`D1:3.5 _:0.5` at run2
  }
  track Bass {
    instrument PressureBass(cutoff: 0.3)
    insert gate(depth: 0.92, beats: 0.25, duty: 0.55)
    insert crush(bits: 0.25, rate: 0.1, mix: 0.35)
    volume 0.62
    play notes`D2:1 _:0.5 D2:0.5 F2:0.5 _:0.5 D2:1` at run1
    play notes`D2:1 _:0.5 D2:0.5 G2:0.5 _:0.5 D2:1` at run2
    automate gate.duty from 0.55 to 0.25 over bars(33..40)
    automate gate.duty from 0.55 to 0.55 over bars(49..49)
  }
  track Clicks {
    instrument Click(snap: 0.9)
    volume 0.55
    play beat`euclid(7, 16)` at run1
    play beat`euclid(7, 16, rot: 3)` at run2
  }
  track Ticks {
    instrument Tick(tone: 0.5)
    volume 0.5
    play cycle(beat`x - . -`, span: 1.25) at run1
    play cycle(beat`x - . -`, span: 1.25) at run2
  }
  track Blips {
    instrument Blip(decay: 0.06)
    insert delay(time: 0.24, fdbk: 0.4, mix: 0.35)
    insert stutter(beats: 0.125, mix: 0.0)
    volume 0.5
    play notes`A4:0.25 _:1.75 D5:0.25 _:0.75 C5:0.25 _:0.75` at run1
    play notes`A4:0.25 _:0.75 F5:0.25 _:0.75 D5:0.25 _:1.25` at run2
    automate stutter.mix from 0.0 to 0.9 over bars(39..40)
    automate stutter.mix from 0.0 to 0.0 over bars(41..41)
    automate stutter.mix from 0.0 to 0.9 over bars(79..80)
    automate stutter.mix from 0.0 to 0.0 over bars(81..81)
  }
  track Hole {
    instrument ColdTone(beatrate: 0.3)
    insert crush(bits: 0.5, rate: 0.45, mix: 0.6)
    volume 0.5
    play notes`D4:8 A4:8 D4:8 F4:8` at hole
    play notes`D4:8 _:8` at head
    play notes`D4:16 _:8` at tail
    automate volume from 0.5 to 0.0 over bars(89..92)
  }
  track Dust {
    instrument Dust(color: 0.8)
    volume 0.45
    play humanize(beat`- x*2 - - x - - x*3`, time: 0.015, seed: 23) at bars(17..40)
    play humanize(beat`- x*2 - - x - - x*3`, time: 0.015, seed: 24) at bars(57..80)
  }
  track Hiss {
    instrument Hiss(body: 0.5)
    insert gate(depth: 0.85, beats: 0.5, duty: 0.3)
    volume 0.3
    play notes`D3:32` at bars(25..32)
    play notes`D3:32` at bars(65..72)
  }
}
