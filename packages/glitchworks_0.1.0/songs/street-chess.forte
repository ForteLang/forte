// street-chess — hand percussion arguing over a walking upright, tine
// stabs calling the moves, a backspin resetting the board.
import { BackspinPerc } from "../wrapped/glitchset.forte"
import { PercModal } from "../wrapped/grooveworks.forte"
import { UprightWalk } from "../wrapped/bassworks.forte"
import { TineStabCut } from "../wrapped/melodyworks.forte"

song "Street Chess" {
  desc "Hand percussion arguing over a walking upright, tine stabs calling moves, a backspin reset."
  artist "Forte Essentials"
  tempo 104bpm
  swing 0.6
  master 1.15
  key G minor

  play UprightWalk(volume: 0.85) at bars(1..13)
  play PercModal(volume: 0.8) at bars(2..13)
  play TineStabCut(volume: 0.8) at bars(4..13)
  play BackspinPerc(volume: 0.65) at bars(9..13)
}
