// Idle State — the closer: the machine left running overnight. No kick for
// the first half; two drifting cycles and the cold tone breathing on a slow
// gate. When the kick finally enters it is half-tempo and far away. Genre
// signature: the ambient side of Raster-Noton — process music at rest.
import { Click, Tick, Blip } from "../instruments/clicks.forte"
import { ThumpKick, DeepSub, PressureBass } from "../instruments/lowend.forte"
import { Hiss, Dust, ColdTone } from "../instruments/textures.forte"

song "Idle State" {
  desc "The machine left running overnight: drifting cycles, a breathing tone, a distant half-tempo kick. 118bpm."
  artist "Forte Essentials"
  tempo 118bpm
  master 3.8
  key A minor

  section still = bars(1..32)
  section pulse = bars(33..64)
  section fade  = bars(65..80)

  track Tone {
    instrument ColdTone(beatrate: 0.25)
    insert gate(depth: 0.6, beats: 1.0, duty: 0.6)
    insert reverb(size: 0.7, decay: 0.7, mix: 0.35)
    volume 1.00
    play notes`A4:16 E5:16 A4:16 C5:16` at still
    play notes`A4:16 E5:16 A4:16 C5:16` at pulse
    play notes`A4:32 _:16` at fade
    automate volume from 1.0 to 0.0 over bars(75..80)
  }
  track CycleA {
    instrument Blip(decay: 0.12)
    insert delay(time: 0.4, fdbk: 0.55, mix: 0.45)
    volume 0.90
    play cycle(notes`E5:0.25 _:2.75`, span: 3.0) at bars(9..64)
  }
  track CycleB {
    instrument Tick(tone: 0.3)
    volume 0.84
    play cycle(beat`x - - - .`, span: 2.5) at bars(17..72)
  }
  track Clicks {
    instrument Click(snap: 0.7)
    volume 0.90
    play beat`euclid(3, 16)` at pulse
  }
  track Kick {
    instrument ThumpKick(decay: 0.6, drop: 0.2)
    volume 1.00
    play beat`x--- ---- ---- ----` at pulse
    play beat`x--- ---- ---- ----` at bars(65..72)
  }
  track Sub {
    instrument DeepSub(decay: 1.0)
    volume 1.00
    play notes`A1:8 _:8` at pulse
    play notes`A1:8 _:8` at bars(65..72)
  }
  track Dust {
    instrument Dust(color: 0.6)
    volume 0.70
    play humanize(beat`- - x - - - - -`, time: 0.03, seed: 61) at bars(25..64)
  }
  track Hiss {
    instrument Hiss(body: 0.3)
    insert gate(depth: 0.5, beats: 1.0, duty: 0.5)
    volume 0.60
    play notes`A3:64` at bars(1..16)
    play notes`A3:64` at bars(49..64)
    play notes`A3:32 _:16` at fade
    automate volume from 0.60 to 0.0 over bars(75..80)
  }
}
