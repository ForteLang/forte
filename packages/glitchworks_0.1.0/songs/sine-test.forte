// Sine Test — the album opener: a test signal becomes a groove. Almost
// pure sine waves (Raster-Noton discipline), a 4/4 thump, euclid clicks
// phasing in, the cold tone holding the room. Genre signature: minimal
// techno's unbroken kick + clicks-and-cuts micro-percussion.
import { Click, Tick, Blip } from "../instruments/clicks.forte"
import { ThumpKick, DeepSub, PressureBass } from "../instruments/lowend.forte"
import { Hiss, Dust, ColdTone } from "../instruments/textures.forte"

song "Sine Test" {
  desc "A test signal becomes a groove: sine kick, euclid clicks, one cold tone. 124bpm glitch minimal."
  artist "Forte Essentials"
  tempo 124bpm
  master 3.8
  key A minor

  section intro = bars(1..16)
  section build = bars(17..32)
  section main  = bars(33..64)
  section strip = bars(65..72)
  section outro = bars(73..88)

  track Kick {
    instrument ThumpKick(decay: 0.45, drop: 0.35)
    insert comp(thresh: 0.5, ratio: 0.5, attack: 0.01, release: 0.12, makeup: 0.15)
    volume 0.95
    play beat`x--- x--- x--- x---` at bars(9..64)
    play beat`x--- x--- x--- x---` at bars(73..84)
  }
  track Sub {
    instrument DeepSub(decay: 0.8)
    volume 0.7
    play notes`A1:3 _:1` at bars(17..64)
    play notes`A1:3 _:1` at bars(73..84)
  }
  track Bass {
    instrument PressureBass(cutoff: 0.32)
    insert crush(bits: 0.3, rate: 0.15, mix: 0.4)
    volume 0.6
    play notes`A1:0.25 _:0.75 A1:0.25 _:0.25 C2:0.25 _:0.25 A1:0.25 _:1.75` at bars(33..64)
    automate cutoff from 0.25 to 0.55 over bars(49..64)
  }
  track Clicks {
    instrument Click(snap: 0.85)
    volume 0.55
    play beat`euclid(5, 16)` at bars(17..64)
    play beat`euclid(7, 16)` at bars(49..64)
    play beat`euclid(5, 16)` at bars(73..88)
  }
  track Ticks {
    instrument Tick(tone: 0.4)
    volume 0.5
    play cycle(beat`x-.`, span: 0.75) at bars(33..64)
  }
  track Blips {
    instrument Blip(decay: 0.07)
    insert delay(time: 0.28, fdbk: 0.35, mix: 0.3)
    insert stutter(beats: 0.25, mix: 0.0)
    volume 0.5
    play notes`E5:0.25 _:1.75 A4:0.25 _:1.75` at bars(33..48)
    play notes`E5:0.25 _:0.75 B4:0.25 _:0.75 A4:0.25 _:1.25` at bars(49..64)
    automate stutter.mix from 0.0 to 0.85 over bars(63..64)
    automate stutter.mix from 0.0 to 0.0 over bars(65..65)
  }
  track Hiss {
    instrument Hiss(body: 0.45)
    insert gate(depth: 0.9, beats: 0.25, duty: 0.4)
    volume 0.35
    play notes`A3:32` at bars(33..40)
    play notes`A3:32` at bars(49..56)
  }
  track Tone {
    instrument ColdTone(beatrate: 0.2)
    volume 0.45
    play notes`A4:8 _:8` at bars(1..16)
    play notes`A4:8 E5:8` at bars(65..72)
    play notes`A4:16` at bars(73..88)
    automate volume from 0.45 to 0.0 over bars(85..88)
  }
  track Dust {
    instrument Dust(color: 0.75)
    volume 0.45
    play beat`- - x*3 - - x*2 - -` at bars(41..64)
    play humanize(beat`- x - - x*3 - - -`, time: 0.02, seed: 11) at bars(57..64)
  }
}
