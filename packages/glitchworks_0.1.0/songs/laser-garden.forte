// laser-garden — beams re-aimed every eighth over a low kit, bleeps
// scattering off the leaves, a frozen sky holding still.
import { LowKit, FreezeChoirHard } from "../wrapped/glitchset.forte"
import { LaserBass } from "../wrapped/bassworks.forte"
import { ZapArp } from "../wrapped/textureworks.forte"

song "Laser Garden" {
  desc "Beams re-aimed every eighth, bleeps off the leaves, a frozen sky."
  artist "Forte Essentials"
  tempo 136bpm
  swing 0.53
  master 1.15
  key E minor

  play LowKit at bars(1..17)
  play LaserBass(volume: 0.85) at bars(3..17)
  play ZapArp(volume: 0.6) at bars(7..15)
  play FreezeChoirHard(volume: 0.6) at bars(9..17)
}
