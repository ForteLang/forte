// Sketch: momentkit — audition piece, NOT an album track. ONE instrument
// that contains a whole production, effects first: a resampled Prophet
// chord rising +24 semitones through a 20 ms metal comb, a closing
// resonant filter and a long reverb; a produced kick; a snare on a
// dub-depth crushed 80 ms echo. No other instrument plays in this sketch —
// the rack is the beat, the melody, the harmony and the ending.
//   bars 1-2  the COMPONENTS as a beat: C1 kick moment, C2 snare-echo
//             moment, the C3 riser swelling into bar 3
//   bars 3-6  the WHOLE production as music — held wrap notes and a
//             stacked chord, every note dragging its comb, echo tails and
//             reverb to the new pitch
//   bars 7-8  one held chord of the entire moment while the rack's pitch
//             knob rides down and a tape stop cuts the power
import { MomentKit } from "../wrapped/chopworks.forte"

song "Sketch Momentkit" {
  desc "Audition sketch: a produced moment (comb riser + kick + crushed echo snare) as one playable rack — components as the beat, the production as melody and chord, pitch and tapestop ridden live. Not an album track."
  artist "Forte Essentials"
  tempo 90bpm
  swing 0.56
  master 1.4
  key C minor

  block Rack : MomentKit {
    track Rack {
      insert tapestop(amount: 0.0)
      // bars 1-2: the components ARE the beat
      play notes`C1:0.5 _:0.5 C2:0.75 _:0.25 C1:0.5 _:0.25 C1:0.25 C2:0.5 _:0.5` at bars(1..2)
      play notes`_:2 C3~:2` at bars(2..2)
      // bars 3-6: the beat keeps running under the wrap
      play notes`C1:0.5 _:1 C2:0.5 _:1 C1:0.5 C2:0.5` at bars(3..6)
      // the whole production, repitched as a line then stacked as a chord
      play notes`C4~:1.5 D#4:0.5 G4~:2 [C4 D#4 G4]~:2 F4~:1 D4:1` at bars(3..6)
      // bars 7-8: one held world; pitch rides down; the power gets cut
      play notes`[C4 G4]~:8` at bars(7..8)
      automate pitch from 0.5 to 0.396 over bars(7..8)
      automate tapestop.amount from 0.0 to 1.0 over bars(8..8)
    }
  }

  play Rack at bars(1..8)
}
