// Sketch: momentkit — audition piece, NOT an album track. ONE instrument
// that contains a whole production: a JUNO pitch-riser through 20 ms delay,
// a closing filter and reverb; a kick; a snare on an 80 ms echo — each
// bounced alone and all bounced together.
//   bars 1-4  the COMPONENTS played raw off their pads: C1 kick moment,
//             C2 snare-echo moment, C3 the riser
//   bars 5-8  the WHOLE moment as a melody — every note replays the full
//             production repitched from C4 in the audio domain (the echo
//             tails and reverb bend WITH the note), and in bar 8 the rack's
//             pitch knob rides down −6 semitones under held notes
// The question for the ear: does one key = one produced WORLD?
import { MomentKit } from "../wrapped/chopworks.forte"
import { HatClosed } from "../../essentials_0.6.0/instruments/drums.forte"

song "Sketch Momentkit" {
  desc "Audition sketch: a produced moment (riser+kick+snare-echo) as one playable rack — components on pads, the whole production repitched as a melody, pitch ridden live. Not an album track."
  artist "Forte Essentials"
  tempo 90bpm
  swing 0.55
  master 1.4
  key C minor

  block Rack : MomentKit {
    track Rack {
      // bars 1-4: the components, as a beat
      play notes`C1:0.5 _:0.5 C2:0.75 _:0.25 C1:0.5 C1:0.5 C2:0.5 _:0.5` at bars(1..4)
      play notes`C3~:3 _:1` at bars(3..4)
      // bars 5-8: the whole moment, as a melody
      play notes`C4:0.75 D#4:0.75 G4:0.5 F4~:1 A#3~:1` at bars(5..8)
      // bar 8: ride the wrap pitch down under the held notes
      automate pitch from 0.5 to 0.375 over bars(8..8)
    }
  }

  block Time {
    track H {
      instrument HatClosed
      volume 0.3
      play humanize(beat`x-x- x-x- x-x- x-x-`, time: 0.008, vel: 12, seed: 4) at bars(1..8)
    }
  }

  play Rack at bars(1..8)
  play Time at bars(1..8)
}
