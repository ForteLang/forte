// copper-lane — dark jazz-hop: a wooden-shell backbeat that re-edits
// itself, a walking upright re-walked by the sampler, a piano re-cut
// every bar, drips echoing off the walls.
import { BodyBeat, ReCutPiano, CaveDrip } from "../wrapped/glitchset.forte"
import { UprightWalk } from "../wrapped/bassworks.forte"

song "Copper Lane" {
  desc "Wooden-shell backbeat, re-walked upright, a piano re-cut every bar, drips off the walls."
  artist "Forte Essentials"
  tempo 92bpm
  swing 0.6
  master 1.2
  key C minor

  play ReCutPiano(volume: 0.85) at bars(1..11)
  play UprightWalk(volume: 0.8) at bars(2..11)
  play BodyBeat at bars(3..10)
  play CaveDrip(volume: 0.7) at bars(6..11)
}
