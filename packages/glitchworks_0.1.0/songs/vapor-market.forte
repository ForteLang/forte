// vapor-market — the funk grain haggling with dub stabs, wood ticking,
// a ghost choir drifting between the stalls.
import { EnsembleFunk, WoodTick } from "../wrapped/glitchset.forte"
import { BassStabEcho } from "../wrapped/bassworks.forte"
import { GhostChoir } from "../wrapped/chopworks.forte"

song "Vapor Market" {
  desc "The funk grain haggling with dub stabs, wood ticking, a ghost choir between the stalls."
  artist "Forte Essentials"
  tempo 106bpm
  swing 0.58
  master 1.7
  key E minor

  play BassStabEcho(volume: 0.85) at bars(1..13)
  play EnsembleFunk(volume: 0.85) at bars(3..13)
  play WoodTick(volume: 0.6) at bars(5..12)
  block Ghost : GhostChoir {
    track Vox { play notes`_:1.5 C3:0.75 _:1.75` at bars(1..4) }
    track Answer { play notes`_:3 E3:0.5 _:0.5` at bars(3..4) }
  }
  play Ghost(volume: 0.7) at bars(8..13)
}
