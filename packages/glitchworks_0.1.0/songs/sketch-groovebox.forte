// Sketch: groovebox — audition piece, NOT an album track. Fifth cut, one
// rule learned from the fourth: the snare-edit machine only reads if it is
// the ONLY snare in the room. The previous cut buried SnareRainbow under
// SlicerBeat, whose bounced phrase carries its own static backbeat — the
// ear locked onto that and called the whole thing monotonous. Here
// SnareRainbow is the sole snare voice for all sixteen bars, front and
// center: the beat-2 gate/pitch edits, the rotating beat-4 colors, the
// headless cuts, the smear leaning over the barline, the reversed
// pre-echoes. Sixteenth energy comes from HatWork (no snare inside).
//   bars 1-4   snare edits + stacked kick + octaver bass + piano + street
//   bars 5-8   hats join, wah bass takes over, violin answers
//   bars 9-12  chip arp + braindance warmth, power wall on the turn
//   bars 13-16 strip to rain, birds, sub — the snare edits stay exposed
import { SnareRainbow, KickStack } from "../wrapped/drumcolor.forte"
import { HatWork } from "../wrapped/grooveworks.forte"
import { OctaveHouse, FuzzWahBass, SubDeep } from "../wrapped/bassworks.forte"
import { PianoLoop, ViolinSolo, ChipArp, BraindanceKeys } from "../wrapped/melodyworks.forte"
import { RainField, BirdSong, StreetAir, PowerWall, TapeAir } from "../wrapped/textureworks.forte"

song "Sketch Groovebox" {
  desc "Audition sketch: the snare-edit machine as the only snare in the room — gate/pitch edits, rotating colors, smears and reversed pre-echoes over stacked kicks, octaver-to-wah bass, piano/violin/chip/braindance, ending in rain and birds. Not an album track."
  artist "Forte Essentials"
  tempo 90bpm
  swing 0.56
  master 1.1
  key C minor

  play TapeAir at bars(1..12)
  play StreetAir at bars(1..4)

  // the drums: ONE snare voice, ONE kick voice, hats for the 16ths
  play SnareRainbow(volume: 1.0) at bars(1..16)
  play KickStack at bars(1..16)
  play HatWork(volume: 0.7) at bars(5..12)

  // the bass relay
  play OctaveHouse(volume: 0.55) at bars(1..4)
  play FuzzWahBass(volume: 0.7) at bars(5..8)
  play SubDeep at bars(9..16)

  // the music, kept out of the snare's lane
  play PianoLoop(volume: 0.8) at bars(1..8)
  play ViolinSolo(volume: 0.75) at bars(5..8)
  play ChipArp(volume: 0.7) at bars(9..12)
  play BraindanceKeys(volume: 0.8) at bars(9..16)
  play PowerWall(volume: 0.8) at bars(12..12)

  play RainField at bars(13..16)
  play BirdSong at bars(13..16)
}
