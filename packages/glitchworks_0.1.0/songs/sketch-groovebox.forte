// Sketch: groovebox — audition piece, NOT an album track. Third cut. The
// first two died the same death: a snare that never changed. This one is
// built on drumcolor — the snare is SEVEN produced colors on a rotating
// backbeat, the kick is a stack in three weights with fragment fills, and
// SlicerBeat re-decides its slice order every bar. On top: the expanded
// palette — an octaver house bass handing over to a fuzz-wah pedalboard,
// a piano loop that never existed, a violin answering, chip bleeps,
// braindance warmth, rain and birds outside the window at the end.
//   bars 1-4   drumcolor groove + octaver bass + piano loop + street air
//   bars 5-8   slicer joins, wah bass takes over, violin answers
//   bars 9-12  full: chip arp, braindance pad, power wall on the turn
//   bars 13-16 strip back to rain, birds, sub and the seven snares
import { SnareRainbow, KickStack, SlicerBeat } from "../wrapped/drumcolor.forte"
import { OctaveHouse, FuzzWahBass, SubDeep } from "../wrapped/bassworks.forte"
import { PianoLoop, ViolinSolo, ChipArp, BraindanceKeys } from "../wrapped/melodyworks.forte"
import { RainField, BirdSong, StreetAir, PowerWall, TapeAir } from "../wrapped/textureworks.forte"

song "Sketch Groovebox" {
  desc "Audition sketch: seven snare colors on a rotating backbeat, stacked kicks, a self-re-slicing beat, octaver-to-wah bass, piano/violin/chip/braindance on top, rain and birds at the end. Not an album track."
  artist "Forte Essentials"
  tempo 90bpm
  swing 0.56
  master 1.1
  key C minor

  play TapeAir at bars(1..12)
  play StreetAir at bars(1..4)

  play SnareRainbow at bars(1..16)
  play KickStack at bars(1..12)
  play SlicerBeat at bars(5..12)

  play OctaveHouse at bars(1..4)
  play FuzzWahBass at bars(5..8)
  play SubDeep at bars(9..16)

  play PianoLoop at bars(1..8)
  play ViolinSolo at bars(5..8)
  play ChipArp at bars(9..12)
  play BraindanceKeys at bars(9..16)
  play PowerWall at bars(12..12)

  play RainField at bars(13..16)
  play BirdSong at bars(13..16)
}
