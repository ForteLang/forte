// Checksum â€” the densest cut and the album's peak: every rhythm layer from
// the record verified at once. Euclid against polymeter against ratchets,
// stutter fills every 16, the gate chopping the whole hiss bed. Genre
// signature: peak-time minimal â€” density from arithmetic, not from chords.
import { Click, Tick, Blip } from "../instruments/clicks.forte"
import { ThumpKick, DeepSub, PressureBass } from "../instruments/lowend.forte"
import { Hiss, Dust, ColdTone } from "../instruments/textures.forte"

song "Checksum" {
  desc "Every rhythm layer verified at once: euclid vs polymeter vs ratchets. 128bpm peak-time glitch."
  artist "Forte Essentials"
  tempo 128bpm
  master 3.5
  key G minor

  section intro = bars(1..8)
  section a     = bars(9..40)
  section gap   = bars(41..44)
  section b     = bars(45..76)
  section outro = bars(77..88)

  track Kick {
    instrument ThumpKick(decay: 0.4, drop: 0.32)
    insert comp(thresh: 0.48, ratio: 0.5, attack: 0.008, release: 0.09, makeup: 0.18)
    volume 0.95
    play beat`x--- x--- x--- x---` at a
    play beat`x--- x--- x--- x---` at b
    play beat`x--- x--- x--- x-x-` at bars(73..76)
  }
  track Sub {
    instrument DeepSub(decay: 0.75)
    volume 0.72
    play notes`G1:3.5 _:0.5` at a
    play notes`G1:3 Bb1:1` at b
  }
  track Bass {
    instrument PressureBass(cutoff: 0.34)
    insert crush(bits: 0.35, rate: 0.2, mix: 0.5)
    volume 0.62
    play notes`G2:0.25 _:0.25 G2:0.25 _:0.75 Bb2:0.25 _:0.25 G2:0.25 _:1.75` at a
    play notes`G2:0.25 _:0.25 G2:0.25 _:0.75 D3:0.25 _:0.25 G2:0.25 _:1.75` at b
    automate cutoff from 0.3 to 0.6 over bars(61..76)
  }
  track ClicksA {
    instrument Click(snap: 0.9)
    volume 0.55
    play beat`euclid(7, 16)` at a
    play beat`euclid(9, 16)` at b
  }
  track ClicksB {
    instrument Tick(tone: 0.5)
    volume 0.5
    play cycle(beat`x . -`, span: 0.75) at a
    play cycle(beat`x . - .`, span: 1.0) at b
  }
  track Ratchets {
    instrument Dust(color: 0.7)
    volume 0.48
    play beat`- x*2 - - - x*3 - -` at a
    play humanize(beat`- x*2 - x - x*3 - x*2`, time: 0.015, seed: 55) at b
  }
  track Blips {
    instrument Blip(decay: 0.05)
    insert delay(time: 0.22, fdbk: 0.4, mix: 0.3)
    insert stutter(beats: 0.125, mix: 0.0)
    volume 0.5
    play notes`D5:0.25 _:0.75 G4:0.25 _:0.75 Bb4:0.25 _:1.75` at a
    play notes`D5:0.25 _:0.25 F5:0.25 _:0.25 G4:0.25 _:0.75 Bb4:0.25 _:1.75` at b
    automate stutter.mix from 0.0 to 0.9 over bars(39..40)
    automate stutter.mix from 0.0 to 0.0 over bars(41..41)
    automate stutter.mix from 0.0 to 0.9 over bars(75..76)
    automate stutter.mix from 0.0 to 0.0 over bars(77..77)
  }
  track Hiss {
    instrument Hiss(body: 0.5)
    insert gate(depth: 0.9, beats: 0.125, duty: 0.5)
    volume 0.32
    play notes`G3:32` at bars(25..32)
    play notes`G3:32` at bars(53..60)
    play notes`G3:32` at bars(69..76)
  }
  track Tone {
    instrument ColdTone(beatrate: 0.2)
    volume 0.42
    play notes`G4:8 _:8` at intro
    play notes`G4:4 D5:4 G4:4 Bb4:4` at gap
    play notes`G4:16 _:8` at outro
    automate volume from 0.42 to 0.0 over bars(85..88)
  }
}
