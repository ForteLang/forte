// Bitmask — two click patterns AND-ed against each other: euclid 5/16 vs a
// 3-beat cycle, agreeing only where the mask allows. Heavier crush, darker
// key. Genre signature: minimal techno's hypnotic repetition, glitch's
// arithmetic percussion.
import { Click, Tick, Blip } from "../instruments/clicks.forte"
import { ThumpKick, DeepSub, PressureBass } from "../instruments/lowend.forte"
import { Hiss, Dust, ColdTone } from "../instruments/textures.forte"

song "Bitmask" {
  desc "Two click patterns AND-ed together: euclid vs a 3-beat cycle, crushed dark. 122bpm glitch minimal."
  artist "Forte Essentials"
  tempo 122bpm
  master 3.6
  key F minor

  section intro = bars(1..8)
  section a     = bars(9..32)
  section b     = bars(33..56)
  section c     = bars(57..72)
  section outro = bars(73..84)

  track Kick {
    instrument ThumpKick(decay: 0.5, drop: 0.25)
    insert comp(thresh: 0.48, ratio: 0.5, attack: 0.01, release: 0.11, makeup: 0.15)
    volume 0.95
    play beat`x--- x--- x--- x---` at bars(9..72)
    play beat`x--- --x- x--- ----` at bars(73..80)
  }
  track Sub {
    instrument DeepSub(decay: 0.85)
    volume 0.72
    play notes`F1:4` at a
    play notes`F1:3 Ab1:1` at b
    play notes`F1:4` at c
  }
  track Bass {
    instrument PressureBass(cutoff: 0.28)
    insert crush(bits: 0.45, rate: 0.25, mix: 0.55)
    volume 0.6
    play notes`F2:0.5 _:0.5 F2:0.25 _:0.75 Ab2:0.25 _:0.25 F2:0.25 _:1.25` at b
    play notes`F2:0.5 _:0.5 F2:0.25 _:0.75 C3:0.25 _:0.25 F2:0.25 _:1.25` at c
    automate crush.mix from 0.55 to 0.85 over bars(65..72)
  }
  track MaskA {
    instrument Click(snap: 0.9)
    volume 0.55
    play beat`euclid(5, 16)` at bars(9..72)
  }
  track MaskB {
    instrument Tick(tone: 0.55)
    volume 0.5
    play cycle(beat`x . -`, span: 0.75) at bars(17..72)
  }
  track Blips {
    instrument Blip(decay: 0.05)
    insert delay(time: 0.3, fdbk: 0.45, mix: 0.3)
    insert stutter(beats: 0.125, mix: 0.0)
    volume 0.48
    play notes`C5:0.25 _:1.75 Ab4:0.25 _:1.75` at b
    play notes`F5:0.25 _:0.75 C5:0.25 _:0.75 Ab4:0.25 _:1.25` at c
    automate stutter.mix from 0.0 to 0.9 over bars(55..56)
    automate stutter.mix from 0.0 to 0.0 over bars(57..57)
  }
  track Tone {
    instrument ColdTone(beatrate: 0.25)
    volume 0.42
    play notes`F4:8 _:8` at intro
    play notes`F4:8 C5:8` at c
    play notes`F4:16 _:8` at outro
    automate volume from 0.42 to 0.0 over bars(81..84)
  }
  track Dust {
    instrument Dust(color: 0.65)
    volume 0.45
    play humanize(beat`x - - x*2 - - x -`, time: 0.02, seed: 5) at bars(25..72)
  }
  track Hiss {
    instrument Hiss(body: 0.4)
    insert gate(depth: 0.9, beats: 0.125, duty: 0.5)
    volume 0.28
    play notes`F3:32` at bars(41..48)
    play notes`F3:32` at bars(57..64)
  }
}
