// Sketch: breaks from wrapped drums — audition piece, NOT an album track.
// A drum phrase is bounced INSIDE this song, sliced into 8, and re-cut as
// a breakbeat: the Amen workflow natively. Reese wire underneath.
import { CrackTight, KnockDeep } from "../wrapped/drums.forte"
import { ReeseWire } from "../wrapped/bassx.forte"
import { SnareBrush, HatClosed } from "../../essentials_0.6.0/instruments/drums.forte"

song "Sketch Breaks" {
  desc "Audition sketch: a phrase bounced and re-cut as a break, reese wire under. Not an album track."
  artist "Forte Essentials"
  tempo 160bpm
  master 2.4
  key E minor

  // a tiny in-song break source: brush snare rolls bounced to audio
  sample BreakSrc = bounce(SnareBrush(), note: D2, beats: 2)

  block Break {
    track Cut {
      instrument sampler(sample: BreakSrc, slices: 8, sustain: 0.0, decay: 0.3)
      insert transient(attack: 0.8, sustain: 0.35)
      insert parcomp(amount: 0.55, drive: 0.6, color: 0.45)
      insert saturate(mode: "tape", drive: 0.4)
      volume 0.75
      // slice order IS the breakbeat
      play notes`D2:0.25 F2:0.25 D#2:0.25 D2:0.25 G2:0.25 D2:0.25 A2:0.25 F2:0.25` at bars(1..14)
      play notes`D2:0.125 D2:0.125 F2:0.25 A2:0.25 G2:0.25 D#2:0.25 F2:0.25 D2:0.5` at bars(15..16)
    }
  }
  block Kick : KnockDeep {
    track Hit { play beat`x--- --x- ---- x---` at bars(1..16) }
  }
  block Snare : CrackTight {
    track Hit { play beat`---- x--- ---- x---` at bars(3..16) }
  }
  block Wire : ReeseWire {
    track Wire {
      play notes`E1~:2 E1~:1 G1~:0.5 E1:0.5` at bars(5..16)
    }
  }
  block Tops {
    track Hat {
      instrument HatClosed
      insert crush(bits: 0.4, rate: 0.25, mix: 0.4)
      volume 0.5
      play beat`x-x- x-xx x-x- xx-x` at bars(9..16)
    }
  }

  play Break at bars(1..16)
  play Kick at bars(1..16)
  play Snare at bars(3..16)
  play Wire at bars(5..16)
  play Tops at bars(9..16)
}
