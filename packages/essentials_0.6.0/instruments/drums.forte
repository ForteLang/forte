// std/drums — 10 percussion devices, all built in the device DSL (noise / osc /
// shaper / svf / adsr), so you can fork one and resculpt the sound down to the character.
// Usage: import { Kick808, Snare908 } from "packages/essentials_0.6.0/instruments/drums.forte"

device Kick808 : Instrument {
  param punch = 0.5 in 0.0..1.0
  param decay = 0.45 in 0.05..1.0

  node env  = adsr(a: 0.001, d: decay, s: 0.0, r: 0.12)
  node penv = adsr(a: 0.001, d: 0.06, s: 0.0, r: 0.03)   // pitch drop
  node o    = osc(shape: "sine", mod: gain(in: penv, level: 0.35))
  node sh   = shaper(in: o, drive: punch, mode: "tanh")
  out gain(in: sh, mod: env, level: 1.0)
}

device Kick909 : Instrument {
  param click = 0.4 in 0.0..1.0

  node env  = adsr(a: 0.001, d: 0.3, s: 0.0, r: 0.1)
  node penv = adsr(a: 0.001, d: 0.045, s: 0.0, r: 0.02)
  node body = osc(shape: "sine", mod: gain(in: penv, level: 0.45))
  node cenv = adsr(a: 0.001, d: 0.02, s: 0.0, r: 0.01)   // attack click
  node cl   = gain(in: svf(in: noise(), cutoff: 0.9, reso: 0.1), mod: cenv, level: click)
  node sum  = mix(a: shaper(in: body, drive: 0.45, mode: "tanh"), b: cl)
  out gain(in: sum, mod: env, level: 1.0)
}

device Snare908 : Instrument {
  param tone = 0.72 in 0.0..1.0
  param snap = 0.6 in 0.0..1.0

  node env  = adsr(a: 0.001, d: 0.13, s: 0.0, r: 0.08)
  node nz   = gain(in: svf(in: noise(), cutoff: tone, reso: 0.3), level: snap)
  node bde  = adsr(a: 0.001, d: 0.055, s: 0.0, r: 0.04)
  node body = gain(in: osc(shape: "sine"), mod: bde, level: 0.5)
  out gain(in: mix(a: nz, b: body), mod: env, level: 0.9)
}

device Clap : Instrument {
  param tone = 0.6 in 0.0..1.0

  node env = adsr(a: 0.008, d: 0.16, s: 0.0, r: 0.1)   // the slow attack is what makes it a clap
  node nz  = svf(in: noise(), cutoff: tone, reso: 0.5)
  node fz  = shaper(in: nz, drive: 0.2, mode: "clip")
  out gain(in: fz, mod: env, level: 0.8)
}

device HatClosed : Instrument {
  param bright = 0.95 in 0.5..1.0

  node env = adsr(a: 0.001, d: 0.04, s: 0.0, r: 0.03)
  node nz  = svf(in: noise(), cutoff: bright, reso: 0.2)
  node fz  = shaper(in: nz, drive: 0.25, mode: "clip")
  out gain(in: fz, mod: env, level: 0.6)
}

device HatOpen : Instrument {
  param decay = 0.28 in 0.05..1.0

  node env = adsr(a: 0.001, d: decay, s: 0.0, r: 0.15)
  node nz  = svf(in: noise(), cutoff: 0.95, reso: 0.2)
  node fz  = shaper(in: nz, drive: 0.2, mode: "clip")
  out gain(in: fz, mod: env, level: 0.55)
}

device Tom : Instrument {
  param fall = 0.3 in 0.0..1.0    // how far the pitch drops

  node env  = adsr(a: 0.001, d: 0.28, s: 0.0, r: 0.15)
  node penv = adsr(a: 0.001, d: 0.09, s: 0.0, r: 0.05)
  node o    = osc(shape: "sine", mod: gain(in: penv, level: fall))
  out gain(in: shaper(in: o, drive: 0.3, mode: "tanh"), mod: env, level: 0.9)
}

device Rim : Instrument {
  node env = adsr(a: 0.001, d: 0.025, s: 0.0, r: 0.02)
  node o   = shaper(in: osc(shape: "square"), drive: 0.5, mode: "clip")
  out gain(in: o, mod: env, level: 0.5)
}

device Shaker : Instrument {
  param soft = 0.35 in 0.0..1.0   // roundness of the attack

  node env = adsr(a: soft, d: 0.07, s: 0.0, r: 0.05)
  node nz  = svf(in: noise(), cutoff: 0.98, reso: 0.1)
  out gain(in: nz, mod: env, level: 0.45)
}

device Cowbell : Instrument {
  param drive = 0.5 in 0.0..1.0

  node env = adsr(a: 0.001, d: 0.16, s: 0.0, r: 0.1)
  // Two square waves stacked at a non-integer ratio (1 : 1.48) — the skeleton of the 808 cowbell
  node hi  = osc(freq: mix(a: note.freq, b: gain(in: note.freq, level: 0.48)), shape: "square")
  node lo  = osc(shape: "square")
  node sum = shaper(in: mix(a: lo, b: gain(in: hi, level: 0.8)), drive: drive, mode: "clip")
  out gain(in: sum, mod: env, level: 0.5)
}

// ---- classic kit extensions (12 devices): acoustic-leaning voices plus cymbals ----

device Kick606 : Instrument {
  param decay = 0.22 in 0.05..0.6

  node env  = adsr(a: 0.001, d: decay, s: 0.0, r: 0.06)
  node penv = adsr(a: 0.001, d: 0.03, s: 0.0, r: 0.02)
  node o    = osc(shape: "sine", mod: gain(in: penv, level: 0.28))
  out gain(in: o, mod: env, level: 0.95)
}

device KickSub : Instrument {
  param weight = 0.7 in 0.0..1.0

  node env  = adsr(a: 0.002, d: 0.6, s: 0.0, r: 0.2)
  node penv = adsr(a: 0.001, d: 0.08, s: 0.0, r: 0.04)
  node o    = osc(freq: gain(in: note.freq, level: 0.5), shape: "sine",
                  mod: gain(in: penv, level: 0.3))
  node sh   = shaper(in: o, drive: weight, mode: "tanh")
  out gain(in: sh, mod: env, level: 1.0)
}

device SnareTight : Instrument {
  param snap = 0.7 in 0.0..1.0

  node env  = adsr(a: 0.001, d: 0.08, s: 0.0, r: 0.05)
  node nz   = gain(in: svf(in: noise(), cutoff: 0.85, reso: 0.4), level: snap)
  node bde  = adsr(a: 0.001, d: 0.04, s: 0.0, r: 0.02)
  node body = gain(in: osc(shape: "tri"), mod: bde, level: 0.45)
  out gain(in: mix(a: nz, b: body), mod: env, level: 0.9)
}

device SnareBrush : Instrument {
  param soft = 0.5 in 0.0..1.0

  node env = adsr(a: 0.02, d: 0.18, s: 0.0, r: 0.12)   // the soft attack is the brush swish
  node nz  = svf(in: noise(), cutoff: 0.6, reso: 0.25)
  node sh  = shaper(in: nz, drive: soft, mode: "tanh")
  out gain(in: sh, mod: env, level: 0.65)
}

device HatPedal : Instrument {
  node env = adsr(a: 0.001, d: 0.025, s: 0.0, r: 0.02)
  node nz  = svf(in: noise(), cutoff: 0.8, reso: 0.3)
  out gain(in: nz, mod: env, level: 0.45)
}

device Ride : Instrument {
  param wash = 0.4 in 0.0..1.0

  node env = adsr(a: 0.001, d: 0.7, s: 0.1, r: 0.9)
  node nz  = svf(in: noise(), cutoff: 0.92, reso: 0.15)
  node pin = gain(in: osc(freq: mix(a: note.freq, b: mix(a: note.freq, b: note.freq)),
                          shape: "tri"), level: 0.2)
  node sum = mix(a: gain(in: nz, level: wash), b: pin)
  out gain(in: sum, mod: env, level: 0.5)
}

device RideBell : Instrument {
  node env = adsr(a: 0.001, d: 0.4, s: 0.0, r: 0.5)
  node f27 = mix(a: mix(a: note.freq, b: note.freq), b: gain(in: note.freq, level: 0.7))
  node o   = osc(freq: f27, shape: "square")
  node f   = svf(in: o, cutoff: 0.9, reso: 0.3)
  out gain(in: f, mod: env, level: 0.5)
}

device Crash : Instrument {
  param decay = 0.9 in 0.3..1.0

  node env = adsr(a: 0.001, d: decay, s: 0.0, r: 1.0)
  node nz  = svf(in: noise(), cutoff: 0.95, reso: 0.1)
  node fz  = shaper(in: nz, drive: 0.3, mode: "clip")
  out gain(in: fz, mod: env, level: 0.55)
}

device Splash : Instrument {
  node env = adsr(a: 0.001, d: 0.35, s: 0.0, r: 0.4)
  node nz  = svf(in: noise(), cutoff: 0.97, reso: 0.2)
  out gain(in: nz, mod: env, level: 0.5)
}

device TomFloor : Instrument {
  param decay = 0.4 in 0.1..0.8

  node env  = adsr(a: 0.001, d: decay, s: 0.0, r: 0.15)
  node penv = adsr(a: 0.001, d: 0.09, s: 0.0, r: 0.05)
  node o    = osc(freq: gain(in: note.freq, level: 0.6), shape: "sine",
                  mod: gain(in: penv, level: 0.25))
  node nz   = gain(in: svf(in: noise(), cutoff: 0.4, reso: 0.2), level: 0.12)
  out gain(in: mix(a: o, b: nz), mod: env, level: 0.85)
}

device Snap : Instrument {
  node env = adsr(a: 0.001, d: 0.05, s: 0.0, r: 0.04)
  node nz  = svf(in: noise(), cutoff: 0.55, reso: 0.75)   // high resonance hits the finger-snap band
  out gain(in: nz, mod: env, level: 0.8)
}

device Stick : Instrument {
  node env = adsr(a: 0.001, d: 0.03, s: 0.0, r: 0.02)
  node o   = osc(freq: mix(a: mix(a: note.freq, b: note.freq), b: note.freq), shape: "tri")
  node nz  = gain(in: svf(in: noise(), cutoff: 0.7, reso: 0.5), level: 0.5)
  out gain(in: mix(a: o, b: nz), mod: env, level: 0.7)
}
