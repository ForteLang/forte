// std/tb303 — acid bass. The real 303 is inseparable from its sequencer:
// it has glide (mono legato), a notes tie `C2~:0.5` slides between steps,
// and a `C2!:0.5` accent opens the filter deeper via velocity.
// Usage: import { Bass303 } from "packages/essentials_0.6.0/instruments/tb303.forte"

device Bass303 : Instrument {
  param cutoff = 0.32 in 0.0..1.0
  param reso   = 0.78 in 0.0..0.95
  param envmod = 0.55 in 0.0..1.0
  param decay  = 0.24 in 0.03..0.8
  param glide  = 0.06 in 0.0..0.3   // reserved name: mono/legato portamento time in seconds

  node fenv = adsr(a: 0.001, d: decay, s: 0.0, r: 0.03)
  node acc  = gain(in: fenv, mod: note.vel, level: 0.35)   // accent circuit:
  node depth = mix(a: gain(in: fenv, level: envmod), b: acc) // hit harder, get deeper env
  node o    = osc(shape: "saw")
  node f    = svf(in: o, cutoff: cutoff, reso: reso, mod: depth)
  node vca  = adsr(a: 0.002, d: 0.5, s: 0.25, r: 0.04)
  node sh   = shaper(in: f, drive: 0.18, mode: "tanh")
  out gain(in: sh, mod: vca, level: 0.85)
}

device Square303 : Instrument {
  param cutoff = 0.3 in 0.0..1.0
  param reso   = 0.75 in 0.0..0.95
  param envmod = 0.5 in 0.0..1.0
  param decay  = 0.22 in 0.03..0.8
  param glide  = 0.06 in 0.0..0.3

  node fenv = adsr(a: 0.001, d: decay, s: 0.0, r: 0.03)
  node acc  = gain(in: fenv, mod: note.vel, level: 0.35)
  node depth = mix(a: gain(in: fenv, level: envmod), b: acc)
  node o    = osc(shape: "square")
  node f    = svf(in: o, cutoff: cutoff, reso: reso, mod: depth)
  node vca  = adsr(a: 0.002, d: 0.5, s: 0.25, r: 0.04)
  out gain(in: f, mod: vca, level: 0.8)
}
