// Downtempo (85bpm) — hazy FifthStack stabs over a laid-back break.
// The temperature of dusk.
import { Kick808, SnareBrush, HatClosed } from "../instruments/drums.forte"
import { Tambourine } from "../instruments/percussion.forte"
import { SubBass } from "../instruments/bass.forte"
import { FifthStack } from "../instruments/synths.forte"

block DowntempoDuskDrums {
  let kick = beat`x--- --x- ---- x---`
  let hat  = beat`x-x- x-xx x-x- x-x-`

  track Kick { instrument Kick808(punch: 0.45, decay: 0.5) volume 0.85 play kick at bars(1..8) }
  track Hat  { instrument HatClosed(bright: 0.75) volume 0.35 pan 0.2 play hat at bars(3..8) }
  track Tamb { instrument Tambourine(jingle: 0.7) volume 0.25 pan -0.25 play beat`---- ---- --x- ----` at bars(5..8) }
}

block DowntempoDuskBass {
  key G minor
  let dusk = prog`Gm7 | Ebmaj7 | Bbmaj7 | F7`

  track Bass {
    instrument SubBass()
    volume 0.8
    play bass(dusk, rate: 0.5) at bars(1..8)
  }
}

// Brush snare and stab share the Haze reverb return, so they live together.
block DowntempoDuskSpace {
  key G minor
  let snare = beat`---- x--- ---- x---`
  let dusk  = prog`Gm7 | Ebmaj7 | Bbmaj7 | F7`

  return Haze {
    insert reverb(size: 0.7, decay: 0.55, mix: 1.0)
    volume 0.7
  }

  track Snare { instrument SnareBrush(soft: 0.5) volume 0.6 send Haze 0.25 play snare at bars(1..8) }

  track Stab {
    instrument FifthStack()
    send Haze 0.45
    volume 0.45
    play chords(dusk) at bars(1..8)
  }
}

block DowntempoDusk {
  tempo 85bpm
  meter 4/4
  key G minor

  play DowntempoDuskDrums at bars(1..8)
  play DowntempoDuskBass at bars(1..8)
  play DowntempoDuskSpace at bars(1..8)
}
