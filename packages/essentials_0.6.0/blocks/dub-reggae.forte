// Dub (70bpm) — one drop + skank dropped in and out of the delay send:
// that is dub. DubBass fills the room with a single note.
import { BD808, RS808, CH808, OH808 } from "../instruments/tr808.forte"
import { DubBass } from "../instruments/bass.forte"
import { Organ, Clav } from "../instruments/keys.forte"

block DubReggaeDrums {
  let drop = beat`---- ---- x--- ----`
  let hat  = beat`x-x. x-x- x-x. x-xx`

  track Drop { instrument BD808(tone: 0.3, decay: 0.7) volume 0.9 play drop at bars(1..8) }
  track Hat  { instrument CH808() volume 0.35 pan 0.2 play hat at bars(1..8) }
  track OH   { instrument OH808(decay: 0.3) volume 0.25 play beat`---- --x- ---- ----` at bars(5..8) }
}

block DubReggaeBass {
  key G minor

  track Bass {
    instrument DubBass(depth: 0.9)
    volume 0.95
    play notes`G1:0.75 _:0.25 _:0.5 Bb1:0.5 _:1 G1:0.5 D2:0.5 G1:0.75 _:0.25 F1:0.5 G1:0.5 _:2` at bars(1..8)
  }
}

// Everything that feeds the Tape delay and Spring reverb returns lives here.
block DubReggaeSpace {
  key G minor
  let drop  = beat`---- ---- x--- ----`
  let skank = beat`--x- --x- --x- --x-`
  let bubble = beat`-x-- -x-- -x-- -x--`
  let roots  = prog`Gm | Gm | Eb | F`

  return Tape {
    insert delay(time: 0.428, fdbk: 0.55, mix: 1.0)
    volume 0.55
  }
  return Spring {
    insert reverb(size: 0.75, decay: 0.6, mix: 1.0)
    volume 0.5
  }

  track Rim { instrument RS808() send Spring 0.35 volume 0.6 play drop at bars(1..8) }

  track Skank {
    instrument Organ(drawbar: 0.35)
    send Tape 0.45
    volume 0.4
    play chords(roots) at bars(1..8)
  }

  track Bubble {
    instrument Clav(mute: 0.7)
    send Tape 0.3
    volume 0.3
    pan -0.2
    play arp(roots, rate: 0.25, style: "up") at bars(3..6)
  }
}

block DubReggae {
  tempo 70bpm
  meter 4/4
  key G minor

  play DubReggaeDrums at bars(1..8)
  play DubReggaeBass at bars(1..8)
  play DubReggaeSpace at bars(1..8)
}
