// DnB Roller (174bpm) — 2-bar break + Reese bass.
// Ghost hats fill the gaps between kick and snare.
import { Kick909, SnareTight, HatClosed, HatOpen } from "../instruments/drums.forte"
import { ReeseBass } from "../instruments/bass.forte"
import { DarkPad } from "../instruments/pads.forte"

block DnbRollerDrums {
  let kick = beat`x--- ---- --x- ---- x--- ---- ---- x---`
  let hat  = beat`x-xx x-xx xxx- x-xx x-xx x-xx x-xx xx-x`

  track Kick { instrument Kick909(click: 0.6) volume 0.9 play kick at bars(1..8) }
  track Hat  { instrument HatClosed(bright: 0.95) volume 0.35 pan 0.2 play hat at bars(1..8) }
}

block DnbRollerBass {
  key F minor
  let dark = prog`Fm | Fm | Db | Eb`

  track Reese {
    instrument ReeseBass()
    insert drive(drive: 0.25)
    volume 0.75
    play bass(dark, rate: 1) at bars(1..8)
  }
}

// Snare and pad share the Void reverb return, so they live together.
block DnbRollerSpace {
  key F minor
  let snare = beat`---- X--- ---- X--- ---- X--- --x- X---`
  let dark  = prog`Fm | Fm | Db | Eb`

  return Void {
    insert reverb(size: 0.7, decay: 0.5, mix: 1.0)
    volume 0.6
  }

  track Snare { instrument SnareTight(snap: 0.8) volume 0.75 send Void 0.15 play snare at bars(1..8) }

  track Pad {
    instrument DarkPad()
    send Void 0.45
    volume 0.4
    play chords(dark) at bars(5..8)
  }
}

block DnbRoller {
  tempo 174bpm
  meter 4/4
  key F minor

  play DnbRollerDrums at bars(1..8)
  play DnbRollerBass at bars(1..8)
  play DnbRollerSpace at bars(1..8)
}
