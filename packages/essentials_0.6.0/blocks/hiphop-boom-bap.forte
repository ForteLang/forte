// Boom Bap (92bpm) — off-grid kick and a tight snare.
// The m7 EPiano loop brings the 90s dust.
import { Kick808, SnareTight, HatClosed, HatOpen } from "../instruments/drums.forte"
import { UprightBass } from "../instruments/bass.forte"
import { EPiano } from "../instruments/keys.forte"

block HiphopBoomBapDrums {
  let kick  = beat`x--- --x- -x-- ----`
  let snare = beat`---- X--- ---- X---`
  let hat   = beat`x-x- x-x- x-x- x-xx`
  let open  = beat`---- ---- ---- --x-`

  track Kick  { instrument Kick808(punch: 0.55, decay: 0.5) volume 0.9 play kick at bars(1..8) }
  track Snare { instrument SnareTight(snap: 0.7) volume 0.75 play snare at bars(1..8) }
  track Hat   { instrument HatClosed(bright: 0.8) volume 0.45 pan 0.15 play hat at bars(1..8) }
  track Open  { instrument HatOpen(decay: 0.25) volume 0.35 play open at bars(5..8) }
}

block HiphopBoomBapBass {
  key D minor
  let loop = prog`Dm7 | Gm7 | Bbmaj7 | A7`

  track Bass {
    instrument UprightBass()
    volume 0.8
    play bass(loop, rate: 0.5) at bars(1..8)
  }
}

block HiphopBoomBapKeys {
  key D minor
  let loop = prog`Dm7 | Gm7 | Bbmaj7 | A7`

  track Keys {
    instrument EPiano(tine: 0.25)
    insert reverb(size: 0.4, decay: 0.35, mix: 0.15)
    volume 0.55
    play chords(loop) at bars(1..8)
  }
}

block HiphopBoomBap {
  tempo 92bpm
  meter 4/4
  key D minor

  play HiphopBoomBapDrums at bars(1..8)
  play HiphopBoomBapBass at bars(1..8)
  play HiphopBoomBapKeys at bars(1..8)
}
