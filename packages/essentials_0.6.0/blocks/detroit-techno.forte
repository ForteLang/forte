// Pattern: Detroit Techno (128bpm) — 909 ride and the melancholy of strings.
// Hi-tech soul: human harmony riding on top of a machine beat.
import { BD909, CH909, OH909, RC909, CP909 } from "../instruments/tr909.forte"
import { SH101Bass } from "../instruments/sh101.forte"
import { P5Strings } from "../instruments/prophet5.forte"

block DetroitTechnoDrums {
  let four = beat`X--- x--- x--- x---`
  let chh  = beat`x.x. x.x. x.x. x.xX`
  let ohh  = beat`--x- --x- --x- --x-`
  let ride = beat`x--- x-x- x--- x-x-`

  track BD   { instrument BD909(attack: 0.55, decay: 0.4) insert comp(thresh: 0.4, ratio: 0.6) volume 0.95 play four at bars(1..8) }
  track CH   { instrument CH909() volume 0.4 pan 0.15 play chh at bars(1..8) }
  track OH   { instrument OH909(decay: 0.35) volume 0.45 play ohh at bars(1..8) }
  track Ride { instrument RC909(ping: 0.4) volume 0.3 pan -0.25 play ride at bars(5..8) }
}

block DetroitTechnoBass {
  key F minor
  track Bass {
    instrument SH101Bass(cutoff: 0.4)
    insert pump(amount: 0.45)
    volume 0.8
    play notes`F1:0.25 _:0.25 F1:0.25 Ab1:0.25 _:0.25 F1:0.25 C2:0.25 _:0.25 F1:0.25 _:0.25 Eb2:0.25 F1:0.25 _:0.5 Db2:0.25 C2:0.25` at bars(1..8)
  }
}

block DetroitTechnoStrings {
  key F minor
  let clap = beat`---- x--- ---- x---`
  let soul = prog`Fm7 | Dbmaj7 | Ebm7 | Fm7`

  return Space {
    insert reverb(size: 0.7, decay: 0.5, mix: 1.0)
    volume 0.7
  }

  track CP { instrument CP909(room: 0.5) send Space 0.3 volume 0.5 play clap at bars(3..8) }

  track Strings {
    instrument P5Strings()
    insert chorus(rate: 0.25, depth: 0.5, mix: 0.45)
    insert pump(amount: 0.5)
    send Space 0.45
    volume 0.5
    play chords(soul) at bars(1..8)
  }
}

block DetroitTechno {
  tempo 128bpm
  swing 0.52
  meter 4/4
  key F minor

  play DetroitTechnoDrums at bars(1..8)
  play DetroitTechnoBass at bars(1..8)
  play DetroitTechnoStrings at bars(1..8)
}
