// Classic House (124bpm) — four-on-the-floor + offbeat open hats +
// piano stabs. The whole backbone of house lives in these 8 bars.
import { Kick909, Clap, HatClosed, HatOpen } from "../instruments/drums.forte"
import { OctaveBass } from "../instruments/bass.forte"
import { EPiano } from "../instruments/keys.forte"

block HouseClassicDrums {
  let four = beat`x--- x--- x--- x---`
  let hats = beat`--x- --x- --x- --x-`
  let ride = beat`x-xx x-xx x-xx x-xX`

  track Kick { instrument Kick909(click: 0.5)    volume 0.9  play four at bars(1..8) }
  track Open { instrument HatOpen(decay: 0.25)   volume 0.5  pan 0.15 play hats at bars(1..8) }
  track Hats { instrument HatClosed(bright: 0.9) volume 0.35 pan -0.1 play ride at bars(3..8) }
}

block HouseClassicBass {
  key A minor
  let jam = prog`Am7 | F | C | G`

  track Bass {
    instrument OctaveBass(blend: 0.55)
    volume 0.75
    play bass(jam, rate: 0.5) at bars(1..8)
  }
}

// Clap and piano share the Room reverb return, so they live together.
block HouseClassicSpace {
  key A minor
  let clap = beat`---- x--- ---- x---`
  let jam  = prog`Am7 | F | C | G`

  return Room {
    insert reverb(size: 0.5, decay: 0.4, mix: 1.0)
    volume 0.7
  }

  track Clap { instrument Clap(tone: 0.6) volume 0.65 send Room 0.2 play clap at bars(1..8) }

  track Piano {
    instrument EPiano(tine: 0.45)
    insert drive(drive: 0.15)
    send Room 0.35
    volume 0.6
    play chords(jam) at bars(1..8)
  }
}

block HouseClassic {
  tempo 124bpm
  meter 4/4
  key A minor

  play HouseClassicDrums at bars(1..8)
  play HouseClassicBass at bars(1..8)
  play HouseClassicSpace at bars(1..8)
}
