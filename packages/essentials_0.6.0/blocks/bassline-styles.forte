// Pattern: Bassline Styles (110bpm) — four bassline archetypes,
// 8 bars each: octave / walking / syncopated / pedal.
import { OctaveBass, UprightBass, PickBass } from "../instruments/bass.forte"
import { SH101Bass } from "../instruments/sh101.forte"
import { Kick909, HatClosed, SnareTight } from "../instruments/drums.forte"

block BasslineStylesDrums {
  let four = beat`x--- x--- x--- x---`
  let back = beat`---- x--- ---- x---`
  let hat  = beat`x-x- x-x- x-x- x-x-`

  track Kick  { instrument Kick909(click: 0.5) volume 0.85 play four at bars(1..32) }
  track Snare { instrument SnareTight(snap: 0.7) volume 0.6 play back at bars(1..32) }
  track Hat   { instrument HatClosed(bright: 0.85) volume 0.35 pan 0.15 play hat at bars(1..32) }
}

block BasslineStylesBass {
  key A minor

  section octave  = bars(1..8)
  section walking = bars(9..16)
  section syncop  = bars(17..24)
  section pedal   = bars(25..32)

  let tour = prog`Am7 | Dm7 | G7 | Cmaj7`

  track Octave {
    instrument OctaveBass(blend: 0.6)
    volume 0.8
    play arp(tour, rate: 0.25, style: "up") at octave
  }
  track Walking {
    instrument UprightBass()
    volume 0.8
    play bass(tour, rate: 1) at walking
  }
  track Syncop {
    instrument PickBass()
    volume 0.8
    play notes`A1:0.5 _:0.25 A1:0.25 _:0.5 C2:0.25 D2:0.25 _:0.5 D2:0.5 _:0.25 F2:0.25 D2:0.5 G1:0.5 _:0.25 G1:0.25 B1:0.5 C2:0.5 _:0.5 E2:0.25 G2~:0.75` at syncop
  }
  track Pedal {
    instrument SH101Bass(cutoff: 0.4)
    volume 0.8
    play notes`A1:0.25 A1:0.25 A1:0.25 A1:0.25 A1:0.25 A1:0.25 A2:0.25 A1:0.25` at pedal
  }
}

block BasslineStyles {
  tempo 110bpm
  meter 4/4
  key A minor

  play BasslineStylesDrums at bars(1..32)
  play BasslineStylesBass at bars(1..32)
}
