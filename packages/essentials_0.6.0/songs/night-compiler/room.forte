// Night Compiler — room parts.
import { HollowPad } from "../../instruments/pads.forte"
import { GlideLead } from "../../instruments/leads.forte"

// The pad that is actually the room.
block Room {
  key F minor
  track Pad {
    instrument HollowPad()
    insert eq(low: 0.35, mid: 0.5, high: 0.52)
    insert width(amount: 0.9)
    insert reverb(size: 0.9, decay: 0.8, mix: 0.4)
    insert pump(amount: 0.3, beats: 1)
    volume 0.42
    pan -0.05
    play notes`[F2 C3 G#3 D#4]:16 [C#2 G#2 F3 C4]:16` at bars(1..8)
  }
}

// One voice, very late: a glide lead that hums four bars and leaves.
block Hum {
  key F minor
  track Lead {
    instrument GlideLead()
    insert eq(low: 0.25, mid: 0.52, high: 0.58)
    insert delay(time: 0.469, fdbk: 0.45, mix: 0.35)
    insert reverb(size: 0.7, decay: 0.6, mix: 0.25)
    volume 0.45
    pan 0.1
    play notes`_:2 C4~:1.5 D#4~:1 C4~:2 G#3~:1.5 F3:4 _:4` at bars(1..4)
  }
}
