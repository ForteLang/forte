// Segfault Boogie — leads parts.
import { Wobble, SquareLead } from "../../instruments/leads.forte"

// The talking lead: a wobble that mumbles the hook, then screams it.
block Mumble {
  key E minor
  track Talk {
    instrument Wobble(rate: 0.3)
    insert eq(low: 0.3, mid: 0.55, high: 0.58)
    insert drive(drive: 0.2)
    insert delay(time: 0.375, fdbk: 0.4, mix: 0.28)
    insert width(amount: 0.5)
    volume 0.55
    pan 0.15
    play notes`_:2 E4:0.5 G4:0.5 A4~:0.5 A4:0.5 G4:0.5 E4~:1.5 _:1.5 B4:0.25 A4:0.25 G4:0.5 E4:0.5 D4~:1 E4:2.5 _:1` at bars(1..4)
  }
}

// the scream: same hook, faster wobble, delay feeding back into the jam
block Scream : Mumble {
  track Talk {
    instrument Wobble(rate: 0.5)
    insert drive(drive: 0.32)
    insert delay(time: 0.375, fdbk: 0.5, mix: 0.36)
    volume 0.58
    automate delay.mix from 0.28 to 0.44 over bars(1..12)
  }
}

// The reboot lead for the last act — square, proud, slightly too loud.
block Reboot {
  key E minor
  track Lead {
    instrument SquareLead(drive: 0.45)
    insert eq(low: 0.2, mid: 0.55, high: 0.6)
    insert delay(time: 0.25, fdbk: 0.35, mix: 0.25)
    volume 0.5
    pan -0.1
    play notes`E4:0.5 E4:0.25 G4:0.25 A4:0.5 B4~:1 B4:0.5 A4:0.5 G4:0.5 A4~:0.5 G4:0.5 E4:1.5 _:2` at bars(1..2)
  }
}
