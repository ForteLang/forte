// Whitespace â€” the notes are just delimiters; the music is the space
// between them. Celesta and kalimba scattered over a brushed pulse,
// pads as wide as an empty buffer, a flute that phrases in indents.
// Significant whitespace, 108bpm.
//
// STRUCTURE: `Lattice` nests `Bells` (celesta + glass) and `Grain`
// (kalimba), placed offset inside the block so they interleave without
// ever colliding â€” the variants re-indent the same lattice (`as Lattice`).
import { Kick808, SnareBrush, HatPedal, Shaker, Rim } from "../instruments/drums.forte"
import { HollowBass } from "../instruments/bass.forte"
import { Celesta, Glass, Kalimba } from "../instruments/keys.forte"
import { GlassPad, WarmPad } from "../instruments/pads.forte"
import { FluteLead } from "../instruments/leads.forte"
import { Triangle } from "../instruments/percussion.forte"
import { Downlifter } from "../instruments/fx.forte"

// ---- the lattice: tuned percussion interleaved by nested placement ---------------
block Lattice {
  key C major
  block Bells {
    track Celesta {
      instrument Celesta()
      insert eq(low: 0.15, mid: 0.5, high: 0.58)
      insert delay(time: 0.417, fdbk: 0.42, mix: 0.34)
      insert reverb(size: 0.7, decay: 0.6, mix: 0.26)
      volume 0.42
      pan -0.2
      play notes`G5:0.5 _:1 E5:0.5 _:0.5 D5:0.5 _:1.5 C5:0.5 _:1 G4:0.5 _:1 A4:0.5 _:2 E5:0.5 _:0.75 G5:0.25 A5:0.5 _:1 G5:0.5 _:2` at bars(1..4)
    }
    track Glass {
      instrument Glass(shimmer: 0.45)
      insert eq(low: 0.15, mid: 0.5, high: 0.56)
      insert delay(time: 0.625, fdbk: 0.45, mix: 0.36)
      insert reverb(size: 0.75, decay: 0.65, mix: 0.28)
      volume 0.34
      pan 0.28
      play notes`_:2 C5:0.5 _:2.5 E5:0.5 _:2 D5:0.5 _:3 G4:0.5 _:1.5 A4:0.5 _:2.5` at bars(1..4)
    }
  }
  block Grain {
    track Kalimba {
      instrument Kalimba()
      insert eq(low: 0.2, mid: 0.55, high: 0.56)
      insert delay(time: 0.278, fdbk: 0.35, mix: 0.28)
      volume 0.38
      pan 0.1
      play notes`C4:0.25 _:0.75 E4:0.25 _:0.5 G4:0.25 _:1 A4:0.25 _:0.75 G4:0.25 _:0.5 E4:0.25 _:0.75 D4:0.25 _:1.25 C4:0.25 _:0.5` at bars(1..2)
    }
  }
  play Bells at bars(1..4)
  play Grain at bars(3..4)
}
// two-space indent: only the kalimba grain, bells resting
block LatticeThin : Lattice {
  block Bells {
    track Celesta {
      instrument Celesta()
      insert eq(low: 0.15, mid: 0.5, high: 0.58)
      insert delay(time: 0.417, fdbk: 0.42, mix: 0.38)
      insert reverb(size: 0.7, decay: 0.6, mix: 0.3)
      volume 0.32
      pan -0.2
      play notes`G5:0.5 _:3.5 _:4 E5:0.5 _:3.5 _:4` at bars(1..4)
    }
    track Glass {
      instrument Glass(shimmer: 0.45)
      insert eq(low: 0.15, mid: 0.5, high: 0.56)
      insert delay(time: 0.625, fdbk: 0.45, mix: 0.36)
      insert reverb(size: 0.75, decay: 0.65, mix: 0.28)
      volume 0.26
      pan 0.28
      play notes`_:6 C5:0.5 _:9.5` at bars(1..4)
    }
  }
}
// full indent: the lattice fills in, glass answering every celesta phrase
block LatticeFull : Lattice {
  block Bells {
    track Celesta {
      instrument Celesta()
      insert eq(low: 0.15, mid: 0.5, high: 0.58)
      insert delay(time: 0.417, fdbk: 0.48, mix: 0.38)
      insert reverb(size: 0.7, decay: 0.6, mix: 0.26)
      volume 0.44
      pan -0.2
      play notes`G5:0.5 _:0.5 E5:0.5 _:0.5 D5:0.5 _:0.5 E5:0.25 D5:0.25 C5:0.5 _:1 G4:0.5 _:0.5 A4:0.5 _:0.5 C5:0.5 _:1 E5:0.5 _:0.25 G5:0.25 A5:0.5 _:0.5 G5:0.5 _:0.5 E5:0.5 D5:0.5 C5:0.5 _:1.5` at bars(1..4)
      automate delay.mix from 0.34 to 0.46 over bars(1..16)
    }
    track Glass {
      instrument Glass(shimmer: 0.5)
      insert eq(low: 0.15, mid: 0.5, high: 0.56)
      insert delay(time: 0.625, fdbk: 0.5, mix: 0.4)
      insert reverb(size: 0.75, decay: 0.65, mix: 0.28)
      volume 0.36
      pan 0.28
      play notes`_:1 C5:0.5 _:1.5 E5:0.5 _:1 D5:0.5 _:1.5 G4:0.5 _:1 A4:0.5 _:1.5 C5:0.5 _:1 E5:0.5 _:1.5 D5:0.5 _:1` at bars(1..4)
    }
  }
  block Grain {
    track Kalimba {
      instrument Kalimba()
      insert eq(low: 0.2, mid: 0.55, high: 0.56)
      insert delay(time: 0.278, fdbk: 0.4, mix: 0.32)
      volume 0.4
      pan 0.1
      play notes`C4:0.25 _:0.25 E4:0.25 _:0.25 G4:0.25 _:0.5 A4:0.25 _:0.25 G4:0.25 _:0.25 E4:0.25 _:0.5 D4:0.25 _:0.25 C4:0.25 _:0.5 D4:0.25 E4:0.25 _:0.25 G4:0.25 _:0.5 E4:0.25 _:0.25 D4:0.25 _:0.25 C4:0.25 _:0.75` at bars(1..2)
    }
  }
}

// The pulse: a kick you feel more than hear, brushes sweeping the floor.
block Pulse {
  track Kick {
    instrument Kick808(punch: 0.4, decay: 0.4)
    insert eq(low: 0.56, mid: 0.44, high: 0.44)
    insert comp(thresh: 0.45, ratio: 0.55, attack: 0.025, release: 0.18, makeup: 0.15)
    volume 0.72
    play beat`X--- ---- x--- ---- X--- ---- x--- --.-` at bars(1..2)
  }
  track Brush {
    instrument SnareBrush()
    insert eq(low: 0.2, mid: 0.55, high: 0.56)
    insert comp(thresh: 0.48, ratio: 0.45, attack: 0.008, release: 0.12, makeup: 0.12)
    insert reverb(size: 0.55, decay: 0.45, mix: 0.2)
    volume 0.36
    pan 0.1
    play beat`---- x--- ---- --.- ---- x--- .--- ----` at bars(1..2)
  }
  track Ped {
    instrument HatPedal()
    insert eq(low: 0.1, mid: 0.5, high: 0.55)
    volume 0.16
    pan -0.15
    play beat`--x- --x- --x- --x-` at bars(1..4)
  }
  track Shk {
    instrument Shaker(soft: 0.6)
    insert eq(low: 0.1, mid: 0.5, high: 0.58)
    volume 0.16
    pan 0.25
    play beat`.x.. .x.x .x.. .x..` at bars(1..2)
  }
}
// the pulse with tab stops: ghost brushes marking every indent level
block PulseTabs : Pulse {
  track Brush {
    volume 0.4
    play beat`--.- x--. ---- x--- .--- x--. --.- x.-.` at bars(1..2)
  }
  track Shk { volume 0.2 play beat`.x.x .x.x .x.x .xx.` at bars(1..2) }
}

// The floor: a hollow bass holding roots like line numbers â€” always
// there, never the point.
block Margin {
  key C major
  track Bass {
    instrument HollowBass()
    insert eq(low: 0.56, mid: 0.48, high: 0.42)
    insert comp(thresh: 0.44, ratio: 0.55, attack: 0.02, release: 0.18, makeup: 0.18)
    insert pump(amount: 0.2, beats: 1)
    volume 0.66
    play notes`C2:3 _:1 A1:3 _:1 F1:3 _:1 G1:2.5 _:0.5 B1:1` at bars(1..4)
  }
}

// The two pads: the page itself.
block Page {
  key C major
  track Wide {
    instrument WarmPad(cutoff: 0.36)
    insert eq(low: 0.3, mid: 0.5, high: 0.52)
    insert width(amount: 0.9)
    insert reverb(size: 0.9, decay: 0.75, mix: 0.38)
    volume 0.4
    pan -0.05
    play notes`[C3 G3 E4 B4]:8 [F3 C4 A4 E5]:8` at bars(1..4)
    automate cutoff from 0.3 to 0.44 over bars(1..16)
  }
  track Under {
    instrument GlassPad()
    insert eq(low: 0.3, mid: 0.5, high: 0.53)
    insert pump(amount: 0.22, beats: 1)
    insert width(amount: 0.7)
    volume 0.3
    pan 0.15
    play notes`[E3 B3 G4]:8 [C3 A3 F4]:8` at bars(1..4)
  }
}

// The flute: phrases indented one level deeper each time.
block Indent {
  key C major
  track Flute {
    instrument FluteLead()
    insert eq(low: 0.2, mid: 0.52, high: 0.56)
    insert delay(time: 0.417, fdbk: 0.4, mix: 0.3)
    insert reverb(size: 0.7, decay: 0.6, mix: 0.26)
    volume 0.46
    pan 0.05
    play notes`_:2 E4~:1.5 G4~:1 A4~:1.5 G4~:1.5 E4~:1.5 _:1.5 D4~:1 E4~:2 G4~:1.5 E4~:1.5 D4~:1 C4~:2.5 _:2 G4~:1 A4~:1.5 C5~:2 B4~:1.5 A4~:1 G4~:2 _:2.5` at bars(1..8)
  }
}

// One triangle, once per eight bars. The cursor blink of the whole piece.
block Blink {
  track Tri {
    instrument Triangle()
    insert eq(low: 0.1, mid: 0.45, high: 0.6)
    insert reverb(size: 0.85, decay: 0.75, mix: 0.4)
    volume 0.22
    pan -0.3
    play beat`x--- ---- ---- ----` at bars(1..8)
  }
}

block Hush { track D { instrument Downlifter() volume 0.3 pan 0.1 play beat`x--- ---- ---- ----` at bars(1..1) } }

song "Whitespace" {
  desc "The notes are delimiters; the music is the space between them. Celesta and kalimba interleaved by nested blocks over a brushed pulse â€” significant whitespace at 108bpm."
  artist "Forte Essentials"
  tempo 108bpm
  swing 0.55
  meter 4/4
  key C major

  section blank   = bars(1..8)
  section draft   = bars(9..24)
  section phrase  = bars(25..40)
  section fold    = bars(41..48)
  section indent2 = bars(49..64)
  section eof     = bars(65..76)

  // blank page: pads and the lattice land together, already beautiful
  play Page at blank
  play Lattice at blank
  play Blink at blank

  // draft: the pulse writes the first lines
  play Pulse at draft
  play Margin at draft
  play Lattice at draft
  play Page(volume: 0.8) at draft
  play Blink at draft

  // phrase: the flute reads the paragraph aloud
  play Pulse at phrase
  play Margin at phrase
  play LatticeFull as Lattice at phrase
  play Page(volume: 0.75) at phrase
  play Indent at phrase
  play Blink at phrase

  // fold: everything collapses to the thin lattice â€” whitespace only
  play Hush at bars(41..41)
  play LatticeThin as Lattice at fold
  play Page at fold
  play Margin(volume: 0.6) at fold
  play Blink at fold

  // indent2: the deepest level â€” tab-stop brushes, full lattice, flute
  play PulseTabs as Pulse at indent2
  play Margin at indent2
  play LatticeFull as Lattice at indent2
  play Page(volume: 0.75) at indent2
  play Indent at indent2
  play Blink at indent2

  // eof: the lattice thins back out; the file ends in a newline
  play LatticeThin as Lattice at eof
  play Page at eof
  play Blink at eof
  automate Page.volume from 1 to 0 over bars(71..76)
  automate Lattice.volume from 1 to 0 over bars(73..76)
}
