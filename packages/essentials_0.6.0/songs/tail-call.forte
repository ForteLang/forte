// Tail Call — a phrase that ends by calling itself a fourth higher.
// The recursion is unrolled as nested placements: one two-bar motif,
// placed against its own transpositions until the stack is a chord.
// Driving but warm — congas and a pick attack under detuned keys. 122bpm.
//
// STRUCTURE: `Unroll` is a block whose body is nothing but placements of
// `Call` at three call sites (home, +4th, +7th) — the deepest nesting in
// the album: song → Unroll → Call. The engine below is a nested kit with
// `as`-aliased intensities.
import { Kick909, Snare908, HatClosed, HatOpen, HatPedal, Shaker } from "../instruments/drums.forte"
import { Conga, Timbale, Cabasa } from "../instruments/percussion.forte"
import { FMBass } from "../instruments/bass.forte"
import { Pluck, GlideLead } from "../instruments/leads.forte"
import { DreamSynth } from "../instruments/synths.forte"
import { StringPad } from "../instruments/pads.forte"
import { Riser, Impact } from "../instruments/fx.forte"

// ---- the recursive phrase and its unrolling --------------------------------------
// the call: two bars that end pointing at their own beginning
block Call {
  key B minor
  track Arp {
    instrument Pluck()
    insert eq(low: 0.2, mid: 0.52, high: 0.58)
    insert delay(time: 0.246, fdbk: 0.42, mix: 0.3)
    insert width(amount: 0.55)
    volume 0.46
    pan -0.12
    play notes`B3:0.25 D4:0.25 F#4:0.25 B4:0.25 A4:0.25 F#4:0.25 D4:0.25 F#4:0.25 B3:0.25 D4:0.25 F#4:0.25 A4:0.25 B4:0.5 A4:0.25 F#4:0.25 B3:0.25 D4:0.25 F#4:0.25 B4:0.25 C#5:0.25 B4:0.25 A4:0.25 F#4:0.25 E4:0.5 D4:0.25 C#4:0.25 D4:0.5 F#4:0.5` at bars(1..2)
  }
}
// the unrolled stack: home call, then itself a fourth up, then a fifth
block Unroll {
  key B minor
  play Call at bars(1..2)
  play Call(key: "E minor", volume: 0.85) at bars(3..4)
  play Call(key: "F# minor", volume: 0.75) at bars(5..6)
  play Call at bars(7..8)
}
// base case: just the home phrase, twice as patient
block UnrollBase {
  key B minor
  play Call(volume: 0.8) at bars(1..8)
}

// ---- the engine: nested kit + latin hands, one aliased lane ----------------------
block Engine {
  block Kit {
    track Kick {
      instrument Kick909(click: 0.58)
      insert eq(low: 0.6, mid: 0.45, high: 0.5)
      insert comp(thresh: 0.38, ratio: 0.64, attack: 0.018, release: 0.15, makeup: 0.24)
      volume 0.92
      play beat`X--- x--- x--- x---` at bars(1..4)
    }
    track Snare {
      instrument Snare908(tone: 0.62, snap: 0.6)
      insert eq(low: 0.28, mid: 0.55, high: 0.58)
      insert comp(thresh: 0.42, ratio: 0.55, attack: 0.006, release: 0.1, makeup: 0.18)
      insert reverb(size: 0.45, decay: 0.35, mix: 0.13)
      volume 0.56
      pan 0.04
      play beat`---- x--- ---- x---` at bars(1..2)
    }
    track Ped {
      instrument HatPedal()
      insert eq(low: 0.1, mid: 0.5, high: 0.56)
      volume 0.2
      pan -0.12
      play beat`--x- --x- --x- --x-` at bars(1..4)
    }
    track Hat {
      instrument HatClosed(bright: 0.85)
      insert eq(low: 0.12, mid: 0.45, high: 0.68)
      insert comp(thresh: 0.5, ratio: 0.45, attack: 0.005, release: 0.08, makeup: 0.1)
      volume 0.28
      pan 0.18
      play beat`x.x. x.xX x.x. x.x.` at bars(1..2)
    }
  }
  block Latin {
    track Conga {
      instrument Conga(open: 0.55)
      insert eq(low: 0.32, mid: 0.55, high: 0.52)
      insert comp(thresh: 0.46, ratio: 0.5, attack: 0.008, release: 0.12, makeup: 0.14)
      volume 0.32
      pan -0.28
      play beat`--x- ---x --x- x--- --x- ---x -x-- --x-` at bars(1..2)
    }
    track Timb {
      instrument Timbale()
      insert eq(low: 0.25, mid: 0.55, high: 0.55)
      insert delay(time: 0.246, fdbk: 0.3, mix: 0.22)
      volume 0.24
      pan 0.32
      play beat`---- ---- --x- ---- ---- -x-- ---- ---x` at bars(1..2)
    }
    track Cab {
      instrument Cabasa()
      insert eq(low: 0.1, mid: 0.5, high: 0.6)
      volume 0.2
      pan 0.22
      play beat`.x.x .x.x .x.x .x.x` at bars(1..2)
    }
  }
  play Kit at bars(1..4)
  play Latin at bars(1..4)
}
// first frame: kick and pedal only — the stack is still shallow
block EngineIn : Engine {
  block Kit {
    track Kick {
      instrument Kick909(click: 0.5)
      insert eq(low: 0.6, mid: 0.45, high: 0.5)
      insert comp(thresh: 0.4, ratio: 0.6, attack: 0.02, release: 0.16, makeup: 0.2)
      volume 0.86
      play beat`X--- x--- x--- x---` at bars(1..4)
    }
    track Snare {
      instrument Snare908(tone: 0.6, snap: 0.55)
      insert eq(low: 0.28, mid: 0.55, high: 0.56)
      insert comp(thresh: 0.44, ratio: 0.52, attack: 0.006, release: 0.1, makeup: 0.16)
      insert reverb(size: 0.45, decay: 0.35, mix: 0.15)
      volume 0.4
      pan 0.04
      play beat`---- ---- ---- x---` at bars(1..2)
    }
    track Ped {
      instrument HatPedal()
      insert eq(low: 0.1, mid: 0.5, high: 0.56)
      volume 0.16
      pan -0.12
      play beat`--x- --x- --x- --x-` at bars(1..4)
    }
    track Hat {
      instrument HatClosed(bright: 0.75)
      insert eq(low: 0.12, mid: 0.45, high: 0.62)
      insert comp(thresh: 0.5, ratio: 0.45, attack: 0.005, release: 0.08, makeup: 0.1)
      volume 0.18
      pan 0.18
      play beat`..x. ..x. ..x. ..x.` at bars(1..2)
    }
  }
  block Latin {
    track Conga {
      instrument Conga(open: 0.5)
      insert eq(low: 0.32, mid: 0.55, high: 0.52)
      insert comp(thresh: 0.46, ratio: 0.5, attack: 0.008, release: 0.12, makeup: 0.14)
      volume 0.2
      pan -0.28
      play beat`---- ---x ---- x---` at bars(1..2)
    }
    track Timb {
      instrument Timbale()
      insert eq(low: 0.25, mid: 0.55, high: 0.55)
      insert delay(time: 0.246, fdbk: 0.3, mix: 0.22)
      volume 0.12
      pan 0.32
      play beat`---- ---- ---- ---x` at bars(1..4)
    }
    track Cab {
      instrument Cabasa()
      insert eq(low: 0.1, mid: 0.5, high: 0.6)
      volume 0.12
      pan 0.22
      play beat`.x.. .x.. .x.. .x..` at bars(1..2)
    }
  }
}
// deep frames: ghosts, drags, timbale answering across the field
block EngineDeep : Engine {
  block Kit {
    track Kick {
      instrument Kick909(click: 0.62)
      insert eq(low: 0.6, mid: 0.45, high: 0.5)
      insert comp(thresh: 0.36, ratio: 0.66, attack: 0.016, release: 0.14, makeup: 0.26)
      volume 0.94
      play beat`X--- x--- x--. x--- X--- x--- x--- x-.x` at bars(1..2)
    }
    track Snare {
      instrument Snare908(tone: 0.65, snap: 0.65)
      insert eq(low: 0.28, mid: 0.55, high: 0.58)
      insert comp(thresh: 0.4, ratio: 0.58, attack: 0.006, release: 0.1, makeup: 0.2)
      insert reverb(size: 0.45, decay: 0.35, mix: 0.13)
      volume 0.58
      pan 0.04
      play beat`---- x--- --.- x--. ---- x--- .--- x-x.` at bars(1..2)
    }
    track Ped {
      instrument HatPedal()
      insert eq(low: 0.1, mid: 0.5, high: 0.56)
      volume 0.22
      pan -0.12
      play beat`--x- --x- --x- --xx` at bars(1..4)
    }
    track Hat {
      instrument HatClosed(bright: 0.9)
      insert eq(low: 0.12, mid: 0.45, high: 0.7)
      insert comp(thresh: 0.48, ratio: 0.46, attack: 0.005, release: 0.08, makeup: 0.12)
      volume 0.32
      pan 0.18
      play beat`x.xX x.x. xxx. x.xX x.x. x.xx x.xX xxxX` at bars(1..2)
    }
  }
  block Latin {
    track Conga {
      instrument Conga(open: 0.6)
      insert eq(low: 0.32, mid: 0.55, high: 0.52)
      insert comp(thresh: 0.44, ratio: 0.52, attack: 0.008, release: 0.12, makeup: 0.16)
      volume 0.36
      pan -0.28
      play beat`--x- x--x --x- x-x- --x- ---x -xx- --x-` at bars(1..2)
    }
    track Timb {
      instrument Timbale()
      insert eq(low: 0.25, mid: 0.55, high: 0.55)
      insert delay(time: 0.246, fdbk: 0.38, mix: 0.3)
      volume 0.28
      pan 0.32
      play beat`---- --x- --x- -x-- x--- -x-- ---- x--x` at bars(1..2)
    }
    track Cab {
      instrument Cabasa()
      insert eq(low: 0.1, mid: 0.5, high: 0.6)
      volume 0.24
      pan 0.22
      play beat`.x.x .xxx .x.x .xx.` at bars(1..2)
    }
  }
}

// The frame pointer: an FM bass that never loses its place.
block Frame {
  key B minor
  track Bass {
    instrument FMBass(bite: 0.5)
    insert eq(low: 0.58, mid: 0.5, high: 0.5)
    insert comp(thresh: 0.42, ratio: 0.56, attack: 0.012, release: 0.14, makeup: 0.2)
    insert drive(drive: 0.22)
    insert pump(amount: 0.35, beats: 1)
    volume 0.74
    play notes`B1:0.25 _:0.25 B1:0.25 B2:0.25 _:0.25 B1:0.25 A1:0.25 B1:0.25 _:0.25 B1:0.25 D2:0.25 B1:0.25 E2:0.25 _:0.25 F#2:0.25 A1:0.25` at bars(1..1)
    modulate bite with lfo(rate: 0.16, amount: 0.14, shape: "tri")
  }
}
// the return: same pointer, filter opening as frames pop
block FrameOpen : Frame {
  track Bass {
    instrument FMBass(bite: 0.6)
    insert drive(drive: 0.3)
    automate drive.drive from 0.22 to 0.36 over bars(1..16)
  }
}

// The accumulator: dream-synth chords gathering what each call returns.
block Accum {
  key B minor
  track Dream {
    instrument DreamSynth()
    insert eq(low: 0.28, mid: 0.5, high: 0.55)
    insert chorus(rate: 0.24, depth: 0.55, mix: 0.5)
    insert width(amount: 0.7)
    insert pump(amount: 0.25, beats: 1)
    volume 0.46
    pan 0.08
    play notes`_:0.5 [B2 F#3 A3 D4]:1 _:2.5 _:0.5 [E3 B3 D4 G4]:1 _:2.5 _:0.5 [B2 F#3 A3 D4]:1 _:1.5 [A2 E3 G3 C#4]:1 _:0.5 [G2 D3 F#3 B3]:1.5 [F#2 C#3 E3 A#3]:1.5 _:1` at bars(1..4)
  }
}

// The observer: a glide lead narrating the recursion from above.
block Trace {
  key B minor
  track Lead {
    instrument GlideLead()
    insert eq(low: 0.22, mid: 0.52, high: 0.58)
    insert delay(time: 0.369, fdbk: 0.45, mix: 0.32)
    insert reverb(size: 0.68, decay: 0.58, mix: 0.24)
    volume 0.5
    pan -0.06
    play notes`_:1 F#4~:1.5 A4~:1 B4~:1.5 A4~:1 F#4~:2 _:1.5 D4~:1 E4~:1.5 F#4~:1.5 E4~:1.5 D4~:1 B3~:2.5 _:1 B4~:1 C#5~:1.5 D5~:1.5 C#5~:1 B4~:1.5 A4~:1 F#4~:3 _:2.5` at bars(1..8)
  }
}

// The stack: strings rising a layer per section.
block Stack {
  key B minor
  track Str {
    instrument StringPad()
    insert eq(low: 0.3, mid: 0.5, high: 0.53)
    insert width(amount: 0.85)
    insert reverb(size: 0.85, decay: 0.7, mix: 0.34)
    volume 0.38
    pan -0.05
    play notes`[B2 F#3 D4]:8 [G2 D3 B3]:8 [E3 B3 G4]:8 [F#3 C#4 A#4]:8` at bars(1..8)
  }
}

block Up   { track R { instrument Riser(climb: 0.9) volume 0.55 pan 0.1 play beat`x--- ---- ---- ----` at bars(1..1) } }
block Land { track I { instrument Impact() insert reverb(size: 0.82, decay: 0.62, mix: 0.32) volume 0.62 play beat`x--- ---- ---- ----` at bars(1..1) } }

song "Tail Call" {
  desc "A phrase that ends by calling itself a fourth higher — recursion unrolled as nested block placements over congas, an FM frame pointer and dream-synth accumulators. 122bpm."
  artist "Forte Essentials"
  tempo 122bpm
  meter 4/4
  key B minor

  section base    = bars(1..8)
  section frame1  = bars(9..24)
  section frame2  = bars(25..40)
  section popped  = bars(41..48)
  section deepest = bars(49..68)
  section returned = bars(69..80)

  // base case: the call lands with the kick already running
  play Land at bars(1..1)
  play EngineIn as Engine at base
  play UnrollBase as Unroll at base
  play Frame at bars(5..8)
  play Accum at bars(5..8)

  // frame 1: full engine, the phrase starts calling itself
  play Engine at frame1
  play Frame at frame1
  play Unroll at frame1
  play Accum at frame1
  play Stack at bars(17..24)

  // frame 2: the trace narrates over the recursion
  play Engine at frame2
  play Frame at frame2
  play Unroll at frame2
  play Accum at frame2
  play Trace at frame2
  play Stack(volume: 0.8) at frame2

  // popped: engine holds its breath — the stack rings out alone
  play Up at bars(47..48)
  play UnrollBase as Unroll at popped
  play Stack at popped
  play Accum(volume: 0.7) at popped

  // deepest: everything at once, drive opening as the frames return
  play Land at bars(49..49)
  play EngineDeep as Engine at deepest
  play FrameOpen as Frame at deepest
  play Unroll at deepest
  play Accum at deepest
  play Trace at deepest
  play Stack(volume: 0.75) at deepest

  // returned: base case again — the phrase finally just ends
  play EngineIn as Engine at bars(69..76)
  play UnrollBase as Unroll at returned
  play Frame at bars(69..76)
  play Stack at returned
  automate Stack.volume from 1 to 0 over bars(75..80)
  automate Unroll.volume from 1 to 0.4 over bars(77..80)
}
