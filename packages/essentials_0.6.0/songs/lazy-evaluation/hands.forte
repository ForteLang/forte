// Lazy Evaluation — hands parts.
import { Cabasa, Conga } from "../../instruments/percussion.forte"

// Hands: cabasa and a far conga — the percussion section that shows up late.
block Hands {
  track Cab {
    instrument Cabasa()
    insert eq(low: 0.1, mid: 0.5, high: 0.6)
    volume 0.2
    pan 0.3
    play beat`.x.x .x.x .x.x .xxx` at bars(1..2)
  }
  track Conga {
    instrument Conga(open: 0.5)
    insert eq(low: 0.35, mid: 0.55, high: 0.5)
    insert delay(time: 0.312, fdbk: 0.3, mix: 0.22)
    volume 0.3
    pan -0.3
    play beat`---- --x- ---- x--- ---- --x- -x-- ----` at bars(1..2)
  }
}
