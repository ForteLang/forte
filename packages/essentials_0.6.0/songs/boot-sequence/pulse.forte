// Boot Sequence — pulse parts.
import { Kick808 } from "../../instruments/drums.forte"
import { SubBass } from "../../instruments/bass.forte"

// ---- the heartbeat: ONE kick+sub lane, three intensities -----------------------
// 808 four-floor with a sub layered under it, compressed together so the
// low end is one instrument, not two.
block Pulse {
  track Kick {
    instrument Kick808(punch: 0.6, decay: 0.4)
    insert eq(low: 0.6, mid: 0.45, high: 0.48)
    insert comp(thresh: 0.42, ratio: 0.6, attack: 0.02, release: 0.16, makeup: 0.2)
    volume 0.95
    play beat`X--- x--- x--- x---` at bars(1..4)
  }
  track Sub {
    instrument SubBass(drive: 0.3)
    insert filter(type: "lp", cutoff: 0.22)
    insert comp(thresh: 0.4, ratio: 0.6, attack: 0.03, release: 0.2, makeup: 0.18)
    volume 0.6
    play notes`A0:0.75 _:0.25 A0:0.5 _:0.5 A0:0.75 _:0.25 A0:0.5 G0:0.5` at bars(1..4)
  }
}

// first landing: punchier hit, the sub still closed down
block PulseIn : Pulse {
  track Kick { instrument Kick808(punch: 0.5, decay: 0.35) volume 0.9 }
  track Sub {
    insert filter(type: "lp", cutoff: 0.16)
    volume 0.5
    automate filter.cutoff from 0.14 to 0.24 over bars(1..12)
  }
}

// finale: ghost before the 4, sub opened and driven
block PulseWide : Pulse {
  track Kick {
    insert comp(thresh: 0.36, ratio: 0.68, attack: 0.015, release: 0.14, makeup: 0.28)
    play beat`X--- x--- x--. x--- X--- x--- x--- x-.x` at bars(1..2)
  }
  track Sub {
    instrument SubBass(drive: 0.45)
    insert filter(type: "lp", cutoff: 0.3)
    volume 0.66
  }
}
