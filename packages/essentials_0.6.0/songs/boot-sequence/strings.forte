// Boot Sequence — strings parts.
import { StringMachine, AnalogBrass } from "../../instruments/synths.forte"

// Strings for the breakdown — the machine dreams for eight bars.
block Dream {
  key A minor
  let theme = prog`Am | F | C | G`
  track Str {
    instrument StringMachine()
    insert filter(type: "lp", cutoff: 0.4)
    insert eq(low: 0.3, mid: 0.5, high: 0.55)
    insert width(amount: 0.8)
    insert reverb(size: 0.8, decay: 0.7, mix: 0.3)
    volume 0.5
    pan -0.05
    play chords(theme) at bars(1..4)
    automate filter.cutoff from 0.25 to 0.6 over bars(1..8)
  }
}

// Brass hits for the final act.
block Horns {
  key A minor
  track Brass {
    instrument AnalogBrass(blow: 0.6)
    insert eq(low: 0.4, mid: 0.55, high: 0.55)
    insert comp(thresh: 0.45, ratio: 0.5, attack: 0.01, release: 0.15, makeup: 0.15)
    insert drive(drive: 0.2)
    insert width(amount: 0.5)
    volume 0.5
    pan 0.15
    play notes`_:3 [A3 E4 A4]:0.5 _:0.5 _:3 [G3 D4 G4]:0.5 _:0.5` at bars(1..2)
  }
}
