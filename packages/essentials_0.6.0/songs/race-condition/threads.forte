// Race Condition — threads parts.
import { Hoover } from "../../instruments/synths.forte"
import { ScreamLead } from "../../instruments/leads.forte"

// ---- thread A: ONE hoover lane, closed → racing → victorious --------------------
block ThreadA {
  key G minor
  track Hoover {
    instrument Hoover()
    insert drive(drive: 0.25)
    insert filter(type: "lp", cutoff: 0.55, reso: 0.35)
    insert eq(low: 0.4, mid: 0.55, high: 0.55)
    insert delay(time: 0.224, fdbk: 0.35, mix: 0.2)
    insert width(amount: 0.6)
    volume 0.6
    play notes`G2:0.5 G2:0.25 G2:0.25 A#2:0.5 G2:0.5 F2:0.5 G2~:1.5 _:0.25 D3:0.25 C3:0.5 A#2:0.5 G2:0.5 F2:0.5 G2~:1 _:0.5` at bars(1..2)
    modulate filter.cutoff with lfo(rate: 0.24, amount: 0.15, shape: "saw")
  }
}

// leg one: the filter opens as A pulls ahead
block ThreadARace : ThreadA {
  track Hoover {
    automate filter.cutoff from 0.45 to 0.68 over bars(1..16)
    automate drive.drive from 0.25 to 0.35 over bars(1..16)
  }
}

// victory lap: wide, driven, the delay carrying the riff over the line
block ThreadAWin : ThreadA {
  track Hoover {
    instrument Hoover()
    insert drive(drive: 0.35)
    insert filter(type: "lp", cutoff: 0.7, reso: 0.4)
    insert delay(time: 0.224, fdbk: 0.45, mix: 0.3)
    insert width(amount: 0.8)
    volume 0.64
    automate delay.mix from 0.2 to 0.42 over bars(9..16)
  }
}

// Thread B: the scream lead — same lock, higher priority, worse manners.
block ThreadB {
  key G minor
  track Scream {
    instrument ScreamLead(edge: 0.75)
    insert filter(type: "bp", cutoff: 0.6, reso: 0.45)
    insert eq(low: 0.2, mid: 0.55, high: 0.62)
    insert delay(time: 0.336, fdbk: 0.45, mix: 0.3)
    volume 0.45
    pan 0.25
    play notes`_:4 G4:0.25 G4:0.25 A#4:0.25 C5:0.25 D5~:1 D5:0.5 C5:0.5 A#4:0.5 G4~:0.75 _:0.25` at bars(1..2)
  }
}

// preempting: B leans on its bandpass and shouts over the top
block ThreadBLoud : ThreadB {
  track Scream {
    instrument ScreamLead(edge: 0.85)
    volume 0.48
    automate filter.cutoff from 0.5 to 0.75 over bars(1..16)
  }
}
