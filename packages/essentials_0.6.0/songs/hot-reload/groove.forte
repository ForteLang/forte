// Hot Reload — groove parts.
import { Kick808, HatClosed, HatPedal, Rim, Shaker, Snap } from "../../instruments/drums.forte"

// ---- the rhythm machine: a block of blocks --------------------------------------
block Groove {
  // feet: an 808 that steps around the one instead of hammering it
  block Feet {
    track Kick {
      instrument Kick808(punch: 0.55, decay: 0.38)
      insert eq(low: 0.6, mid: 0.45, high: 0.48)
      insert comp(thresh: 0.42, ratio: 0.6, attack: 0.02, release: 0.16, makeup: 0.2)
      volume 0.88
      play beat`X--- --x- ---- x--- X--- --x- --.- x-.-` at bars(1..2)
    }
  }
  // hands: pedal hats breathing, a shaker leaning on the offbeat
  block Hands {
    track Hat {
      instrument HatClosed(bright: 0.75)
      insert eq(low: 0.12, mid: 0.45, high: 0.65)
      insert comp(thresh: 0.5, ratio: 0.45, attack: 0.005, release: 0.08, makeup: 0.1)
      volume 0.26
      pan 0.18
      play beat`x.x. x.xX x.x. x.x.` at bars(1..4)
    }
    track Ped {
      instrument HatPedal()
      insert eq(low: 0.1, mid: 0.5, high: 0.58)
      volume 0.2
      pan -0.12
      play beat`--x- --x- --x- --x-` at bars(1..4)
    }
    track Shk {
      instrument Shaker(soft: 0.55)
      insert eq(low: 0.1, mid: 0.5, high: 0.6)
      volume 0.22
      pan -0.25
      play beat`.x.x .x.x .x.x .x.x` at bars(1..4)
    }
  }
  // fingers: rim ghosts and a snap that lands like a page saving
  block Fingers {
    track Rim {
      instrument Rim()
      insert eq(low: 0.2, mid: 0.58, high: 0.55)
      insert delay(time: 0.288, fdbk: 0.35, mix: 0.28)
      volume 0.28
      pan 0.35
      play beat`---- --x- ---. ---- ---- -x-- ---- --.-` at bars(1..2)
    }
    track Snap {
      instrument Snap()
      insert eq(low: 0.15, mid: 0.55, high: 0.6)
      insert comp(thresh: 0.45, ratio: 0.5, attack: 0.004, release: 0.1, makeup: 0.15)
      insert reverb(size: 0.45, decay: 0.35, mix: 0.14)
      volume 0.5
      pan -0.05
      play beat`---- x--- ---- x---` at bars(1..1)
    }
  }
  play Feet at bars(1..4)
  play Hands at bars(1..4)
  play Fingers at bars(1..4)
}

// warm-up: the same machine, inner parts swapped for sparser ones
block GrooveIn : Groove {
  block Feet {
    track Kick {
      instrument Kick808(punch: 0.45, decay: 0.36)
      insert eq(low: 0.6, mid: 0.45, high: 0.48)
      insert comp(thresh: 0.44, ratio: 0.55, attack: 0.02, release: 0.16, makeup: 0.18)
      volume 0.8
      play beat`X--- ---- --x- ----` at bars(1..2)
    }
  }
  block Hands {
    track Hat {
      instrument HatClosed(bright: 0.7)
      insert eq(low: 0.12, mid: 0.45, high: 0.62)
      insert comp(thresh: 0.5, ratio: 0.45, attack: 0.005, release: 0.08, makeup: 0.1)
      volume 0.18
      pan 0.18
      play beat`..x. ..x. ..x. ..x.` at bars(1..4)
    }
    track Ped {
      instrument HatPedal()
      insert eq(low: 0.1, mid: 0.5, high: 0.58)
      volume 0.14
      pan -0.12
      play beat`---- --x- ---- --x-` at bars(1..4)
    }
    track Shk {
      instrument Shaker(soft: 0.6)
      insert eq(low: 0.1, mid: 0.5, high: 0.6)
      volume 0.15
      pan -0.25
      play beat`.x.. .x.. .x.. .x..` at bars(1..4)
    }
  }
}

// full flow: ghost 16ths everywhere, the snap answers itself
block GrooveFull : Groove {
  block Hands {
    track Hat {
      instrument HatClosed(bright: 0.8)
      insert eq(low: 0.12, mid: 0.45, high: 0.68)
      insert comp(thresh: 0.5, ratio: 0.45, attack: 0.005, release: 0.08, makeup: 0.1)
      volume 0.3
      pan 0.18
      play beat`x.xX x.x. xxx. x.xX x.x. x.xx x.xX xxx.` at bars(1..2)
    }
    track Ped {
      instrument HatPedal()
      insert eq(low: 0.1, mid: 0.5, high: 0.58)
      volume 0.22
      pan -0.12
      play beat`--x- --x- --x- --xx` at bars(1..4)
    }
    track Shk {
      instrument Shaker(soft: 0.5)
      insert eq(low: 0.1, mid: 0.5, high: 0.6)
      volume 0.26
      pan -0.25
      play beat`.x.x .xxx .x.x .x.x` at bars(1..2)
    }
  }
  block Fingers {
    track Rim {
      instrument Rim()
      insert eq(low: 0.2, mid: 0.58, high: 0.55)
      insert delay(time: 0.288, fdbk: 0.42, mix: 0.34)
      volume 0.3
      pan 0.35
      play beat`---- --x- -.-x ---- -x-- --x- ---- x-.-` at bars(1..2)
    }
    track Snap {
      instrument Snap()
      insert eq(low: 0.15, mid: 0.55, high: 0.6)
      insert comp(thresh: 0.45, ratio: 0.5, attack: 0.004, release: 0.1, makeup: 0.15)
      insert reverb(size: 0.45, decay: 0.35, mix: 0.14)
      volume 0.54
      pan -0.05
      play beat`---- x--- --.- x--. ---- x--- .--- x-x-` at bars(1..2)
    }
  }
}
