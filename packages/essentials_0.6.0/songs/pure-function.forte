// Pure Function — precision rhythm programming. Clicks, sticks and a
// deep sub locked to a 16th grid so tight it feels hand-played; one cold
// chord for harmony and no side effects anywhere. Same input, same
// groove, every single time. 118bpm.
//
// STRUCTURE: the machine is nested three levels — `Machine` places `Grid`
// (kick+sub), `Clicks` (the micro-percussion ensemble) and `Tops`, and
// the section variants swap `Clicks` wholesale: the same lane set clicks
// a different sentence each act (`as Machine`).
import { Kick909, KickSub, Rim, Snap, Stick, HatClosed, HatOpen } from "../instruments/drums.forte"
import { Woodblock, Clave, Guiro } from "../instruments/percussion.forte"
import { SubBass, FMBass } from "../instruments/bass.forte"
import { SoftSquare } from "../instruments/synths.forte"
import { GlassPad } from "../instruments/pads.forte"
import { BitLead } from "../instruments/leads.forte"
import { Zap, Impact } from "../instruments/fx.forte"

// ---- the machine: three nested sections on one internal timeline ----------------
block Machine {
  // grid: a 909 that steps AROUND the one, sub answering underneath
  block Grid {
    track Kick {
      instrument Kick909(click: 0.55)
      insert eq(low: 0.6, mid: 0.45, high: 0.5)
      insert comp(thresh: 0.38, ratio: 0.65, attack: 0.018, release: 0.15, makeup: 0.25)
      volume 0.9
      play beat`X--- --x- ---- x--- X--- ---- x--- --x-` at bars(1..2)
    }
    track Sub {
      instrument KickSub(weight: 0.7)
      insert eq(low: 0.58, mid: 0.42, high: 0.4)
      insert comp(thresh: 0.42, ratio: 0.6, attack: 0.03, release: 0.2, makeup: 0.15)
      volume 0.45
      play beat`---- x--- --x- ---- --x- x--- ---- x---` at bars(1..2)
    }
  }
  // clicks: the ensemble of tiny sounds — the actual melody of the track
  block Clicks {
    track Stick {
      instrument Stick()
      insert eq(low: 0.2, mid: 0.58, high: 0.58)
      insert delay(time: 0.254, fdbk: 0.3, mix: 0.24)
      volume 0.34
      pan 0.3
      play beat`-x-- ---x -x-- ---- ---x -x-- ---- x-x-` at bars(1..2)
    }
    track Block {
      instrument Woodblock()
      insert eq(low: 0.2, mid: 0.55, high: 0.58)
      volume 0.26
      pan -0.35
      play beat`---- x--- --x- ---- ---- --x- ---- -x--` at bars(1..2)
    }
    track Rim {
      instrument Rim()
      insert eq(low: 0.2, mid: 0.58, high: 0.55)
      insert comp(thresh: 0.48, ratio: 0.45, attack: 0.004, release: 0.08, makeup: 0.12)
      volume 0.3
      pan 0.12
      play beat`---- x-.- ---- x--. --.- x--- ---- x---` at bars(1..2)
    }
  }
  // tops: hats kept almost subliminal — the grid needs air, not wash
  block Tops {
    track Hat {
      instrument HatClosed(bright: 0.85)
      insert eq(low: 0.1, mid: 0.45, high: 0.66)
      insert comp(thresh: 0.5, ratio: 0.45, attack: 0.005, release: 0.08, makeup: 0.1)
      volume 0.24
      pan 0.15
      play beat`x.x. x.x. x.xX x.x.` at bars(1..4)
    }
    track Open {
      instrument HatOpen(decay: 0.18)
      insert eq(low: 0.1, mid: 0.5, high: 0.6)
      insert pump(amount: 0.3, beats: 1)
      volume 0.28
      pan -0.1
      play beat`--x- ---- --x- ----` at bars(1..4)
    }
  }
  play Grid at bars(1..4)
  play Clicks at bars(1..4)
  play Tops at bars(1..4)
}
// input A: sparser clicks — the function warming its cache
block MachineA : Machine {
  block Clicks {
    track Stick {
      instrument Stick()
      insert eq(low: 0.2, mid: 0.58, high: 0.58)
      insert delay(time: 0.254, fdbk: 0.3, mix: 0.24)
      volume 0.28
      pan 0.3
      play beat`-x-- ---- ---- ---x ---- -x-- ---- ----` at bars(1..2)
    }
    track Block {
      instrument Woodblock()
      insert eq(low: 0.2, mid: 0.55, high: 0.58)
      volume 0.2
      pan -0.35
      play beat`---- x--- ---- ---- ---- --x- ---- ----` at bars(1..2)
    }
    track Rim {
      instrument Rim()
      insert eq(low: 0.2, mid: 0.58, high: 0.55)
      insert comp(thresh: 0.48, ratio: 0.45, attack: 0.004, release: 0.08, makeup: 0.12)
      volume 0.26
      pan 0.12
      play beat`---- x--- ---- ----` at bars(1..1)
    }
  }
}
// input B: the full sentence — ratchets, drags, answers across the field
block MachineB : Machine {
  block Clicks {
    track Stick {
      instrument Stick()
      insert eq(low: 0.2, mid: 0.58, high: 0.58)
      insert delay(time: 0.254, fdbk: 0.38, mix: 0.3)
      volume 0.36
      pan 0.3
      play beat`-x-x ---x -xx- --x- ---x -x-- x--- x-xx` at bars(1..2)
    }
    track Block {
      instrument Woodblock()
      insert eq(low: 0.2, mid: 0.55, high: 0.58)
      volume 0.3
      pan -0.35
      play beat`--x- x--- --x- -x-- ---- --x- x-x- -x--` at bars(1..2)
    }
    track Rim {
      instrument Rim()
      insert eq(low: 0.2, mid: 0.58, high: 0.55)
      insert comp(thresh: 0.46, ratio: 0.48, attack: 0.004, release: 0.08, makeup: 0.14)
      volume 0.32
      pan 0.12
      play beat`--.- x-.- ---- x--. --.- x--- .x-- x.x.` at bars(1..2)
    }
  }
}

// The argument: a sub bass line passed by value, never mutated.
block Argument {
  key D minor
  track Bass {
    instrument SubBass(drive: 0.28)
    insert filter(type: "lp", cutoff: 0.3)
    insert eq(low: 0.6, mid: 0.46, high: 0.42)
    insert comp(thresh: 0.4, ratio: 0.6, attack: 0.015, release: 0.16, makeup: 0.22)
    insert pump(amount: 0.35, beats: 1)
    volume 0.76
    play notes`D1:0.5 _:0.25 D1:0.25 _:0.5 F1:0.25 D1:0.25 _:0.5 D1:0.25 D2:0.25 _:0.25 C1:0.25 D1:0.5 D1:0.5 _:0.25 D1:0.25 A1:0.5 _:0.25 G1:0.25 F1:0.25 _:0.25 D1:0.25 C1:0.25 D1:0.75 _:0.25` at bars(1..2)
  }
}
// the return value: same line, harmonics allowed through
block ReturnValue : Argument {
  track Bass {
    insert filter(type: "lp", cutoff: 0.4)
    automate filter.cutoff from 0.3 to 0.5 over bars(1..16)
  }
}

// The one chord — cold glass, struck once per four bars. All the harmony
// a pure function needs.
block Constant {
  key D minor
  track Chord {
    instrument SoftSquare()
    insert filter(type: "lp", cutoff: 0.5, reso: 0.3)
    insert eq(low: 0.28, mid: 0.5, high: 0.55)
    insert chorus(rate: 0.25, depth: 0.45, mix: 0.4)
    insert width(amount: 0.7)
    insert delay(time: 0.508, fdbk: 0.5, mix: 0.38)
    volume 0.44
    pan -0.08
    play notes`[D3 A3 C4 F4]:1 _:15` at bars(1..4)
    modulate filter.cutoff with lfo(rate: 0.07, amount: 0.15, shape: "sine")
  }
}

// The map: a bit lead iterating over the argument, one element at a time.
block Map {
  key D minor
  track Blip {
    instrument BitLead()
    insert filter(type: "lp", cutoff: 0.55, reso: 0.3)
    insert eq(low: 0.15, mid: 0.5, high: 0.6)
    insert delay(time: 0.381, fdbk: 0.48, mix: 0.34)
    volume 0.36
    pan 0.25
    play notes`_:0.5 D5:0.25 _:0.75 F5:0.25 _:0.5 D5:0.25 A4:0.25 _:0.75 C5:0.25 _:0.5 G4:0.25 A4:0.25 _:0.5 F4:0.25 _:1.5 D5:0.25 C5:0.25 A4:0.25 _:0.25` at bars(1..2)
    automate filter.cutoff from 0.4 to 0.65 over bars(1..16)
  }
}

// The pad that proves there are no side effects — it never changes state.
block Stateless {
  key D minor
  track Glass {
    instrument GlassPad()
    insert eq(low: 0.3, mid: 0.5, high: 0.54)
    insert width(amount: 0.85)
    insert pump(amount: 0.3, beats: 1)
    insert reverb(size: 0.8, decay: 0.7, mix: 0.32)
    volume 0.36
    pan 0.05
    play notes`[D3 A3 F4]:16 [C3 G3 E4]:16` at bars(1..8)
  }
}

block Hit { track I { instrument Impact() insert reverb(size: 0.8, decay: 0.6, mix: 0.3) volume 0.6 play beat`x--- ---- ---- ----` at bars(1..1) } }
block Ping { track Z { instrument Zap() insert delay(time: 0.254, fdbk: 0.6, mix: 0.5) insert eq(low: 0.2, mid: 0.5, high: 0.6) volume 0.35 pan -0.3 play beat`x--- ---- ---- --x- ---- -x-- ---- ----` at bars(1..2) } }

song "Pure Function" {
  desc "Precision rhythm programming: sticks, blocks and rims composed as a nested click ensemble over a deep sub — one cold chord, no side effects, same groove every time. 118bpm."
  artist "Forte Essentials"
  tempo 118bpm
  meter 4/4
  key D minor

  section call    = bars(1..8)
  section applyA  = bars(9..24)
  section applyB  = bars(25..40)
  section identity = bars(41..48)
  section compose = bars(49..68)
  section returns = bars(69..80)

  // call: the grid and the argument land together — no fade, full stop
  play Hit at bars(1..1)
  play Machine at call
  play Argument at call
  play Constant at call

  // apply, input A: cache warm-up clicks, the map starts iterating
  play MachineA as Machine at applyA
  play Argument at applyA
  play Constant at applyA
  play Map at bars(17..24)
  play Ping at bars(9..12)

  // apply, input B: the full click sentence
  play MachineB as Machine at applyB
  play Argument at applyB
  play Constant at applyB
  play Map at applyB
  play Stateless at applyB

  // identity: drums hold their breath — the chord and the pad prove purity
  play Constant at identity
  play Stateless at identity
  play Argument(volume: 0.6) at identity
  play Ping at bars(45..48)

  // compose: everything applied at once, filter opening on the return
  play Hit at bars(49..49)
  play MachineB as Machine at compose
  play ReturnValue as Argument at compose
  play Constant at compose
  play Map at compose
  play Stateless(volume: 0.8) at compose

  // returns: the machine unwinds to input A and hands back the groove
  play MachineA as Machine at returns
  play Argument at returns
  play Constant at returns
  play Stateless at returns
  automate Machine.volume from 1 to 0.4 over bars(77..80)
  automate Argument.volume from 1 to 0 over bars(77..80)
}
