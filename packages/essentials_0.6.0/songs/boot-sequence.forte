// Boot Sequence — the machine wakes up. YMO-school electro: a fifths arp
// that never stops, tom fills answering the melody, block chords stabbed
// on the offbeat. Every section is a block; the song is just placements —
// and the pulse, tops, bass and tom fills are FAMILIES of inherited
// variants sharing one lane each (`as`), so each track evolves from soft
// boot to full finale on a single line of the arrangement.
import { Kick808, HatClosed, HatOpen, Clap, Tom, TomFloor, Rim } from "../instruments/drums.forte"
import { SubBass, FMBass } from "../instruments/bass.forte"
import { PolySaw, StringMachine, AnalogBrass } from "../instruments/synths.forte"
import { EPiano, Bell } from "../instruments/keys.forte"
import { BitLead } from "../instruments/leads.forte"
import { SH101Zap } from "../instruments/sh101.forte"
import { Riser, Impact } from "../instruments/fx.forte"

// ---- the heartbeat: ONE kick+sub lane, three intensities -----------------------
// 808 four-floor with a sub layered under it, compressed together so the
// low end is one instrument, not two.
block Pulse {
  track Kick {
    instrument Kick808(punch: 0.6, decay: 0.4)
    insert eq(low: 0.6, mid: 0.45, high: 0.48)
    insert comp(thresh: 0.42, ratio: 0.6, attack: 0.02, release: 0.16, makeup: 0.2)
    volume 0.95
    play beat`X--- x--- x--- x---` at bars(1..4)
  }
  track Sub {
    instrument SubBass(drive: 0.3)
    insert filter(type: "lp", cutoff: 0.22)
    insert comp(thresh: 0.4, ratio: 0.6, attack: 0.03, release: 0.2, makeup: 0.18)
    volume 0.6
    play notes`A0:0.75 _:0.25 A0:0.5 _:0.5 A0:0.75 _:0.25 A0:0.5 G0:0.5` at bars(1..4)
  }
}
// first landing: punchier hit, the sub still closed down
block PulseIn : Pulse {
  track Kick { instrument Kick808(punch: 0.5, decay: 0.35) volume 0.9 }
  track Sub {
    insert filter(type: "lp", cutoff: 0.16)
    volume 0.5
    automate filter.cutoff from 0.14 to 0.24 over bars(1..12)
  }
}
// finale: ghost before the 4, sub opened and driven
block PulseWide : Pulse {
  track Kick {
    insert comp(thresh: 0.36, ratio: 0.68, attack: 0.015, release: 0.14, makeup: 0.28)
    play beat`X--- x--- x--. x--- X--- x--- x--- x-.x` at bars(1..2)
  }
  track Sub {
    instrument SubBass(drive: 0.45)
    insert filter(type: "lp", cutoff: 0.3)
    volume 0.66
  }
}

// ---- machine tops: ONE lane, boot → groove → finale ----------------------------
block Tops {
  track Hats {
    instrument HatClosed(bright: 0.9)
    insert eq(low: 0.2, mid: 0.45, high: 0.7)
    insert comp(thresh: 0.5, ratio: 0.45, attack: 0.005, release: 0.08, makeup: 0.1)
    volume 0.34
    pan 0.18
    play beat`x.x. X.x. x.xX x.x.` at bars(1..4)
  }
  track Open {
    instrument HatOpen(decay: 0.24)
    insert eq(low: 0.1, mid: 0.5, high: 0.62)
    volume 0.3
    pan -0.12
    play beat`--x- --x- --x- --x-` at bars(1..4)
  }
  track Rim {
    instrument Rim()
    insert eq(low: 0.2, mid: 0.6, high: 0.55)
    insert delay(time: 0.24, fdbk: 0.35, mix: 0.3)
    volume 0.3
    pan 0.35
    play beat`---- --x- ---- ---x` at bars(1..4)
  }
}
// entrance: only ghosts and the offbeat open
block TopsIn : Tops {
  track Hats { volume 0.26 play beat`..x. ..x. ..x. ..X.` at bars(1..4) }
  track Open { volume 0.24 play beat`---- --x- ---- --x-` at bars(1..4) }
  track Rim  { volume 0.2 play beat`---- ---- ---- ---x` at bars(1..4) }
}
// finale: 16th ghosts crowd in, the rim chatters across the delay
block TopsWide : Tops {
  track Hats {
    volume 0.38
    play beat`x.x. XxX. x.xX xxx. x.x. X.x. xxxX x.xx` at bars(1..2)
  }
  track Open { volume 0.34 play beat`--x- --x- --x- --xx` at bars(1..4) }
  track Rim {
    insert delay(time: 0.24, fdbk: 0.45, mix: 0.4)
    volume 0.34
    play beat`---- --x- -x-- ---x ---- x-x- ---- ---x` at bars(1..2)
  }
}

// ---- the engine room: ONE bass lane, closed → open → sprinting -----------------
block Engine {
  key A minor
  track Bass {
    instrument FMBass(bite: 0.45)
    insert eq(low: 0.58, mid: 0.5, high: 0.52)
    insert comp(thresh: 0.42, ratio: 0.55, attack: 0.012, release: 0.14, makeup: 0.2)
    insert drive(drive: 0.25)
    insert pump(amount: 0.45, beats: 1)
    volume 0.72
    play notes`A1:0.25 A1:0.25 A2:0.25 A1:0.25 _:0.25 A1:0.25 G1:0.25 A1:0.25 A1:0.25 A2:0.25 _:0.25 A1:0.25 C2:0.25 C2:0.25 G1:0.25 B1:0.25` at bars(1..2)
    modulate bite with lfo(rate: 0.14, amount: 0.15, shape: "tri")
  }
}
// rise: more bite arriving over sixteen bars, drive leaning in
block EngineRise : Engine {
  track Bass {
    instrument FMBass(bite: 0.55)
    insert drive(drive: 0.32)
    automate drive.drive from 0.25 to 0.4 over bars(1..16)
  }
}
// finale: the line doubles up, octave jumps everywhere
block EngineWide : Engine {
  track Bass {
    instrument FMBass(bite: 0.6)
    insert drive(drive: 0.38)
    volume 0.75
    play notes`A1:0.25 A2:0.25 A1:0.25 A2:0.25 G1:0.25 A1:0.25 A2:0.25 A1:0.25 C2:0.25 C3:0.25 _:0.25 C2:0.25 B1:0.25 G1:0.25 A1:0.25 A2:0.25` at bars(1..2)
  }
}

// The fifths arp — the signature. It runs the whole song; sections fade
// and filter it from outside.
block ArpFifths {
  key A minor
  param cutoff = 0.55 in 0..1
  let seq = prog`Am | F | C | G`
  track Arp {
    instrument PolySaw(cutoff: cutoff)
    insert eq(low: 0.3, mid: 0.5, high: 0.6)
    insert chorus(rate: 0.25, depth: 0.4, mix: 0.35)
    insert delay(time: 0.318, fdbk: 0.4, mix: 0.22)
    insert pump(amount: 0.3, beats: 1)
    volume 0.5
    pan -0.2
    play arp(seq, rate: 0.25, style: "updown") at bars(1..4)
  }
}

// YMO block chords: EPiano stabs on the offbeat, wide and chorused.
block Stabs {
  key A minor
  track EP {
    instrument EPiano(tine: 0.4)
    insert eq(low: 0.25, mid: 0.55, high: 0.58)
    insert chorus(rate: 0.3, depth: 0.5, mix: 0.45)
    insert width(amount: 0.7)
    volume 0.55
    pan 0.08
    play notes`_:0.5 [A3 C4 E4]:0.5 _:0.5 [A3 C4 E4]:0.5 _:0.5 [F3 A3 C4]:0.5 _:0.5 [F3 A3 C4]:0.5 _:0.5 [C4 E4 G4]:0.5 _:0.5 [C4 E4 G4]:0.5 _:0.5 [G3 B3 D4]:0.5 _:0.5 [G3 B3 D4]:0.5` at bars(1..4)
  }
}

// ---- the melody: ONE bell lane, theme → finale ---------------------------------
// A pentatonic hook, phrased call-and-answer, thrown into a dotted delay.
// This is the part you whistle later.
block Hook {
  key A minor
  track Bell {
    instrument Bell(decay: 0.6)
    insert eq(low: 0.15, mid: 0.5, high: 0.6)
    insert delay(time: 0.381, fdbk: 0.45, mix: 0.35)
    insert reverb(size: 0.6, decay: 0.5, mix: 0.18)
    volume 0.6
    pan 0.1
    play notes`A4:0.5 C5:0.5 D5:0.5 E5:1 _:0.5 G5:0.5 E5:0.5 D5~:0.5 C5:1 _:0.5 A4:0.5 C5:0.5 D5:0.75 C5:0.25 A4:1.5 _:0.5 G4:0.5 A4:2 _:1` at bars(1..4)
  }
}
// finale: the delay throws longer and the room grows around the bell
block HookWide : Hook {
  track Bell {
    insert delay(time: 0.381, fdbk: 0.55, mix: 0.42)
    insert reverb(size: 0.75, decay: 0.6, mix: 0.26)
    volume 0.62
    automate delay.mix from 0.35 to 0.5 over bars(9..16)
  }
}

// Counter-melody for the last act: a bit-crushed lead answering the bell.
block Counter {
  key A minor
  track Blip {
    instrument BitLead()
    insert filter(type: "lp", cutoff: 0.6, reso: 0.3)
    insert eq(low: 0.15, mid: 0.5, high: 0.62)
    insert delay(time: 0.238, fdbk: 0.5, mix: 0.3)
    volume 0.4
    pan -0.35
    play notes`_:1 E5:0.25 D5:0.25 C5:0.25 D5:0.25 _:0.5 A4:0.25 C5:0.25 _:1.5 E5:0.25 G5:0.25 E5:0.25 D5:0.25 _:0.5 C5:0.5 D5:1` at bars(1..2)
    automate filter.cutoff from 0.45 to 0.75 over bars(1..16)
  }
}

// ---- Rydeen's grandchildren: ONE tom-fill lane, phrase-end → finale ------------
block TomFill {
  track Toms {
    instrument Tom(fall: 0.4)
    insert eq(low: 0.45, mid: 0.55, high: 0.5)
    insert comp(thresh: 0.45, ratio: 0.5, attack: 0.008, release: 0.12, makeup: 0.15)
    volume 0.55
    pan -0.15
    play beat`---- ---- x-x- xxxx` at bars(1..1)
  }
  track Floor {
    instrument TomFloor(decay: 0.45)
    insert eq(low: 0.55, mid: 0.5, high: 0.45)
    insert comp(thresh: 0.45, ratio: 0.5, attack: 0.01, release: 0.14, makeup: 0.15)
    volume 0.5
    pan 0.2
    play beat`---- ---- ---- x-x-` at bars(1..1)
  }
}
// the big one: a full-bar ratchet cascade high to low
block TomFillBig : TomFill {
  track Toms  { volume 0.6 play beat`x-x- xx-x x.xx xxxx` at bars(1..1) }
  track Floor { volume 0.55 play beat`---- x--- x-x- xxxx` at bars(1..1) }
}

// Startup noises: zaps that ping across the stereo field over the intro.
block Blips {
  track Zap {
    instrument SH101Zap()
    insert eq(low: 0.2, mid: 0.5, high: 0.6)
    insert delay(time: 0.318, fdbk: 0.55, mix: 0.45)
    volume 0.4
    pan 0.4
    play beat`x--- ---- --x- ---- ---- x--- ---- --x-` at bars(1..2)
  }
}

// Transition hardware.
block Lift { track R { instrument Riser(climb: 0.85) volume 0.5 pan 0.1 play beat`x--- ---- ---- ----` at bars(1..1) } }
block Hit  { track I { instrument Impact() insert reverb(size: 0.8, decay: 0.6, mix: 0.3) volume 0.6 play beat`x--- ---- ---- ----` at bars(1..1) } }

// Strings for the breakdown — the machine dreams for eight bars.
block Dream {
  key A minor
  let theme = prog`Am | F | C | G`
  track Str {
    instrument StringMachine()
    insert filter(type: "lp", cutoff: 0.4)
    insert eq(low: 0.3, mid: 0.5, high: 0.55)
    insert width(amount: 0.8)
    insert reverb(size: 0.8, decay: 0.7, mix: 0.3)
    volume 0.5
    pan -0.05
    play chords(theme) at bars(1..4)
    automate filter.cutoff from 0.25 to 0.6 over bars(1..8)
  }
}

// Brass hits for the final act.
block Horns {
  key A minor
  track Brass {
    instrument AnalogBrass(blow: 0.6)
    insert eq(low: 0.4, mid: 0.55, high: 0.55)
    insert comp(thresh: 0.45, ratio: 0.5, attack: 0.01, release: 0.15, makeup: 0.15)
    insert drive(drive: 0.2)
    insert width(amount: 0.5)
    volume 0.5
    pan 0.15
    play notes`_:3 [A3 E4 A4]:0.5 _:0.5 _:3 [G3 D4 G4]:0.5 _:0.5` at bars(1..2)
  }
}

song "Boot Sequence" {
  desc "The machine wakes up: a fifths arp that never stops, YMO block chords, tom fills answering a bell hook — every lane a family of blocks that evolves from boot to finale. 118bpm electro."
  artist "Forte Essentials"
  tempo 118bpm
  meter 4/4
  key A minor

  section boot    = bars(1..8)
  section groove  = bars(9..24)
  section theme   = bars(25..40)
  section dream   = bars(41..48)
  section rise    = bars(49..64)
  section finale  = bars(65..80)
  section off     = bars(81..88)

  // boot: POWER ON — an impact, a full tom cascade, the kick and the arp
  // already open on beat one. The machine doesn't fade in, it boots.
  play Hit at bars(1..1)
  play TomFillBig as TomFill at bars(1..1)
  play Pulse at bars(1..8)
  play Blips at bars(3..8)
  play ArpFifths(cutoff: 0.55) at bars(1..88)

  // groove: a second impact, tops and the engine bass pile on
  play Hit at bars(9..9)
  play Pulse at groove
  play TopsIn as Tops at bars(9..16)
  play Tops at bars(17..24)
  play Engine at bars(13..24)
  play TomFill at bars(16..16)
  play TomFill at bars(24..24)

  // theme: the hook sings over the full band
  play Pulse at theme
  play Tops at theme
  play Engine at theme
  play Stabs at theme
  play Hook at theme
  play TomFill at bars(32..32)
  play TomFillBig as TomFill at bars(40..40)

  // dream: drums drop out, strings swell, the arp filters open
  play Lift at bars(40..40)
  play Dream at dream
  play Blips at bars(45..48)
  automate Dream.volume from 0 to 1 over bars(41..44)

  // rise: everything returns a fourth up — the classic YMO lift
  play Hit at bars(49..49)
  play Pulse at rise
  play Tops at rise
  play EngineRise(key: "D minor") as Engine at rise
  play Stabs(key: "D minor") at rise
  play Hook(key: "D minor") at rise
  play TomFill at bars(56..56)
  play TomFillBig as TomFill at bars(64..64)

  // finale: back home, wide variants of every lane, horns and counter on top
  play PulseWide as Pulse at finale
  play TopsWide as Tops at finale
  play EngineWide as Engine at finale
  play Stabs at finale
  play HookWide as Hook at finale
  play Counter at finale
  play Horns at finale
  play TomFill at bars(72..72)
  play TomFillBig as TomFill at bars(80..80)

  // off: the band leaves, the arp and blips power down alone
  play Blips at off
  play Dream(volume: 0.6) at off
  automate ArpFifths.volume from 1 to 0 over bars(81..88)
}
