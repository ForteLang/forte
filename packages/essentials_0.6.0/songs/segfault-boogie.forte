// Segfault Boogie — the crash you can dance to. Denki-school electro
// funk: a clav that won't sit still, a talking wobble lead, cowbells from
// a cheap rhythm box, and one glorious wrong chord where the pointer
// dereferences. 120bpm, swung.
//
// The beat, the box and the clav are FAMILIES of inherited variants on
// ONE lane each (`as`): the same drum track walks in soft, gets funky,
// reboots harder, and jams out with ratchet fills — all visible as one
// evolving line in the arrangement.
import { Kick808, Snare908, HatClosed, HatOpen, Clap, Snap } from "../instruments/drums.forte"
import { BD78, Cowbell78, Claves78, Tamb78 } from "../instruments/cr78.forte"
import { FMBass, RubberBass } from "../instruments/bass.forte"
import { Clav, Wurli } from "../instruments/keys.forte"
import { Wobble, SquareLead } from "../instruments/leads.forte"
import { ChorusPulse } from "../instruments/synths.forte"
import { Zap, Impact, Riser } from "../instruments/fx.forte"

// ---- the beat: ONE lane — funk, harder reboot, jam with fills ------------------
// 808 kick syncopated against a 908 snare, snaps on the backbeat ghosts.
// This is a FUNK pattern, not a techno one.
block Beat {
  track Kick {
    instrument Kick808(punch: 0.65, decay: 0.42)
    insert eq(low: 0.6, mid: 0.45, high: 0.5)
    insert comp(thresh: 0.4, ratio: 0.6, attack: 0.02, release: 0.16, makeup: 0.2)
    volume 0.92
    play beat`X--- --x- ---- x-x- X--- --x- ---x ----` at bars(1..2)
  }
  track Snare {
    instrument Snare908(tone: 0.7, snap: 0.65)
    insert eq(low: 0.3, mid: 0.55, high: 0.6)
    insert comp(thresh: 0.42, ratio: 0.55, attack: 0.005, release: 0.1, makeup: 0.2)
    insert reverb(size: 0.4, decay: 0.3, mix: 0.12)
    volume 0.7
    play beat`---- X--- ---- X--.` at bars(1..1)
  }
  track Snap {
    instrument Snap()
    insert eq(low: 0.15, mid: 0.55, high: 0.6)
    volume 0.4
    pan 0.25
    play beat`---- ---- --x- ----` at bars(1..1)
  }
}
// reboot: tighter comp, ghost kick doubled, snare drags a ghost behind the 2
block BeatHard : Beat {
  track Kick {
    insert comp(thresh: 0.35, ratio: 0.68, attack: 0.015, release: 0.14, makeup: 0.28)
    play beat`X--- --x- --.- x-x- X--- --x- ---x -.x-` at bars(1..2)
  }
  track Snare { volume 0.74 play beat`---- X--- .--- X-.x` at bars(1..1) }
  track Snap  { volume 0.45 play beat`---- ---- --x- --.x` at bars(1..1) }
}
// jam: the full boogie — ratchet snare fill closing every 4th bar
block BeatJam : Beat {
  track Kick {
    play beat`X--- --x- --.- x-x- X--- --x- ---x ---- X--- --x- ---- x-x- X--- --x- x-xx -xx-` at bars(1..4)
  }
  track Snare {
    volume 0.74
    play beat`---- X--- ---- X--. ---- X--- ---- X--. ---- X--- ---- X--. ---- X--- .xxX x.xX` at bars(1..4)
  }
  track Snap { volume 0.45 play beat`---- ---- --x- ---x` at bars(1..1) }
}

// ---- the rhythm box: ONE lane of CR-78 doing its best --------------------------
block Box {
  track Hat {
    instrument HatClosed(bright: 0.85)
    insert eq(low: 0.15, mid: 0.45, high: 0.68)
    volume 0.3
    pan -0.15
    play beat`x.x. x.xX x.x. Xxx.` at bars(1..2)
  }
  track Bell {
    instrument Cowbell78()
    insert eq(low: 0.2, mid: 0.6, high: 0.55)
    insert delay(time: 0.25, fdbk: 0.3, mix: 0.25)
    volume 0.35
    pan 0.3
    play beat`---- --x- ---- ---- ---- --x- -x-- ----` at bars(1..2)
  }
  track Claves {
    instrument Claves78()
    insert eq(low: 0.2, mid: 0.55, high: 0.58)
    volume 0.3
    pan -0.35
    play beat`---x ---- --x- ---- ---x ---- ---- x---` at bars(1..2)
  }
  track Tamb {
    instrument Tamb78()
    insert eq(low: 0.1, mid: 0.5, high: 0.6)
    volume 0.25
    pan 0.1
    play beat`--x- --x- --x- --x-` at bars(1..1)
  }
}
// walk-in: just claves and a far cowbell — the box warming up
block BoxIn : Box {
  track Hat    { volume 0.18 play beat`..x. ..x. ..x. ..x.` at bars(1..1) }
  track Bell   { volume 0.28 insert delay(time: 0.25, fdbk: 0.45, mix: 0.4) play beat`---- ---- ---- --x-` at bars(1..2) }
  track Claves { volume 0.26 play beat`---x ---- ---- ----` at bars(1..2) }
  track Tamb   { volume 0.12 play beat`---- --x- ---- --x-` at bars(1..1) }
}
// jam: the box chatters — tambourine 16ths, cowbell answering itself
block BoxJam : Box {
  track Hat  { volume 0.33 play beat`x.xX xxx. x.xX x.xx` at bars(1..1) }
  track Bell {
    insert delay(time: 0.25, fdbk: 0.4, mix: 0.32)
    volume 0.38
    play beat`---- --x- ---- -x-- ---- --x- -x-- --x-` at bars(1..2)
  }
  track Tamb { volume 0.28 play beat`x.x. x.x. x.x. xxx.` at bars(1..1) }
}

// The bassline: rubber FM funk with octave pops and a chromatic walk-up.
block Rubber {
  key E minor
  track Bass {
    instrument FMBass(bite: 0.5)
    insert eq(low: 0.58, mid: 0.5, high: 0.52)
    insert drive(drive: 0.3)
    insert comp(thresh: 0.45, ratio: 0.5, attack: 0.012, release: 0.14, makeup: 0.2)
    insert pump(amount: 0.3, beats: 1)
    volume 0.75
    play notes`E1:0.25 _:0.25 E2:0.25 E1:0.25 _:0.25 G1:0.25 E1:0.25 _:0.25 B1:0.25 _:0.25 E1:0.25 D2~:0.25 D2:0.25 C2:0.25 B1:0.25 A1!:0.25` at bars(1..2)
    modulate bite with lfo(rate: 0.2, amount: 0.18, shape: "tri")
  }
}
// jam: the walk-up doubles and pops the octave harder
block RubberJam : Rubber {
  track Bass {
    instrument FMBass(bite: 0.6)
    insert drive(drive: 0.38)
    volume 0.78
    play notes`E1:0.25 E2!:0.25 E1:0.25 E2:0.25 _:0.25 G1:0.25 E1:0.25 G2:0.25 B1:0.25 B2!:0.25 E1:0.25 D2~:0.25 D2:0.25 C2:0.25 B1:0.25 A1!:0.25` at bars(1..2)
  }
}

// ---- the clav — the itch of the whole track. ONE lane, three tempers -----------
// 16th funk chops through a touch-wah (LFO on a bandpass), doubled by chorus.
block Itch {
  key E minor
  track Clav {
    instrument Clav(mute: 0.55)
    insert filter(type: "bp", cutoff: 0.5, reso: 0.55)
    insert eq(low: 0.25, mid: 0.55, high: 0.6)
    insert chorus(rate: 0.35, depth: 0.4, mix: 0.3)
    volume 0.55
    pan -0.2
    play notes`E3:0.25 _:0.25 E3:0.25 G3:0.25 _:0.25 E3:0.25 _:0.25 B3:0.25 _:0.25 A3:0.25 G3:0.25 _:0.25 E3:0.25 _:0.25 D3:0.25 E3:0.25` at bars(1..2)
    modulate filter.cutoff with lfo(rate: 0.32, amount: 0.25, shape: "sine")
  }
}
// reboot: the wah opens over sixteen bars — scratching the itch
block ItchOpen : Itch {
  track Clav {
    automate filter.cutoff from 0.4 to 0.62 over bars(1..16)
    automate chorus.mix from 0.3 to 0.42 over bars(9..16)
  }
}
// jam: double chops crowding the offbeats
block ItchJam : Itch {
  track Clav {
    insert filter(type: "bp", cutoff: 0.58, reso: 0.6)
    volume 0.58
    play notes`E3:0.25 E3:0.25 _:0.25 G3:0.25 E3:0.25 _:0.25 B3:0.25 B3:0.25 _:0.25 A3:0.25 G3:0.25 A3:0.25 E3:0.25 D3:0.25 _:0.25 E3:0.25` at bars(1..2)
    modulate filter.cutoff with lfo(rate: 0.4, amount: 0.28, shape: "sine")
  }
}

// The talking lead: a wobble that mumbles the hook, then screams it.
block Mumble {
  key E minor
  track Talk {
    instrument Wobble(rate: 0.3)
    insert eq(low: 0.3, mid: 0.55, high: 0.58)
    insert drive(drive: 0.2)
    insert delay(time: 0.375, fdbk: 0.4, mix: 0.28)
    insert width(amount: 0.5)
    volume 0.55
    pan 0.15
    play notes`_:2 E4:0.5 G4:0.5 A4~:0.5 A4:0.5 G4:0.5 E4~:1.5 _:1.5 B4:0.25 A4:0.25 G4:0.5 E4:0.5 D4~:1 E4:2.5 _:1` at bars(1..4)
  }
}
// the scream: same hook, faster wobble, delay feeding back into the jam
block Scream : Mumble {
  track Talk {
    instrument Wobble(rate: 0.5)
    insert drive(drive: 0.32)
    insert delay(time: 0.375, fdbk: 0.5, mix: 0.36)
    volume 0.58
    automate delay.mix from 0.28 to 0.44 over bars(1..12)
  }
}

// Wurli comping — lazy offbeat chords that keep the funk polite.
block Comp {
  key E minor
  track Keys {
    instrument Wurli(bark: 0.45)
    insert eq(low: 0.3, mid: 0.5, high: 0.55)
    insert chorus(rate: 0.3, depth: 0.5, mix: 0.4)
    insert width(amount: 0.6)
    volume 0.45
    pan 0.05
    play notes`_:0.5 [E3 G3 B3]:0.75 _:0.75 [E3 G3 B3]:0.5 _:1.5 _:0.5 [D3 G3 B3]:0.75 _:0.75 [C3 E3 G3]:0.5 _:1.5` at bars(1..2)
  }
}

// THE SEGFAULT: everything halts on a wrong chord, a zap panic-scatters,
// then the beat reboots. Comedy in four bars.
block Crash {
  key E minor
  track Wrong {
    instrument ChorusPulse()
    insert filter(type: "lp", cutoff: 0.7, reso: 0.5)
    insert eq(low: 0.35, mid: 0.55, high: 0.55)
    insert reverb(size: 0.8, decay: 0.7, mix: 0.4)
    volume 0.6
    pan -0.05
    play notes`[E3 F3 A#3 B3]:3 _:1` at bars(1..1)
    automate filter.cutoff from 0.7 to 0.25 over bars(1..2)
  }
  track Panic {
    instrument Zap()
    insert eq(low: 0.2, mid: 0.5, high: 0.6)
    insert delay(time: 0.19, fdbk: 0.65, mix: 0.5)
    volume 0.5
    pan 0.3
    play beat`x-x- xx-- x--- ----` at bars(2..2)
  }
}

// The reboot lead for the last act — square, proud, slightly too loud.
block Reboot {
  key E minor
  track Lead {
    instrument SquareLead(drive: 0.45)
    insert eq(low: 0.2, mid: 0.55, high: 0.6)
    insert delay(time: 0.25, fdbk: 0.35, mix: 0.25)
    volume 0.5
    pan -0.1
    play notes`E4:0.5 E4:0.25 G4:0.25 A4:0.5 B4~:1 B4:0.5 A4:0.5 G4:0.5 A4~:0.5 G4:0.5 E4:1.5 _:2` at bars(1..2)
  }
}

block Boom { track I { instrument Impact() insert reverb(size: 0.8, decay: 0.6, mix: 0.3) volume 0.6 play beat`x--- ---- ---- ----` at bars(1..1) } }
block Lift { track R { instrument Riser(climb: 0.8) volume 0.5 pan 0.1 play beat`x--- ---- ---- ----` at bars(1..1) } }

song "Segfault Boogie" {
  desc "The crash you can dance to: restless clav funk, a talking wobble lead, CR-78 cowbells — and one glorious wrong chord where the pointer dereferences. 120bpm swung electro funk."
  artist "Forte Essentials"
  tempo 120bpm
  swing 0.56
  meter 4/4
  key E minor

  section walk   = bars(1..8)
  section funk   = bars(9..24)
  section talkA  = bars(25..40)
  section fault  = bars(41..44)
  section reboot = bars(45..60)
  section jam    = bars(61..80)
  section out    = bars(81..88)

  // walk in: bass and the box warming up — the funk before the funk
  play Rubber at walk
  play BoxIn as Box at bars(3..8)

  // funk: the beat drops, clav starts itching
  play Boom at bars(9..9)
  play Beat at funk
  play Box at funk
  play Rubber at funk
  play Itch at bars(13..24)

  // talk: the wobble mumbles the hook over wurli comping
  play Beat at talkA
  play Box at talkA
  play Rubber at talkA
  play Itch at talkA
  play Comp at talkA
  play Mumble at bars(29..40)

  // SEGFAULT (the beat stops mid-sentence)
  play Crash at fault
  play Lift at bars(43..44)

  // reboot: everything returns harder — same lanes, harder variants
  play Boom at bars(45..45)
  play BeatHard as Beat at reboot
  play Box at reboot
  play Rubber at reboot
  play ItchOpen as Itch at reboot
  play Reboot at bars(49..60)

  // jam: full band, jam variants everywhere, both leads trading
  play BeatJam as Beat at jam
  play BoxJam as Box at jam
  play RubberJam as Rubber at jam
  play ItchJam as Itch at jam
  play Comp at jam
  play Scream as Mumble at bars(61..72)
  play Reboot at bars(73..80)

  // out: the machine gives up politely
  play Rubber at out
  play BoxIn as Box at out
  play Comp at out
  automate Rubber.volume from 1 to 0 over bars(85..88)
  automate Box.volume from 1 to 0 over bars(85..88)
  automate Comp.volume from 1 to 0 over bars(85..88)
}
