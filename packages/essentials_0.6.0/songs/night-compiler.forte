// Night Compiler — deep dub techno for the long build. A chord stab
// swimming in feedback delay, a sub that only moves when it must, hats
// like keystrokes at 2am. Nothing shouts; everything accumulates. 128bpm.
import { Kick909, KickSub, HatClosed, HatOpen, Ride, Rim, Shaker } from "../instruments/drums.forte"
import { DubBass } from "../instruments/bass.forte"
import { DarkPad, HollowPad } from "../instruments/pads.forte"
import { PolySaw, VintagePoly } from "../instruments/synths.forte"
import { GlideLead } from "../instruments/leads.forte"
import { Downlifter, Impact } from "../instruments/fx.forte"

// The floor at 2am: a 909 with a sub kick underneath, sidechain source
// for everything above it.
block Floor {
  track Kick {
    instrument Kick909(click: 0.45)
    insert comp(thresh: 0.36, ratio: 0.65, makeup: 0.25)
    volume 0.92
    play beat`X--- x--- x--- x---` at bars(1..4)
  }
  track Sub {
    instrument KickSub(weight: 0.75)
    volume 0.5
    play beat`x--- x--- x--- x---` at bars(1..4)
  }
}

// Keystrokes: shaker 16ths, a rim that lands like the enter key.
block Keys2am {
  track Shk {
    instrument Shaker(soft: 0.4)
    volume 0.3
    pan -0.2
    play beat`x.x. x.x. x.x. x.x.` at bars(1..4)
  }
  track Hat {
    instrument HatClosed(bright: 0.8)
    insert eq(high: 0.65, low: 0.1)
    volume 0.26
    pan 0.15
    play beat`--x- --x- --x- --xX` at bars(1..4)
  }
  track Rim {
    instrument Rim()
    insert delay(time: 0.352, fdbk: 0.5, mix: 0.4)
    volume 0.32
    pan 0.35
    play beat`---- ---- --x- ---- ---- -x-- ---- ----` at bars(1..2)
  }
}

// The sub bassline: three notes an hour. Dub weight, no hurry.
block Deep {
  key F minor
  track Bass {
    instrument DubBass(depth: 0.85)
    insert filter(type: "lp", cutoff: 0.3)
    insert pump(amount: 0.4, beats: 1)
    volume 0.78
    play notes`F1:3 _:1 F1:2 G#1~:2 F1:3 _:1 C1:2 C#1~:2` at bars(1..4)
  }
}

// THE chord — one minor 9 stab thrown into a feedback delay that answers
// across the bar. This is the dub in dub techno.
block Echo {
  key F minor
  track Stab {
    instrument VintagePoly(age: 0.6)
    insert filter(type: "bp", cutoff: 0.45, reso: 0.4)
    insert delay(time: 0.703, fdbk: 0.62, mix: 0.45)
    insert width(amount: 0.75)
    insert pump(amount: 0.35, beats: 1)
    volume 0.5
    play notes`_:0.5 [F3 G#3 C4 D#4 G4]:0.5 _:7 _:0.5 [F3 G#3 C4 D#4 G4]:0.25 _:0.25 [F3 G#3 C4 D#4 G4]:0.5 _:6.5` at bars(1..4)
    modulate filter.cutoff with lfo(rate: 0.08, amount: 0.2, shape: "sine")
  }
}

// The compile loop: a 16th arp that opens over 32 bars — progress bars
// have never sounded this patient.
block Loop {
  key F minor
  let walk = prog`Fm | Fm | G#maj7 | C#maj7`
  track Arp {
    instrument PolySaw(cutoff: 0.35)
    insert drive(drive: 0.15)
    insert delay(time: 0.234, fdbk: 0.4, mix: 0.25)
    insert pump(amount: 0.45, beats: 1)
    volume 0.44
    pan -0.25
    play arp(walk, rate: 0.25, style: "up") at bars(1..8)
    automate cutoff from 0.3 to 0.62 over bars(1..32)
  }
}

// The pad that is actually the room.
block Room {
  key F minor
  track Pad {
    instrument HollowPad()
    insert width(amount: 0.9)
    insert reverb(size: 0.9, decay: 0.8, mix: 0.4)
    insert pump(amount: 0.3, beats: 1)
    volume 0.42
    play notes`[F2 C3 G#3 D#4]:16 [C#2 G#2 F3 C4]:16` at bars(1..8)
  }
}

// One voice, very late: a glide lead that hums four bars and leaves.
block Hum {
  key F minor
  track Lead {
    instrument GlideLead()
    insert delay(time: 0.469, fdbk: 0.45, mix: 0.35)
    insert reverb(size: 0.7, decay: 0.6, mix: 0.25)
    volume 0.45
    pan 0.1
    play notes`_:2 C4~:1.5 D#4~:1 C4~:2 G#3~:1.5 F3:4 _:4` at bars(1..4)
  }
}

block Drop { track D { instrument Downlifter() volume 0.45 play beat`x--- ---- ---- ----` at bars(1..1) } }
block Boom { track I { instrument Impact() insert reverb(size: 0.9, decay: 0.7, mix: 0.4) volume 0.55 play beat`x--- ---- ---- ----` at bars(1..1) } }

song "Night Compiler" {
  desc "Deep dub techno for the long build: one minor-9 stab swimming in feedback delay, a sub that moves three notes an hour, hats like keystrokes at 2am. 128bpm."
  artist "Forte Essentials"
  tempo 128bpm
  meter 4/4
  key F minor

  section boot    = bars(1..8)
  section work    = bars(9..32)
  section deeper  = bars(33..56)
  section pause   = bars(57..64)
  section flow    = bars(65..88)
  section commit  = bars(89..96)

  // boot: room tone and the first echoes
  play Room at boot
  play Echo at bars(5..8)
  automate Room.volume from 0 to 1 over bars(1..6)

  // work: the floor lands, the loop starts compiling
  play Boom at bars(9..9)
  play Floor at work
  play Keys2am at bars(13..32)
  play Deep at work
  play Echo at work
  play Loop at bars(17..32)

  // deeper: ride joins, the loop keeps opening, hum passes through
  play Floor at deeper
  play Keys2am at deeper
  play Deep at deeper
  play Echo at deeper
  play Loop at deeper
  play Room(volume: 0.7) at deeper
  play Hum at bars(41..48)

  // pause: the floor drops out — echoes and the room breathe alone
  play Drop at bars(57..57)
  play Echo at pause
  play Room at pause
  play Loop(volume: 0.6) at pause
  play Hum at bars(61..64)

  // flow: everything returns, arp wide open, hum answering the stab
  play Boom at bars(65..65)
  play Floor at flow
  play Keys2am at flow
  play Deep at flow
  play Echo at flow
  play Loop at flow
  play Room(volume: 0.6) at flow
  play Hum at bars(73..80)
  play Hum at bars(81..88)

  // commit: the floor stops; the delay tail is the exit
  play Echo at commit
  play Room at commit
  automate Echo.volume from 1 to 0 over bars(93..96)
  automate Room.volume from 1 to 0 over bars(93..96)
}
