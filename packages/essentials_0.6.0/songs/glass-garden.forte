// Glass Garden — 24-bar ambient, drumless, block-composed. Glass grains
// (the arp) thicken little by little and dissolve again; the drone block
// inherits a swell for the bloom and a decay for the fade, and the bell
// theme's closing phrase returns as everything melts away.
import { DronePad, GlassPad, ShimmerPad } from "../instruments/pads.forte"
import { Bell, Kalimba } from "../instruments/keys.forte"

// The drone bed: eight bars of slow air.
block Drone {
  key E minor
  let air = prog`Em7 | Cmaj7 | Gmaj7 | Dmaj7`
  return Garden {
    insert reverb(size: 0.9, decay: 0.8, mix: 1.0)
    volume 0.85
  }
  track Drone {
    instrument DronePad()
    send Garden 0.5
    volume 0.5
    play chords(air) at bars(1..8)
  }
}

// Bloom: the same drone, rising out of silence.
block DroneBloom : Drone {
  track Drone {
    automate volume from 0.2 to 0.5 over bars(1..8)
  }
}

// Fade: the same drone, sinking back into it.
block DroneFade : Drone {
  track Drone {
    automate volume from 0.5 to 0.15 over bars(1..8)
  }
}

// Shimmer layer for the full section.
block Shimmer {
  key E minor
  let air = prog`Em7 | Cmaj7 | Gmaj7 | Dmaj7`
  return Garden {
    insert reverb(size: 0.9, decay: 0.8, mix: 1.0)
    volume 0.85
  }
  track Shimmer {
    instrument ShimmerPad()
    send Garden 0.6
    volume 0.4
    pan 0.15
    play chords(air) at bars(1..4)
  }
}

// The glass grains: a delayed kalimba arp.
block Grains {
  key E minor
  let air = prog`Em7 | Cmaj7 | Gmaj7 | Dmaj7`
  return Garden {
    insert reverb(size: 0.9, decay: 0.8, mix: 1.0)
    volume 0.85
  }
  track Grain {
    instrument Kalimba()
    insert delay(time: 0.42, fdbk: 0.5, mix: 0.4)
    send Garden 0.5
    volume 0.4
    pan -0.2
    play arp(air, rate: 0.5, style: "up") at bars(1..4)
  }
}

// Six bars of bell theme; its last two bars are the rising question
// the arrangement brings back at the very end.
block Bells {
  key E minor
  return Garden {
    insert reverb(size: 0.9, decay: 0.8, mix: 1.0)
    volume 0.85
  }
  track Bell {
    instrument Bell(decay: 0.75)
    insert delay(time: 0.63, fdbk: 0.45, mix: 0.4)
    send Garden 0.55
    volume 0.35
    pan 0.25
    play notes`_:3 B4:2 G4:2 _:1 _:2 E5:2 D5:2 B4:2 _:2 G4:2 A4:2 B4:2` at bars(1..6)
  }
}

song "Glass Garden" {
  tempo 62bpm
  meter 4/4
  key E minor

  section bloom = bars(1..8)
  section full  = bars(9..16)
  section fade  = bars(17..24)

  play DroneBloom at bloom
  play Drone at full
  play DroneFade at fade

  play Grains at bars(5..20)
  play Shimmer at full
  play Bells at full
  // only the closing phrase, echoing while the garden dissolves
  play Bells(from: 5, to: 6) at bars(21..24)
}
