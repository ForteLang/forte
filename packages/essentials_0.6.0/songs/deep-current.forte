// Deep Current — 32-bar deep house, block-composed. Sub pressure and
// m9-ish stacks below the surface; the pad floats up in the break, then
// the kit inherits an offbeat hat for the second dive.
import { Kick808, Shaker, Rim, HatOpen } from "../instruments/drums.forte"
import { SubBass } from "../instruments/bass.forte"
import { WarmPad, HollowPad } from "../instruments/pads.forte"
import { Pluck } from "../instruments/leads.forte"

// First-dive kit: four-on-the-floor and a rim into the ocean verb.
block DiveKit {
  let four = beat`x--- x--- x--- x---`
  let rim  = beat`---- x--- --x- x---`
  return Ocean {
    insert reverb(size: 0.75, decay: 0.6, mix: 1.0)
    volume 0.75
  }
  track Kick { instrument Kick808(punch: 0.35, decay: 0.5) volume 0.9 play four at bars(1..1) }
  track Rim  { instrument Rim() volume 0.4 pan -0.2 send Ocean 0.3 play rim at bars(1..1) }
}

// Second dive inherits the kit and opens the offbeats.
block DeepKit : DiveKit {
  let off = beat`--x- --x- --x- --x-`
  track Off { instrument HatOpen(decay: 0.22) volume 0.4 play off at bars(1..1) }
}

// Shaker ostinato — its own layer so it can run across the break.
block Shakes {
  let shk = beat`x-xX x-xx x-xX x-xx`
  track Shk { instrument Shaker() volume 0.35 pan 0.2 play shk at bars(1..1) }
}

// The sub bassline under both dives.
block SubLine {
  key B minor
  let sea = prog`Bm7 | Gmaj7 | Dmaj7 | Em7`
  track Sub {
    instrument SubBass()
    volume 0.85
    play bass(sea, rate: 0.5) at bars(1..4)
  }
}

// The break: a warm pad surfaces (swells in over its first half).
block Surfacing {
  key B minor
  let sea = prog`Bm7 | Gmaj7 | Dmaj7 | Em7`
  return Ocean {
    insert reverb(size: 0.75, decay: 0.6, mix: 1.0)
    volume 0.75
  }
  track Pad {
    instrument WarmPad(cutoff: 0.4)
    send Ocean 0.45
    volume 0.5
    play chords(sea) at bars(1..8)
    automate volume from 0.2 to 0.5 over bars(1..4)
  }
}

// Hollow pad bed for the second dive.
block Undertow {
  key B minor
  let sea = prog`Bm7 | Gmaj7 | Dmaj7 | Em7`
  return Ocean {
    insert reverb(size: 0.75, decay: 0.6, mix: 1.0)
    volume 0.75
  }
  track Hollow {
    instrument HollowPad()
    send Ocean 0.5
    volume 0.35
    play chords(sea) at bars(1..4)
  }
}

// Delayed pluck drops — upward arp; the variant below weaves up and down.
block Drops {
  key B minor
  let sea = prog`Bm7 | Gmaj7 | Dmaj7 | Em7`
  return Ocean {
    insert reverb(size: 0.75, decay: 0.6, mix: 1.0)
    volume 0.75
  }
  track Drops {
    instrument Pluck()
    insert delay(time: 0.375, fdbk: 0.45, mix: 0.35)
    send Ocean 0.4
    volume 0.4
    pan 0.3
    play arp(sea, rate: 0.25, style: "up") at bars(1..4)
  }
}

block DropsWeave : Drops {
  track Drops {
    play arp(sea, rate: 0.25, style: "updown") at bars(1..4)
  }
}

song "Deep Current" {
  tempo 121bpm
  meter 4/4
  key B minor

  section dive    = bars(1..12)
  section surface = bars(13..20)
  section deep    = bars(21..32)

  play DiveKit at dive
  play DeepKit at deep
  play Shakes at bars(5..30)

  play SubLine at dive
  play Drops at bars(9..12)
  play Surfacing at surface
  play SubLine at deep
  play Undertow at deep
  play DropsWeave at deep
}
