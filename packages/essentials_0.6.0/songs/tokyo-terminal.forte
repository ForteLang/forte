// Tokyo Terminal — technopolis synthpop. A pentatonic marimba riff that
// could run a train station, brass hits stabbing the offbeat, strings
// that open like doors, and a disco machine underneath. 122bpm.
import { Kick909, HatClosed, HatOpen, Clap, Tom, TomFloor, Crash } from "../instruments/drums.forte"
import { PluckBass, OctaveBass } from "../instruments/bass.forte"
import { JunoBrass, JunoStrings } from "../instruments/juno60.forte"
import { P5Strings } from "../instruments/prophet5.forte"
import { Marimba, Bell, Celesta } from "../instruments/keys.forte"
import { ChoirPad } from "../instruments/pads.forte"
import { NightLead } from "../instruments/leads.forte"
import { Impact, Riser } from "../instruments/fx.forte"

// Disco machine: four-floor with open hats pushing every offbeat.
block Machine {
  track Kick {
    instrument Kick909(click: 0.5)
    insert comp(thresh: 0.4, ratio: 0.6, makeup: 0.2)
    volume 0.9
    play beat`X--- x--- x--- x---` at bars(1..4)
  }
  track Open {
    instrument HatOpen(decay: 0.3)
    insert pump(amount: 0.35, beats: 1)
    volume 0.4
    play beat`--x- --x- --x- --x-` at bars(1..4)
  }
  track Hats {
    instrument HatClosed(bright: 0.9)
    volume 0.28
    pan 0.2
    play beat`x.x. x.x. x.x. x.x.` at bars(1..4)
  }
  track Clap {
    instrument Clap(tone: 0.55)
    insert reverb(size: 0.5, decay: 0.4, mix: 0.15)
    volume 0.5
    play beat`---- x--- ---- x---` at bars(1..4)
  }
}

// The bass: plucked eighths walking the root, octave pops on the turn.
block Walk {
  key D minor
  track Bass {
    instrument PluckBass(decay: 0.32)
    insert drive(drive: 0.2)
    insert pump(amount: 0.35, beats: 1)
    volume 0.75
    play notes`D1:0.5 D1:0.5 D2:0.5 D1:0.5 D1:0.5 C2:0.5 D1:0.5 A1:0.5 A#0:0.5 A#0:0.5 A#1:0.5 A#0:0.5 C1:0.5 C1:0.5 C2:0.5 G1:0.5` at bars(1..2)
  }
}

// The station riff: marimba pentatonic 16ths, doubled by a celesta an
// octave up — the melody a departure board would sing.
block Departure {
  key D minor
  track Marimba {
    instrument Marimba()
    insert delay(time: 0.246, fdbk: 0.35, mix: 0.22)
    volume 0.6
    pan -0.15
    play notes`D4:0.25 F4:0.25 G4:0.25 A4:0.25 C5:0.25 A4:0.25 G4:0.25 F4:0.25 D4:0.25 F4:0.25 G4:0.25 A4:0.25 G4:0.25 F4:0.25 D4:0.25 C4:0.25` at bars(1..2)
  }
  track Celesta {
    instrument Celesta()
    insert reverb(size: 0.55, decay: 0.45, mix: 0.2)
    volume 0.35
    pan 0.3
    play notes`D5:0.25 F5:0.25 G5:0.25 A5:0.25 C6:0.25 A5:0.25 G5:0.25 F5:0.25 _:4` at bars(1..2)
  }
}

// Brass hits — the exclamation marks. Juno brass, driven, on the
// and-of-two and the four.
block Hits {
  key D minor
  track Brass {
    instrument JunoBrass()
    insert drive(drive: 0.25)
    insert width(amount: 0.55)
    insert reverb(size: 0.45, decay: 0.35, mix: 0.12)
    volume 0.55
    play notes`_:1.5 [D3 A3 D4]:0.25 _:1.25 [D3 A3 D4]:0.5 _:0.5 _:1.5 [C3 G3 C4]:0.25 _:1.25 [A2 E3 A3]:0.5 _:0.5` at bars(1..2)
  }
}

// Strings: the wide shot of the city. Prophet strings under Juno strings,
// two layers breathing at different rates.
block Skyline {
  key D minor
  track P5 {
    instrument P5Strings()
    insert width(amount: 0.8)
    insert reverb(size: 0.8, decay: 0.65, mix: 0.3)
    volume 0.45
    play notes`[D3 F3 A3 D4]:8 [A#2 D3 F3 A#3]:8 [C3 E3 G3 C4]:8 [A2 C#3 E3 A3]:8` at bars(1..8)
  }
  track Juno {
    instrument JunoStrings(bright: 0.55)
    insert chorus(rate: 0.25, depth: 0.5, mix: 0.5)
    insert pump(amount: 0.25, beats: 1)
    volume 0.4
    pan -0.1
    play notes`[F4 A4 D5]:8 [F4 A#4 D5]:8 [E4 G4 C5]:8 [E4 A4 C#5]:8` at bars(1..8)
  }
}

// The vocoder feeling without a vocoder: a choir pad speaking the chords
// through a pumping gate.
block Ghost {
  key D minor
  track Choir {
    instrument ChoirPad()
    insert pump(amount: 0.6, beats: 0.5)
    insert width(amount: 0.7)
    insert delay(time: 0.492, fdbk: 0.35, mix: 0.25)
    volume 0.45
    play notes`[D4 F4 A4]:4 [A#3 D4 F4]:4 [C4 E4 G4]:4 [A3 C#4 E4]:4` at bars(1..4)
  }
}

// The chorus lead — a night synth singing the big tune over everything.
block Anthem {
  key D minor
  track Lead {
    instrument NightLead()
    insert delay(time: 0.369, fdbk: 0.4, mix: 0.3)
    insert reverb(size: 0.6, decay: 0.5, mix: 0.18)
    volume 0.6
    play notes`D5:0.75 E5:0.25 F5:1 A5~:1.5 G5:0.5 F5:0.5 E5:0.5 D5~:1 D5:1 _:0.5 C5:0.5 D5:0.75 E5:0.25 F5:0.5 E5:0.5 D5:0.5 C5~:1.5 D5:2.5 _:1` at bars(1..4)
  }
}

// Rydeen toms close each phrase.
block TomRun {
  track Hi { instrument Tom(fall: 0.35) volume 0.5 pan -0.2 play beat`---- ---- ---- x-xx` at bars(1..1) }
  track Lo { instrument TomFloor(decay: 0.4) volume 0.5 pan 0.25 play beat`---- ---- ---- --x-` at bars(1..1) }
}

block Boom { track I { instrument Impact() insert reverb(size: 0.8, decay: 0.6, mix: 0.3) volume 0.6 play beat`x--- ---- ---- ----` at bars(1..1) } }
block Up   { track R { instrument Riser(climb: 0.85) volume 0.5 play beat`x--- ---- ---- ----` at bars(1..1) } }
block Wash { track C { instrument Crash(decay: 0.85) volume 0.4 play beat`x--- ---- ---- ----` at bars(1..1) } }

song "Tokyo Terminal" {
  desc "Technopolis synthpop: a pentatonic departure-board riff, Juno brass exclamation marks, strings that open like doors over a disco machine. 122bpm."
  artist "Forte Essentials"
  tempo 122bpm
  meter 4/4
  key D minor

  section doors   = bars(1..8)
  section platform = bars(9..24)
  section express = bars(25..40)
  section transfer = bars(41..48)
  section anthem  = bars(49..64)
  section anthem2 = bars(65..80)
  section last    = bars(81..90)

  // doors open: the riff alone with the ghost choir
  play Departure at doors
  play Ghost at doors
  automate Ghost.volume from 0 to 1 over bars(1..4)

  // platform: the machine and the bass arrive
  play Boom at bars(9..9)
  play Machine at platform
  play Walk at platform
  play Departure at platform
  play Hits at bars(17..24)
  play TomRun at bars(16..16)
  play TomRun at bars(24..24)

  // express: strings widen the frame, riff keeps running
  play Wash at bars(25..25)
  play Machine at express
  play Walk at express
  play Departure at express
  play Hits at express
  play Skyline at express
  play TomRun at bars(32..32)
  play TomRun at bars(40..40)

  // transfer: drums thin out, ghost choir and strings hold the hall
  play Up at bars(47..48)
  play Ghost at transfer
  play Skyline(volume: 0.8) at transfer
  play Departure(volume: 0.5) at transfer

  // anthem: the big tune, twice — second time a tone up
  play Boom at bars(49..49)
  play Machine at anthem
  play Walk at anthem
  play Departure at anthem
  play Hits at anthem
  play Anthem at anthem
  play TomRun at bars(56..56)
  play TomRun at bars(64..64)

  play Wash at bars(65..65)
  play Machine at anthem2
  play Walk(key: "E minor") at anthem2
  play Departure(key: "E minor") at anthem2
  play Hits(key: "E minor") at anthem2
  play Skyline(key: "E minor", volume: 0.8) at anthem2
  play Anthem(key: "E minor") at anthem2
  play TomRun at bars(72..72)
  play TomRun at bars(80..80)

  // last train: the riff and the choir, fading down the tunnel
  play Departure(key: "E minor") at last
  play Ghost(key: "E minor") at last
  automate Departure.volume from 1 to 0 over bars(85..90)
  automate Ghost.volume from 1 to 0 over bars(85..90)
}
