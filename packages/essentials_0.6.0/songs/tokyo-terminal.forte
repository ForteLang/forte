// Tokyo Terminal — technopolis synthpop. A pentatonic marimba riff that
// could run a train station, brass hits stabbing the offbeat, strings
// that open like doors, and a disco machine underneath. 122bpm.
//
// The machine, the riff, the bass and the tom runs are FAMILIES of
// inherited variants sharing ONE lane each (`as`): the drum track goes
// platform → express → full anthem on a single line, and the departure
// riff gains echo and a celesta answer as the song travels.
import { Kick909, HatClosed, HatOpen, Clap, Tom, TomFloor, Crash } from "../instruments/drums.forte"
import { PluckBass, OctaveBass } from "../instruments/bass.forte"
import { JunoBrass, JunoStrings } from "../instruments/juno60.forte"
import { P5Strings } from "../instruments/prophet5.forte"
import { Marimba, Bell, Celesta } from "../instruments/keys.forte"
import { ChoirPad } from "../instruments/pads.forte"
import { NightLead } from "../instruments/leads.forte"
import { Impact, Riser } from "../instruments/fx.forte"

// ---- disco machine: ONE lane — platform, express, anthem -----------------------
block Machine {
  track Kick {
    instrument Kick909(click: 0.5)
    insert eq(low: 0.6, mid: 0.45, high: 0.5)
    insert comp(thresh: 0.4, ratio: 0.6, attack: 0.02, release: 0.16, makeup: 0.2)
    volume 0.9
    play beat`X--- x--- x--- x---` at bars(1..4)
  }
  track Open {
    instrument HatOpen(decay: 0.3)
    insert eq(low: 0.1, mid: 0.5, high: 0.62)
    insert pump(amount: 0.35, beats: 1)
    volume 0.4
    pan -0.08
    play beat`--x- --x- --x- --x-` at bars(1..4)
  }
  track Hats {
    instrument HatClosed(bright: 0.9)
    insert eq(low: 0.15, mid: 0.45, high: 0.7)
    insert comp(thresh: 0.5, ratio: 0.45, attack: 0.005, release: 0.08, makeup: 0.1)
    volume 0.28
    pan 0.2
    play beat`x.x. x.x. x.x. x.x.` at bars(1..4)
  }
  track Clap {
    instrument Clap(tone: 0.55)
    insert eq(low: 0.2, mid: 0.6, high: 0.55)
    insert comp(thresh: 0.45, ratio: 0.5, attack: 0.004, release: 0.12, makeup: 0.15)
    insert reverb(size: 0.5, decay: 0.4, mix: 0.15)
    volume 0.5
    pan -0.05
    play beat`---- x--- ---- x---` at bars(1..4)
  }
}
// platform: the machine idles — no clap yet, hats only breathing
block MachineIn : Machine {
  track Hats { volume 0.22 play beat`..x. ..x. ..x. ..x.` at bars(1..4) }
  track Clap { volume 0.42 play beat`---- ---- ---- x---` at bars(1..4) }
  track Open { volume 0.34 }
}
// anthem: ghost hats crowd the grid, the clap answers itself into the room
block MachineFull : Machine {
  track Hats {
    volume 0.32
    play beat`x.xX x.x. xxx. x.xX x.x. x.xX x.xx xxxX` at bars(1..2)
  }
  track Open { insert pump(amount: 0.45, beats: 1) volume 0.46 }
  track Clap {
    insert reverb(size: 0.55, decay: 0.45, mix: 0.22)
    volume 0.55
    play beat`---- x--- ---- x--. ---- x--- .--- x-.x` at bars(1..2)
  }
}

// ---- the bass: ONE lane, walking → sprinting ------------------------------------
block Walk {
  key D minor
  track Bass {
    instrument PluckBass(decay: 0.32)
    insert eq(low: 0.58, mid: 0.5, high: 0.5)
    insert comp(thresh: 0.42, ratio: 0.55, attack: 0.012, release: 0.14, makeup: 0.2)
    insert drive(drive: 0.2)
    insert pump(amount: 0.35, beats: 1)
    volume 0.75
    play notes`D1:0.5 D1:0.5 D2:0.5 D1:0.5 D1:0.5 C2:0.5 D1:0.5 A1:0.5 A#0:0.5 A#0:0.5 A#1:0.5 A#0:0.5 C1:0.5 C1:0.5 C2:0.5 G1:0.5` at bars(1..2)
  }
}
// anthem: 16th pickups between the eighths — the last train is leaving
block WalkRun : Walk {
  track Bass {
    instrument PluckBass(decay: 0.28)
    insert drive(drive: 0.28)
    volume 0.78
    play notes`D1:0.5 D1:0.25 D2:0.25 D2:0.5 D1:0.5 D1:0.5 C2:0.5 D1:0.25 D2:0.25 A1:0.5 A#0:0.5 A#0:0.25 A#1:0.25 A#1:0.5 A#0:0.5 C1:0.5 C1:0.25 C2:0.25 C2:0.5 G1:0.5` at bars(1..2)
  }
}

// ---- the station riff: ONE lane — plain, echoed, answered ----------------------
// Marimba pentatonic 16ths, doubled by a celesta an octave up — the
// melody a departure board would sing.
block Departure {
  key D minor
  track Marimba {
    instrument Marimba()
    insert eq(low: 0.25, mid: 0.55, high: 0.58)
    insert delay(time: 0.246, fdbk: 0.35, mix: 0.22)
    volume 0.6
    pan -0.15
    play notes`D4:0.25 F4:0.25 G4:0.25 A4:0.25 C5:0.25 A4:0.25 G4:0.25 F4:0.25 D4:0.25 F4:0.25 G4:0.25 A4:0.25 G4:0.25 F4:0.25 D4:0.25 C4:0.25` at bars(1..2)
  }
  track Celesta {
    instrument Celesta()
    insert eq(low: 0.15, mid: 0.5, high: 0.6)
    insert reverb(size: 0.55, decay: 0.45, mix: 0.2)
    volume 0.35
    pan 0.3
    play notes`D5:0.25 F5:0.25 G5:0.25 A5:0.25 C6:0.25 A5:0.25 G5:0.25 F5:0.25 _:4` at bars(1..2)
  }
}
// transfer/last: the riff recedes into its own echo
block DepartureEcho : Departure {
  track Marimba {
    insert delay(time: 0.246, fdbk: 0.52, mix: 0.4)
    volume 0.52
    automate delay.mix from 0.25 to 0.45 over bars(1..8)
  }
  track Celesta { volume 0.3 insert reverb(size: 0.7, decay: 0.55, mix: 0.3) }
}
// anthem: the celesta stops waiting and answers the whole phrase
block DepartureFull : Departure {
  track Marimba { volume 0.62 }
  track Celesta {
    volume 0.4
    play notes`_:2 C6:0.25 A5:0.25 G5:0.25 F5:0.25 _:1 D5:0.25 F5:0.25 G5:0.25 A5:0.25 _:2` at bars(1..2)
  }
}

// Brass hits — the exclamation marks. Juno brass, driven, on the
// and-of-two and the four.
block Hits {
  key D minor
  track Brass {
    instrument JunoBrass()
    insert eq(low: 0.4, mid: 0.55, high: 0.55)
    insert comp(thresh: 0.45, ratio: 0.5, attack: 0.008, release: 0.12, makeup: 0.18)
    insert drive(drive: 0.25)
    insert width(amount: 0.55)
    insert reverb(size: 0.45, decay: 0.35, mix: 0.12)
    volume 0.55
    pan 0.1
    play notes`_:1.5 [D3 A3 D4]:0.25 _:1.25 [D3 A3 D4]:0.5 _:0.5 _:1.5 [C3 G3 C4]:0.25 _:1.25 [A2 E3 A3]:0.5 _:0.5` at bars(1..2)
  }
}

// Strings: the wide shot of the city. Prophet strings under Juno strings,
// two layers breathing at different rates.
block Skyline {
  key D minor
  track P5 {
    instrument P5Strings()
    insert eq(low: 0.35, mid: 0.5, high: 0.55)
    insert width(amount: 0.8)
    insert reverb(size: 0.8, decay: 0.65, mix: 0.3)
    volume 0.45
    pan -0.05
    play notes`[D3 F3 A3 D4]:8 [A#2 D3 F3 A#3]:8 [C3 E3 G3 C4]:8 [A2 C#3 E3 A3]:8` at bars(1..8)
  }
  track Juno {
    instrument JunoStrings(bright: 0.55)
    insert eq(low: 0.3, mid: 0.5, high: 0.58)
    insert chorus(rate: 0.25, depth: 0.5, mix: 0.5)
    insert pump(amount: 0.25, beats: 1)
    volume 0.4
    pan -0.1
    play notes`[F4 A4 D5]:8 [F4 A#4 D5]:8 [E4 G4 C5]:8 [E4 A4 C#5]:8` at bars(1..8)
  }
}

// The vocoder feeling without a vocoder: a choir pad speaking the chords
// through a pumping gate.
block Ghost {
  key D minor
  track Choir {
    instrument ChoirPad()
    insert eq(low: 0.3, mid: 0.5, high: 0.55)
    insert pump(amount: 0.6, beats: 0.5)
    insert width(amount: 0.7)
    insert delay(time: 0.492, fdbk: 0.35, mix: 0.25)
    volume 0.45
    pan 0.05
    play notes`[D4 F4 A4]:4 [A#3 D4 F4]:4 [C4 E4 G4]:4 [A3 C#4 E4]:4` at bars(1..4)
  }
}

// The chorus lead — a night synth singing the big tune over everything.
block Anthem {
  key D minor
  track Lead {
    instrument NightLead()
    insert eq(low: 0.25, mid: 0.55, high: 0.6)
    insert delay(time: 0.369, fdbk: 0.4, mix: 0.3)
    insert reverb(size: 0.6, decay: 0.5, mix: 0.18)
    volume 0.6
    pan -0.05
    play notes`D5:0.75 E5:0.25 F5:1 A5~:1.5 G5:0.5 F5:0.5 E5:0.5 D5~:1 D5:1 _:0.5 C5:0.5 D5:0.75 E5:0.25 F5:0.5 E5:0.5 D5:0.5 C5~:1.5 D5:2.5 _:1` at bars(1..4)
  }
}
// second chorus: the delay sings along and the room doubles
block AnthemWide : Anthem {
  track Lead {
    insert delay(time: 0.369, fdbk: 0.5, mix: 0.38)
    insert reverb(size: 0.72, decay: 0.6, mix: 0.26)
    volume 0.62
    automate delay.mix from 0.3 to 0.45 over bars(9..16)
  }
}

// ---- Rydeen toms close each phrase: ONE lane, run → cascade --------------------
block TomRun {
  track Hi {
    instrument Tom(fall: 0.35)
    insert eq(low: 0.45, mid: 0.55, high: 0.5)
    insert comp(thresh: 0.45, ratio: 0.5, attack: 0.008, release: 0.12, makeup: 0.15)
    volume 0.5
    pan -0.2
    play beat`---- ---- ---- x-xx` at bars(1..1)
  }
  track Lo {
    instrument TomFloor(decay: 0.4)
    insert eq(low: 0.55, mid: 0.5, high: 0.45)
    insert comp(thresh: 0.45, ratio: 0.5, attack: 0.01, release: 0.14, makeup: 0.15)
    volume 0.5
    pan 0.25
    play beat`---- ---- ---- --x-` at bars(1..1)
  }
}
// phrase-end cascade for the anthems
block TomRunBig : TomRun {
  track Hi { volume 0.55 play beat`---- x-x- x.xx xxxx` at bars(1..1) }
  track Lo { volume 0.55 play beat`---- ---- x--- x-xx` at bars(1..1) }
}

block Boom { track I { instrument Impact() insert reverb(size: 0.8, decay: 0.6, mix: 0.3) volume 0.6 play beat`x--- ---- ---- ----` at bars(1..1) } }
block Up   { track R { instrument Riser(climb: 0.85) volume 0.5 pan 0.1 play beat`x--- ---- ---- ----` at bars(1..1) } }
block Wash { track C { instrument Crash(decay: 0.85) volume 0.4 pan 0.2 play beat`x--- ---- ---- ----` at bars(1..1) } }

song "Tokyo Terminal" {
  desc "Technopolis synthpop: a pentatonic departure-board riff, Juno brass exclamation marks, strings that open like doors over a disco machine — every lane an evolving family of blocks. 122bpm."
  artist "Forte Essentials"
  tempo 122bpm
  meter 4/4
  key D minor

  section doors   = bars(1..8)
  section platform = bars(9..24)
  section express = bars(25..40)
  section transfer = bars(41..48)
  section anthem  = bars(49..64)
  section anthem2 = bars(65..80)
  section last    = bars(81..90)

  // doors open: the riff alone with the ghost choir
  play Departure at doors
  play Ghost at doors
  automate Ghost.volume from 0 to 1 over bars(1..4)

  // platform: the machine idles in, the bass walks
  play Boom at bars(9..9)
  play MachineIn as Machine at bars(9..16)
  play Machine at bars(17..24)
  play Walk at platform
  play Departure at platform
  play Hits at bars(17..24)
  play TomRun at bars(16..16)
  play TomRun at bars(24..24)

  // express: strings widen the frame, riff keeps running
  play Wash at bars(25..25)
  play Machine at express
  play Walk at express
  play Departure at express
  play Hits at express
  play Skyline at express
  play TomRun at bars(32..32)
  play TomRunBig as TomRun at bars(40..40)

  // transfer: drums thin out, the riff recedes into its echo
  play Up at bars(47..48)
  play Ghost at transfer
  play Skyline(volume: 0.8) at transfer
  play DepartureEcho as Departure at transfer

  // anthem: the big tune over the full machine
  play Boom at bars(49..49)
  play MachineFull as Machine at anthem
  play WalkRun as Walk at anthem
  play DepartureFull as Departure at anthem
  play Hits at anthem
  play Anthem at anthem
  play TomRun at bars(56..56)
  play TomRunBig as TomRun at bars(64..64)

  // anthem again, a tone up — the classic key lift
  play Wash at bars(65..65)
  play MachineFull as Machine at anthem2
  play WalkRun(key: "E minor") as Walk at anthem2
  play DepartureFull(key: "E minor") as Departure at anthem2
  play Hits(key: "E minor") at anthem2
  play Skyline(key: "E minor", volume: 0.8) at anthem2
  play AnthemWide(key: "E minor") as Anthem at anthem2
  play TomRun at bars(72..72)
  play TomRunBig as TomRun at bars(80..80)

  // last train: the riff and the choir, fading down the tunnel
  play DepartureEcho(key: "E minor") as Departure at last
  play Ghost(key: "E minor") at last
  automate Departure.volume from 1 to 0 over bars(85..90)
  automate Ghost.volume from 1 to 0 over bars(85..90)
}
