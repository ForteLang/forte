// Neon Nights — synthwave, 32 bars, rebuilt the block way. Gated-reverb
// snare, a running 16th bass, and a lead melody that arrives at the chorus.
// Each role is a block; the song only decides when everything plays.
import { Kick808, SnareTight, HatClosed, Crash } from "../instruments/drums.forte"
import { RetroWave, StringMachine } from "../instruments/synths.forte"
import { EightiesPad } from "../instruments/pads.forte"
import { SoftLead } from "../instruments/leads.forte"

// The kick alone — the pulse that starts before the full kit.
block Pulse {
  track Kick { instrument Kick808(punch: 0.5, decay: 0.45) volume 0.9 play beat`x--- ---- x--- ----` at bars(1..4) }
}

// Full kit: the pulse plus the gated snare and ticking hats. The gate
// return lives here with its only sender.
block Drums : Pulse {
  return Gate {
    insert reverb(size: 0.7, decay: 0.35, mix: 1.0)
    volume 0.75
  }
  track Snare { instrument SnareTight(snap: 0.7) volume 0.75 send Gate 0.45 play beat`---- X--- ---- X---` at bars(1..4) }
  track Hat   { instrument HatClosed(bright: 0.85) volume 0.3 pan 0.15 play beat`x-x- x-x- x-x- x-x-` at bars(1..4) }
}

// One washed crash to open the chorus.
block Splash {
  track Cym { instrument Crash(decay: 0.85) insert reverb(size: 0.7, decay: 0.35, mix: 0.3) volume 0.4 play beat`x--- ---- ---- ----` at bars(1..1) }
}

// Running 16th bass over the night-drive changes.
block Bassline {
  key A minor
  let night = prog`Am | F | C | G`
  let lift  = prog`F | G | Am | Am`
  track Bass {
    instrument RetroWave()
    volume 0.7
    play arp(night, rate: 0.25, style: "up") at bars(1..4)
  }
}

// Chorus variant: same bass, the lifted changes.
block BasslineLift : Bassline {
  track Bass { play arp(lift, rate: 0.25, style: "up") at bars(1..4) }
}

// The pad bed, sent to its own gate wash.
block PadBed {
  key A minor
  let night = prog`Am | F | C | G`
  let lift  = prog`F | G | Am | Am`
  return Gate {
    insert reverb(size: 0.7, decay: 0.35, mix: 1.0)
    volume 0.75
  }
  track Pad {
    instrument EightiesPad(shimmer: 0.45)
    send Gate 0.35
    volume 0.5
    play chords(night) at bars(1..4)
  }
}

// Intro variant: eight bars fading in from nothing.
block PadIntro : PadBed {
  track Pad {
    play chords(night) at bars(1..8)
    automate volume from 0.25 to 0.5 over bars(1..8)
  }
}

// Chorus variant: the lifted changes under the strings.
block PadLift : PadBed {
  track Pad { play chords(lift) at bars(1..4) }
}

// String machine doubling the chorus lift.
block Strings {
  key A minor
  let lift = prog`F | G | Am | Am`
  return Gate {
    insert reverb(size: 0.7, decay: 0.35, mix: 1.0)
    volume 0.75
  }
  track Strings {
    instrument StringMachine()
    send Gate 0.4
    volume 0.4
    pan -0.15
    play chords(lift) at bars(1..4)
  }
}

// The verse hook — a soft lead humming over the changes.
block Hook {
  key A minor
  return Gate {
    insert reverb(size: 0.7, decay: 0.35, mix: 1.0)
    volume 0.75
  }
  track Lead {
    instrument SoftLead()
    insert delay(time: 0.35, fdbk: 0.4, mix: 0.3)
    send Gate 0.35
    volume 0.5
    pan 0.1
    play notes`_:2 E4:1 C4:0.5 A3:0.5 _:2 F4:1 E4:0.5 C4:1.5 _:2 G4:1 E4:0.5 D4:0.5 C4:2` at bars(1..8)
  }
}

// Chorus variant: the anthem melody.
block HookChorus : Hook {
  track Lead {
    play notes`A4:1.5 G4:0.5 E4:1 C4:1 F4:1.5 E4:0.5 D4:1 G4:1 A4:1.5 G4:0.5 E4:1 G4:1 A4:3 _:1` at bars(1..8)
  }
}

song "Neon Nights" {
  tempo 106bpm
  meter 4/4
  key A minor

  section intro  = bars(1..8)
  section verse  = bars(9..16)
  section chorus = bars(17..28)
  section outro  = bars(29..32)

  play Pulse at bars(3..8)
  play PadIntro at intro

  play Drums at bars(9..30)
  play Pulse at bars(31..31)
  play Splash at bars(17..17)

  play Bassline at verse
  play BasslineLift at chorus

  play PadBed at verse
  play PadLift at chorus
  play PadBed at outro

  play Strings at chorus

  play Hook at verse
  play HookChorus at chorus
}
