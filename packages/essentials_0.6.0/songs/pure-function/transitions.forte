// Pure Function — transitions parts.
import { Zap, Impact } from "../../instruments/fx.forte"

block Hit { track I { instrument Impact() insert reverb(size: 0.8, decay: 0.6, mix: 0.3) volume 0.6 play beat`x--- ---- ---- ----` at bars(1..1) } }

block Ping { track Z { instrument Zap() insert delay(time: 0.254, fdbk: 0.6, mix: 0.5) insert eq(low: 0.2, mid: 0.5, high: 0.6) volume 0.35 pan -0.3 play beat`x--- ---- ---- --x- ---- -x-- ---- ----` at bars(1..2) } }
