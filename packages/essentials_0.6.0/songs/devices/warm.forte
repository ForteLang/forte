// warm.forte — a homemade instrument library. A file without a song is a device
// library and can be imported by other songs (verify: forte check songs/devices/warm.forte).

device WarmLead : Instrument {
  param cutoff = 0.6 in 0.0..1.0
  param vib    = 0.25

  node o    = osc(shape: "saw")                       // freq defaults to note.freq
  node env  = adsr(a: 0.03, d: 0.25, s: 0.6, r: 0.3)  // gate defaults to note.gate
  node wob  = lfo(rate: vib, shape: "sine")
  node f    = svf(in: o, cutoff: cutoff, reso: 0.3, mod: wob)
  out gain(in: f, mod: env, level: 0.9)
}

device SubBass : Instrument {
  param drivein = 0.7

  node o   = osc(shape: "square")
  node env = adsr(a: 0.01, d: 0.2, s: 0.7, r: 0.15)
  node f   = svf(in: o, cutoff: 0.25, reso: 0.15)
  out gain(in: f, mod: env, level: drivein)
}
