// Midnight Roller â€” 32-bar late-night DnB, block-composed. The reese
// growls over the break; the breakdown strips everything back to pad and
// lead, and the second drop inherits the bassline at half speed.
import { Kick909, SnareTight, HatClosed, Crash } from "../instruments/drums.forte"
import { ReeseBass, SubBass } from "../instruments/bass.forte"
import { DarkPad } from "../instruments/pads.forte"
import { NightLead } from "../instruments/leads.forte"
import { Riser } from "../instruments/fx.forte"

// The roller kit: 2-bar broken kick, cross-snare, restless hats.
block RollerKit {
  let kick  = beat`x--- ---- --x- ---- x--- ---- ---- x---`
  let snare = beat`---- X--- ---- X--- ---- X--- --x- X---`
  let hat   = beat`x-xx x-xx xxx- x-xx x-xx x-xx x-xx xx-x`
  return Void {
    insert reverb(size: 0.7, decay: 0.5, mix: 1.0)
    volume 0.6
  }
  track Kick  { instrument Kick909(click: 0.6) volume 0.9 play kick at bars(1..2) }
  track Snare { instrument SnareTight(snap: 0.8) volume 0.75 send Void 0.15 play snare at bars(1..2) }
  track Hat   { instrument HatClosed(bright: 0.95) volume 0.35 pan 0.2 play hat at bars(1..2) }
}

// One crash to open the second drop.
block Smash {
  return Void {
    insert reverb(size: 0.7, decay: 0.5, mix: 1.0)
    volume 0.6
  }
  track Cym { instrument Crash(decay: 0.9) volume 0.4 send Void 0.3 play beat`x--- ---- ---- ----` at bars(1..1) }
}

// The reese, snarling one note per bar through the first drop.
block Roller {
  key E minor
  let deep = prog`Em | Em | C | D`
  track Reese {
    instrument ReeseBass()
    insert drive(drive: 0.25)
    volume 0.75
    play bass(deep, rate: 1) at bars(1..4)
  }
}

// Second drop: same reese, half-speed and heavier.
block RollerWide : Roller {
  track Reese {
    play bass(deep, rate: 0.5) at bars(1..4)
  }
}

// The breakdown: sub holds the floor, the pad swells, the lead sings,
// and a riser drags everything into the second drop.
block Breakdown {
  key E minor
  let deep = prog`Em | Em | C | D`
  return Void {
    insert reverb(size: 0.7, decay: 0.5, mix: 1.0)
    volume 0.6
  }
  track Sub {
    instrument SubBass()
    volume 0.6
    play bass(deep, rate: 2) at bars(1..8)
  }
  track Pad {
    instrument DarkPad()
    send Void 0.5
    volume 0.45
    play chords(deep) at bars(1..8)
    automate volume from 0.15 to 0.5 over bars(1..8)
  }
  track Lead {
    instrument NightLead()
    insert delay(time: 0.17, fdbk: 0.35, mix: 0.25)
    send Void 0.35
    volume 0.4
    pan 0.15
    play notes`_:4 E4:0.5 G4:0.5 B4:1 A4:1 G4:0.5 E4:1.5 _:3 D4:0.5 E4:0.5 G4:1.5 E4:1.5` at bars(1..8)
  }
  track Rise {
    instrument Riser(climb: 0.85)
    send Void 0.3
    volume 0.45
    play notes`C3:8` at bars(7..8)
  }
}

song "Midnight Roller" {
  tempo 172bpm
  meter 4/4
  key E minor

  section drop1 = bars(1..12)
  section break = bars(13..20)
  section drop2 = bars(21..32)

  play RollerKit at drop1
  play Roller at drop1
  play Breakdown at break
  play Smash at bars(21..21)
  play RollerKit at drop2
  play RollerWide at drop2
}
