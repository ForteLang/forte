// Juno Nights — 32-bar 80s synth-pop, block-composed. A CR-78 intro
// hands the baton to the 808; Juno strings (chorus required) carry the
// verse, and the P5 brass + SH101 hook owns the chorus. The string and
// pad blocks swap their progression by inheritance for the hook.
import { JunoStrings, JunoBass, JunoPad } from "../instruments/juno60.forte"
import { P5Brass } from "../instruments/prophet5.forte"
import { SH101Lead } from "../instruments/sh101.forte"
import { BD78, HH78, SD78 } from "../instruments/cr78.forte"
import { BD808, SD808, CH808, OH808, CP808 } from "../instruments/tr808.forte"

// The CR-78 rhythm box that opens the song.
block Cr78Box {
  let bd78 = beat`x--- ---- x-x- ----`
  let hh78 = beat`x-x- x-x- x-x- x-x-`
  let sd78 = beat`---- x--- ---- x---`
  track BD78 { instrument BD78() volume 0.8 play bd78 at bars(1..1) }
  track HH78 { instrument HH78() volume 0.45 pan 0.15 play hh78 at bars(1..1) }
  track SD78 { instrument SD78() volume 0.55 play sd78 at bars(1..1) }
}

// The 808 kick: a 4-bar phrase with its pickup fill, running to the end.
block Pulse808 {
  let kick = beat`x--- ---- x--- --x- x--- ---- x--- ---- x--- ---- x--- --x- x--- ---- x--. x---`
  track BD { instrument BD808(tone: 0.4, decay: 0.5) insert comp(thresh: 0.45, ratio: 0.5) volume 0.9 play kick at bars(1..4) }
}

// Snare + closed hats on top of the 808 kick.
block Backbeat808 {
  let snare = beat`---- X--- ---- X---`
  let chh   = beat`x.x. x.x. x.x. x.xX`
  return Neon {
    insert reverb(size: 0.7, decay: 0.4, mix: 1.0)
    volume 0.7
  }
  track SD { instrument SD808(snappy: 0.6) send Neon 0.35 volume 0.75 play snare at bars(1..1) }
  track CH { instrument CH808() volume 0.4 pan 0.15 play chh at bars(1..1) }
}

// Open hats joining from the chorus onward.
block OpenHats {
  let ohh = beat`--x- ---- --x- ----`
  track OH { instrument OH808(decay: 0.3) volume 0.35 pan -0.1 play ohh at bars(1..1) }
}

// Chorus claps.
block NeonClaps {
  let clap = beat`---- x--- ---- x--x`
  return Neon {
    insert reverb(size: 0.7, decay: 0.4, mix: 1.0)
    volume 0.7
  }
  track CP { instrument CP808(room: 0.5) send Neon 0.3 volume 0.5 play clap at bars(1..1) }
}

// The Juno bass: a 4.5-beat riff, written across 9 bars so eight
// repetitions land exactly back on the downbeat.
block NightBass {
  key F minor
  track Bass {
    instrument JunoBass()
    insert comp(thresh: 0.5, ratio: 0.4)
    volume 0.8
    play notes`F1:0.5 F1:0.25 F2:0.25 _:0.25 F1:0.5 Eb2:0.25 _:0.25 F1:0.25 F2:0.5 Db2:0.25 _:0.25 C2:0.5 F1:0.5` at bars(1..9)
  }
}

// Juno strings over the night changes (chorus insert is mandatory).
block NightStrings {
  key F minor
  let night = prog`Fm | Db | Ab | Eb`
  return Neon {
    insert reverb(size: 0.7, decay: 0.4, mix: 1.0)
    volume 0.7
  }
  track Strings {
    instrument JunoStrings(bright: 0.55)
    insert chorus(rate: 0.3, depth: 0.55, mix: 0.55)
    send Neon 0.4
    volume 0.5
    play chords(night) at bars(1..8)
  }
}

// Verse entrance: the same strings fading up over the first four bars.
block RisingStrings : NightStrings {
  track Strings {
    automate volume from 0.2 to 0.5 over bars(1..4)
  }
}

// Chorus strings: same block, hook progression.
block HookStrings : NightStrings {
  let night = prog`Db | Eb | Fm | Fm`
}

// Wide Juno pad on the night changes.
block NightPad {
  key F minor
  let night = prog`Fm | Db | Ab | Eb`
  return Neon {
    insert reverb(size: 0.7, decay: 0.4, mix: 1.0)
    volume 0.7
  }
  track Pad {
    instrument JunoPad()
    insert chorus(rate: 0.25, depth: 0.5, mix: 0.5)
    insert width(amount: 0.85)
    send Neon 0.45
    volume 0.45
    play chords(night) at bars(1..4)
  }
}

// The pad follows the hook in the chorus.
block HookPad : NightPad {
  let night = prog`Db | Eb | Fm | Fm`
}

// P5 brass stabs for the hook.
block HookBrass {
  key F minor
  return Neon {
    insert reverb(size: 0.7, decay: 0.4, mix: 1.0)
    volume 0.7
  }
  track Brass {
    instrument P5Brass(blow: 0.55)
    send Neon 0.3
    volume 0.5
    pan -0.1
    play notes`_:2 [Db4 F4 Ab4]:0.75 _:0.25 [Eb4 G4 Bb4]:0.75 _:0.25 [F4 Ab4 C5]:2 _:2` at bars(1..2)
  }
}

// The SH101 lead: the chorus melody rises, the outro lets it fall away.
block NightLead {
  key F minor
  section rise = bars(1..8)
  section fall = bars(9..16)
  return Neon {
    insert reverb(size: 0.7, decay: 0.4, mix: 1.0)
    volume 0.7
  }
  track Lead {
    instrument SH101Lead(glide: 0.07)
    insert delay(time: 0.288, fdbk: 0.35, mix: 0.3)
    send Neon 0.35
    volume 0.45
    pan 0.15
    play notes`_:2 C5:0.75 Ab4~:0.75 F4:1.5 _:1 Db5~:1 C5:0.75 Ab4~:1.25 _:2 Eb5:0.75 C5~:0.75 Ab4:1.5 F4~:3` at rise
    play notes`_:4 F5~:1.5 Eb5~:1 C5~:1.5 _:8` at fall
  }
}

song "Juno Nights" {
  tempo 104bpm
  swing 0.52
  meter 4/4
  key F minor

  section intro  = bars(1..8)
  section verse  = bars(9..16)
  section chorus = bars(17..24)
  section outro  = bars(25..32)

  play Cr78Box at intro
  play NightPad at intro

  play Pulse808 at bars(9..31)
  play Backbeat808 at bars(9..30)
  play OpenHats at bars(17..30)
  play NeonClaps at chorus

  play NightBass at bars(9..30)
  play RisingStrings at verse
  play HookStrings at chorus
  play HookPad at chorus
  play HookBrass at chorus
  play NightLead at bars(17..32)
  play NightStrings at outro
}
