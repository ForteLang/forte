// Tokyo Terminal — toms parts.
import { Tom, TomFloor } from "../../instruments/drums.forte"

// ---- Rydeen toms close each phrase: ONE lane, run → cascade --------------------
block TomRun {
  track Hi {
    instrument Tom(fall: 0.35)
    insert eq(low: 0.45, mid: 0.55, high: 0.5)
    insert comp(thresh: 0.45, ratio: 0.5, attack: 0.008, release: 0.12, makeup: 0.15)
    volume 0.5
    pan -0.2
    play beat`---- ---- ---- x-xx` at bars(1..1)
  }
  track Lo {
    instrument TomFloor(decay: 0.4)
    insert eq(low: 0.55, mid: 0.5, high: 0.45)
    insert comp(thresh: 0.45, ratio: 0.5, attack: 0.01, release: 0.14, makeup: 0.15)
    volume 0.5
    pan 0.25
    play beat`---- ---- ---- --x-` at bars(1..1)
  }
}

// phrase-end cascade for the anthems
block TomRunBig : TomRun {
  track Hi { volume 0.55 play beat`---- x-x- x.xx xxxx` at bars(1..1) }
  track Lo { volume 0.55 play beat`---- ---- x--- x-xx` at bars(1..1) }
}
