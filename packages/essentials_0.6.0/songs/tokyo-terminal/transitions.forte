// Tokyo Terminal — transitions parts.
import { Crash } from "../../instruments/drums.forte"
import { Impact, Riser } from "../../instruments/fx.forte"

block Boom { track I { instrument Impact() insert reverb(size: 0.8, decay: 0.6, mix: 0.3) volume 0.6 play beat`x--- ---- ---- ----` at bars(1..1) } }

block Up   { track R { instrument Riser(climb: 0.85) volume 0.5 pan 0.1 play beat`x--- ---- ---- ----` at bars(1..1) } }

block Wash { track C { instrument Crash(decay: 0.85) volume 0.4 pan 0.2 play beat`x--- ---- ---- ----` at bars(1..1) } }
