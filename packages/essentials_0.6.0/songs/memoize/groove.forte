// Memoize — groove parts.
import { Kick808, SnareTight, HatClosed, HatPedal } from "../../instruments/drums.forte"
import { Bongo, Cabasa } from "../../instruments/percussion.forte"

// ---- the groove: nested kit + hands, aliased densities ----------------------------
block Groove {
  block Kit {
    track Kick {
      instrument Kick808(punch: 0.5, decay: 0.4)
      insert eq(low: 0.58, mid: 0.45, high: 0.46)
      insert comp(thresh: 0.42, ratio: 0.58, attack: 0.02, release: 0.16, makeup: 0.18)
      volume 0.84
      play beat`X--- --x- ---- x--- X--- ---- --x- ----` at bars(1..2)
    }
    track Snare {
      instrument SnareTight(snap: 0.55)
      insert eq(low: 0.25, mid: 0.55, high: 0.56)
      insert comp(thresh: 0.44, ratio: 0.52, attack: 0.006, release: 0.1, makeup: 0.16)
      insert reverb(size: 0.45, decay: 0.35, mix: 0.14)
      volume 0.52
      pan 0.05
      play beat`---- x--- ---- x--.` at bars(1..1)
    }
    track Ped {
      instrument HatPedal()
      insert eq(low: 0.1, mid: 0.5, high: 0.56)
      volume 0.18
      pan -0.12
      play beat`--x- --x- --x- --x-` at bars(1..4)
    }
  }
  block HandsPerc {
    track Hat {
      instrument HatClosed(bright: 0.78)
      insert eq(low: 0.12, mid: 0.45, high: 0.64)
      insert comp(thresh: 0.5, ratio: 0.45, attack: 0.005, release: 0.08, makeup: 0.1)
      volume 0.24
      pan 0.18
      play beat`x.x. x.xX x.x. x.x.` at bars(1..2)
    }
    track Bongo {
      instrument Bongo()
      insert eq(low: 0.3, mid: 0.55, high: 0.52)
      insert delay(time: 0.268, fdbk: 0.3, mix: 0.22)
      volume 0.26
      pan -0.3
      play beat`---- --x- ---- -x-- ---x --x- ---- ----` at bars(1..2)
    }
    track Cab {
      instrument Cabasa()
      insert eq(low: 0.1, mid: 0.5, high: 0.6)
      volume 0.18
      pan 0.3
      play beat`.x.x .x.x .x.x .x.x` at bars(1..2)
    }
  }
  play Kit at bars(1..4)
  play HandsPerc at bars(1..4)
}

// first call: kit only, hands still empty
block GrooveCold : Groove {
  block HandsPerc {
    track Hat {
      instrument HatClosed(bright: 0.72)
      insert eq(low: 0.12, mid: 0.45, high: 0.6)
      insert comp(thresh: 0.5, ratio: 0.45, attack: 0.005, release: 0.08, makeup: 0.1)
      volume 0.16
      pan 0.18
      play beat`..x. ..x. ..x. ..x.` at bars(1..2)
    }
    track Bongo {
      instrument Bongo()
      insert eq(low: 0.3, mid: 0.55, high: 0.52)
      insert delay(time: 0.268, fdbk: 0.3, mix: 0.22)
      volume 0.18
      pan -0.3
      play beat`---- ---- ---- -x--` at bars(1..2)
    }
    track Cab {
      instrument Cabasa()
      insert eq(low: 0.1, mid: 0.5, high: 0.6)
      volume 0.1
      pan 0.3
      play beat`.x.. .x.. .x.. .x..` at bars(1..2)
    }
  }
}

// hot path: everything answering everything
block GrooveHot : Groove {
  block Kit {
    track Kick {
      instrument Kick808(punch: 0.55, decay: 0.4)
      insert eq(low: 0.58, mid: 0.45, high: 0.46)
      insert comp(thresh: 0.4, ratio: 0.6, attack: 0.018, release: 0.15, makeup: 0.2)
      volume 0.86
      play beat`X--- --x- --.- x--- X--- --x- --x- -.x-` at bars(1..2)
    }
    track Snare {
      instrument SnareTight(snap: 0.6)
      insert eq(low: 0.25, mid: 0.55, high: 0.58)
      insert comp(thresh: 0.42, ratio: 0.55, attack: 0.006, release: 0.1, makeup: 0.18)
      insert reverb(size: 0.45, decay: 0.35, mix: 0.14)
      volume 0.55
      pan 0.05
      play beat`---- x--- --.- x--. ---- x--- .--- x.x.` at bars(1..2)
    }
    track Ped {
      instrument HatPedal()
      insert eq(low: 0.1, mid: 0.5, high: 0.56)
      volume 0.22
      pan -0.12
      play beat`--x- --x- --x- --xx` at bars(1..4)
    }
  }
  block HandsPerc {
    track Hat {
      instrument HatClosed(bright: 0.82)
      insert eq(low: 0.12, mid: 0.45, high: 0.66)
      insert comp(thresh: 0.48, ratio: 0.46, attack: 0.005, release: 0.08, makeup: 0.12)
      volume 0.28
      pan 0.18
      play beat`x.xX x.x. xxx. x.xX x.x. x.xx x.xX x.x.` at bars(1..2)
    }
    track Bongo {
      instrument Bongo()
      insert eq(low: 0.3, mid: 0.55, high: 0.52)
      insert delay(time: 0.268, fdbk: 0.36, mix: 0.28)
      volume 0.3
      pan -0.3
      play beat`--x- --x- -x-- -x-x ---x --x- x--- --x-` at bars(1..2)
    }
    track Cab {
      instrument Cabasa()
      insert eq(low: 0.1, mid: 0.5, high: 0.6)
      volume 0.22
      pan 0.3
      play beat`.x.x .xxx .x.x .x.x` at bars(1..2)
    }
  }
}
