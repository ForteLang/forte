// Hello World — transition hardware: riser, impact, downlifter, crash.
import { Riser, Impact, Downlifter } from "../../instruments/fx.forte"
import { Crash } from "../../instruments/drums.forte"

block Lift { track R { instrument Riser(climb: 0.9) volume 0.55 pan 0.1 play beat`x--- ---- ---- ----` at bars(1..1) } }
block Boom { track I { instrument Impact() insert reverb(size: 0.85, decay: 0.65, mix: 0.35) volume 0.65 play beat`x--- ---- ---- ----` at bars(1..1) } }
block Fall { track D { instrument Downlifter() volume 0.5 pan -0.1 play beat`x--- ---- ---- ----` at bars(1..1) } }
block Wash { track C { instrument Crash(decay: 0.9) insert reverb(size: 0.8, decay: 0.6, mix: 0.3) volume 0.45 pan 0.2 play beat`x--- ---- ---- ----` at bars(1..1) } }
