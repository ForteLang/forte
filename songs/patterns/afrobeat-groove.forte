// Pattern: Afrobeat (112bpm) — アゴゴのベルパターンが時計。
// シェイカーの 16 分と会話するシンコペのベース。
import { Kick606, SnareTight, Shaker } from "../../lib/std/drums.forte"
import { Agogo, Conga } from "../../lib/std/percussion.forte"
import { RubberBass } from "../../lib/std/bass.forte"
import { Clav } from "../../lib/std/keys.forte"

song "Pattern: Afrobeat" {
  tempo 112bpm
  meter 4/4
  key C minor

  let bell  = beat`x--x --x- x-x- --x-`
  let kick  = beat`x--- ---- x--- -x--`
  let snare = beat`---- x--- --x- x---`
  let shk   = beat`xxxX xxxx xxxX xxxx`
  let conga = beat`--x- x--x --x- x--x`
  let vamp  = prog`Cm7 | Cm7 | F7 | Cm7`

  track Bell  { instrument Agogo() volume 0.5 pan 0.25 play bell at bars(1..8) }
  track Kick  { instrument Kick606(decay: 0.28) volume 0.85 play kick at bars(1..8) }
  track Snare { instrument SnareTight(snap: 0.6) volume 0.5 pan -0.1 play snare at bars(3..8) }
  track Shk   { instrument Shaker() volume 0.35 pan -0.25 play shk at bars(1..8) }
  track Conga { instrument Conga(open: 0.45) volume 0.55 pan 0.1 play conga at bars(1..8) }

  track Bass {
    instrument RubberBass()
    volume 0.8
    play notes`C2:0.5 _:0.5 Eb2:0.25 C2:0.25 _:0.5 G1:0.5 _:0.5 C2:0.5 Bb1:0.5 C2:0.5` at bars(1..8)
  }

  track Keys {
    instrument Clav(mute: 0.55)
    volume 0.4
    pan 0.15
    play arp(vamp, rate: 0.25, style: "up") at bars(5..8)
  }
}
